.sph-review-card__imgs  { display:flex; gap:8px; }
.sph-review-card__imgs img { width:60px; height:60px; object-fit:cover; border-radius:var(--radius-sm,4px); }
.sph-review-card__body { font-size:var(--text-sm,.875rem); color:var(--color-text-muted,#666); line-height:1.6; }
.sph-faq__list { display:flex; flex-direction:column; }
.sph-faq__item { border-bottom:1px solid var(--color-border,#e5e5e5); }
.sph-faq__item:first-child { border-top:1px solid var(--color-border,#e5e5e5); }
.sph-faq__q { display:flex; justify-content:space-between; align-items:center; gap:12px; padding:16px 0; cursor:pointer; list-style:none; font-size:var(--text-sm,.875rem); font-weight:700; color:var(--color-text,#111); }
.sph-faq__q::-webkit-details-marker { display:none; }
.sph-faq__chevron { transition:transform .3s ease; flex-shrink:0; }
details[open] .sph-faq__chevron { transform:rotate(180deg); }
.sph-faq__a { padding-bottom:16px; font-size:var(--text-sm,.875rem); color:var(--color-text-muted,#666); line-height:1.7; }
</style>

