{%- liquid
  assign storefront_mode = settings.storefront_mode | default: 'single_product'
  assign section_visibility = section.settings.visibility | default: 'follow_global'
  assign render_section = true
  if section_visibility == 'follow_global' and settings.single_product_sections_follow_mode and storefront_mode == 'multi_product'
    assign render_section = false
  elsif section_visibility == 'single_only' and storefront_mode == 'multi_product'
    assign render_section = false
  elsif section_visibility == 'multi_only' and storefront_mode != 'multi_product'
    assign render_section = false
  endif
  assign sp = section.settings.product
  if sp == blank and settings.primary_product != blank
    assign sp = settings.primary_product
  endif
  if sp == blank
    assign sp = product
  endif
  assign fv = sp.selected_or_first_available_variant
  assign price = fv.price
  assign compare = fv.compare_at_price
  assign is_sale = false
  if compare > price
    assign is_sale = true
    assign save_pct = compare | minus: price | times: 100 | divided_by: compare
  endif
  assign atc_label = section.settings.atc_label | default: settings.conversion_primary_cta_label | default: 'Add to Cart'
  assign buy_label = section.settings.buy_label | default: settings.conversion_fast_checkout_label | default: settings.conversion_buy_now_label | default: 'Buy Now'
  assign cta_button_mode = settings.conversion_checkout_button_mode | default: 'both'
  assign fast_checkout_destination = settings.fast_checkout_destination | default: 'checkout'
  assign fast_checkout_suffix = ''
  if fast_checkout_destination == 'cart'
    assign fast_checkout_suffix = '?storefront=true'
  endif
  assign show_cart_button = true
  assign show_buy_now = section.settings.show_buy_now
  if settings.conversion_show_fast_checkout == false or cta_button_mode == 'cart_only'
    assign show_buy_now = false
  endif
  if cta_button_mode == 'checkout_only' and settings.conversion_show_fast_checkout
    assign show_cart_button = false
  endif
  if show_cart_button == false and show_buy_now == false
    assign show_cart_button = true
  endif
  assign sph_offer_enabled = settings.weekly_offer_enabled
  assign sph_offer_label = settings.weekly_offer_label
  if settings.offer_countdown_mode == 'upcoming_sale' and settings.upcoming_sale_enabled
    assign sph_offer_enabled = true
    assign sph_offer_label = settings.upcoming_sale_label
  endif
  assign sph_show_sale_strip = false
  if section.settings.show_sale_strip and settings.sale_stripe_enabled
    if is_sale or settings.sale_stripe_always_show
      assign sph_show_sale_strip = true
    endif
  endif
  assign visible_reviews_count = section.settings.visible_reviews_count
  assign review_slider_cycling = section.settings.enable_review_slider_cycling
  assign review_slider_interval = section.settings.review_slider_interval
  if section.settings.use_global_review_settings
    assign visible_reviews_count = settings.reviews_visible_count | default: 3
    assign review_slider_cycling = settings.reviews_autoplay
    assign review_slider_interval = settings.reviews_autoplay_interval | default: 4
  endif
  assign desktop_info_style = section.settings.desktop_info_style | default: 'standard'
  assign mobile_info_style = section.settings.mobile_info_style | default: 'compact'
  assign mobile_media_visibility = section.settings.mobile_media_visibility | default: 'show'
  assign desktop_cta_layout = section.settings.desktop_cta_layout | default: 'row'
  assign mobile_cta_layout = section.settings.mobile_cta_layout | default: 'row'
  assign show_payment_icons_desktop = true
  assign show_payment_icons_mobile = true
  if section.settings.show_payment_icons == false
    assign show_payment_icons_desktop = false
    assign show_payment_icons_mobile = false
  endif
  if section.settings.show_payment_icons_desktop == false
    assign show_payment_icons_desktop = false
  endif
  if section.settings.show_payment_icons_mobile == false
    assign show_payment_icons_mobile = false
  endif
  assign show_trust_desktop = true
  assign show_trust_mobile = true
  if section.settings.show_trust_strip == false
    assign show_trust_desktop = false
    assign show_trust_mobile = false
  endif
  if section.settings.show_trust_strip_desktop == false
    assign show_trust_desktop = false
  endif
  if section.settings.show_trust_strip_mobile == false
    assign show_trust_mobile = false
  endif
  assign show_wishlist_button = section.settings.show_wishlist_button
  assign show_compare_button = section.settings.show_compare_button
  if storefront_mode != 'multi_product'
    assign show_compare_button = false
  endif
-%}

{%- if render_section -%}

{%- comment -%}LCP preload — hero image is always above fold{%- endcomment -%}
{%- if sp != blank and sp.featured_image != blank -%}
  {{ sp.featured_image | image_url: width: 900 | preload_tag: as: 'image' }}
{%- elsif section.settings.fallback_image != blank -%}
  {{ section.settings.fallback_image | image_url: width: 900 | preload_tag: as: 'image' }}
{%- endif -%}

{%- style -%}
  #SingleProductHome-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    {%- if section.settings.bg_color_override != blank -%}
      background: {{ section.settings.bg_color_override }};
    {%- endif -%}
    {%- if section.settings.text_color_override != blank -%}
      --color-text: {{ section.settings.text_color_override }};
    {%- endif -%}
  }

  #SingleProductHome-{{ section.id }} .sph-review-cards > .sph-review-card:nth-child(n+{{ visible_reviews_count | plus: 1 }}) {
    display: none !important;
  }

  @media (max-width: 768px) {
    #SingleProductHome-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top | default: section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom | default: section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}


<section class="sph sph--desktop-info-{{ desktop_info_style }} sph--mobile-info-{{ mobile_info_style }} sph--mobile-media-{{ mobile_media_visibility }} sph--desktop-cta-{{ desktop_cta_layout }} sph--mobile-cta-{{ mobile_cta_layout }}" id="SingleProductHome-{{ section.id }}" data-product-detail {% if sp != blank %}data-variants="{{ sp.variants | json | escape }}"{% endif %} {{ section.shopify_attributes }}>
  <div class="sph__inner sph__inner--media-{{ section.settings.media_position | default: 'left' }} container">

    <div class="sph__media">
      <div class="sph__media-main">
        {%- if sp != blank and sp.featured_image != blank -%}
          {%- assign sph_main_alt = sp.featured_image.alt | default: sp.title | escape -%}
          {{ sp.featured_image | image_url: width: 900 | image_tag: class: 'sph__img sph__img--primary', widths: '450,900,1200', loading: 'eager', decoding: 'async', width: 900, height: 900, alt: sph_main_alt, data-main-image: '' }}
          {%- if section.settings.show_hover_image and sp.images.size > 1 -%}
            {{ sp.images[1] | image_url: width: 900 | image_tag: class: 'sph__img sph__img--hover', widths: '450,900,1200', loading: 'lazy', decoding: 'async', width: 900, height: 900, alt: sph_main_alt }}
          {%- endif -%}
        {%- elsif section.settings.fallback_image != blank -%}
          {%- assign sph_fallback_alt = section.settings.heading | escape -%}
          {{ section.settings.fallback_image | image_url: width: 900 | image_tag: class: 'sph__img', widths: '450,900,1200', loading: 'eager', decoding: 'async', width: 900, height: 900, alt: sph_fallback_alt, data-main-image: '' }}
        {%- else -%}
          <div class="sph__img-placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if sp != blank -%}
          {%- if show_wishlist_button or show_compare_button -%}
            <div class="sph__media-actions" aria-label="Product actions">
              {%- if show_wishlist_button -%}
                {%- render 'wishlist-btn', product: sp -%}
              {%- endif -%}
              {%- if show_compare_button -%}
                <button
                  class="sph__compare-btn"
                  data-compare-btn
                  data-product-id="{{ sp.id }}"
                  data-product-title="{{ sp.title | escape }}"
                  data-product-url="{{ sp.url }}"
                  aria-label="Add {{ sp.title | escape }} to compare"
                  aria-pressed="false">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" aria-hidden="true">
                    <path d="M8 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3"/>
                    <path d="M16 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3"/>
                    <path d="M12 4v16"/>
                    <path d="m10 8-2 2 2 2"/>
                    <path d="m14 16 2-2-2-2"/>
                  </svg>
                </button>
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="sph__badges">
            {%- if compare > price -%}
              {%- assign savings = compare | minus: price | times: 100 | divided_by: compare -%}
              {%- if section.settings.show_sale_badge -%}
                <span class="badge badge--sale">-{{ savings }}%</span>
              {%- endif -%}
            {%- elsif settings.card_show_new_badge -%}
              {%- if sp.tags contains 'new' -%}
                <span class="badge badge--new">New</span>
              {%- elsif sp.tags contains 'bestseller' -%}
                <span class="badge badge--bestseller">Bestseller</span>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if sph_show_sale_strip -%}
          {%- render 'sale-strip', 
            is_sale: is_sale, 
            savings: save_pct, 
            style: section.settings.sale_stripe_design, 
            position: section.settings.sale_stripe_orientation 
          -%}
        {%- endif -%}

        {%- if sp != blank and sp.images.size > 1 -%}
          <button class="sph__media-nav sph__media-nav--prev" data-sph-nav="prev" aria-label="Previous image">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <button class="sph__media-nav sph__media-nav--next" data-sph-nav="next" aria-label="Next image">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        {%- endif -%}
      </div>

      {%- if sp != blank and sp.images.size > 1 -%}
        <div class="sph__thumbs" role="list" aria-label="Product images">
          {%- for img in sp.images limit: 5 -%}
            <button
              class="sph__thumb{% if forloop.first %} is-active{% endif %}"
              data-sph-thumb
              data-src="{{ img | image_url: width: 900 }}"
              aria-label="View image {{ forloop.index }}"
              role="listitem">
              {%- assign sph_thumb_alt = img.alt | default: sp.title | escape -%}
              {{ img | image_url: width: 120 | image_tag: widths: '60,120', loading: 'lazy', decoding: 'async', width: 60, height: 60, alt: sph_thumb_alt }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if sph_offer_enabled and sph_offer_label != blank -%}
        <div class="sph__weekly-badge">
          <span class="sph__weekly-badge-dot"></span>
          {{ sph_offer_label | escape }}
        </div>
      {%- endif -%}
    </div>

    <div class="sph__info">

      {%- if section.settings.show_eyebrow -%}
        {%- assign eyebrow = section.settings.eyebrow -%}
        {%- if eyebrow == blank and sp != blank and settings.card_show_vendor -%}
          {%- assign eyebrow = sp.vendor -%}
        {%- endif -%}
        {%- if eyebrow != blank -%}
          <p class="sph__eyebrow">{{ eyebrow | upcase | escape }}</p>
        {%- endif -%}
      {%- endif -%}

      <h1 class="sph__title">
        {%- if section.settings.heading != blank -%}
          {{ section.settings.heading | escape }}
        {%- elsif sp != blank -%}
          {{ sp.title | escape }}
        {%- else -%}
          Adventure Ready
        {%- endif -%}
      </h1>

      {%- assign subtitle = section.settings.subheading -%}
      {%- if subtitle == blank and sp != blank -%}
        {%- assign subtitle = sp.description | strip_html | truncate: 100 -%}
      {%- endif -%}
      {%- if subtitle != blank -%}
        <p class="sph__sub">{{ subtitle | escape }}</p>
      {%- endif -%}

      <div class="sph__price-row">
        <span class="sph__price{% if is_sale %} is-sale{% endif %}">
          {%- if sp != blank -%}{{ price | money }}{%- else -%}$149.00{%- endif -%}
        </span>
        {%- if is_sale -%}
          <span class="sph__price-was">{{ compare | money }}</span>
          {%- if section.settings.show_sale_badge -%}
            <span class="sph__badge">Save {{ save_pct }}%</span>
          {%- endif -%}
        {%- endif -%}

        {%- if settings.card_show_new_badge -%}
          {%- if sp.tags contains 'new' -%}
            <span class="sph__badge sph__badge--new">New</span>
          {%- elsif sp.tags contains 'bestseller' -%}
            <span class="sph__badge sph__badge--bestseller">Bestseller</span>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.show_rating -%}
          {%- assign rating_val = sp.metafields.reviews.rating.value | plus: 0 -%}
          {%- assign rating_count = sp.metafields.reviews.rating_count.value | plus: 0 -%}
          {%- if rating_val > 0 or section.settings.show_demo_rating -%}
            {%- unless rating_val > 0 -%}{%- assign rating_val = 4.8 -%}{%- assign rating_count = 1150 -%}{%- endunless -%}
            <div class="sph__stars" aria-label="{{ rating_val }} out of 5 stars">
              {%- assign full = rating_val | floor -%}
              {%- for i in (1..5) -%}
                <svg width="14" height="14" viewBox="0 0 24 24"
                  fill="{% if i <= full %}#f5a623{% else %}none{% endif %}"
                  stroke="#f5a623" stroke-width="1.5" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- endfor -%}
              <span class="sph__rating-label">{{ rating_val }} | {{ rating_count }} + Reviews</span>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- capture cta_buttons_html -%}
        <div class="sph__btns">
          {%- comment -%}Scarcity text from global settings{%- endcomment -%}
          {%- if settings.weekly_scarcity_text != blank -%}
            <p class="sph__scarcity" role="status">
              <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><circle cx="5" cy="5" r="5" fill="#e8260d"/></svg>
              {{ settings.weekly_scarcity_text }}
            </p>
          {%- endif -%}

          {%- if sp != blank and fv.available -%}
            {%- if show_cart_button -%}
              <button
                class="btn sph__btn-atc sph__btn-atc--pulse"
                data-add-to-cart
                data-variant-id="{{ fv.id }}"
                data-qty="1"
                aria-label="Add {{ sp.title | escape }} to cart">
                <span class="atc-btn-text">{{ atc_label | escape }}</span>
              </button>
            {%- endif -%}
            {%- if show_buy_now -%}
              <a href="{{ routes.cart_url }}/{{ fv.id }}:1{{ fast_checkout_suffix }}"
                class="btn sph__btn-buy"
                data-buy-now
                data-checkout-destination="{{ fast_checkout_destination }}"
                data-variant-id="{{ fv.id }}">
                {{ buy_label | escape }}
              </a>
            {%- endif -%}
            {%- if settings.conversion_microcopy != blank -%}
              <p class="sph__cta-microcopy">{{ settings.conversion_microcopy | escape }}</p>
            {%- endif -%}
          {%- else -%}
            <button class="btn sph__btn-atc" disabled aria-disabled="true">Sold Out</button>
          {%- endif -%}
        </div>

        {%- if show_payment_icons_desktop or show_payment_icons_mobile -%}
          <div class="sph__payment-icons{% unless show_payment_icons_desktop %} sph__payment-icons--hide-desktop{% endunless %}{% unless show_payment_icons_mobile %} sph__payment-icons--hide-mobile{% endunless %}">
            <span class="sph__payment-icons-label">We accept:</span>
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'sph__payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endcapture -%}

      {%- capture options_html -%}
        <div class="sph__options-row">
          {%- if section.settings.show_qty_selector -%}
            <div class="sph__qty-wrap">
              <p class="sph__opt-label">Quantity</p>
              <div class="sph__qty" data-qty-stepper>
                <button class="sph__qty-btn" data-qty-minus aria-label="Decrease">&#8722;</button>
                <input class="sph__qty-val" type="number" value="1" min="1" max="99"
                  readonly aria-label="Quantity">
                <button class="sph__qty-btn" data-qty-plus aria-label="Increase">&#43;</button>
              </div>
            </div>
          {%- endif -%}

          {%- if sp != blank and sp.has_only_default_variant == false -%}
            {%- for opt in sp.options_with_values -%}
              <div class="product-option">
                <p class="sph__opt-label">
                  {{ opt.name | escape }}:
                  <strong id="selected-{{ section.id }}-{{ opt.name | handleize }}">{{ opt.selected_value | escape }}</strong>
                </p>

                {%- if opt.name == 'Color' or opt.name == 'Colour' -%}
                  <div class="product-option__swatches" role="radiogroup" aria-label="{{ opt.name }}">
                    {%- for value in opt.values -%}
                      <button
                        class="option-swatch sph__swatch{% if value == opt.selected_value %} is-active{% endif %}"
                        data-option-name="{{ opt.name | escape }}"
                        data-option-value="{{ value | escape }}"
                        style="background-color: {{ value | downcase | replace: ' ', '' }};"
                        aria-pressed="{% if value == opt.selected_value %}true{% else %}false{% endif %}"
                        aria-label="{{ value | escape }}">
                      </button>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <div class="product-option__swatches product-option__swatches--pills" role="radiogroup" aria-label="{{ opt.name }}">
                    {%- for value in opt.values -%}
                      <button
                        class="option-swatch sph__pill{% if value == opt.selected_value %} is-active{% endif %}"
                        data-option-name="{{ opt.name | escape }}"
                        data-option-value="{{ value | escape }}"
                        aria-pressed="{% if value == opt.selected_value %}true{% else %}false{% endif %}"
                        aria-label="{{ value | escape }}">
                        {{ value | escape }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endcapture -%}

      {%- if section.settings.cta_position == 'above' -%}
        {{ cta_buttons_html }}
        {{ options_html }}
      {%- else -%}
        {{ options_html }}
        {{ cta_buttons_html }}
      {%- endif -%}

      {%- if show_trust_desktop or show_trust_mobile -%}
        <div class="sph__trust{% unless show_trust_desktop %} sph__trust--hide-desktop{% endunless %}{% unless show_trust_mobile %} sph__trust--hide-mobile{% endunless %}" aria-label="Guarantees">
          <span>&#10003; {{ section.settings.trust_1 | default: 'Free Shipping' | escape }}</span>
          <span class="sph__trust-sep">|</span>
          <span>&#10003; {{ section.settings.trust_2 | default: 'Secure Checkout' | escape }}</span>
          <span class="sph__trust-sep">|</span>
          <span>&#10003; {{ section.settings.trust_3 | default: '30-Day Guarantee' | escape }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.description_style == 'accordion' -%}
        {%- liquid
          assign desc_open_desktop = section.settings.description_open_desktop
          assign desc_open_mobile  = section.settings.description_open_mobile
        -%}
        <details-accordion>
          <div class="sph__description-accordion"
            data-desc-open-desktop="{{ desc_open_desktop }}"
            data-desc-open-mobile="{{ desc_open_mobile }}">
            <details
              class="sph-description__item"
              id="SphDescDetails-{{ section.id }}">
              <summary class="sph-description__q">
                <span>{{ section.settings.description_label | default: 'Description' | escape }}</span>
                <svg class="sph-description__chevron" width="16" height="16" viewBox="0 0 24 24"
                  fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </summary>
              <div class="sph-description__a rte">
                {%- if sp != blank and sp.description != blank -%}
                  {{ sp.description }}
                {%- else -%}
                  <p>This premium product is crafted from high-quality materials to ensure durability and comfort. Designed for daily use, it offers a perfect blend of style, functionality, and performance.</p>
                {%- endif -%}
              </div>
            </details>
          </div>
        </details-accordion>
        <script>
        (function() {
          var el = document.getElementById('SphDescDetails-{{ section.id }}');
          var wrap = el ? el.closest('[data-desc-open-desktop]') : null;
          if (!el || !wrap) return;
          var isMobile = window.innerWidth < 768;
          var openDesktop = wrap.dataset.descOpenDesktop === 'true';
          var openMobile  = wrap.dataset.descOpenMobile  === 'true';
          if (isMobile && openMobile)  { el.setAttribute('open', ''); }
          if (!isMobile && openDesktop) { el.setAttribute('open', ''); }
        })();
        </script>
      {%- elsif section.settings.description_style == 'plain' -%}
        <div class="sph-description__plain rte">
          {%- if sp != blank and sp.description != blank -%}
            {{ sp.description }}
          {%- else -%}
            <p>This premium product is crafted from high-quality materials to ensure durability and comfort. Designed for daily use, it offers a perfect blend of style, functionality, and performance.</p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{%- liquid
  assign feature_blocks = 0
  for block in section.blocks
    if block.type == 'feature'
      assign feature_visibility = block.settings.visibility | default: 'all'
      if feature_visibility == 'all' or feature_visibility == storefront_mode
        assign feature_blocks = feature_blocks | plus: 1
      endif
    endif
  endfor
  assign fallback_features = false
  if feature_blocks == 0
    if section.settings.feat_1_title != blank or section.settings.feat_2_title != blank or section.settings.feat_3_title != blank
      assign fallback_features = true
    endif
  endif
-%}

{%- if section.settings.show_features and feature_blocks > 0 or section.settings.show_features and fallback_features -%}
<section class="sph-features" aria-label="Key features">
  <div class="container">
    <div class="sph-features__grid">
      {%- if feature_blocks > 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            {%- assign feature_visibility = block.settings.visibility | default: 'all' -%}
            {%- if feature_visibility == 'all' or feature_visibility == storefront_mode -%}
          <div class="sph-features__item" {{ block.shopify_attributes }}>
            <div class="sph-features__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'heart' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 1 0-7.8 7.8L12 21.2l8.8-8.8a5.5 5.5 0 0 0 0-7.8z"/></svg>
                {%- when 'compare' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3"/><path d="M16 3h3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-3"/><path d="M12 4v16"/><path d="m10 8-2 2 2 2"/><path d="m14 16 2-2-2-2"/></svg>
                {%- when 'article' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>
                {%- when 'speed' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 14a8 8 0 1 1 16 0"/><path d="M12 14l4-4"/><path d="M3 20h18"/></svg>
                {%- when 'seo' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/><path d="M8 11h6M11 8v6"/></svg>
                {%- when 'code' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m8 9-4 3 4 3"/><path d="m16 9 4 3-4 3"/><path d="m14 4-4 16"/></svg>
                {%- when 'water' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6 9 4 13 4 16a8 8 0 0 0 16 0c0-3-2-7-8-14z"/></svg>
                {%- when 'leaf' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.31M15 8a6 6 0 0 0-6 6"/><path d="M3.82 19.31a10.32 10.32 0 0 0 9.4-8.19"/></svg>
                {%- when 'bag' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                {%- when 'shield' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {%- when 'truck' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- when 'star' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
              {%- endcase -%}
            </div>
            <strong class="sph-features__title">{{ block.settings.title | escape }}</strong>
            {%- if block.settings.subtitle != blank -%}
              <span class="sph-features__sub">{{ block.settings.subtitle | escape }}</span>
            {%- endif -%}
          </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {%- liquid
            assign feature_title_key = 'feat_' | append: i | append: '_title'
            assign feature_sub_key = 'feat_' | append: i | append: '_sub'
            assign feature_icon_key = 'feat_' | append: i | append: '_icon'
            assign feature_title = section.settings[feature_title_key]
            assign feature_sub = section.settings[feature_sub_key]
            assign feature_icon = section.settings[feature_icon_key]
          -%}
          {%- if feature_title != blank -%}
            <div class="sph-features__item">
              <div class="sph-features__icon" aria-hidden="true">
                {%- case feature_icon -%}
                  {%- when 'leaf' -%}
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.31M15 8a6 6 0 0 0-6 6"/><path d="M3.82 19.31a10.32 10.32 0 0 0 9.4-8.19"/></svg>
                  {%- when 'bag' -%}
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  {%- when 'shield' -%}
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- when 'truck' -%}
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'star' -%}
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- else -%}
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6 9 4 13 4 16a8 8 0 0 0 16 0c0-3-2-7-8-14z"/></svg>
                {%- endcase -%}
              </div>
              <strong class="sph-features__title">{{ feature_title | escape }}</strong>
              {%- if feature_sub != blank -%}
                <span class="sph-features__sub">{{ feature_sub | escape }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>
{%- endif -%}

{%- if section.settings.show_reviews or section.settings.show_faq -%}
<section class="sph-bottom section-spacing sph-bottom--align-{{ section.settings.bottom_alignment | default: 'left' }}">
  <div class="container">
    <div class="sph-bottom__grid {% if section.settings.show_reviews and section.settings.show_faq %}sph-bottom__grid--split{% else %}sph-bottom__grid--full{% endif %}">

      {%- if section.settings.show_reviews -%}
        <div class="sph-reviews">
          <h2 class="sph-section-title">{{ section.settings.reviews_title | default: 'Reviews' }}</h2>

          {%- if sp != blank -%}
            <div id="shopify-product-reviews" data-id="{{ sp.id }}"></div>
          {%- endif -%}

          {%- if section.blocks.size > 0 -%}
            <div class="sph-review-cards"
              data-cycling="{{ review_slider_cycling }}"
              data-interval="{{ review_slider_interval | times: 1000 }}"
              data-visible="{{ visible_reviews_count }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'review' -%}
                  <div class="sph-review-card" {{ block.shopify_attributes }}>
                    <div class="sph-review-card__head">
                      {%- if block.settings.avatar != blank -%}
                        {%- assign avatar_alt = block.settings.name | escape -%}
                        {{ block.settings.avatar | image_url: width: 80 | image_tag: widths: '40,80', loading: 'lazy', decoding: 'async', width: 40, height: 40, class: 'sph-review-card__avatar', alt: avatar_alt }}
                      {%- else -%}
                        <div class="sph-review-card__avatar sph-review-card__avatar--initials">
                          {{ block.settings.name | slice: 0, 1 | upcase }}
                        </div>
                      {%- endif -%}
                      <div>
                        <strong class="sph-review-card__name">{{ block.settings.name | default: 'Customer' }}</strong>
                        <div class="sph-review-card__stars" aria-label="{{ block.settings.rating }} stars">
                          {%- assign r = block.settings.rating | default: 5 | plus: 0 -%}
                          {%- for i in (1..5) -%}
                            <svg width="12" height="12" viewBox="0 0 24 24"
                              fill="{% if i <= r %}#f5a623{% else %}none{% endif %}"
                              stroke="#f5a623" stroke-width="1.5" aria-hidden="true">
                              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                            </svg>
                          {%- endfor -%}
                        </div>
                      </div>
                    </div>
                    {%- if block.settings.images != blank -%}
                      <div class="sph-review-card__imgs">
                        {{ block.settings.images | image_url: width: 200 | image_tag: widths: '60,120,200', loading: 'lazy', decoding: 'async', width: 60, height: 60, alt: 'Review photo' }}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.body != blank -%}
                      <p class="sph-review-card__body">{{ block.settings.body }}</p>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_faq -%}
        <div class="sph-faq">
          <h2 class="sph-section-title">{{ section.settings.faq_title | default: 'FAQ' }}</h2>
          <div class="sph-faq__list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'faq' -%}
                <details class="sph-faq__item" {{ block.shopify_attributes }}>
                  <summary class="sph-faq__q">
                    {{ block.settings.question }}
                    <svg class="sph-faq__chevron" width="16" height="16" viewBox="0 0 24 24"
                      fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </summary>
                  <div class="sph-faq__a">{{ block.settings.answer }}</div>
                </details>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>
{%- endif -%}

<style>
/* ── Hero layout ── */
.sph { background: var(--color-bg); padding-block: clamp(24px, 4vw, 48px) clamp(32px, 5vw, 64px); }
.sph__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(32px, 4vw, 80px);
  align-items: start;
}
@media (min-width: 769px) {
  .sph__inner--media-left {
    grid-template-columns: 1fr 1fr;
  }
  .sph__inner--media-right {
    grid-template-columns: 1fr 1fr;
  }
  .sph__inner--media-right .sph__media {
    order: 2;
  }
  .sph__inner--media-right .sph__info {
    order: 1;
  }
  .sph__inner--media-top {
    grid-template-columns: 1fr;
  }
  .sph__inner--media-top .sph__media {
    order: 1;
    max-width: 768px;
    margin: 0 auto;
    width: 100%;
  }
  .sph__inner--media-top .sph__info {
    order: 2;
    max-width: 768px;
    margin: 0 auto;
    width: 100%;
  }
  .sph__inner--media-bottom {
    grid-template-columns: 1fr;
  }
  .sph__inner--media-bottom .sph__media {
    order: 2;
    max-width: 768px;
    margin: 0 auto;
    width: 100%;
  }
  .sph__inner--media-bottom .sph__info {
    order: 1;
    max-width: 768px;
    margin: 0 auto;
    width: 100%;
  }
  .sph--desktop-info-card .sph__info {
    background: color-mix(in oklab, var(--color-bg, #ffffff) 94%, var(--color-surface, #f7f7f7));
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--radius-lg, 12px);
    padding: clamp(24px, 3vw, 40px);
    box-shadow: 0 18px 48px rgba(0,0,0,0.06);
  }
  .sph--desktop-cta-stack .sph__btns {
    flex-direction: column;
  }
  .sph--desktop-cta-stack .sph__btn-atc,
  .sph--desktop-cta-stack .sph__btn-buy {
    width: 100%;
  }
  .sph__payment-icons--hide-desktop,
  .sph__trust--hide-desktop {
    display: none !important;
  }
}
@media (max-width: 768px) {
  .sph {
    padding-block: 0;
  }
  .sph__inner {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .sph--mobile-media-hide .sph__media {
    display: none;
  }
  .sph__thumbs {
    flex-wrap: nowrap;
    overflow-x: auto;
    justify-content: flex-start;
    padding-bottom: 6px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .sph__thumbs::-webkit-scrollbar {
    display: none;
  }
  .sph__media-main img {
    cursor: pointer;
  }
  .sph--mobile-info-card .sph__info {
    background: color-mix(in oklab, var(--color-bg, #ffffff) 96%, var(--color-surface, #f7f7f7));
    border: 1px solid var(--color-border, #e5e5e5);
    border-radius: var(--radius-lg, 12px);
    padding: 18px;
    box-shadow: 0 12px 36px rgba(0,0,0,0.06);
  }
  .sph--mobile-info-compact .sph__info {
    gap: 14px;
  }
  .sph--mobile-info-compact .sph__title {
    font-size: clamp(1.8rem, 9vw, 2.55rem);
    line-height: 1.02;
  }
  .sph--mobile-info-compact .sph__sub {
    font-size: 0.94rem;
    line-height: 1.55;
  }
  .sph--mobile-info-compact .sph__price-row {
    gap: 8px;
  }
  .sph--mobile-info-compact .sph__price {
    font-size: 1.45rem;
  }
  .sph--mobile-info-compact .sph__rating-label {
    font-size: 0.68rem;
  }
  .sph--mobile-cta-stack .sph__btns {
    flex-direction: column;
  }
  .sph--mobile-cta-stack .sph__btn-atc,
  .sph--mobile-cta-stack .sph__btn-buy {
    width: 100%;
  }
  .sph__payment-icons--hide-mobile,
  .sph__trust--hide-mobile {
    display: none !important;
  }
}

/* ── Gallery Nav Arrows ── */
.sph__media-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  border: 1px solid rgba(0, 0, 0, 0.1);
  color: #111;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 15;
  transition: all 0.2s ease;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
.sph__media-nav:hover {
  background: #ffffff;
  transform: translateY(-50%) scale(1.05);
}
.sph__media-nav:active {
  transform: translateY(-50%) scale(0.95);
}
.sph__media-nav--prev {
  left: 12px;
}
.sph__media-nav--next {
  right: 12px;
}
.sph__media-nav svg {
  width: 20px;
  height: 20px;
  display: block;
}
.sph__media-nav::after {
  content: '';
  position: absolute;
  top: -4px; left: -4px; right: -4px; bottom: -4px;
}

/* ── Sticky image ── */
.sph__media {
  position: sticky;
  top: 88px; /* below sticky header */
}
.sph__media-main {
  position: relative;
  border-radius: var(--radius-lg, 12px);
  overflow: hidden;
  aspect-ratio: 1;
  background: var(--color-surface);
}
.sph__media-actions {
  position: absolute;
  top: 14px;
  right: 14px;
  z-index: 18;
  display: flex;
  gap: 8px;
}
.sph__media-actions .wl-btn,
.sph__compare-btn {
  width: 42px;
  height: 42px;
  border-radius: var(--radius-full, 9999px);
  background: color-mix(in oklab, var(--color-bg, #fff) 90%, transparent);
  border: 1px solid color-mix(in oklab, var(--color-border, #e5e5e5) 85%, transparent);
  color: var(--color-text, #111);
  box-shadow: 0 8px 22px rgba(0,0,0,0.12);
  backdrop-filter: blur(10px);
}
.sph__compare-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease;
}
.sph__media-actions .wl-btn:hover,
.sph__compare-btn:hover,
.sph__compare-btn.is-saved {
  transform: translateY(-1px);
  background: var(--color-primary, #111);
  color: var(--color-primary-text, #fff);
}
.sph__badges {
  position: absolute;
  top: 16px;
  left: 16px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  pointer-events: none;
  z-index: 10;
}
.sph__badges .badge {
  padding: 4px 8px;
  font-size: 11px;
  font-weight: 700;
  border-radius: var(--radius-sm, 4px);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
}
.sph__badges .badge--sale {
  background: var(--color-sale, #e8260d);
  color: var(--color-text-inverse, #ffffff);
}
.sph__badges .badge--new {
  background: var(--color-primary, #111111);
  color: var(--color-primary-text, #ffffff);
}
.sph__badges .badge--bestseller {
  background: var(--color-gold, #c8941a);
  color: #ffffff;
}
.sph__img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.25s ease;
}
.sph__img--hover {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.4s ease;
}
.sph__media-main:hover .sph__img--hover {
  opacity: 1;
}
.sph__img-placeholder {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface);
  color: var(--color-text-muted);
}
.sph__thumbs {
  display: flex;
  gap: 8px;
  margin-top: 10px;
  flex-wrap: wrap;
}
.sph__thumb {
  width: 60px; height: 60px;
  border-radius: var(--radius-sm, 4px);
  overflow: hidden;
  border: 2px solid transparent;
  transition: border-color 0.18s ease;
  flex-shrink: 0;
  cursor: pointer;
}
.sph__thumb img { width: 100%; height: 100%; object-fit: cover; }
.sph__thumb.is-active, .sph__thumb:hover { border-color: var(--color-text, #111); }

/* ── Info col ── */
.sph__info {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding-top: 4px;
}
.sph__eyebrow {
  font-size: var(--text-xs, 0.75rem);
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--color-text-muted, #666);
}
.sph__title {
  font-family: var(--font-display, Georgia, serif);
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.01em;
  color: var(--color-text, #111);
}
.sph__sub {
  font-size: var(--text-base, 1rem);
  color: var(--color-text-muted, #666);
  line-height: 1.6;
  max-width: 46ch;
}

/* Price + stars */
.sph__price-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
}
.sph__price {
  font-size: clamp(1.5rem, 2.5vw, 2rem);
  font-weight: 800;
  color: var(--color-text, #111);
  font-variant-numeric: tabular-nums;
}
.sph__price.is-sale { color: var(--color-sale, #e8260d); }
.sph__price-was {
  font-size: var(--text-base, 1rem);
  color: var(--color-text-muted, #666);
  text-decoration: line-through;
}
.sph__badge {
  font-size: var(--text-xs, 0.75rem);
  font-weight: 700;
  background: var(--color-sale-bg, #ffeeed);
  color: var(--color-sale, #e8260d);
  padding: 3px 8px;
  border-radius: var(--radius-full, 9999px);
}
.sph__badge--new {
  background: var(--color-primary, #111111);
  color: var(--color-primary-text, #ffffff);
}
.sph__badge--bestseller {
  background: var(--color-gold, #c8941a);
  color: #ffffff;
}
.sph__stars {
  display: flex;
  align-items: center;
  gap: 3px;
}
.sph__rating-label {
  font-size: var(--text-xs, 0.75rem);
  color: var(--color-text-muted, #666);
  margin-left: 4px;
}

/* Buttons */
.sph__btns {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}
.sph__cta-microcopy {
  width: 100%;
  margin: -2px 0 0;
  color: var(--color-text-muted, #666);
  font-size: var(--text-xs, 12px);
  font-weight: 700;
  line-height: 1.45;
}
.sph__btn-atc {
  flex: 1;
  min-width: 160px;
  padding: 16px 24px;
  min-height: 54px;
  background: var(--color-primary);
  color: var(--color-text-inverse, #ffffff);
  font-size: var(--text-sm, 0.875rem);
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-radius: var(--btn-radius, 6px);
  border: none;
  cursor: pointer;
  transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
}
.sph__btn-atc:hover {
  background: var(--color-primary-hover);
  transform: translateY(-2px);
