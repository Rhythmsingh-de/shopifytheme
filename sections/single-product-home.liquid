<script>
  (function() {
    function initReviewSlider() {
      var container = document.querySelector('.sph-review-cards');
      if (!container) return;
      
      // If already running an interval, don't create another
      if (container.dataset.sliderIntervalId) {
        clearInterval(parseInt(container.dataset.sliderIntervalId, 10));
      }

      var cards = container.querySelectorAll('.sph-review-card');
      if (cards.length === 0) return;

      // Randomly shuffle reviews on page load / section reload
      var cardsArray = Array.from(cards);
      cardsArray.sort(function() { return 0.5 - Math.random(); });
      cardsArray.forEach(function(card) {
        container.appendChild(card);
      });

      var cyclingEnabled = container.dataset.cycling === 'true';
      var intervalMs = parseFloat(container.dataset.interval) || 3500;
      var visibleCount = parseInt(container.dataset.visible, 10) || 3;

      var updatedCards = container.querySelectorAll('.sph-review-card');
      if (updatedCards.length <= visibleCount) return;

      if (!cyclingEnabled) return;

      var intervalId = setInterval(function() {
        var first = container.querySelector('.sph-review-card');
        if (!first) return;

        var nextCard = container.children[visibleCount];
        if (nextCard) {
          nextCard.style.display = 'flex';
          nextCard.style.opacity = '0';
          nextCard.style.transition = 'opacity 0.6s ease';
          // Force reflow
          nextCard.offsetHeight;
          nextCard.style.opacity = '1';
        }

        first.style.transition = 'opacity 0.6s ease, transform 0.6s ease, max-height 0.6s ease, margin 0.6s ease, padding 0.6s ease, border-width 0.6s ease';
        first.style.opacity = '0';
        first.style.transform = 'translateY(-20px)';
        first.style.maxHeight = '0';
        first.style.paddingTop = '0';
        first.style.paddingBottom = '0';
        first.style.marginTop = '0';
        first.style.marginBottom = '0';
        first.style.borderWidth = '0';
        first.style.overflow = 'hidden';

        setTimeout(function() {
          first.style.transition = '';
          first.style.opacity = '';
          first.style.transform = '';
          first.style.maxHeight = '';
          first.style.paddingTop = '';
          first.style.paddingBottom = '';
          first.style.marginTop = '';
          first.style.marginBottom = '';
          first.style.borderWidth = '';
          first.style.overflow = '';

          if (nextCard) {
            nextCard.style.transition = '';
            nextCard.style.opacity = '';
            nextCard.style.display = '';
          }

          container.appendChild(first);
        }, 600);
      }, intervalMs);

      container.dataset.sliderIntervalId = String(intervalId);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initReviewSlider);
    } else {
      initReviewSlider();
    }
    
    // Support Shopify Theme Editor reloads
    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.classList.contains('shopify-section-single-product-home') || e.target.querySelector('.sph-review-cards')) {
        initReviewSlider();
      }
    });
  })();

  class DetailsAccordion extends HTMLElement {
    connectedCallback() {
      this.details = this.querySelector('details');
      this.summary = this.querySelector('summary');
      this.content = this.querySelector('.sph-description__a');
      this.animation = null;
      this.isClosing = false;
      this.isExpanding = false;
      this.summary.addEventListener('click', (e) => this.onClick(e));
    }

    onClick(e) {
      e.preventDefault();
      this.details.style.overflow = 'hidden';
      if (this.isClosing || !this.details.open) {
        this.open();
      } else if (this.isExpanding || this.details.open) {
        this.shrink();
      }
    }

    shrink() {
      this.isClosing = true;
      const startHeight = `${this.details.offsetHeight}px`;
      const endHeight = `${this.summary.offsetHeight}px`;

      if (this.animation) {
        this.animation.cancel();
      }

      this.animation = this.details.animate({
        height: [startHeight, endHeight]
      }, {
        duration: 300,
        easing: 'cubic-bezier(0.16, 1, 0.3, 1)'
      });

      this.animation.onfinish = () => this.onAnimationFinish(false);
      this.animation.oncancel = () => this.isClosing = false;
    }

    open() {
      this.details.style.height = `${this.details.offsetHeight}px`;
      this.details.open = true;
      window.requestAnimationFrame(() => this.expand());
    }

    expand() {
      this.isExpanding = true;
      const startHeight = `${this.details.offsetHeight}px`;
      const endHeight = `${this.summary.offsetHeight + this.content.offsetHeight}px`;

      if (this.animation) {
        this.animation.cancel();
      }

      this.animation = this.details.animate({
        height: [startHeight, endHeight]
      }, {
        duration: 350,
        easing: 'cubic-bezier(0.16, 1, 0.3, 1)'
      });

      this.animation.onfinish = () => this.onAnimationFinish(true);
      this.animation.oncancel = () => this.isExpanding = false;
    }

    onAnimationFinish(open) {
      this.details.open = open;
      this.animation = null;
      this.isClosing = false;
      this.isExpanding = false;
      this.details.style.height = '';
      this.details.style.overflow = '';
      if (open) {
        this.setAttribute('open', '');
      } else {
        this.removeAttribute('open');
      }
    }
  }
  if (!customElements.get('details-accordion')) {
    customElements.define('details-accordion', DetailsAccordion);
  }
</script>
