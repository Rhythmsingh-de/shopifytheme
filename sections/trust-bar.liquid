<section class="trust-bar section--sm" style="background:{{ section.settings.bg_color | default: '#ffffff' }};border-bottom:1px solid var(--color-border)">
  <div class="container">
    <div class="trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item reveal" style="transition-delay:{{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
          <div class="trust-bar__icon">
            {%- case block.settings.icon -%}
              {%- when 'shipping' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'returns' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>
              {%- when 'secure' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'guarantee' -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
              {%- else -%}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {%- endcase -%}
          </div>
          <div>
            <div class="trust-bar__label">{{ block.settings.label }}</div>
            {%- if block.settings.sub != blank -%}
              <div class="trust-bar__sub">{{ block.settings.sub }}</div>
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        {%- assign default_badges = settings.trust_badge_1 | append: '||' | append: settings.trust_badge_2 | append: '||' | append: settings.trust_badge_3 | append: '||' | append: settings.trust_badge_4 | split: '||' -%}
        {%- assign badge_icons = 'shipping,returns,secure,guarantee' | split: ',' -%}
        {%- for b in default_badges -%}
          {%- if b != blank -%}
            <div class="trust-bar__item reveal" style="transition-delay:{{ forloop.index0 | times: 80 }}ms">
              <div class="trust-bar__icon">
                {%- case badge_icons[forloop.index0] -%}
                  {%- when 'shipping' -%}<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {%- when 'returns' -%}<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>
                  {%- when 'secure' -%}<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  {%- else -%}<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                {%- endcase -%}
              </div>
              <div>
                <div class="trust-bar__label">{{ b }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
.trust-bar__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--sp-6);
}
.trust-bar__item {
  display: flex; align-items: center; gap: var(--sp-3);
  padding: var(--sp-3) 0;
}
.trust-bar__icon {
  flex-shrink: 0;
  width: 52px; height: 52px;
  background: color-mix(in oklch, var(--color-primary) 8%, #fff);
  border-radius: var(--radius-lg);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-primary);
}
.trust-bar__label {
  font-weight: 700; font-size: var(--text-sm);
  color: var(--color-text); line-height: 1.3;
}
.trust-bar__sub {
  font-size: var(--text-xs); color: var(--color-text-muted);
  margin-top: 2px;
}
@media (max-width: 640px) {
  .trust-bar__grid { grid-template-columns: 1fr 1fr; gap: var(--sp-4); }
}
</style>
{% schema %}
{
  "name": "Trust Bar",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust Item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "shipping", "label": "Shipping truck" },
          { "value": "returns", "label": "Returns arrow" },
          { "value": "secure", "label": "Secure shield" },
          { "value": "guarantee", "label": "Guarantee badge" }
        ], "default": "shipping" },
        { "type": "text", "id": "label", "label": "Label", "default": "Free Shipping" },
        { "type": "text", "id": "sub", "label": "Subtext", "default": "On orders over $75" }
      ]
    }
  ],
  "presets": [{ "name": "Trust Bar" }]
}
{% endschema %}
