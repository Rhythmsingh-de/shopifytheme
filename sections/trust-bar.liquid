
{%- if section.settings.show -%}
<div class="trust-bar" style="background:{{ section.settings.bg_color }};">
  <div class="page-width trust-bar-inner">
    {%- for block in section.blocks -%}
      <div class="trust-item" {{ block.shopify_attributes }}>
        <svg viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.icon_color }}" stroke-width="2" width="18" height="18">
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}<rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
            {%- when 'shield' -%}<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            {%- when 'refresh' -%}<polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
            {%- when 'star' -%}<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            {%- else -%}<polyline points="20 6 9 17 4 12"/>
          {%- endcase -%}
        </svg>
        <span>{{ block.settings.text }}</span>
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Trust bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show trust bar", "default": true },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free U.S. shipping $75+" },
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "truck", "label": "Truck / Shipping" },
          { "value": "shield", "label": "Shield / Secure" },
          { "value": "refresh", "label": "Refresh / Returns" },
          { "value": "star", "label": "Star / Quality" },
          { "value": "check", "label": "Checkmark" }
        ], "default": "truck" },
        { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#c9a96e" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "Free U.S. shipping on $75+", "icon": "truck" } },
        { "type": "trust_item", "settings": { "text": "30-day hassle-free returns", "icon": "refresh" } },
        { "type": "trust_item", "settings": { "text": "Secure & encrypted checkout", "icon": "shield" } },
        { "type": "trust_item", "settings": { "text": "50,000+ happy customers", "icon": "star" } }
      ]
    }
  ]
}
{% endschema %}
