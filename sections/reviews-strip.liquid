<section class="reviews-strip reveal" style="background:{{ section.settings.bg_color | default: '#ffffff' }};color:{{ section.settings.text_color | default: '#111111' }};">
  <div class="container">
    
    <div class="reviews-strip__head">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="reviews-strip__subtext">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>

    <div class="reviews-strip__grid">
      {% for block in section.blocks %}
        {% if block.type == 'review' %}
          <div class="review-card reveal" style="transition-delay: {{ forloop.index0 | times: 80 }}ms;" {{ block.shopify_attributes }}>
            
            <div class="review-card__header">
              {% if block.settings.avatar != blank %}
                <img 
                  src="{{ block.settings.avatar | image_url: width: 100, height: 100, crop: 'center' }}" 
                  class="review-card__avatar" 
                  alt="{{ block.settings.author | escape }}" 
                  width="44" height="44" 
                  loading="lazy" decoding="async">
              {% else %}
                <div class="review-card__avatar-placeholder">
                  {{ block.settings.author | slice: 0, 1 | upcase }}
                </div>
              {% endif %}
              
              <div class="review-card__author-info">
                <div class="review-card__author-row">
                  <span class="review-card__author">{{ block.settings.author }}</span>
                  {% if block.settings.verified %}
                    <svg class="review-card__verified" width="14" height="14" viewBox="0 0 24 24" fill="#0066cc" aria-hidden="true" title="Verified Customer">
                      <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                    </svg>
                  {% endif %}
                </div>
                <div class="review-card__stars" aria-label="{{ block.settings.stars }} stars">
                  {% assign stars_count = block.settings.stars | size %}
                  {% if stars_count > 0 %}
                    {% for i in (1..block.settings.stars) %}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="#f5a623" stroke="#f5a623" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {% endfor %}
                  {% else %}
                    {% for i in (1..5) %}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="#f5a623" stroke="#f5a623" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    {% endfor %}
                  {% endif %}
                </div>
              </div>
            </div>

            <p class="review-card__text">"{{ block.settings.text }}"</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
.reviews-strip {
  padding: clamp(48px, 6vw, 80px) 0;
  border-bottom: 1px solid var(--color-border, #dddbd7);
}
.reviews-strip__head {
  text-align: center;
  margin-bottom: clamp(32px, 5vw, 48px);
}
.reviews-strip__head h2 {
  font-family: var(--font-display, inherit);
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 8px;
}
.reviews-strip__subtext {
  color: var(--color-text-muted, #666);
  font-size: var(--text-sm, 14px);
  margin-top: 4px;
}
.reviews-strip__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--sp-6, 24px);
}
.review-card {
  background: var(--color-surface, #ffffff);
  border: 1px solid var(--color-border, #dddbd7);
  border-radius: var(--radius-lg, 12px);
  padding: var(--sp-6, 24px);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.review-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.06);
}
.review-card__header {
  display: flex;
  align-items: center;
  gap: 12px;
}
.review-card__avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
}
.review-card__avatar-placeholder {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--color-btn-primary-bg, #1a1a1a);
  color: var(--color-btn-primary-text, #ffffff);
  font-weight: 700;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.review-card__author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.review-card__author-row {
  display: flex;
  align-items: center;
  gap: 6px;
}
.review-card__author {
  font-weight: 700;
  font-size: var(--text-sm, 14px);
  color: var(--color-text, #111111);
}
.review-card__verified {
  flex-shrink: 0;
  margin-top: 1px;
}
.review-card__stars {
  display: flex;
  align-items: center;
  gap: 2px;
}
.review-card__text {
  font-size: var(--text-sm, 14px);
  line-height: 1.6;
  color: var(--color-text-muted, #555555);
  margin: 0;
  flex: 1;
}
</style>

{% schema %}
{
  "name": "Reviews Strip",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"Loved by Thousands"},
    {"type":"text","id":"subtext","label":"Subtext","default":"Excellent  ★★★★★  4.8/5 from 2,500+ reviews"},
    {"type":"header","content":"Design Customization"},
    {"type":"color","id":"bg_color","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text_color","label":"Text color","default":"#111111"}
  ],
  "blocks":[{
    "type":"review","name":"Review",
    "settings":[
      {"type":"image_picker","id":"avatar","label":"Reviewer avatar"},
      {"type":"range","id":"stars","label":"Stars rating","min":1,"max":5,"step":1,"default":5},
      {"type":"textarea","id":"text","label":"Review text","default":"I ordered three items and every single one arrived beautifully packaged. The quality is outstanding — soft, well-fitted and exactly as described."},
      {"type":"text","id":"author","label":"Author name","default":"Sarah M."},
      {"type":"checkbox","id":"verified","label":"Verified purchase badge","default":true}
    ]
  }],
  "presets":[{
    "name":"Reviews Strip",
    "blocks":[
      {"type":"review","settings":{"stars":5,"text":"This bottle changed the way I hydrate. The reminders are super helpful and the battery lasts forever!","author":"James D.","verified":true}},
      {"type":"review","settings":{"stars":5,"text":"Love the design and the app integration. It keeps me accountable every single day.","author":"Sarah M.","verified":true}},
      {"type":"review","settings":{"stars":5,"text":"Perfect for the gym and work. Durable, stylish, and actually makes a difference.","author":"Michael T.","verified":true}}
    ]
  }]
}
{% endschema %}
