<section class="reviews-strip" style="background:{{ section.settings.bg_color | default: 'var(--color-surface, #ffffff)' }};color:{{ section.settings.text_color | default: 'var(--color-text, #111111)' }};">
  <div class="page-w">
    <div class="reviews-strip__head">
      <h2>{{ section.settings.heading }}</h2>
      {% if section.settings.subtext != blank %}
        <p class="reviews-strip__subtext">{{ section.settings.subtext }}</p>
      {% endif %}
    </div>
    <div class="reviews-strip__grid">
      {% for block in section.blocks %}
        <div class="review-card" {{ block.shopify_attributes }}>
          <div class="review-stars">{{ block.settings.stars }}</div>
          <p class="review-text">"{{ block.settings.text }}"</p>
          <div class="review-author">{{ block.settings.author }}</div>
          {% if block.settings.verified %}
            <div class="review-verified">✓ Verified Purchase</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.reviews-strip {
  padding: clamp(60px, 8vw, 100px) 0;
  border-bottom: 1px solid var(--color-border, #ddd);
}
.reviews-strip__head {
  text-align: center;
  margin-bottom: clamp(40px, 6vw, 60px);
}
.reviews-strip__head h2 {
  font-family: var(--font-display, inherit);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: var(--sp-2, 8px);
}
.reviews-strip__subtext {
  color: var(--color-text-muted, #888);
  font-size: var(--text-base, 16px);
  margin-top: var(--sp-1, 4px);
}
.reviews-strip__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: var(--sp-6, 24px);
}
.reviews-strip .review-card {
  background: var(--color-surface-2, #f5f3f0);
  border: 1px solid var(--color-border, #ddd);
  border-radius: var(--radius-lg, 12px);
  padding: var(--sp-6, 24px);
  transition: transform var(--transition, 180ms ease), box-shadow var(--transition, 180ms ease);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2, 8px);
}
.reviews-strip .review-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md, 0 4px 12px rgba(0,0,0,0.09));
}
.reviews-strip .review-stars {
  color: var(--color-gold, #c8941a);
  font-size: 1.15rem;
  letter-spacing: 2px;
}
.reviews-strip .review-text {
  font-style: italic;
  color: var(--color-text, #111);
  font-size: var(--text-sm, 14px);
  line-height: 1.6;
  flex: 1;
}
.reviews-strip .review-author {
  font-weight: 700;
  font-size: var(--text-xs, 12px);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: var(--sp-3, 12px);
  color: var(--color-text-muted, #666);
}
.reviews-strip .review-verified {
  font-size: 10px;
  color: var(--color-success, #1d6b44);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
</style>

{% schema %}
{
  "name": "Reviews Strip",
  "settings": [
    {"type":"text","id":"heading","label":"Heading","default":"What Our Customers Say"},
    {"type":"text","id":"subtext","label":"Subtext","default":"4.9 out of 5 stars · 12,000+ reviews"},
    {"type":"header","content":"Design Customization"},
    {"type":"color","id":"bg_color","label":"Background color","default":"#ffffff"},
    {"type":"color","id":"text_color","label":"Text color","default":"#111111"}
  ],
  "blocks":[{
    "type":"review","name":"Review",
    "settings":[
      {"type":"text","id":"stars","label":"Stars (use ★)","default":"★★★★★"},
      {"type":"textarea","id":"text","label":"Review text","default":"I ordered three items and every single one arrived beautifully packaged. The quality is outstanding — soft, well-fitted and exactly as described."},
      {"type":"text","id":"author","label":"Author name","default":"Sarah M."},
      {"type":"checkbox","id":"verified","label":"Verified purchase badge","default":true}
    ]
  }],
  "presets":[{
    "name":"Reviews Strip",
    "blocks":[
      {"type":"review","settings":{"stars":"★★★★★","text":"Absolutely love the quality. These are the most comfortable clothes I've ever worn — worth every penny!","author":"Emma L.","verified":true}},
      {"type":"review","settings":{"stars":"★★★★★","text":"The jewellery is stunning. Packaged beautifully, arrived fast, and the craftsmanship is incredible. Already ordered again.","author":"Priya K.","verified":true}},
      {"type":"review","settings":{"stars":"★★★★★","text":"My dog went crazy for the toys — built really tough too. Great brand, great mission. I'll be a customer for life.","author":"James T.","verified":true}}
    ]
  }]
}
{% endschema %}
