<header id="site-header" class="site-header{% if section.settings.sticky %} site-header--sticky{% endif %}"
  style="--logo-width: {{ section.settings.logo_width | default: 120 }}px; --logo-width-mobile: {{ section.settings.logo_width_mobile | default: 80 }}px;">
  <div class="container">
    <div class="header__inner" data-logo-pos="{{ section.settings.logo_position | default: 'left' }}">

      <button class="header__icon-btn header__hamburger" id="mobileNavTrigger"
        aria-label="Open navigation" aria-expanded="false" aria-controls="nav-drawer">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

      <a href="/" class="header__logo" aria-label="{{ shop.name }} home">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
          {%- assign logo_width_desktop = section.settings.logo_width | default: 120 -%}
          {%- assign logo_height_desktop = logo_width_desktop | divided_by: section.settings.logo.aspect_ratio | round -%}
          {{ section.settings.logo | image_url: width: 600 | image_tag:
            widths: '120,240,360,600',
            width: logo_width_desktop,
            height: logo_height_desktop,
            class: 'header__logo-image',
            loading: 'eager',
            fetchpriority: 'high',
            alt: logo_alt }}
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>

      <nav class="header__nav" aria-label="Main navigation">
        {%- for link in section.settings.menu.links -%}
          <a href="{{ link.url }}" class="header__nav-link{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
        {%- endfor -%}
      </nav>

      <div class="header__actions">
        <button class="header__icon-btn search-toggle" aria-label="Search" data-search-toggle>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>

        {%- if section.settings.show_account_icon -%}
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="header__icon-btn"
            aria-label="{%- if customer -%}My account ({{ customer.first_name | escape }}){%- else -%}Log in{%- endif -%}">
            {%- if customer -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {%- else -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            {%- endif -%}
          </a>
        {%- endif -%}

        <button class="header__icon-btn" aria-label="Cart ({{ cart.item_count }} items)" data-cart-toggle>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
          </svg>
          <span class="header__cart-count" data-cart-count aria-hidden="true"
            style="display:{% if cart.item_count > 0 %}flex{% else %}none{% endif %}">
            {{ cart.item_count }}
          </span>
        </button>

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_link | default: '#SingleProductHome' }}" class="btn header__cta-btn">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</header>

<style>
.header__cta-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8px 20px;
  min-height: 40px;
  font-size: var(--text-xs, 12px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  background: var(--color-secondary, #ff501a);
  color: #ffffff !important;
  border-radius: var(--btn-radius, 9999px);
  transition: transform 0.2s ease, opacity 0.2s ease;
  margin-left: 8px;
  white-space: nowrap;
}
.header__cta-btn:hover {
  transform: translateY(-1px);
  opacity: 0.95;
}
@media (max-width: 640px) {
  .header__cta-btn { display: none; }
}
.site-header {
  background: var(--color-header-bg);
  padding: var(--sp-4) 0;
  border-bottom: 1px solid var(--color-border);
  z-index: 200;
  position: relative;
  transition: background 0.35s ease, box-shadow 0.35s ease, backdrop-filter 0.35s ease, border-color 0.35s ease;
}
.site-header--sticky { position: sticky; top: 0; }
.header--scrolled { box-shadow: var(--shadow-sm); }

/* ── Transparent hero mode ── */
.site-header--transparent {
  background: transparent !important;
  border-bottom-color: transparent !important;
  box-shadow: none !important;
}
.site-header--transparent .header__logo-text,
.site-header--transparent .header__nav-link,
.site-header--transparent .header__icon-btn {
  color: #ffffff;
}
.site-header--transparent .header__nav-link:hover { color: rgba(255,255,255,0.75); }
.site-header--solid {
  background: rgba(var(--color-header-bg-rgb, 255,255,255), 0.92) !important;
  backdrop-filter: blur(12px) !important;
  -webkit-backdrop-filter: blur(12px) !important;
  border-bottom-color: var(--color-border) !important;
  box-shadow: 0 2px 20px rgba(0,0,0,0.08) !important;
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
}
.header__logo {
  display: flex;
  align-items: center;
  text-decoration: none;
}
.header__logo-image {
  display: block;
  max-width: 100%;
  width: var(--logo-width-mobile, 80px);
  height: auto;
  object-fit: contain;
}
.header__logo-text {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-header-text);
  line-height: 1;
}
.header__nav { display: flex; gap: var(--sp-8); }
.header__nav-link {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  transition: color var(--trans-base);
}
.header__nav-link:hover,
.header__nav-link.is-active { color: var(--color-text); }
.header__actions { display: flex; align-items: center; gap: var(--sp-3); }
.header__icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-md);
  color: var(--color-header-text);
  position: relative;
  transition: background var(--trans-base);
}
.header__icon-btn:hover { background: var(--color-surface); }
.header__cart-count {
  position: absolute;
  top: 4px; right: 4px;
  background: var(--color-primary);
  color: var(--color-primary-text);
  font-size: 0.6rem;
  font-weight: 700;
  width: 16px; height: 16px;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.header__hamburger { display: none; }

@media (max-width: 768px) {
  .header__nav { display: none; }
  .header__hamburger { display: flex; }
  
  /* Centered logo on mobile */
  .header__inner[data-logo-pos="center"],
  .header__inner[data-logo-pos="center-bottom"] {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    width: 100%;
  }
  .header__inner[data-logo-pos="center"] .header__hamburger,
  .header__inner[data-logo-pos="center-bottom"] .header__hamburger {
    grid-column: 1;
    justify-self: start;
    display: flex;
  }
  .header__inner[data-logo-pos="center"] .header__logo,
  .header__inner[data-logo-pos="center-bottom"] .header__logo {
    grid-column: 2;
    justify-self: center;
  }
  .header__inner[data-logo-pos="center"] .header__actions,
  .header__inner[data-logo-pos="center-bottom"] .header__actions {
    grid-column: 3;
    justify-self: end;
  }

  /* Left logo on mobile */
  .header__inner[data-logo-pos="left"] .header__logo,
  .header__inner[data-logo-pos="left-left"] .header__logo,
  .header__inner[data-logo-pos="right"] .header__logo {
    order: 1;
  }
  .header__inner[data-logo-pos="left"] .header__actions,
  .header__inner[data-logo-pos="left-left"] .header__actions,
  .header__inner[data-logo-pos="right"] .header__actions {
    order: 2;
    margin-left: auto;
  }
  .header__inner[data-logo-pos="left"] .header__hamburger,
  .header__inner[data-logo-pos="left-left"] .header__hamburger,
  .header__inner[data-logo-pos="right"] .header__hamburger {
    order: 3;
  }
}

@media (min-width: 769px) {
  .header__inner {
    display: grid;
    align-items: center;
  }
  .header__logo-image {
    width: var(--logo-width, 120px);
  }

  /* Left (menu center) */
  .header__inner[data-logo-pos="left"] {
    grid-template-columns: 1fr auto 1fr;
  }
  .header__inner[data-logo-pos="left"] .header__logo { grid-column: 1; justify-self: start; }
  .header__inner[data-logo-pos="left"] .header__nav { grid-column: 2; justify-self: center; }
  .header__inner[data-logo-pos="left"] .header__actions { grid-column: 3; justify-self: end; }

  /* Left-left (logo left, menu left, actions right) */
  .header__inner[data-logo-pos="left-left"] {
    grid-template-columns: auto 1fr auto;
    gap: var(--sp-8);
  }
  .header__inner[data-logo-pos="left-left"] .header__logo { grid-column: 1; justify-self: start; }
  .header__inner[data-logo-pos="left-left"] .header__nav { grid-column: 2; justify-self: start; }
  .header__inner[data-logo-pos="left-left"] .header__actions { grid-column: 3; justify-self: end; }

  /* Center (logo center, menu left, actions right) */
  .header__inner[data-logo-pos="center"] {
    grid-template-columns: 1fr auto 1fr;
  }
  .header__inner[data-logo-pos="center"] .header__nav { grid-column: 1; justify-self: start; }
  .header__inner[data-logo-pos="center"] .header__logo { grid-column: 2; justify-self: center; }
  .header__inner[data-logo-pos="center"] .header__actions { grid-column: 3; justify-self: end; }

  /* Center-bottom (logo center, menu below) */
  .header__inner[data-logo-pos="center-bottom"] {
    grid-template-columns: 1fr auto 1fr;
    grid-template-rows: auto auto;
    row-gap: var(--sp-3);
  }
  .header__inner[data-logo-pos="center-bottom"] .header__logo { grid-column: 2; grid-row: 1; justify-self: center; }
  .header__inner[data-logo-pos="center-bottom"] .header__actions { grid-column: 3; grid-row: 1; justify-self: end; }
  .header__inner[data-logo-pos="center-bottom"] .header__nav { grid-column: 1 / span 3; grid-row: 2; justify-self: center; }

  /* Right (logo right, menu center, actions left) */
  .header__inner[data-logo-pos="right"] {
    grid-template-columns: 1fr auto 1fr;
  }
  .header__inner[data-logo-pos="right"] .header__actions { grid-column: 1; justify-self: start; }
  .header__inner[data-logo-pos="right"] .header__nav { grid-column: 2; justify-self: center; }
  .header__inner[data-logo-pos="right"] .header__logo { grid-column: 3; justify-self: end; }
}
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "select", "id": "logo_position", "label": "Logo position (desktop)", "options": [
      { "value": "left", "label": "Left (menu center)" },
      { "value": "left-left", "label": "Left (menu left)" },
      { "value": "center", "label": "Center (menu left)" },
      { "value": "center-bottom", "label": "Center (menu below)" },
      { "value": "right", "label": "Right (menu center)" }
    ], "default": "left" },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width (desktop)",
      "default": 120
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Logo width (mobile)",
      "default": 80
    },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu" },
    { "type": "checkbox", "id": "sticky", "label": "Sticky header", "default": true },
    { "type": "checkbox", "id": "show_account_icon", "label": "Show account icon", "default": true },
    { "type": "header", "content": "Header Button CTA" },
    { "type": "text", "id": "cta_label", "label": "CTA button label", "default": "Buy Now — $89" },
    { "type": "url", "id": "cta_link", "label": "CTA button link" }
  ]
}
{% endschema %}
