
<header class="site-header" id="site-header" role="banner" style="--header-bg:{{ section.settings.bg_color }};">
  <style>
    .site-header { background: {{ section.settings.bg_color }}; }
    .brand { font-size: {{ section.settings.brand_size }}px; }
    .nav__link { color: {{ section.settings.nav_color }}; }
    .cart-btn { background: {{ section.settings.cart_btn_color }}; color: {{ section.settings.cart_btn_text }}; }
  </style>
  <div class="page-width header-inner">

    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 300 }}"
             alt="{{ shop.name }}"
             width="{{ section.settings.logo_width }}"
             height="auto"
             loading="eager">
      {%- else -%}
        {{ section.settings.brand_name | default: shop.name }}
      {%- endif -%}
    </a>

    <nav class="nav" aria-label="Main navigation">
      {%- for link in linklists[section.settings.menu].links -%}
        <a class="nav__link{% if link.active %} active{% endif %}" href="{{ link.url }}">
          {{ link.title }}
        </a>
      {%- endfor -%}
    </nav>

    <div class="header-actions">
      {%- if section.settings.show_search -%}
        <a class="header-icon-btn" href="{{ routes.search_url }}" aria-label="Search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
        <a class="header-icon-btn" href="{{ routes.account_url }}" aria-label="Account">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="20" height="20"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
      {%- endif -%}
      <button class="cart-btn" id="cart-drawer-trigger" aria-label="Open cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {{ section.settings.cart_label | default: "Cart" }}
        <span class="cart-count" id="cart-count">{{ cart.item_count }}</span>
      </button>
      <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    { "type": "image_picker", "id": "logo", "label": "Logo image" },
    { "type": "range", "id": "logo_width", "min": 60, "max": 300, "step": 10, "unit": "px", "label": "Logo width", "default": 140 },
    { "type": "text", "id": "brand_name", "label": "Brand name (used if no logo)", "default": "BodyLuxCare" },
    { "type": "range", "id": "brand_size", "min": 14, "max": 36, "step": 1, "unit": "px", "label": "Brand name size", "default": 22 },
    {
      "type": "header",
      "content": "Navigation"
    },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" },
    { "type": "color", "id": "nav_color", "label": "Nav link color", "default": "#111111" },
    {
      "type": "header",
      "content": "Actions"
    },
    { "type": "checkbox", "id": "show_search", "label": "Show search icon", "default": true },
    { "type": "checkbox", "id": "show_account", "label": "Show account icon", "default": true },
    { "type": "text", "id": "cart_label", "label": "Cart button label", "default": "Cart" },
    {
      "type": "header",
      "content": "Colors"
    },
    { "type": "color", "id": "bg_color", "label": "Header background", "default": "#faf8f5" },
    { "type": "color", "id": "cart_btn_color", "label": "Cart button color", "default": "#111111" },
    { "type": "color", "id": "cart_btn_text", "label": "Cart button text color", "default": "#ffffff" }
  ]
}
{% endschema %}
