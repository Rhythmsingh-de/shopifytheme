
<style>
.site-header{position:sticky;top:0;z-index:200;background:var(--c-header-bg,#fff);border-bottom:1px solid var(--c-header-border,#e4e2de);transition:box-shadow .2s ease}
.site-header.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.08)}
.header-inner{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:{{ section.settings.header_height }}px;padding:0 clamp(16px,3vw,40px);gap:8px}
.header-left{display:flex;align-items:center;gap:4px}
.header-logo{display:flex;align-items:center;justify-content:center;text-decoration:none}
.header-logo img{height:{{ section.settings.logo_height }}px;width:auto;display:block;object-fit:contain}
.header-logo-text{font-size:20px;font-weight:900;letter-spacing:-.05em;color:var(--c-header-text,#1a1a1a);text-decoration:none}
.header-logo-text .accent{color:var(--c-deco,#2d7a4f)}
.header-nav{display:flex;align-items:center;gap:2px}
.header-nav>a,.nav-item>a{font-size:13px;font-weight:600;letter-spacing:.02em;color:var(--c-header-text,#1a1a1a);text-decoration:none;padding:8px 12px;border-radius:6px;transition:background .15s,color .15s;white-space:nowrap;display:block}
.header-nav>a:hover,.nav-item>a:hover{background:rgba(0,0,0,.05);color:var(--c-deco,#2d7a4f)}
.header-actions{display:flex;align-items:center;justify-content:flex-end;gap:2px}
.icon-btn{width:40px;height:40px;display:flex;align-items:center;justify-content:center;border-radius:8px;color:var(--c-header-text,#1a1a1a);background:none;border:none;cursor:pointer;text-decoration:none;position:relative;transition:background .15s}
.icon-btn:hover{background:rgba(0,0,0,.06)}
.icon-btn svg{width:20px;height:20px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;display:block}
.cart-badge{position:absolute;top:5px;right:5px;background:#e8260d;color:#fff;font-size:9px;font-weight:900;min-width:16px;height:16px;border-radius:999px;display:flex;align-items:center;justify-content:center;padding:0 3px;line-height:1;border:1.5px solid var(--c-header-bg,#fff)}
.hamburger{width:40px;height:40px;display:none;flex-direction:column;justify-content:center;align-items:center;gap:5px;border-radius:8px;background:none;border:none;cursor:pointer;transition:background .15s}
.hamburger:hover{background:rgba(0,0,0,.06)}
.ham-line{display:block;width:20px;height:2px;background:var(--c-header-text,#1a1a1a);border-radius:2px;transition:transform .25s,opacity .25s}
/* Mega nav */
.nav-item{position:relative}
.nav-dropdown{position:absolute;top:calc(100% + 4px);left:50%;transform:translateX(-50%) translateY(-6px);min-width:520px;background:#fff;border:1px solid #e4e2de;border-radius:14px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,.14);display:grid;grid-template-columns:repeat(4,1fr);gap:4px;opacity:0;visibility:hidden;transition:opacity .18s ease,transform .18s ease,visibility .18s;z-index:300;pointer-events:none}
.nav-item:hover .nav-dropdown,.nav-item:focus-within .nav-dropdown{opacity:1;visibility:visible;transform:translateX(-50%) translateY(0);pointer-events:auto}
.nd-col{display:flex;flex-direction:column;gap:2px}
.nd-head{font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:#aaa;padding:4px 10px 8px;border-bottom:1px solid #f0f0f0;margin-bottom:4px}
.nd-col a{font-size:13px;font-weight:500;color:#1a1a1a;text-decoration:none;padding:7px 10px;border-radius:7px;transition:background .12s,color .12s;white-space:nowrap}
.nd-col a:hover{background:var(--c-deco-light,#e8f5ee);color:var(--c-deco,#2d7a4f)}
/* Search bar */
.header-search-bar{overflow:hidden;max-height:0;transition:max-height .3s ease,padding .3s ease;background:var(--c-header-bg,#fff);border-top:0px solid #e4e2de}
.header-search-bar.open{max-height:80px;border-top-width:1px;padding:10px clamp(16px,3vw,40px)}
.header-search-form{max-width:560px;margin:0 auto;display:flex;gap:8px}
.header-search-form input{flex:1;padding:10px 16px;border:1.5px solid #e4e2de;border-radius:9999px;font-size:14px;outline:none;transition:border-color .15s}
.header-search-form input:focus{border-color:var(--c-deco,#2d7a4f)}
.header-search-form button{padding:10px 20px;background:var(--c-deco,#2d7a4f);color:#fff;border:none;border-radius:9999px;font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;transition:filter .15s}
.header-search-form button:hover{filter:brightness(.9)}
@media(max-width:900px){.header-nav,.header-actions .icon-btn:not(.cart-icon-btn):not(#searchToggle){display:none}.hamburger{display:flex}.header-inner{grid-template-columns:44px 1fr 44px}}
</style>

<header class="site-header" id="siteHeader" role="banner">
  <div class="header-inner">
    <!-- Left -->
    <div class="header-left">
      <button class="hamburger" id="hamburger" aria-label="Open navigation menu" aria-expanded="false" aria-controls="mobileNav">
        <span class="ham-line"></span><span class="ham-line"></span><span class="ham-line"></span>
      </button>
      <nav class="header-nav" aria-label="Main navigation">
        <!-- Shop mega nav -->
        <div class="nav-item">
          <a href="/collections/all" aria-haspopup="true">Shop ▾</a>
          <div class="nav-dropdown" role="menu">
            <div class="nd-col">
              <div class="nd-head">Women</div>
              <a href="/collections/womens-beauty">Beauty</a>
              <a href="/collections/womens-wellness">Wellness</a>
              <a href="/collections/womens-massage">Massage</a>
              <a href="/collections/womens-accessories">Accessories</a>
            </div>
            <div class="nd-col">
              <div class="nd-head">Men</div>
              <a href="/collections/mens-grooming">Grooming</a>
              <a href="/collections/mens-wellness">Wellness</a>
              <a href="/collections/mens-massage">Massage</a>
              <a href="/collections/mens-accessories">Accessories</a>
            </div>
            <div class="nd-col">
              <div class="nd-head">Pets</div>
              <a href="/collections/pets-dogs">Dogs</a>
              <a href="/collections/pets-cats">Cats</a>
              <a href="/collections/pets-grooming">Grooming</a>
              <a href="/collections/pets-wellness">Wellness</a>
            </div>
            <div class="nd-col">
              <div class="nd-head">Home</div>
              <a href="/collections/home-decor">Decor</a>
              <a href="/collections/home-aromatherapy">Aromatherapy</a>
              <a href="/collections/home-bedding">Bedding</a>
              <a href="/collections/massage-recovery">Recovery</a>
            </div>
          </div>
        </div>
        {% for link in linklists.main-menu.links %}
          <a href="{{ link.url }}"{% if link.url == request.path %} class="active" aria-current="page"{% endif %}>{{ link.title }}</a>
        {% endfor %}
      </nav>
    </div>

    <!-- Center: Logo -->
    <a class="header-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }} — Home">
      {% if section.settings.logo != blank %}
        {{ section.settings.logo | image_url: width: 300 | image_tag:
           alt: shop.name,
           width: section.settings.logo_width,
           height: section.settings.logo_height,
           loading: 'eager',
           fetchpriority: 'high' }}
      {% else %}
        <span class="header-logo-text">Body<span class="accent">Lux</span>Care</span>
      {% endif %}
    </a>

    <!-- Right: icons -->
    <div class="header-actions">
      <button class="icon-btn" id="searchToggle" aria-label="Search" aria-expanded="false" aria-controls="headerSearchBar">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      </button>
      {% if section.settings.show_account %}
      <a class="icon-btn" href="{{ routes.account_url }}" aria-label="My account">
        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      {% endif %}
      <button class="icon-btn cart-icon-btn" id="cartToggle" aria-label="Open cart, {{ cart.item_count }} items">
        <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-badge" id="cartBadge"{% if cart.item_count == 0 %} style="display:none"{% endif %}>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  <!-- Search bar -->
  <div class="header-search-bar" id="headerSearchBar">
    <form class="header-search-form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Search products…' }}"
             aria-label="Search products" value="{{ search.terms | escape }}" autocomplete="off">
      <button type="submit">Search</button>
    </form>
  </div>
</header>

<script>
(function(){
  var hdr = document.getElementById('siteHeader');
  var cartDrawer = document.getElementById('cartDrawer');
  var mobileNav  = document.getElementById('mobileNav');

  // Sticky shadow
  window.addEventListener('scroll', function(){ hdr.classList.toggle('scrolled', window.scrollY > 8); }, {passive:true});

  // Search toggle
  var searchBtn = document.getElementById('searchToggle');
  var searchBar = document.getElementById('headerSearchBar');
  searchBtn.addEventListener('click', function(){
    var open = searchBar.classList.toggle('open');
    searchBtn.setAttribute('aria-expanded', open);
    if(open) setTimeout(function(){ searchBar.querySelector('input').focus(); }, 320);
  });

  // Cart open/close
  function openCart(){ cartDrawer.classList.add('open'); cartDrawer.removeAttribute('aria-hidden'); document.body.style.overflow='hidden'; }
  function closeCart(){ cartDrawer.classList.remove('open'); cartDrawer.setAttribute('aria-hidden','true'); document.body.style.overflow=''; }
  document.getElementById('cartToggle')?.addEventListener('click', openCart);
  document.getElementById('cartClose')?.addEventListener('click', closeCart);
  document.getElementById('cartOverlay')?.addEventListener('click', closeCart);
  document.getElementById('cartContinue')?.addEventListener('click', closeCart);

  // Mobile nav open/close
  function openNav(){ mobileNav.classList.add('open'); mobileNav.removeAttribute('aria-hidden'); document.body.style.overflow='hidden'; document.getElementById('hamburger').setAttribute('aria-expanded','true'); }
  function closeNav(){ mobileNav.classList.remove('open'); mobileNav.setAttribute('aria-hidden','true'); document.body.style.overflow=''; document.getElementById('hamburger').setAttribute('aria-expanded','false'); }
  document.getElementById('hamburger')?.addEventListener('click', openNav);
  document.getElementById('mobileClose')?.addEventListener('click', closeNav);
  document.getElementById('mobileOverlay')?.addEventListener('click', closeNav);

  // Escape key closes everything
  document.addEventListener('keydown', function(e){ if(e.key==='Escape'){ closeCart(); closeNav(); searchBar.classList.remove('open'); }});
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {"type":"image_picker","id":"logo","label":"Logo image","info":"Upload your logo. SVG or PNG with transparent background works best."},
    {"type":"range","id":"logo_width","min":60,"max":260,"step":10,"unit":"px","label":"Logo width","default":140},
    {"type":"range","id":"logo_height","min":24,"max":60,"step":2,"unit":"px","label":"Logo max height","default":40},
    {"type":"range","id":"header_height","min":50,"max":90,"step":2,"unit":"px","label":"Header height","default":64},
    {"type":"checkbox","id":"show_account","label":"Show account icon","default":true},
    {"type":"text","id":"search_placeholder","label":"Search placeholder text","default":"Search wellness, beauty, home…"}
  ],
  "presets":[{"name":"Header"}]
}
{% endschema %}
