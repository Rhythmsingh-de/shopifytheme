
<style>
.ann-bar{background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};overflow:hidden;position:relative}
.ann-track{display:flex;width:max-content;animation:ann-scroll {{ section.settings.speed }}s linear infinite}
.ann-track:hover{animation-play-state:paused}
.ann-item{display:flex;align-items:center;gap:10px;padding:0 48px;height:{{ section.settings.bar_height }}px;font-size:13px;font-weight:600;letter-spacing:.03em;white-space:nowrap}
.ann-item .ann-icon{font-size:15px;flex-shrink:0}
.ann-dot{width:4px;height:4px;border-radius:50%;background:currentColor;opacity:.4;flex-shrink:0}
.ann-link{color:inherit;text-decoration:underline;text-underline-offset:2px;font-weight:700;margin-left:4px}
.ann-close{position:absolute;right:12px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:inherit;opacity:.6;line-height:1;font-size:18px;padding:4px;transition:opacity .15s}
.ann-close:hover{opacity:1}
@keyframes ann-scroll{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@media(prefers-reduced-motion:reduce){.ann-track{animation:none;justify-content:center}}
</style>

<div class="ann-bar" id="annBar" role="region" aria-label="Store announcements">
  <div class="ann-track" id="annTrack" aria-live="polite">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        {% if block.settings.text != blank %}
          <div class="ann-item" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}<span class="ann-icon">{{ block.settings.icon }}</span>{% endif %}
            <span>{{ block.settings.text }}{% if block.settings.link_label != blank %}<a class="ann-link" href="{{ block.settings.link_url | default: '#' }}">{{ block.settings.link_label }}</a>{% endif %}</span>
          </div>
          <span class="ann-dot" aria-hidden="true"></span>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
  {% if section.settings.show_close %}
    <button class="ann-close" id="annClose" aria-label="Dismiss announcements">✕</button>
  {% endif %}
</div>

<script>
(function(){
  var bar = document.getElementById('annBar');
  var btn = document.getElementById('annClose');
  if(btn) btn.addEventListener('click', function(){
    bar.style.maxHeight = bar.offsetHeight + 'px';
    requestAnimationFrame(function(){
      bar.style.transition = 'max-height .4s ease, opacity .4s ease';
      bar.style.maxHeight = '0';
      bar.style.opacity   = '0';
    });
  });
  // Auto-detect active discount code from metafield or global variable
  {% if section.settings.discount_code != blank %}
  (function(){
    var code = '{{ section.settings.discount_code }}';
    document.querySelectorAll('.ann-code-slot').forEach(function(el){ el.textContent = code; });
  })();
  {% endif %}
})();
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {"type":"color","id":"bg_color","label":"Background colour","default":"#1a1a1a"},
    {"type":"color","id":"text_color","label":"Text colour","default":"#ffffff"},
    {"type":"range","id":"bar_height","min":30,"max":56,"step":2,"unit":"px","label":"Bar height","default":40},
    {"type":"range","id":"speed","min":10,"max":60,"step":5,"unit":"s","label":"Scroll speed","default":30},
    {"type":"checkbox","id":"show_close","label":"Show close button","default":true},
    {"type":"text","id":"discount_code","label":"Active discount code (auto-inject)","info":"Shown as .ann-code-slot in any block text that contains that placeholder.","default":""}
  ],
  "blocks":[
    {
      "type":"message",
      "name":"Message",
      "settings":[
        {"type":"text","id":"icon","label":"Emoji / icon","default":"🚚"},
        {"type":"richtext","id":"text","label":"Message text","default":"<p>Free U.S. shipping on orders $75+</p>"},
        {"type":"text","id":"link_label","label":"Link label (optional)","default":""},
        {"type":"url","id":"link_url","label":"Link URL","default":""}
      ]
    }
  ],
  "default":{
    "blocks":[
      {"type":"message","settings":{"icon":"🚚","text":"<p>Free U.S. shipping on orders $75+</p>","link_label":"","link_url":""}},
      {"type":"message","settings":{"icon":"🎁","text":"<p>Use code <strong>WELCOME10</strong> for 10% off your first order</p>","link_label":"Shop now","link_url":"/collections/all"}},
      {"type":"message","settings":{"icon":"✨","text":"<p>30-day easy returns · No questions asked</p>","link_label":"","link_url":""}}
    ]
  },
  "presets":[{"name":"Announcement Bar"}]
}
{% endschema %}
