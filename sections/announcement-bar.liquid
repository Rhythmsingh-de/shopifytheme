
{%- if section.settings.show_bar -%}
<div class="announcement-bar" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <div class="page-width">
    {%- if section.settings.link != blank -%}
      <a href="{{ section.settings.link }}" style="color:{{ section.settings.link_color }};">{{ section.settings.text }}</a>
    {%- else -%}
      {{ section.settings.text }}
    {%- endif -%}
  </div>
  {%- if section.settings.dismissible -%}
    <button class="announcement-bar__close" onclick="this.closest('.announcement-bar').remove()" aria-label="Close">&#x2715;</button>
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show_bar", "label": "Show bar", "default": true },
    { "type": "text", "id": "text", "label": "Message", "default": "🚚 Free U.S. shipping on orders $75+ · 30-day easy returns" },
    { "type": "url", "id": "link", "label": "Link URL (optional)" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "link_color", "label": "Link color", "default": "#c9a96e" },
    { "type": "checkbox", "id": "dismissible", "label": "Show close button", "default": true }
  ]
}
{% endschema %}
