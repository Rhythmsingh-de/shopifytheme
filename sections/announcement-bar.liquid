{%- if section.settings.enabled -%}
<div
  id="announcement-bar-{{ section.id }}"
  style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};"
  role="region"
  aria-label="Store announcements"
>
  <div class="ann-inner">
    <button class="ann-nav-btn" id="ann-prev-{{ section.id }}" aria-label="Previous announcement">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="ann-track" id="ann-track-{{ section.id }}" role="status" aria-live="polite">
      {%- if section.settings.text_1 != blank -%}
        <span class="ann-msg ann-msg--active">
          {%- if section.settings.link != blank -%}<a href="{{ section.settings.link }}" style="color:inherit;text-decoration:underline;text-underline-offset:2px">{%- endif -%}
          {{ section.settings.text_1 }}
          {%- if section.settings.link != blank -%}</a>{%- endif -%}
        </span>
      {%- endif -%}
      {%- if section.settings.text_2 != blank -%}
        <span class="ann-msg">{{ section.settings.text_2 }}</span>
      {%- endif -%}
      {%- if section.settings.text_3 != blank -%}
        <span class="ann-msg">{{ section.settings.text_3 }}</span>
      {%- endif -%}
    </div>
    <button class="ann-nav-btn" id="ann-next-{{ section.id }}" aria-label="Next announcement">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    {%- if section.settings.offer_mode and settings.weekly_offer_enabled -%}
      <div class="ann-countdown" id="ann-countdown-{{ section.id }}" aria-label="Offer countdown">
        <span class="ann-countdown__dot"></span>
        <span class="ann-countdown__label">{{ section.settings.countdown_prefix | default: 'Ends in' }}</span>
        <span class="ann-countdown__time" id="ann-time-{{ section.id }}">--:--:--</span>
      </div>
    {%- endif -%}

    <button class="ann-close" id="ann-close-{{ section.id }}" aria-label="Dismiss">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</div>

<style>
#announcement-bar-{{ section.id }} {
  position: relative; z-index: 600;
  font-size: clamp(11px, 1.3vw, 13px);
  font-weight: 600; letter-spacing: 0.04em;
}
.ann-inner {
  display: flex; align-items: center; justify-content: center;
  min-height: 44px; padding: 0 clamp(48px, 7vw, 100px);
  gap: 8px; position: relative;
}
.ann-track {
  position: relative; flex: 1;
  max-width: clamp(280px, 60vw, 680px);
  height: 22px; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.ann-msg {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  text-align: center; white-space: nowrap;
  opacity: 0; transform: translateY(8px);
  transition: opacity 0.4s ease, transform 0.4s ease;
  pointer-events: none;
}
.ann-msg--active { opacity: 1; transform: translateY(0); pointer-events: auto; }
.ann-msg--exit   { opacity: 0; transform: translateY(-8px); }
.ann-nav-btn, .ann-close {
  flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.18); color: inherit;
  border: none; cursor: pointer;
  transition: background 0.15s ease;
}
.ann-nav-btn:hover, .ann-close:hover { background: rgba(255,255,255,0.32); }
.ann-close { position: absolute; right: 14px; top: 50%; transform: translateY(-50%); }

/* Countdown */
.ann-countdown {
  display: flex; align-items: center; gap: 6px;
  flex-shrink: 0;
  font-weight: 700;
  font-size: 12px;
  letter-spacing: 0.04em;
  background: rgba(255,255,255,0.15);
  border-radius: 9999px;
  padding: 4px 12px;
  white-space: nowrap;
}
.ann-countdown__dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 0 2px rgba(74,222,128,0.4);
  animation: ann-dot-pulse 2s ease-in-out infinite;
  flex-shrink: 0;
}
@keyframes ann-dot-pulse {
  0%,100% { box-shadow: 0 0 0 2px rgba(74,222,128,0.4); }
  50%      { box-shadow: 0 0 0 5px rgba(74,222,128,0.1); }
}
.ann-countdown__label { opacity: 0.8; }
.ann-countdown__time  { font-variant-numeric: tabular-nums; }

@media (max-width: 480px) {
  .ann-msg { white-space: normal; font-size: 11px; }
  .ann-nav-btn { display: none; }
  .ann-inner { padding: 0 44px 0 16px; }
  .ann-countdown { display: none; }
}
</style>

<script>
(function () {
  var sid = '{{ section.id }}';
  var bar   = document.getElementById('announcement-bar-' + sid);
  var track = document.getElementById('ann-track-' + sid);
  if (!bar || !track) return;

  document.getElementById('ann-close-' + sid).addEventListener('click', function () {
    bar.style.transition = 'max-height 0.3s, padding 0.3s, opacity 0.3s';
    bar.style.maxHeight  = bar.offsetHeight + 'px';
    bar.style.overflow   = 'hidden';
    requestAnimationFrame(function () {
      bar.style.maxHeight = '0';
      bar.style.opacity   = '0';
      bar.style.padding   = '0';
    });
    setTimeout(function () { bar.remove(); }, 350);
  });

  var msgs = track.querySelectorAll('.ann-msg');
  if (msgs.length < 2) return;

  var current = 0;
  var speed = {{ section.settings.speed }} * 1000;
  var timer;

  function goTo(n) {
    msgs[current].classList.add('ann-msg--exit');
    var leaving = msgs[current];
    setTimeout(function () {
      leaving.classList.remove('ann-msg--active', 'ann-msg--exit');
    }, 380);

    current = (n + msgs.length) % msgs.length;
    msgs[current].classList.add('ann-msg--active');
  }

  function playNext() {
    timer = setTimeout(function () {
      goTo(current + 1);
      playNext();
    }, speed);
  }

  document.getElementById('ann-prev-' + sid).addEventListener('click', function () {
    clearTimeout(timer);
    goTo(current - 1);
    playNext();
  });

  document.getElementById('ann-next-' + sid).addEventListener('click', function () {
    clearTimeout(timer);
    goTo(current + 1);
    playNext();
  });

  playNext();
})();
</script>

{%- if section.settings.offer_mode -%}
<script>
(function() {
  var timeEl = document.getElementById('ann-time-{{ section.id }}');
  if (!timeEl) return;
  var endMeta = document.querySelector('meta[name="weekly-offer-end"]');
  if (!endMeta) return;
  var endTime = new Date(endMeta.content).getTime();
  function pad(n) { return n < 10 ? '0' + n : '' + n; }
  function tick() {
    var diff = endTime - Date.now();
    if (diff <= 0) { timeEl.textContent = '00:00:00'; return; }
    var h = Math.floor(diff / 3600000);
    var m = Math.floor((diff % 3600000) / 60000);
    var s = Math.floor((diff % 60000) / 1000);
    timeEl.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
    setTimeout(tick, 1000);
  }
  tick();
})();
</script>
{%- endif -%}

{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "settings": [
    { "type": "checkbox", "id": "enabled",    "label": "Show announcement bar",  "default": true },
    { "type": "color",    "id": "bg_color",   "label": "Background color",        "default": "#111111" },
    { "type": "color",    "id": "text_color", "label": "Text color",              "default": "#ffffff" },
    { "type": "text",     "id": "text_1",     "label": "Message 1",              "default": "\u26a1 Free shipping on orders over $75" },
    { "type": "text",     "id": "text_2",     "label": "Message 2",              "default": "\ud83d\udd12 60-Day Money-Back Guarantee" },
    { "type": "text",     "id": "text_3",     "label": "Message 3" },
    { "type": "url",      "id": "link",       "label": "Link (optional)" },
    { "type": "checkbox", "id": "auto_rotate","label": "Auto-rotate messages",   "default": true },
    { "type": "range",    "id": "speed",      "label": "Rotation speed (seconds)", "min": 2, "max": 10, "step": 1, "default": 4 },
    { "type": "header",   "content": "Weekly Offer Countdown" },
    { "type": "checkbox", "id": "offer_mode", "label": "Show live countdown timer", "default": false,
      "info": "Reads offer end date from Theme Settings > Weekly Offer. Enable 'Weekly Offer' there first." },
    { "type": "text",     "id": "countdown_prefix", "label": "Countdown label text", "default": "Ends in" }
  ],
  "presets": [
    { "name": "Announcement Bar" }
  ]
}
{% endschema %}
