
<div class="ann-bar" id="annBar" {% unless section.settings.show %}style="display:none"{% endunless %}>
  {{ section.settings.text }}
  {% if section.settings.link_url != blank %}
    <a href="{{ section.settings.link_url }}"> {{ section.settings.link_text }}</a>
  {% endif %}
  <span class="ann-close" id="annClose" aria-label="Close announcement" role="button" tabindex="0">✕</span>
</div>
<script>
  document.getElementById('annClose')?.addEventListener('click', function(){
    document.getElementById('annBar').style.display='none';
  });
</script>
{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {"type":"checkbox","id":"show","label":"Show bar","default":true},
    {"type":"richtext","id":"text","label":"Message","default":"<p>Free shipping on orders $75+ · Use code <strong>WELCOME10</strong> for 10% off</p>"},
    {"type":"url","id":"link_url","label":"Link URL"},
    {"type":"text","id":"link_text","label":"Link text","default":"Shop Now"}
  ],
  "presets":[{"name":"Announcement Bar"}]
}
{% endschema %}
