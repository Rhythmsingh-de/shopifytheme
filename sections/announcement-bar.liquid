{%- if settings.announcement_enabled -%}
<div id="announcement-bar" style="background:{{ settings.color_announcement_bg }};color:{{ settings.color_announcement_text }};" role="region" aria-label="Store announcements">
  <div class="ann-inner">
    <button class="ann-nav-btn" id="ann-prev" aria-label="Previous announcement">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="ann-track" id="ann-track" role="status" aria-live="polite">
      {%- if settings.announcement_text_1 != blank -%}
        <span class="ann-msg ann-msg--active">
          {%- if settings.announcement_link != blank -%}<a href="{{ settings.announcement_link }}" style="color:inherit;text-decoration:underline;text-underline-offset:2px">{%- endif -%}
          {{ settings.announcement_text_1 }}
          {%- if settings.announcement_link != blank -%}</a>{%- endif -%}
        </span>
      {%- endif -%}
      {%- if settings.announcement_text_2 != blank -%}
        <span class="ann-msg">{{ settings.announcement_text_2 }}</span>
      {%- endif -%}
      {%- if settings.announcement_text_3 != blank -%}
        <span class="ann-msg">{{ settings.announcement_text_3 }}</span>
      {%- endif -%}
    </div>
    <button class="ann-nav-btn" id="ann-next" aria-label="Next announcement">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <button class="ann-close" id="ann-close" aria-label="Dismiss announcement bar">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</div>

<style>
#announcement-bar {
  position: relative; z-index: 600;
  font-size: clamp(11px, 1.3vw, 13px);
  font-weight: 600; letter-spacing: 0.04em;
}
.ann-inner {
  display: flex; align-items: center; justify-content: center;
  min-height: 44px; padding: 0 clamp(48px, 7vw, 100px);
  gap: var(--sp-2); position: relative;
}
.ann-track {
  position: relative; flex: 1;
  max-width: clamp(280px, 60vw, 680px);
  height: 22px; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
}
.ann-msg {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  text-align: center; white-space: nowrap;
  opacity: 0; transform: translateY(8px);
  transition: opacity 0.4s var(--ease-out), transform 0.4s var(--ease-out);
  pointer-events: none;
}
.ann-msg--active { opacity: 1; transform: translateY(0); pointer-events: auto; }
.ann-msg--exit   { opacity: 0; transform: translateY(-8px); }
.ann-nav-btn {
  flex-shrink: 0; width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.18); color: inherit;
  border: none; cursor: pointer;
  transition: background var(--trans-fast);
}
.ann-nav-btn:hover { background: rgba(255,255,255,0.32); }
.ann-close {
  position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,0.18); color: inherit;
  border: none; cursor: pointer;
  transition: background var(--trans-fast);
}
.ann-close:hover { background: rgba(255,255,255,0.32); }
@media (max-width: 480px) {
  .ann-msg { white-space: normal; font-size: 11px; }
  .ann-nav-btn { display: none; }
  .ann-inner { padding: 0 44px 0 var(--sp-4); }
}
</style>

<script>
(function() {
  const bar   = document.getElementById('announcement-bar');
  const track = document.getElementById('ann-track');
  if (!bar || !track) return;

  // Dismiss
  document.getElementById('ann-close')?.addEventListener('click', () => {
    bar.style.transition = 'max-height 0.3s, padding 0.3s, opacity 0.3s';
    bar.style.maxHeight  = bar.offsetHeight + 'px';
    bar.style.overflow   = 'hidden';
    requestAnimationFrame(() => { bar.style.maxHeight = '0'; bar.style.opacity = '0'; bar.style.padding = '0'; });
    setTimeout(() => bar.remove(), 350);
  });

  const msgs = track.querySelectorAll('.ann-msg');
  if (msgs.length < 2) return;

  let current = 0;
  const speed = {{ settings.announcement_speed | default: 4 }} * 1000;

  function goTo(n) {
    msgs[current].classList.add('ann-msg--exit');
    const leaving = msgs[current];
    setTimeout(() => leaving.classList.remove('ann-msg--active', 'ann-msg--exit'), 420);
    current = ((n % msgs.length) + msgs.length) % msgs.length;
    msgs[current].classList.add('ann-msg--active');
  }

  let timer;
  function start() {
    clearInterval(timer);
    {%- if settings.announcement_auto_rotate -%}
    timer = setInterval(() => goTo(current + 1), speed);
    {%- endif -%}
  }

  document.getElementById('ann-next')?.addEventListener('click', () => { goTo(current + 1); start(); });
  document.getElementById('ann-prev')?.addEventListener('click', () => { goTo(current - 1); start(); });

  start();
})();
</script>
{%- endif -%}

{% schema %}
{ "name": "Announcement Bar", "settings": [] }
{% endschema %}
