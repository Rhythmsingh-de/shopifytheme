{%- comment -%} BodyLuxCare — Featured Products Section v5 {%- endcomment -%}

{%- assign fp_coll = collections[section.settings.collection] -%}
{%- assign has_products = false -%}
{%- if fp_coll != blank and fp_coll.products.size > 0 -%}
  {%- assign has_products = true -%}
{%- elsif collections.all.products.size > 0 -%}
  {%- assign fp_coll = collections.all -%}
  {%- assign has_products = true -%}
{%- endif -%}

<section class="fp-section section-gap" id="featured-products">
  <div class="page-w">

    <header class="section-hdr reveal" style="text-align:{{ section.settings.heading_align | default: 'center' }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title | default: 'Featured Products' }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </header>

    {%- if has_products -%}
      {%- assign fp_count = section.settings.products_count | default: 4 -%}
      <div class="prod-grid prod-grid--{{ section.settings.columns | default: 4 }}">
        {%- for product in fp_coll.products limit: fp_count -%}
          {%- render 'product-card', product: product, index: forloop.index0 -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      {%- comment -%} Mock cards — replace when store has products {%- endcomment -%}
      <div class="prod-grid prod-grid--4">
        {%- for block in section.blocks -%}
          {%- if block.type == 'mock_product' -%}
          <article class="prod-card reveal" style="transition-delay:{{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
            <div class="prod-card__media">
              {%- if block.settings.image != blank -%}
                <a href="{{ block.settings.url | default: '/collections/all' }}">
                  <img src="{{ block.settings.image | image_url: width: 600 }}"
                       alt="{{ block.settings.title | escape }}"
                       width="600" height="750" loading="lazy" decoding="async"
                       class="prod-card__img prod-card__img--primary">
                </a>
              {%- else -%}
                <a href="{{ block.settings.url | default: '/collections/all' }}" class="prod-card__placeholder-link">
                  <div class="prod-card__img-placeholder">
                    {%- assign ph_colors = '#e8f5e9,#fce4ec,#e3f2fd,#fff3e0,#f3e5f5' | split: ',' -%}
                    {%- assign color_index = forloop.index0 | modulo: 5 -%}
                    {%- assign ph_color = ph_colors[color_index] -%}
                    <div style="background:{{ ph_color }};width:100%;height:100%;display:flex;align-items:center;justify-content:center">
                      {%- if block.settings.category == 'women' -%}
                        <svg viewBox="0 0 80 100" width="60" height="75" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="40" cy="28" rx="16" ry="20" fill="#c8e6c9" stroke="#4caf50" stroke-width="2"/><path d="M20 55 Q20 80 40 85 Q60 80 60 55 L55 42 Q40 50 25 42Z" fill="#a5d6a7" stroke="#4caf50" stroke-width="2"/><line x1="40" y1="85" x2="40" y2="98" stroke="#4caf50" stroke-width="2"/></svg>
                      {%- elsif block.settings.category == 'men' -%}
                        <svg viewBox="0 0 80 100" width="60" height="75" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="26" r="16" fill="#bbdefb" stroke="#1976d2" stroke-width="2"/><rect x="18" y="46" width="44" height="38" rx="4" fill="#90caf9" stroke="#1976d2" stroke-width="2"/><line x1="30" y1="98" x2="30" y2="84" stroke="#1976d2" stroke-width="2"/><line x1="50" y1="98" x2="50" y2="84" stroke="#1976d2" stroke-width="2"/></svg>
                      {%- elsif block.settings.category == 'jewelry' -%}
                        <svg viewBox="0 0 80 80" width="60" height="60" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="40" cy="40" r="22" fill="#fff8e1" stroke="#f9a825" stroke-width="2"/><circle cx="40" cy="40" r="12" fill="#ffecb3" stroke="#f9a825" stroke-width="1.5"/><circle cx="40" cy="40" r="5" fill="#f9a825"/><line x1="40" y1="18" x2="40" y2="12" stroke="#f9a825" stroke-width="2"/><path d="M30 12 Q40 8 50 12" fill="none" stroke="#f9a825" stroke-width="2"/></svg>
                      {%- elsif block.settings.category == 'pets' -%}
                        <svg viewBox="0 0 80 80" width="60" height="60" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="40" cy="50" rx="22" ry="18" fill="#f8bbd0" stroke="#e91e63" stroke-width="2"/><circle cx="40" cy="30" r="12" fill="#fce4ec" stroke="#e91e63" stroke-width="2"/><ellipse cx="31" cy="22" rx="5" ry="7" fill="#fce4ec" stroke="#e91e63" stroke-width="1.5"/><ellipse cx="49" cy="22" rx="5" ry="7" fill="#fce4ec" stroke="#e91e63" stroke-width="1.5"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 80 80" width="60" height="60" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="12" y="20" width="56" height="44" rx="4" fill="#ede7f6" stroke="#7b1fa2" stroke-width="2"/><path d="M12 30 Q40 38 68 30" fill="none" stroke="#7b1fa2" stroke-width="2"/><rect x="28" y="12" width="24" height="14" rx="3" fill="#e1bee7" stroke="#7b1fa2" stroke-width="2"/></svg>
                      {%- endif -%}
                    </div>
                  </div>
                </a>
              {%- endif -%}
              {%- if block.settings.badge != blank -%}
                <span class="prod-card__badge prod-card__badge--{{ block.settings.badge_style | default: 'sale' }}">{{ block.settings.badge }}</span>
              {%- endif -%}
              {%- if settings.card_quick_add -%}
                <div class="prod-card__quick-add">
                  <a href="{{ block.settings.url | default: '/collections/all' }}" class="btn btn--primary btn--sm btn--full">View Product</a>
                </div>
              {%- endif -%}
            </div>
            <div class="prod-card__info">
              {%- if block.settings.vendor != blank -%}
                <p class="prod-card__vendor">{{ block.settings.vendor }}</p>
              {%- endif -%}
              <h3 class="prod-card__title">
                <a href="{{ block.settings.url | default: '/collections/all' }}">{{ block.settings.title | default: 'Featured Product' }}</a>
              </h3>
              {%- if settings.card_show_rating -%}
                <div class="prod-card__rating" aria-label="{{ block.settings.rating | default: 4.8 }} out of 5 stars">
                  <span class="stars">{% for i in (1..5) %}<svg viewBox="0 0 24 24" fill="#f59e0b" width="12" height="12" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>{% endfor %}</span>
                  <span style="font-size:var(--text-xs);color:var(--color-text-muted)">({{ block.settings.review_count | default: 47 }})</span>
                </div>
              {%- endif -%}
              <div class="prod-card__price">
                {%- if block.settings.compare_price != blank -%}
                  <span class="prod-card__price--compare">{{ block.settings.compare_price }}</span>
                {%- endif -%}
                <span class="prod-card__price--current">{{ block.settings.price | default: '$49.00' }}</span>
              </div>
            </div>
          </article>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.blocks.size == 0 -%}
          {%- assign mock_items = "Women's Silk Blouse,Men's Premium Tee,Gold Hoop Earrings,Luxury Pet Toy Set" | split: ',' -%}
          {%- assign mock_cats  = 'women,men,jewelry,pets' | split: ',' -%}
          {%- assign mock_prices= '$38.00,$42.00,$28.00,$24.00' | split: ',' -%}
          {%- for i in (0..3) -%}
            <article class="prod-card reveal" style="transition-delay:{{ i | times: 80 }}ms">
              <div class="prod-card__media">
                <a href="/collections/all" class="prod-card__placeholder-link">
                  <div class="prod-card__img-placeholder">
                    {%- assign ph_colors = '#e8f5e9,#e3f2fd,#fff8e1,#fce4ec' | split: ',' -%}
                    {%- assign ph_color = ph_colors[i] -%}
                    <div style="background:{{ ph_color }};width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:8px">
                      <p style="font-size:11px;color:#999;text-align:center;padding:8px">Add products in Theme Editor</p>
                    </div>
                  </div>
                </a>
              </div>
              <div class="prod-card__info">
                <h3 class="prod-card__title"><a href="/collections/all">{{ mock_items[i] }}</a></h3>
                <div class="prod-card__price"><span class="prod-card__price--current">{{ mock_prices[i] }}</span></div>
              </div>
            </article>
          {%- endfor -%}
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <div class="section-cta reveal">
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--outline btn--lg">
          {{ section.settings.cta_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
.fp-section .prod-card__img-placeholder {
  width: 100%; height: 100%;
  aspect-ratio: 3/4;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  overflow: hidden;
}
.fp-section .prod-card__placeholder-link { display: block; width: 100%; height: 100%; }
.section-cta { text-align: center; margin-top: clamp(var(--sp-8),4vw,var(--sp-12)); }
</style>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text",       "id": "eyebrow",           "label": "Eyebrow text",       "default": "Handpicked for You" },
    { "type": "text",       "id": "title",             "label": "Section title",      "default": "Featured Products" },
    { "type": "textarea",   "id": "subtitle",          "label": "Subtitle",           "default": "Discover our best-selling products" },
    { "type": "select",     "id": "heading_align",     "label": "Heading alignment",
      "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"}], "default": "center" },
    { "type": "header",     "content": "Products Source" },
    { "type": "collection", "id": "collection",        "label": "Collection (auto-fills when set)" },
    { "type": "range",      "id": "products_count",    "label": "Products to show",   "min": 2, "max": 12, "step": 2, "default": 4 },
    { "type": "select",     "id": "columns",           "label": "Columns (desktop)",
      "options": [{"value":"2","label":"2"},{"value":"3","label":"3"},{"value":"4","label":"4"}], "default": "4" },
    { "type": "header",     "content": "CTA Button" },
    { "type": "text",       "id": "cta_text",          "label": "Button label",       "default": "View All Products" },
    { "type": "url",        "id": "cta_url",           "label": "Button URL" }
  ],
  "blocks": [
    {
      "type": "mock_product",
      "name": "Mock Product Card",
      "settings": [
        { "type": "image_picker", "id": "image",        "label": "Product image" },
        { "type": "text",         "id": "title",        "label": "Product name",       "default": "Luxury Product" },
        { "type": "text",         "id": "vendor",       "label": "Brand / Vendor" },
        { "type": "text",         "id": "price",        "label": "Price",              "default": "$49.00" },
        { "type": "text",         "id": "compare_price","label": "Compare-at price (optional)" },
        { "type": "text",         "id": "badge",        "label": "Badge text (e.g. Sale, New, Hot)" },
        { "type": "select",       "id": "badge_style",  "label": "Badge style",
          "options": [{"value":"sale","label":"Sale (red)"},{"value":"new","label":"New (green)"},{"value":"bestseller","label":"Bestseller (gold)"}], "default": "new" },
        { "type": "select",       "id": "category",     "label": "Placeholder icon type",
          "options": [{"value":"women","label":"Women"},{"value":"men","label":"Men"},{"value":"jewelry","label":"Jewelry"},{"value":"pets","label":"Pets"},{"value":"home","label":"Home"}], "default": "women" },
        { "type": "number",       "id": "rating",       "label": "Star rating (1–5)",  "default": 5 },
        { "type": "number",       "id": "review_count", "label": "Review count",        "default": 47 },
        { "type": "url",          "id": "url",          "label": "Product page link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [
        { "type": "mock_product", "settings": { "title": "Women's Silk Blouse", "price": "$38.00", "compare_price": "$55.00", "badge": "Sale", "badge_style": "sale", "category": "women", "review_count": 84 } },
        { "type": "mock_product", "settings": { "title": "Men's Premium Tee", "price": "$42.00", "badge": "New", "badge_style": "new", "category": "men", "review_count": 61 } },
        { "type": "mock_product", "settings": { "title": "Gold Hoop Earrings", "price": "$28.00", "badge": "Bestseller", "badge_style": "bestseller", "category": "jewelry", "review_count": 122 } },
        { "type": "mock_product", "settings": { "title": "Luxury Pet Toy Set", "price": "$24.00", "category": "pets", "review_count": 49 } }
      ]
    }
  ]
}
{% endschema %}
