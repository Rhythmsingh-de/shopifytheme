
<section class="section{{ ' section-alt' if section.settings.bg == 'white' }}"
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="section-hd-row">
      <div>
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.collection != blank -%}
        <a class="btn btn-outline btn-sm" href="{{ collections[section.settings.collection].url }}" data-track="featured_view_all">
          {{ section.settings.view_all_label | default: 'View all' }} →
        </a>
      {%- endif -%}
    </div>
    <div class="product-grid" style="grid-template-columns:repeat({{ section.settings.columns }},1fr);">
      {%- assign feat_col = collections[section.settings.collection] -%}
      {%- if feat_col != blank -%}
        {%- for product in feat_col.products limit: section.settings.product_limit -%}
          <article class="product-card">
            <a href="{{ product.url }}" class="product-card-media">
              {%- if product.featured_image -%}
                <img src="{{ product.featured_image | image_url: width: 800 }}"
                     alt="{{ product.featured_image.alt | default: product.title | escape }}"
                     width="800" height="1000"
                     loading="lazy">
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--surface-alt);aspect-ratio:4/5;"></div>
              {%- endif -%}
              {%- if product.tags contains 'new' -%}
                <span class="product-badge badge-new">New</span>
              {%- elsif product.compare_at_price > product.price -%}
                <span class="product-badge badge-sale">Sale</span>
              {%- endif -%}
            </a>
            <div class="product-card-body">
              <div class="product-stars" aria-label="5 stars">★★★★★</div>
              <a href="{{ product.url }}" class="product-title">{{ product.title }}</a>
              <div class="product-price-row">
                <span class="product-price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="product-compare">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
              <button class="btn-atc" data-product-id="{{ product.variants.first.id }}"
                      data-track="product_atc_{{ product.id }}"
                      aria-label="Add {{ product.title | escape }} to cart">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="15" height="15"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                {{ section.settings.atc_label | default: 'Add to Cart' }}
              </button>
            </div>
          </article>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.product_limit) -%}
          <article class="product-card">
            <div class="product-card-media" style="aspect-ratio:4/5;background:var(--surface-alt);"></div>
            <div class="product-card-body">
              <div class="product-stars">★★★★★</div>
              <div class="product-title">Sample Product {{ i }}</div>
              <div class="product-price-row"><span class="product-price">$49.99</span></div>
              <button class="btn-atc">Add to Cart</button>
            </div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Best Sellers" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Our most-loved products — trusted by thousands of customers" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" },
    { "type": "text", "id": "atc_label", "label": "Add to cart button label", "default": "Add to Cart" },
    { "type": "header", "content": "Collection" },
    { "type": "collection", "id": "collection", "label": "Collection to display" },
    { "type": "range", "id": "product_limit", "min": 2, "max": 12, "step": 1, "label": "Number of products", "default": 4 },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "label": "Columns (desktop)", "default": 4 },
    { "type": "select", "id": "bg", "label": "Background", "options": [
      { "value": "default", "label": "Default" },
      { "value": "white", "label": "White" }
    ], "default": "default" },
    { "type": "range", "id": "padding_top", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 60 }
  ],
  "presets": [
    { "name": "Featured products" },
    { "name": "New Arrivals" },
    { "name": "Trending Now" }
  ]
}
{% endschema %}
