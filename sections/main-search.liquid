<section style="padding: 80px 0;">
  <div class="container">
    <h1 class="page-title">Search</h1>
    <form action="/search" method="get" style="margin-bottom: 48px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..." style="width: 100%; padding: 14px 18px; font-size: 1rem; border: 1px solid #e5e5e5; border-radius: var(--border-radius); outline: none;">
    </form>
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p style="color: var(--text-muted);">No results for "{{ search.terms }}".</p>
      {%- else -%}
        <div class="collection-grid">
          {%- for item in search.results -%}
            <a href="{{ item.url }}" class="product-card">
              {%- if item.featured_image -%}
                <div class="product-card__img-wrap">
                  <img src="{{ item.featured_image | image_url: width: 400 }}" alt="{{ item.title }}" width="400" height="400" loading="lazy">
                </div>
              {%- endif -%}
              <p class="product-card__title">{{ item.title }}</p>
            </a>
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
