
<section style="padding:48px 0 72px">
  <div class="page-w">
    <h1 style="margin-bottom:24px">Search</h1>
    <form action="{{ routes.search_url }}" method="get" style="display:flex;gap:10px;max-width:520px;margin-bottom:40px">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" value="{{ search.terms | escape }}"
             placeholder="Search products…" aria-label="Search"
             style="flex:1;padding:12px 18px;border:1.5px solid #e8e8e8;border-radius:9999px;font-size:15px">
      <button class="btn btn-black" type="submit">Search</button>
    </form>
    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p style="color:#888;font-size:15px">No results for "<strong>{{ search.terms }}</strong>".</p>
      {% else %}
        <p style="color:#888;font-size:14px;margin-bottom:24px">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms }}"</p>
        <div class="coll-grid">
          {% for item in search.results %}
            {% if item.object_type == 'product' %}
              <article class="p-card">
                <a href="{{ item.url }}">
                  <div class="p-card__media">
                    {% if item.featured_image %}
                      {{ item.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: item.title }}
                    {% endif %}
                  </div>
                  <div class="p-card__name">{{ item.title }}</div>
                  <div class="p-card__price-row">
                    <span class="p-card__price">{{ item.price | money }}</span>
                  </div>
                </a>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>
{% schema %}{"name":"Search Page","settings":[],"presets":[{"name":"Search Page"}]}{% endschema %}
