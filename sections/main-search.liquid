<section style="padding: 80px 0;">
  <div class="container">
    <h1 class="page-title">Search</h1>
    <form action="/search" method="get" style="margin-bottom: 48px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..." style="width: 100%; padding: 14px 18px; font-size: 1rem; border: 1px solid #e5e5e5; border-radius: var(--border-radius); outline: none;">
    </form>
    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p style="color: var(--text-muted);">No results for "{{ search.terms }}".</p>
      {%- else -%}
        <div class="collection-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {%- render 'product-card', product: item, index: forloop.index0 -%}
            {%- else -%}
              <a href="{{ item.url }}" class="prod-card" style="padding: var(--sp-4); text-decoration: none; border: 1.5px solid var(--color-border); border-radius: var(--card-radius);">
                <p class="prod-card__vendor" style="margin-bottom: 8px; font-size: var(--text-xs); color: var(--color-text-muted); text-transform: uppercase;">{{ item.object_type }}</p>
                <h3 class="prod-card__title" style="font-size: var(--text-base); font-weight: 600; color: var(--color-text);">{{ item.title }}</h3>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>
{% schema %}
{ "name": "Search", "settings": [] }
{% endschema %}
