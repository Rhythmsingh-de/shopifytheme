
<section class="contact-page">
  <div class="page-w" style="max-width:480px">
    <h1 style="margin-bottom:28px">Create Account</h1>
    {% form 'create_customer' %}
      {{ form.errors | default_errors }}
      <div class="form-row">
        <div class="form-group">
          <label class="form-label" for="FirstName">First name</label>
          <input class="form-input" type="text" id="FirstName" name="customer[first_name]" autocomplete="given-name">
        </div>
        <div class="form-group">
          <label class="form-label" for="LastName">Last name</label>
          <input class="form-input" type="text" id="LastName" name="customer[last_name]" autocomplete="family-name">
        </div>
      </div>
      <div class="form-group">
        <label class="form-label" for="Email">Email</label>
        <input class="form-input" type="email" id="Email" name="customer[email]" autocomplete="email" required>
      </div>
      <div class="form-group">
        <label class="form-label" for="CreatePassword">Password</label>
        <input class="form-input" type="password" id="CreatePassword" name="customer[password]" autocomplete="new-password" required>
      </div>
      <button class="btn btn-black btn-full btn-lg" type="submit" style="margin-bottom:14px">Create Account</button>
    {% endform %}
    <p style="font-size:14px;color:#888;text-align:center">
      Already have an account? <a href="{{ routes.account_login_url }}" style="color:#1a1a1a;font-weight:600">Sign in</a>
    </p>
  </div>
</section>
{% schema %}{"name":"Register Page","settings":[],"presets":[{"name":"Register Page"}]}{% endschema %}
