<section style="padding: 100px 0;">
  <div class="container" style="max-width: 420px;">
    <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 32px;">Create Account</h1>
    {%- form 'create_customer' -%}
      {{ form.errors | default_errors }}
      <div style="margin-bottom: 16px;">
        <label style="display:block; font-size:.85rem; font-weight:600; margin-bottom:6px;">First Name</label>
        <input type="text" name="customer[first_name]" style="width:100%; padding:12px 16px; border:1px solid #e5e5e5; border-radius:var(--border-radius); font-size:1rem;">
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display:block; font-size:.85rem; font-weight:600; margin-bottom:6px;">Last Name</label>
        <input type="text" name="customer[last_name]" style="width:100%; padding:12px 16px; border:1px solid #e5e5e5; border-radius:var(--border-radius); font-size:1rem;">
      </div>
      <div style="margin-bottom: 16px;">
        <label style="display:block; font-size:.85rem; font-weight:600; margin-bottom:6px;">Email</label>
        <input type="email" name="customer[email]" style="width:100%; padding:12px 16px; border:1px solid #e5e5e5; border-radius:var(--border-radius); font-size:1rem;">
      </div>
      <div style="margin-bottom: 24px;">
        <label style="display:block; font-size:.85rem; font-weight:600; margin-bottom:6px;">Password</label>
        <input type="password" name="customer[password]" style="width:100%; padding:12px 16px; border:1px solid #e5e5e5; border-radius:var(--border-radius); font-size:1rem;">
      </div>
      <button type="submit" class="fp__cta">Create Account</button>
    {%- endform -%}
    <p style="margin-top:16px; font-size:.85rem; color:var(--text-muted);">{{ 'customer.register.login_instead' | t }} <a href="{{ routes.account_login_url }}" style="color:var(--accent-color);">{{ 'customer.login.submit' | t }}</a></p>
  </div>
</section>
{% schema %}
{ "name": "Register", "settings": [] }
{% endschema %}
