<section class="section">
  <div class="page-width" style="max-width:480px;">
    <h1 style="font-size:clamp(28px,4vw,42px);font-weight:900;letter-spacing:-.04em;margin:0 0 24px;">Create account</h1>
    {% form 'create_customer' %}
      {{ form.errors | default_errors }}
      <div style="display:grid;gap:14px;margin-bottom:20px;">
        <div>
          <label for="FirstName">First name</label>
          <input type="text" id="FirstName" name="customer[first_name]" autocomplete="given-name" style="width:100%;padding:12px 14px;border:1px solid #dfd7cc;border-radius:12px;margin-top:6px;">
        </div>
        <div>
          <label for="LastName">Last name</label>
          <input type="text" id="LastName" name="customer[last_name]" autocomplete="family-name" style="width:100%;padding:12px 14px;border:1px solid #dfd7cc;border-radius:12px;margin-top:6px;">
        </div>
        <div>
          <label for="Email">Email</label>
          <input type="email" id="Email" name="customer[email]" autocomplete="email" style="width:100%;padding:12px 14px;border:1px solid #dfd7cc;border-radius:12px;margin-top:6px;">
        </div>
        <div>
          <label for="CreatePassword">Password</label>
          <input type="password" id="CreatePassword" name="customer[password]" autocomplete="new-password" style="width:100%;padding:12px 14px;border:1px solid #dfd7cc;border-radius:12px;margin-top:6px;">
        </div>
      </div>
      <button class="btn btn-primary" type="submit" style="width:100%;">Create account</button>
    {% endform %}
    <p style="margin-top:16px;text-align:center;"><a href="{{ routes.account_login_url }}">Already have an account? Log in</a></p>
  </div>
</section>
{% schema %}
{ "name": "Register", "settings": [] }
{% endschema %}
