<section class="section brand-values-section">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <div class="section-head reveal">
        <h2 class="section-title">{{ section.settings.title }}</h2>
      </div>
    {%- endif -%}
    <div class="values-grid">
      {%- for block in section.blocks -%}
        <div class="value-item reveal" style="transition-delay:{{ forloop.index0 | times: 80 }}ms" {{ block.shopify_attributes }}>
          <div class="value-item__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'refresh' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 8C8 10 5.9 16.17 3.82 19.82a1 1 0 0 0 1.71 1.05C7.13 19 9 17 11 14"/><path d="M2 12s2-8 12-8c0 0-2 8-12 8z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {%- endcase -%}
          </div>
          <div class="value-item__body">
            <h3 class="value-item__title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="value-item__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
.brand-values-section { background:var(--color-surface); }
.values-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit,minmax(200px,1fr));
  gap: clamp(var(--sp-4),2vw,var(--sp-8));
  margin-top: clamp(var(--sp-6),3vw,var(--sp-10));
}
.value-item {
  display: flex; align-items: flex-start; gap: var(--sp-4);
  padding: var(--sp-6);
  background: var(--color-bg);
  border-radius: var(--radius-xl);
  border: 1px solid var(--color-border);
  transition: box-shadow var(--trans-base), transform var(--trans-base);
}
.value-item:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.value-item__icon {
  width: 44px; height: 44px; flex-shrink: 0;
  color: var(--color-primary);
  padding: 8px;
  background: color-mix(in oklch, var(--color-primary) 10%, var(--color-bg));
  border-radius: var(--radius-md);
}
.value-item__icon svg { width: 100%; height: 100%; }
.value-item__title { font-weight: 700; font-size: var(--text-sm); margin-bottom: var(--sp-1); }
.value-item__text  { font-size: var(--text-xs); color: var(--color-text-muted); line-height: 1.6; }
</style>
{% schema %}
{
  "name": "Brand Values",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "title", "label": "Section title", "default": "Why BodyLuxCare?" }
  ],
  "blocks": [{
    "type": "value", "name": "Value Item",
    "settings": [
      { "type": "select", "id": "icon", "label": "Icon", "options": [
        {"value":"truck","label":"Truck / Shipping"},
        {"value":"shield","label":"Shield / Security"},
        {"value":"refresh","label":"Refresh / Returns"},
        {"value":"star","label":"Star / Quality"},
        {"value":"heart","label":"Heart / Care"},
        {"value":"leaf","label":"Leaf / Eco"}
      ], "default": "truck" },
      { "type": "text",     "id": "title", "label": "Title", "default": "Free Shipping" },
      { "type": "textarea", "id": "text",  "label": "Description", "default": "Free U.S. shipping on all orders over $75." }
    ]
  }],
  "presets": [{
    "name": "Brand Values",
    "blocks": [
      { "type": "value", "settings": { "icon": "truck",   "title": "Free Shipping",         "text": "Free U.S. shipping on orders $75+. Fast & reliable delivery." } },
      { "type": "value", "settings": { "icon": "refresh", "title": "30-Day Returns",         "text": "Not happy? Return it hassle-free within 30 days." } },
      { "type": "value", "settings": { "icon": "shield",  "title": "Secure Checkout",        "text": "256-bit SSL encryption keeps your data safe." } },
      { "type": "value", "settings": { "icon": "star",    "title": "Premium Quality",        "text": "Curated products that meet our high luxury standards." } }
    ]
  }]
}
{% endschema %}
