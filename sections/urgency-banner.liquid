{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ff501a'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign cta_bg = section.settings.cta_bg | default: '#ffffff'
  assign cta_text = section.settings.cta_text | default: '#ff501a'
-%}

<section
  id="UrgencyBanner-{{ section.id }}"
  class="urgency-banner reveal"
  style="background: {{ bg_color }}; color: {{ text_color }};"
  {{ section.shopify_attributes }}
>
  <div class="container">
    <div class="urgency-banner__grid">
      
      {%- comment -%} Column 1: Copy {%- endcomment -%}
      <div class="urgency-banner__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="urgency-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="urgency-banner__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="urgency-banner__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Column 2: Countdown Timer {%- endcomment -%}
      {%- if section.settings.show_countdown -%}
        <div class="urgency-banner__countdown" id="BannerCountdown-{{ section.id }}" aria-live="polite">
          <div class="urgency-banner__countdown-units">
            <div class="urgency-banner__countdown-unit">
              <span class="urgency-banner__countdown-num" id="bcHours-{{ section.id }}">00</span>
              <span class="urgency-banner__countdown-name">{{ section.settings.hours_label | default: 'Hours' }}</span>
            </div>
            <div class="urgency-banner__countdown-unit">
              <span class="urgency-banner__countdown-num" id="bcMins-{{ section.id }}">00</span>
              <span class="urgency-banner__countdown-name">{{ section.settings.mins_label | default: 'Minutes' }}</span>
            </div>
            <div class="urgency-banner__countdown-unit">
              <span class="urgency-banner__countdown-num" id="bcSecs-{{ section.id }}">00</span>
              <span class="urgency-banner__countdown-name">{{ section.settings.secs_label | default: 'Seconds' }}</span>
            </div>
          </div>
        </div>
        <script>
        (function(){
          var endTime = 0;
          var customEnd = {{ section.settings.countdown_end | json }};
          if (customEnd) {
            endTime = new Date(customEnd).getTime();
          } else {
            var endMeta = document.querySelector('meta[name="weekly-offer-end"]');
            if (endMeta) endTime = new Date(endMeta.content).getTime();
          }
          
          if (!endTime) return;
          var sid = '{{ section.id }}';
          var hEl = document.getElementById('bcHours-' + sid);
          var mEl = document.getElementById('bcMins-'  + sid);
          var sEl = document.getElementById('bcSecs-'  + sid);
          if (!hEl || !mEl || !sEl) return;
          function pad(n) { return n < 10 ? '0' + n : '' + n; }
          function tick() {
            var diff = endTime - Date.now();
            if (diff <= 0) { hEl.textContent = mEl.textContent = sEl.textContent = '00'; return; }
            hEl.textContent = pad(Math.floor(diff / 3600000));
            mEl.textContent = pad(Math.floor((diff % 3600000) / 60000));
            sEl.textContent = pad(Math.floor((diff % 60000) / 1000));
            setTimeout(tick, 1000);
          }
          tick();
        })();
        </script>
      {%- endif -%}

      {%- comment -%} Column 3: CTA button {%- endcomment -%}
      {%- if section.settings.cta_label != blank -%}
        <div class="urgency-banner__cta">
          <a
            href="{{ section.settings.cta_link | default: '#SingleProductHome' }}"
            class="btn urgency-banner__btn"
            style="background: {{ cta_bg }}; color: {{ cta_text }};"
          >
            {%- if section.settings.show_cart_icon -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 8px; vertical-align: middle; display: inline-block;"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            {%- endif -%}
            <span>{{ section.settings.cta_label }}</span>
          </a>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
.urgency-banner {
  padding: var(--sp-6, 24px) 0;
  overflow: hidden;
}
.urgency-banner__grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-6, 24px);
  flex-wrap: wrap;
}
.urgency-banner__copy {
  flex: 1 1 300px;
}
.urgency-banner__eyebrow {
  font-size: var(--text-xs, 12px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 4px;
  opacity: 0.95;
}
.urgency-banner__heading {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 2.5vw, 2.2rem);
  font-weight: 800;
  line-height: 1.1;
  margin: 0 0 4px 0;
  color: inherit;
}
.urgency-banner__sub {
  font-size: var(--text-sm, 14px);
  opacity: 0.85;
  margin: 0;
}
.urgency-banner__countdown {
  flex-shrink: 0;
}
.urgency-banner__countdown-units {
  display: flex;
  align-items: center;
  gap: 12px;
}
.urgency-banner__countdown-unit {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.95);
  color: #111111;
  border-radius: var(--radius-md, 8px);
  width: 72px;
  height: 72px;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}
.urgency-banner__countdown-num {
  font-size: 1.6rem;
  font-weight: 800;
  line-height: 1.1;
}
.urgency-banner__countdown-name {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--color-text-muted, #777777);
}
.urgency-banner__cta {
  flex-shrink: 0;
}
.urgency-banner__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 32px;
  min-height: 52px;
  font-weight: 700;
  font-size: var(--text-sm, 14px);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border-radius: var(--btn-radius, 9999px);
  text-decoration: none;
  box-shadow: 0 4px 15px rgba(0,0,0,0.12);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.urgency-banner__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.16);
}

@media (max-width: 991px) {
  .urgency-banner__grid {
    flex-direction: column;
    text-align: center;
  }
  .urgency-banner__copy {
    flex: none;
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Urgency Promo Banner",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Copywriting" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow tag", "default": "Limited Time Offer!" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 31% Off Today Only" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Don't miss out on our best deal of the year." },
    { "type": "header", "content": "Countdown Settings" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown boxes", "default": true },
    { "type": "text", "id": "countdown_end", "label": "Custom end date (ISO 8601)", "info": "Leave blank to use global weekly offer end date. Format: 2026-12-31T23:59:59" },
    { "type": "text", "id": "hours_label", "label": "Hours label", "default": "Hours" },
    { "type": "text", "id": "mins_label", "label": "Minutes label", "default": "Minutes" },
    { "type": "text", "id": "secs_label", "label": "Seconds label", "default": "Seconds" },
    { "type": "header", "content": "CTA Button" },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Buy Now — $89" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "checkbox", "id": "show_cart_icon", "label": "Show cart icon in button", "default": true },
    { "type": "header", "content": "Colors & Styling" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ff501a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "cta_bg", "label": "Button background", "default": "#ffffff" },
    { "type": "color", "id": "cta_text", "label": "Button text color", "default": "#ff501a" }
  ],
  "presets": [
    {
      "name": "Urgency Promo Banner",
      "settings": {
        "bg_color": "#ff501a",
        "text_color": "#ffffff"
      }
    }
  ]
}
{% endschema %}
