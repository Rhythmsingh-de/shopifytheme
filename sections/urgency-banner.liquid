{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ff501a'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign cta_bg = section.settings.cta_bg | default: '#ffffff'
  assign cta_text = section.settings.cta_text | default: '#ff501a'
  assign active_offer_type = section.settings.offer_type | default: 'global'
  if active_offer_type == 'global'
    assign active_offer_type = settings.offer_countdown_mode | default: 'weekly_offer'
  endif
  assign use_upcoming_offer = false
  if active_offer_type == 'upcoming_sale'
    assign use_upcoming_offer = true
  endif

  assign show_offer = settings.weekly_offer_enabled
  assign offer_scope = settings.weekly_offer_scope | default: 'all'
  assign default_offer_product = settings.weekly_offer_product
  assign default_offer_collection = settings.weekly_offer_collection
  assign default_cta_label = settings.weekly_offer_cta_label
  assign countdown_end = settings.weekly_offer_end_datetime
  assign countdown_label = settings.weekly_countdown_label | default: 'Ends in'

  if use_upcoming_offer
    assign show_offer = settings.upcoming_sale_enabled
    assign offer_scope = settings.upcoming_sale_scope | default: 'all'
    assign default_offer_product = settings.upcoming_sale_product
    assign default_offer_collection = settings.upcoming_sale_collection
    assign default_cta_label = settings.upcoming_sale_cta_label
    assign countdown_end = settings.upcoming_sale_start_datetime
    assign countdown_label = settings.upcoming_sale_countdown_label | default: 'Starts in'
  endif

  assign offer_product = section.settings.offer_product
  if offer_product == blank
    assign offer_product = default_offer_product
  endif
  if offer_product == blank and settings.primary_product != blank
    assign offer_product = settings.primary_product
  endif
  assign offer_collection = section.settings.offer_collection
  if offer_collection == blank
    assign offer_collection = default_offer_collection
  endif
  if offer_collection == blank and settings.primary_collection != blank
    assign offer_collection = settings.primary_collection
  endif
  assign offer_variant = offer_product.selected_or_first_available_variant
  assign cta_label = section.settings.cta_label
  if cta_label == blank
    assign cta_label = default_cta_label
  endif
  if cta_label == blank
    assign cta_label = 'Shop the offer'
  endif
  if section.settings.countdown_end != blank
    assign countdown_end = section.settings.countdown_end
  endif
  assign cta_link = section.settings.cta_link
  if cta_link == blank and offer_product != blank
    assign cta_link = offer_product.url
  elsif cta_link == blank and offer_collection != blank
    assign cta_link = offer_collection.url
  endif
  if cta_link == blank
    assign cta_link = '#MainContent'
  endif
  if offer_scope == 'homepage_only' and request.page_type != 'index'
    assign show_offer = false
  elsif offer_scope == 'all_products' and request.page_type != 'product'
    assign show_offer = false
  elsif offer_scope == 'all_collections' and request.page_type != 'collection'
    assign show_offer = false
  elsif offer_scope == 'selected_products'
    assign show_offer = false
    if request.page_type == 'product' and product != blank
      if use_upcoming_offer
        for scoped_product in settings.upcoming_sale_products
          if scoped_product.id == product.id
            assign show_offer = true
          endif
        endfor
      else
        for scoped_product in settings.weekly_offer_products
          if scoped_product.id == product.id
            assign show_offer = true
          endif
        endfor
      endif
    elsif offer_product != blank
      assign show_offer = true
    endif
  elsif offer_scope == 'selected_collection'
    assign show_offer = false
    if offer_collection != blank
      if request.page_type == 'collection' and collection.handle == offer_collection.handle
        assign show_offer = true
      elsif request.page_type == 'product' and product != blank
        for product_collection in product.collections
          if product_collection.handle == offer_collection.handle
            assign show_offer = true
          endif
        endfor
      endif
    endif
  endif
-%}

{%- if show_offer -%}
<section
  id="UrgencyBanner-{{ section.id }}"
  class="urgency-banner reveal"
  style="background: {{ bg_color }}; color: {{ text_color }};"
  {{ section.shopify_attributes }}
>
  <div class="container">
    <div class="urgency-banner__grid">
      
      {%- comment -%} Column 1: Copy {%- endcomment -%}
      <div class="urgency-banner__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="urgency-banner__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="urgency-banner__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="urgency-banner__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.show_product_card and offer_product != blank -%}
        <a href="{{ offer_product.url }}" class="urgency-banner__product" data-promo-card data-promo-name="{{ section.settings.heading | escape }}">
          {%- if offer_product.featured_image != blank -%}
            {%- assign offer_product_alt = offer_product.featured_image.alt | default: offer_product.title | escape -%}
            {{ offer_product.featured_image | image_url: width: 180 | image_tag:
              widths: '90,180',
              width: 90,
              height: 90,
              loading: 'lazy',
              decoding: 'async',
              class: 'urgency-banner__product-img',
              alt: offer_product_alt
            }}
          {%- endif -%}
          <span class="urgency-banner__product-body">
            <strong>{{ offer_product.title | escape }}</strong>
            <span>
              {{ offer_variant.price | money }}
              {%- if offer_variant.compare_at_price > offer_variant.price -%}
                <s>{{ offer_variant.compare_at_price | money }}</s>
              {%- endif -%}
            </span>
          </span>
        </a>
      {%- endif -%}

      {%- comment -%} Column 2: Countdown Timer {%- endcomment -%}
      {%- if section.settings.show_countdown -%}
        <div class="urgency-banner__countdown">
          {%- render 'offer-countdown',
            id: section.id,
            variant: 'boxed',
            label: countdown_label,
            end_datetime: countdown_end,
            days_label: section.settings.days_label,
            hours_label: section.settings.hours_label,
            mins_label: section.settings.mins_label,
            secs_label: section.settings.secs_label
          -%}
        </div>
      {%- endif -%}

      {%- comment -%} Column 3: CTA button {%- endcomment -%}
      {%- if cta_label != blank -%}
        <div class="urgency-banner__cta">
          {%- if section.settings.cta_behavior == 'add_to_cart' and offer_variant != blank and offer_variant.available -%}
            <button
              type="button"
              class="btn urgency-banner__btn"
              style="background: {{ cta_bg }}; color: {{ cta_text }};"
              data-add-to-cart
              data-variant-id="{{ offer_variant.id }}"
              data-qty="1"
              data-promo-name="{{ section.settings.heading | escape }}">
          {%- else -%}
            <a
              href="{{ cta_link }}"
              class="btn urgency-banner__btn"
              style="background: {{ cta_bg }}; color: {{ cta_text }};"
              data-promo-link
              data-promo-name="{{ section.settings.heading | escape }}">
          {%- endif -%}
            {%- if section.settings.show_cart_icon -%}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right: 8px; vertical-align: middle; display: inline-block;"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            {%- endif -%}
            <span>{{ cta_label | escape }}</span>
          {%- if section.settings.cta_behavior == 'add_to_cart' and offer_variant != blank and offer_variant.available -%}
            </button>
          {%- else -%}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>
{%- endif -%}

<style>
.urgency-banner {
  padding: var(--sp-6, 24px) 0;
  overflow: hidden;
}
.urgency-banner__grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-6, 24px);
  flex-wrap: wrap;
}
.urgency-banner__copy {
  flex: 1 1 300px;
}
.urgency-banner__eyebrow {
  font-size: var(--text-xs, 12px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 4px;
  opacity: 0.95;
}
.urgency-banner__heading {
  font-family: var(--font-display);
  font-size: clamp(1.4rem, 2.5vw, 2.2rem);
  font-weight: 800;
  line-height: 1.1;
  margin: 0 0 4px 0;
  color: inherit;
}
.urgency-banner__sub {
  font-size: var(--text-sm, 14px);
  opacity: 0.85;
  margin: 0;
}
.urgency-banner__countdown {
  flex-shrink: 0;
}
.urgency-banner__product {
  display: flex;
  align-items: center;
  gap: 12px;
  min-width: min(280px, 100%);
  max-width: 340px;
  padding: 10px 12px;
  border-radius: var(--radius-lg, 12px);
  background: rgba(255,255,255,0.14);
  border: 1px solid rgba(255,255,255,0.22);
  color: inherit;
  text-decoration: none;
  transition: transform .2s ease, background-color .2s ease;
}
.urgency-banner__product:hover {
  transform: translateY(-2px);
  background: rgba(255,255,255,0.2);
}
.urgency-banner__product-img {
  width: 58px;
  height: 58px;
  object-fit: cover;
  border-radius: var(--radius-md, 8px);
  background: rgba(255,255,255,0.2);
  flex-shrink: 0;
}
.urgency-banner__product-body {
  display: grid;
  gap: 2px;
  min-width: 0;
}
.urgency-banner__product-body strong {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: var(--text-sm, 14px);
}
.urgency-banner__product-body span {
  display: flex;
  gap: 8px;
  align-items: center;
  font-size: var(--text-xs, 12px);
  font-weight: 800;
}
.urgency-banner__product-body s {
  opacity: .68;
  font-weight: 600;
}
.urgency-banner__cta {
  flex-shrink: 0;
}
.urgency-banner__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 32px;
  min-height: 52px;
  font-weight: 700;
  font-size: var(--text-sm, 14px);
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border-radius: var(--btn-radius, 9999px);
  text-decoration: none;
  box-shadow: 0 4px 15px rgba(0,0,0,0.12);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.urgency-banner__btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.16);
}

@media (max-width: 991px) {
  .urgency-banner__grid {
    flex-direction: column;
    text-align: center;
  }
  .urgency-banner__copy {
    flex: none;
    width: 100%;
  }
  .urgency-banner__product {
    width: 100%;
    justify-content: center;
  }
}
@media (max-width: 520px) {
  .urgency-banner__cta,
  .urgency-banner__btn {
    width: 100%;
  }
}
</style>

{% schema %}
{
  "name": "Urgency Promo Banner",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Copywriting" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow tag", "default": "Limited Time Offer!" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get 31% Off Today Only" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Don't miss out on our best deal of the year." },
    { "type": "header", "content": "Countdown Settings" },
    { "type": "select", "id": "offer_type", "label": "Offer source",
      "options": [
        { "value": "global", "label": "Use Theme Settings countdown source" },
        { "value": "weekly_offer", "label": "Weekly offer" },
        { "value": "upcoming_sale", "label": "Upcoming sale" }
      ],
      "default": "global" },
    { "type": "checkbox", "id": "show_countdown", "label": "Show countdown boxes", "default": true },
    { "type": "text", "id": "countdown_end", "label": "Custom end date (ISO 8601)", "info": "Leave blank to use the selected Theme Settings countdown source. Format: 2026-12-31T23:59:59" },
    { "type": "text", "id": "days_label", "label": "Days label", "default": "Days" },
    { "type": "text", "id": "hours_label", "label": "Hours label", "default": "Hours" },
    { "type": "text", "id": "mins_label", "label": "Minutes label", "default": "Minutes" },
    { "type": "text", "id": "secs_label", "label": "Seconds label", "default": "Seconds" },
    { "type": "header", "content": "Offer Product / Collection" },
    { "type": "checkbox", "id": "show_product_card", "label": "Show product mini-card", "default": true },
    { "type": "product", "id": "offer_product", "label": "Offer product (optional)" },
    { "type": "collection", "id": "offer_collection", "label": "Offer collection fallback" },
    { "type": "header", "content": "CTA Button" },
    { "type": "text", "id": "cta_label", "label": "Button label", "info": "Leave blank to use Theme Settings > Weekly Offer CTA label." },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "select", "id": "cta_behavior", "label": "Button behavior", "options": [
      { "value": "link", "label": "Open link" },
      { "value": "add_to_cart", "label": "Add selected product to cart" }
    ], "default": "link" },
    { "type": "checkbox", "id": "show_cart_icon", "label": "Show cart icon in button", "default": true },
    { "type": "header", "content": "Colors & Styling" },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#ff501a" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "cta_bg", "label": "Button background", "default": "#ffffff" },
    { "type": "color", "id": "cta_text", "label": "Button text color", "default": "#ff501a" }
  ],
  "presets": [
    {
      "name": "Urgency Promo Banner",
      "settings": {
        "bg_color": "#ff501a",
        "text_color": "#ffffff"
      }
    }
  ]
}
{% endschema %}
