{%- liquid
  assign product = section.settings.product | default: product
  assign current_variant = product.selected_or_first_available_variant
  assign compare_price = current_variant.compare_at_price
  assign sale_price = current_variant.price
  assign on_sale = false
  if compare_price > sale_price
    assign on_sale = true
  endif
-%}

<section class="fp" id="featured-product-{{ section.id }}">
  <div class="container">
    <div class="fp__grid">

      <!-- LEFT: Media -->
      <div class="fp__media">
        <div class="fp__media-wrap">
          {%- if on_sale and section.settings.show_sale_badge -%}
            <span class="fp__badge">SALE</span>
          {%- endif -%}
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.featured_image.alt | escape }}"
              width="900"
              height="900"
              loading="eager"
              class="fp__img"
            >
          {%- endif -%}
        </div>
      </div>

      <!-- RIGHT: Info -->
      <div class="fp__info">

        <!-- 1. Social Proof -->
        {%- if section.settings.show_reviews_summary -%}
          <div class="fp__reviews">
            <span class="fp__stars" aria-label="5 stars">★★★★★</span>
            <span class="fp__review-count">{{ section.settings.review_count | default: '1,248' }} reviews</span>
          </div>
        {%- endif -%}

        <!-- 2. Identity -->
        <h1 class="fp__title">{{ product.title }}</h1>

        <div class="fp__price">
          {%- if on_sale -%}
            <span class="fp__price-sale">{{ sale_price | money }}</span>
            <span class="fp__price-compare">{{ compare_price | money }}</span>
          {%- else -%}
            <span class="fp__price-sale">{{ sale_price | money }}</span>
          {%- endif -%}
        </div>

        <!-- 3. Scarcity -->
        {%- if section.settings.show_scarcity_bar -%}
          {%- assign inventory = current_variant.inventory_quantity | default: 12 -%}
          {%- assign max_stock = 50 -%}
          {%- assign pct = inventory | times: 100 | divided_by: max_stock -%}
          <div class="fp__scarcity">
            <div class="fp__scarcity-bar">
              <div class="fp__scarcity-fill" style="width: {{ pct }}%"></div>
            </div>
            <p class="fp__scarcity-text">⚡ Only <strong>{{ inventory }} left</strong> — selling fast</p>
          </div>
        {%- endif -%}

        <!-- 4. Action Layer -->
        {%- form 'product', product, id: 'FeaturedProductForm', class: 'fp__form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">

          <button
            type="submit"
            class="fp__cta"
            id="FeaturedProductCTA"
            {% if current_variant.available == false %}disabled{% endif %}
          >
            {%- if current_variant.available -%}
              {{ section.settings.cta_text | default: 'Add to Cart' }}
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
        {%- endform -%}

        <!-- 5. Trust Badges -->
        {%- if section.settings.show_trust_badges -%}
          <div class="fp__trust">
            <div class="fp__trust-item">🚚 {{ section.settings.delivery_text | default: 'Free shipping over €50' }}</div>
            <div class="fp__trust-item">↩️ {{ section.settings.returns_text | default: '30-day free returns' }}</div>
            <div class="fp__trust-item">🔒 {{ section.settings.privacy_text | default: 'Secure & encrypted checkout' }}</div>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</section>

<style>
  .fp {
    padding: 80px 0;
  }
  .fp__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  @media (max-width: 768px) {
    .fp__grid { grid-template-columns: 1fr; gap: 40px; }
    .fp { padding: 60px 0; }
  }

  /* Media */
  .fp__media-wrap { position: relative; }
  .fp__img { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: var(--border-radius); }
  .fp__badge {
    position: absolute; top: 16px; left: 16px;
    background: var(--accent-color); color: #fff;
    font-size: 0.75rem; font-weight: 700; letter-spacing: 0.08em;
    padding: 4px 10px; border-radius: 2px; z-index: 1;
  }

  /* Reviews */
  .fp__reviews { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
  .fp__stars { color: #f5a623; font-size: 1rem; letter-spacing: 2px; }
  .fp__review-count { font-size: 0.85rem; color: var(--text-muted); }

  /* Title */
  .fp__title { font-size: 2.5rem; font-weight: 700; line-height: 1.15; margin-bottom: 16px; }
  @media (max-width: 768px) { .fp__title { font-size: 1.9rem; } }

  /* Price */
  .fp__price { display: flex; align-items: baseline; gap: 12px; margin-bottom: 28px; }
  .fp__price-sale { font-size: 1.75rem; font-weight: 700; color: var(--text-color); }
  .fp__price-compare { font-size: 1.1rem; color: var(--text-muted); text-decoration: line-through; }

  /* Scarcity */
  .fp__scarcity { margin-bottom: 28px; }
  .fp__scarcity-bar { height: 6px; background: #e5e5e5; border-radius: 3px; overflow: hidden; margin-bottom: 8px; }
  .fp__scarcity-fill { height: 100%; background: var(--accent-color); border-radius: 3px; transition: width 0.4s ease; }
  .fp__scarcity-text { font-size: 0.85rem; color: var(--text-muted); }
  .fp__scarcity-text strong { color: var(--accent-color); }

  /* CTA */
  .fp__form { margin-bottom: 24px; }
  .fp__cta {
    display: block; width: 100%;
    background: var(--accent-color); color: #fff;
    font-size: 1rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
    padding: 18px 24px; border-radius: var(--border-radius);
    transition: background var(--transition), transform var(--transition);
  }
  .fp__cta:hover { background: var(--accent-hover); transform: translateY(-1px); }
  .fp__cta:active { transform: translateY(0); }
  .fp__cta:disabled { background: #ccc; cursor: not-allowed; transform: none; }

  /* Trust */
  .fp__trust { display: flex; flex-direction: column; gap: 10px; padding-top: 8px; border-top: 1px solid #f0f0f0; }
  .fp__trust-item { font-size: 0.85rem; color: var(--text-muted); }
</style>

<script>
  (function() {
    var form = document.getElementById('FeaturedProductForm');
    if (!form) return;

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = document.getElementById('FeaturedProductCTA');
      var variantId = form.querySelector('[name="id"]').value;

      btn.textContent = 'Adding...';
      btn.disabled = true;

      try {
        var res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        });

        var item = await res.json();

        // Track event
        window.trackEvent({
          event: 'add_to_cart',
          content_type: 'product',
          content_ids: [item.variant_id],
          value: (item.price / 100).toFixed(2),
          currency: {{ shop.currency | json }}
        });

        // Instant checkout bypass
        window.location.href = '/checkout';

      } catch(err) {
        btn.textContent = {{ section.settings.cta_text | default: 'Add to Cart' | json }};
        btn.disabled = false;
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Featured Product",
  "tag": "section",
  "class": "section-featured-product",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_reviews_summary",
      "label": "Show reviews summary",
      "default": true
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count (display)",
      "default": "1,248"
    },
    {
      "type": "checkbox",
      "id": "show_sale_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_scarcity_bar",
      "label": "Show scarcity bar",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Add to Cart"
    },
    {
      "type": "text",
      "id": "delivery_text",
      "label": "Delivery trust text",
      "default": "Free shipping over €50"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Returns trust text",
      "default": "30-day free returns"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy trust text",
      "default": "Secure & encrypted checkout"
    }
  ],
  "presets": [
    {
      "name": "Featured Product"
    }
  ]
}
{% endschema %}
