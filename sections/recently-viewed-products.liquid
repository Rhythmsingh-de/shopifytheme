{%- if section.settings.enabled -%}
<section
  id="RecentlyViewed-{{ section.id }}"
  class="recently-viewed section-spacing"
  data-recently-viewed
  data-limit="{{ section.settings.product_limit }}"
  {% if product %}data-current-handle="{{ product.handle }}"{% endif %}
  style="--rv-cols: {{ section.settings.columns_desktop }}; --rv-mobile-cols: {{ section.settings.columns_mobile }};"
  hidden
  {{ section.shopify_attributes }}>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="recently-viewed__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    <div class="recently-viewed__grid" data-recently-viewed-grid></div>
  </div>
</section>

<style>
#RecentlyViewed-{{ section.id }} .recently-viewed__title {
  margin-bottom: clamp(20px, 4vw, 36px);
  font-family: var(--font-display);
  font-size: var(--text-xl);
}
#RecentlyViewed-{{ section.id }} .recently-viewed__grid {
  display: grid;
  grid-template-columns: repeat(var(--rv-cols), minmax(0, 1fr));
  gap: clamp(14px, 2vw, 24px);
}
#RecentlyViewed-{{ section.id }} .recent-card {
  display: grid;
  gap: 8px;
}
#RecentlyViewed-{{ section.id }} .recent-card img {
  width: 100%;
  aspect-ratio: 3 / 4;
  object-fit: cover;
  border-radius: var(--card-radius);
  background: var(--color-surface);
}
#RecentlyViewed-{{ section.id }} .recent-card h3 {
  font-size: var(--text-sm);
  line-height: 1.35;
}
#RecentlyViewed-{{ section.id }} .recent-card p {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  font-weight: 700;
}
@media (max-width: 640px) {
  #RecentlyViewed-{{ section.id }} .recently-viewed__grid {
    grid-template-columns: repeat(var(--rv-mobile-cols), minmax(0, 1fr));
  }
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Recently Viewed Products",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Recently viewed" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "select", "id": "columns_mobile", "label": "Mobile columns", "options": [
      { "value": "1", "label": "1 column" },
      { "value": "2", "label": "2 columns" }
    ], "default": "2" }
  ],
  "presets": [{ "name": "Recently Viewed Products" }]
}
{% endschema %}
