
<section class="mission-banner" style="{% if section.settings.reverse %}direction:rtl{% endif %}">
  <div class="mission-banner__img">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 1200 | image_tag:
         loading: 'lazy', widths: '600,900,1200',
         sizes: '50vw',
         alt: section.settings.heading }}
    {% else %}
      <img src="https://images.unsplash.com/photo-1604176354204-9268737828e4?w=1200&q=80&auto=format&fit=crop"
           alt="{{ section.settings.heading }}" width="600" height="750" loading="lazy"
           style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover">
    {% endif %}
  </div>
  <div class="mission-banner__content" style="{% if section.settings.reverse %}direction:ltr{% endif %}">
    {% if section.settings.eyebrow != blank %}
      <span class="label-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.body }}</p>
    {% if section.settings.cta_label != blank %}
      <a href="{{ section.settings.cta_url }}" class="btn btn-black">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Mission Banner",
  "settings": [
    {"type":"image_picker","id":"image","label":"Image"},
    {"type":"checkbox","id":"reverse","label":"Reverse layout (image right)","default":false},
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Comfort & Purpose"},
    {"type":"text","id":"heading","label":"Heading","default":"Designed for Life. Made with Care."},
    {"type":"textarea","id":"body","label":"Body text","default":"Every piece we make is designed to last, feel incredible, and give back. We believe great products and great impact go hand in hand."},
    {"type":"text","id":"cta_label","label":"Button","default":"Our Story"},
    {"type":"url","id":"cta_url","label":"Button URL"}
  ],
  "presets":[{"name":"Mission Banner"}]
}
{% endschema %}
