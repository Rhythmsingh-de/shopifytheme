<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>Best sellers</h2>
        <p>Lead with the products most likely to convert. Keep choice tight, visual, and easy to scan.</p>
      </div>
      <a class="btn btn-secondary" href="{{ routes.all_products_collection_url }}">View all</a>
    </div>
    <div class="collection-grid">
      {% assign featured = collections['all'] %}
      {% for product in featured.products limit: 4 %}
        <article class="card">
          <a href="{{ product.url }}">
            <div class="product-media">
              {% if product.featured_image %}
                {{ product.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '360, 540, 720, 800', alt: product.title }}
              {% endif %}
            </div>
            <div class="product-card-content">
              <span class="badge">Top pick</span>
              <h3 class="product-card-title">{{ product.title }}</h3>
              <div class="price-row">
                <div class="price">{{ product.price | money }}</div>
                <div>→</div>
              </div>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{ "name": "Featured collection conversion", "settings": [], "presets": [{"name": "Featured collection conversion"}] }
{% endschema %}
