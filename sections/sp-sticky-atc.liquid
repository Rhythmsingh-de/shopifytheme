{%- liquid
  assign sp = section.settings.product
  if sp == blank
    assign sp = product
  endif
  assign fv = sp.selected_or_first_available_variant
  assign sticky_label = section.settings.label | default: settings.conversion_primary_cta_label | default: 'Add to Cart'
  assign sticky_buy_label = section.settings.buy_label | default: settings.conversion_fast_checkout_label | default: settings.conversion_buy_now_label | default: 'Buy Now'
  assign sticky_cta_mode = settings.conversion_checkout_button_mode | default: 'both'
  assign fast_checkout_destination = settings.fast_checkout_destination | default: 'checkout'
  assign fast_checkout_suffix = ''
  if fast_checkout_destination == 'cart'
    assign fast_checkout_suffix = '?storefront=true'
  endif
  assign show_sticky_cart = true
  assign show_sticky_buy = settings.conversion_show_fast_checkout
  if sticky_cta_mode == 'cart_only'
    assign show_sticky_buy = false
  elsif sticky_cta_mode == 'checkout_only' and settings.conversion_show_fast_checkout
    assign show_sticky_cart = false
  endif
  if show_sticky_cart == false and show_sticky_buy == false
    assign show_sticky_cart = true
  endif
-%}

{%- if sp != blank and settings.product_sticky_atc_enabled -%}
<sp-sticky-atc
  class="sticky-atc"
  id="StickyAtc"
  data-trigger="#ProductAddToCart, .sph__btn-atc, .product-fast-checkout, .sph__btn-buy"
  aria-hidden="true"
  aria-label="Sticky add to cart bar">

  <div class="sticky-atc__inner container">

    <div class="sticky-atc__product">
      {%- if sp.featured_image != blank -%}
        {%- assign sa_alt = sp.featured_image.alt | default: sp.title | escape -%}
        {{ sp.featured_image | image_url: width: 80 | image_tag:
          widths: '40,80',
          width: 40, height: 40,
          loading: 'lazy', decoding: 'async',
          class: 'sticky-atc__img',
          alt: sa_alt }}
      {%- endif -%}
      <div class="sticky-atc__meta">
        <span class="sticky-atc__name">{{ sp.title }}</span>
        <span class="sticky-atc__price" id="StickyPrice">
          {{ fv.price | money }}
          {%- if fv.compare_at_price > fv.price -%}
            <s class="sticky-atc__was">{{ fv.compare_at_price | money }}</s>
          {%- endif -%}
        </span>
      </div>
    </div>

    <div class="sticky-atc__actions">
      {%- if fv.available -%}
        <div class="sticky-atc__btn-wrap">
          <div class="sticky-atc__buttons">
            {%- if show_sticky_cart -%}
              <button
                class="btn sticky-atc__btn"
                id="StickyAtcBtn"
                data-add-to-cart
                data-variant-id="{{ fv.id }}"
                data-qty="1"
                aria-label="Add {{ sp.title | escape }} to cart">
                {{ sticky_label | escape }}
              </button>
            {%- endif -%}
            {%- if show_sticky_buy -%}
              <a
                href="{{ routes.cart_url }}/{{ fv.id }}:1{{ fast_checkout_suffix }}"
                class="btn sticky-atc__fast-checkout"
                data-buy-now
                data-checkout-destination="{{ fast_checkout_destination }}"
                data-variant-id="{{ fv.id }}"
                aria-label="Checkout {{ sp.title | escape }}">
                {{ sticky_buy_label | escape }}
              </a>
            {%- endif -%}
          </div>
          <p class="sticky-atc__trust">
            {%- if settings.trust_secure_title != blank -%}
              {{ settings.trust_secure_title | escape }}
            {%- else -%}
              Secure
            {%- endif -%}
            &nbsp;&middot;&nbsp;
            {%- if settings.trust_shipping_title != blank -%}
              {{ settings.trust_shipping_title | escape }}
            {%- else -%}
              Fast Ship
            {%- endif -%}
            &nbsp;&middot;&nbsp;
            {%- if settings.trust_returns_title != blank -%}
              {{ settings.trust_returns_title | escape }}
            {%- else -%}
              14-Day Returns
            {%- endif -%}
          </p>
        </div>
      {%- else -%}
        <button class="btn sticky-atc__btn" disabled aria-disabled="true">Sold Out</button>
      {%- endif -%}
    </div>

  </div>
</sp-sticky-atc>
{%- endif -%}

<style>
.sticky-atc {
  position: fixed;
  bottom: 0;
  left: 0; right: 0;
  z-index: 900;
  background: var(--color-bg);
  border-top: 1px solid var(--color-border);
  box-shadow: 0 -4px 24px rgba(0,0,0,0.08);
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
  will-change: transform;
}
.sticky-atc.is-visible {
  transform: translateY(0);
  animation: sticky-atc-arrive 0.35s cubic-bezier(0.16,1,0.3,1) both;
}
@keyframes sticky-atc-arrive {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.sticky-atc__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding-top: 12px;
  padding-bottom: max(12px, env(safe-area-inset-bottom));
}
.sticky-atc__product {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  min-width: 0;
}
.sticky-atc__img {
  width: 40px; height: 40px;
  border-radius: var(--radius-sm);
  object-fit: cover;
  flex-shrink: 0;
}
.sticky-atc__meta {
  display: flex;
  flex-direction: column;
  min-width: 0;
}
.sticky-atc__name {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200px;
}
.sticky-atc__price {
  font-size: var(--text-sm);
  font-weight: 800;
  color: var(--color-text);
  display: flex;
  align-items: center;
  gap: 6px;
}
.sticky-atc__was {
  font-size: var(--text-xs);
  font-weight: 400;
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.sticky-atc__actions { flex-shrink: 0; }
.sticky-atc__btn-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}
.sticky-atc__buttons {
  display: flex;
  align-items: center;
  gap: 8px;
}
.sticky-atc__trust {
  font-size: 10px;
  color: var(--color-text-muted);
  white-space: nowrap;
  text-align: center;
  letter-spacing: 0.02em;
}
.sticky-atc__btn,
.sticky-atc__fast-checkout {
  padding: 12px 28px;
  min-height: 48px;
  font-size: var(--text-sm);
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-radius: var(--btn-radius);
  border: none;
  cursor: pointer;
  white-space: nowrap;
  position: relative;
  overflow: hidden;
  text-decoration: none;
  transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
}
.sticky-atc__btn {
  background: var(--color-primary);
  color: var(--color-primary-text);
}
.sticky-atc__fast-checkout {
  background: transparent;
  color: var(--color-primary);
  border: 2px solid var(--color-primary);
}
.sticky-atc__btn::before,
.sticky-atc__fast-checkout::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.15);
  transform: translateX(-100%);
  transition: transform 0.4s ease;
}
.sticky-atc__btn:hover::before,
.sticky-atc__fast-checkout:hover::before { transform: translateX(0); }
.sticky-atc__btn:hover,
.sticky-atc__fast-checkout:hover {
  background: var(--color-primary-hover);
  color: var(--color-primary-text);
  transform: translateY(-1px);
  box-shadow: 0 4px 16px color-mix(in oklab, var(--color-primary) 40%, transparent);
}
.sticky-atc__btn:disabled {
  opacity: 0.55; cursor: not-allowed; transform: none; box-shadow: none;
}
@media (max-width: 480px) {
  .sticky-atc__name  { max-width: 120px; }
  .sticky-atc__img   { display: none; }
  .sticky-atc__trust { display: none; }
  .sticky-atc__buttons { gap: 6px; }
  .sticky-atc__btn,
  .sticky-atc__fast-checkout { padding: 14px 14px; font-size: 11px; min-height: 50px; }
  .sticky-atc__inner { gap: var(--space-3); }
}
</style>

<script>
var blcStickyCartUrl = {{ routes.cart_url | json }};

class SpStickyAtc extends HTMLElement {
  connectedCallback() {
    this._visible = false;
    this._triggers = [];
    this._observer = null;
    this._init();

    /* Re-init on Shopify section load (theme editor) */
    document.addEventListener('shopify:section:load', (e) => {
      if (e.target.contains(this)) this._init();
    });

    /* Sync variant from main product form */
    window.addEventListener('variant:changed', (e) => this._syncVariant(e.detail.variant));
    window.addEventListener('sph:variant:changed', (e) => this._syncVariant(e.detail.variant));
  }

  disconnectedCallback() {
    if (this._observer) this._observer.disconnect();
  }

  _init() {
    if (this._observer) this._observer.disconnect();

    const selectors = (this.dataset.trigger || '').split(',').map(s => s.trim()).filter(Boolean);
    this._triggers = selectors.flatMap(s => Array.from(document.querySelectorAll(s)));

    if (!this._triggers.length) return;

    this._observer = new IntersectionObserver((entries) => {
      const anyVisible = entries.some(e => e.isIntersecting);
      this._setVisible(!anyVisible);
    }, { threshold: 0.1 });

    this._triggers.forEach(t => this._observer.observe(t));
  }

  _setVisible(show) {
    if (this._visible === show) return;
    this._visible = show;
    this.classList.toggle('is-visible', show);
    this.setAttribute('aria-hidden', String(!show));
  }

  _syncVariant(variant) {
    if (!variant) return;
    /* Update price */
    const priceEl = this.querySelector('#StickyPrice');
    if (priceEl) {
      const locale = window.Shopify?.locale || document.documentElement.lang || 'en';
      const formatter = new Intl.NumberFormat(locale, { style: 'currency', currency: window.Shopify?.currency?.active || 'USD' });
      const price = formatter.format(variant.price / 100);
      const wasHtml = variant.compare_at_price > variant.price
        ? `<s class="sticky-atc__was">${formatter.format(variant.compare_at_price / 100)}</s>`
        : '';
      priceEl.innerHTML = price + (wasHtml ? ' ' + wasHtml : '');
    }
    /* Update ATC variant id */
    const btn = this.querySelector('[data-add-to-cart]');
    if (btn) {
      btn.dataset.variantId = String(variant.id);
      btn.disabled = !variant.available;
      btn.setAttribute('aria-disabled', String(!variant.available));
    }
    const buy = this.querySelector('[data-buy-now]');
    if (buy) {
      buy.dataset.variantId = String(variant.id);
      buy.href = window.BLC && typeof window.BLC.checkoutHref === 'function'
        ? window.BLC.checkoutHref(variant.id, 1, buy)
        : blcStickyCartUrl + '/' + variant.id + ':1' + (buy.dataset.checkoutDestination === 'cart' ? '?storefront=true' : '');
      buy.toggleAttribute('aria-disabled', !variant.available);
    }
  }
}
customElements.define('sp-sticky-atc', SpStickyAtc);
</script>

{% schema %}
{
  "name": "Sticky Add to Cart",
  "tag": "div",
  "class": "shopify-section-sticky-atc",
  "settings": [
    { "type": "product", "id": "product", "label": "Product (leave blank to use page product)" },
    { "type": "text",    "id": "label",   "label": "Add-to-cart label", "info": "Leave blank to use Theme Settings > Trust & Conversion." },
    { "type": "text",    "id": "buy_label", "label": "Fast checkout label", "info": "Leave blank to use Theme Settings > Trust & Conversion." }
  ],
  "presets": [
    { "name": "Sticky Add to Cart" }
  ]
}
{% endschema %}
