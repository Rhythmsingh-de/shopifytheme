{%- liquid
  assign product = product
  assign first_variant = product.selected_or_first_available_variant
  assign price = first_variant.price
  assign compare_price = first_variant.compare_at_price
  assign is_sale = false
  if compare_price > price
    assign is_sale = true
    assign saving_pct = compare_price | minus: price | times: 100 | divided_by: compare_price
  endif
-%}
<section class="section-spacing" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="product-page-grid" data-product-detail
      data-product-id="{{ product.id }}"
      data-product-title="{{ product.title | escape }}"
      data-product-type="{{ product.type | escape }}"
      data-price="{{ price | divided_by: 100.0 }}"
      data-variant-title="{{ first_variant.title | escape }}">

      <!-- Media -->
      <div class="product-media-stack">
        <div class="product-media-main">
          {%- if product.featured_image != blank -%}
            {{ product.featured_image | image_url: width: 900 | image_tag:
              id: 'ProductMainImage',
              loading: 'eager',
              width: 900, height: 900,
              alt: product.featured_image.alt | default: product.title
            }}
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        {%- if product.images.size > 1 -%}
          <div class="product-media-thumbs" role="list">
            {%- for image in product.images limit: 6 -%}
              <button class="product-media-thumb{% if forloop.first %} is-active{% endif %}"
                aria-label="View image {{ forloop.index }}" role="listitem">
                {{ image | image_url: width: 144 | image_tag:
                  loading: 'lazy',
                  width: 72, height: 72,
                  alt: image.alt | default: product.title
                }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 class="product-info__title">{{ product.title }}</h1>

        <!-- Meta: SKU and type/specs tag -->
        <div class="product-meta-row">
          {%- if first_variant.sku != blank -%}
            <div class="product-meta-pill">
              <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 9h10M7 13h4"/></svg>
              <span>SKU: {{ first_variant.sku }}</span>
            </div>
          {%- endif -%}
          {%- if product.type != blank -%}
            <div class="product-meta-pill">
              <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg>
              <span>{{ product.type }}</span>
            </div>
          {%- endif -%}
        </div>

        {%- if product.metafields.custom.specs != blank -%}
          <ul class="product-specs-list">
            {%- assign specs_lines = product.metafields.custom.specs.value | split: '\n' -%}
            {%- for line in specs_lines -%}
              {%- unless line == '' -%}
                <li>{{ line }}</li>
              {%- endunless -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if product.metafields.reviews.rating.value != blank -%}
          <div class="product-info__rating">
            {%- assign rating = product.metafields.reviews.rating.value | round -%}
            <div style="display:flex;gap:3px;color:var(--color-gold)">
              {%- for i in (1..5) -%}
                <svg width="16" height="16" viewBox="0 0 24 24" fill="{% if i <= rating %}currentColor{% else %}none{% endif %}" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
            {%- if product.metafields.reviews.rating_count.value != blank -%}
              <span style="font-size:var(--text-xs);color:var(--color-text-muted)">{{ product.metafields.reviews.rating_count.value }} reviews</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="product-info__price">
          <span class="{% if is_sale %}product-info__price-sale{% endif %}">{{ price | money }}</span>
          {%- if is_sale -%}
            <span class="product-info__price-compare">{{ compare_price | money }}</span>
            <span class="badge badge--sale">Save {{ saving_pct }}%</span>
          {%- endif -%}
        </div>

        {%- if product.has_only_default_variant == false -%}
          <div class="product-options">
            {%- for option in product.options_with_values -%}
              <div style="margin-bottom:var(--space-5)">
                <p class="product-option__label">{{ option.name }}: <strong id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</strong></p>
                <div class="product-option__swatches" role="radiogroup" aria-label="{{ option.name }}">
                  {%- for value in option.values -%}
                    <button class="option-swatch{% if value == option.selected_value %} is-active{% endif %}"
                      data-option-name="{{ option.name }}"
                      data-option-value="{{ value }}"
                      aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}">
                      {{ value }}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div class="product-add-to-cart">
          <div data-qty-stepper style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-3)">
            <div class="product-qty">
              <button class="product-qty__btn" data-qty-minus aria-label="Decrease quantity">−</button>
              <input class="product-qty__val" type="number" data-qty-input value="1" min="1" aria-label="Quantity" readonly>
              <button class="product-qty__btn" data-qty-plus aria-label="Increase quantity">+</button>
            </div>
            <span style="font-size:var(--text-xs);color:var(--color-text-muted)">
              {%- if first_variant.available -%}In stock{%- else -%}Out of stock{%- endif -%}
            </span>
          </div>

          {%- if first_variant.available -%}
            <button class="btn btn--primary btn--full btn--lg"
              id="ProductAddToCart"
              data-add-to-cart
              data-variant-id="{{ first_variant.id }}"
              data-qty="1"
              data-label="Add to Cart">
              Add to Cart — {{ price | money }}
            </button>
            <a href="/checkout?variant={{ first_variant.id }}&quantity=1" class="btn btn--ghost btn--full btn--lg">
              Buy It Now
            </a>
          {%- else -%}
            <button class="btn btn--primary btn--full btn--lg" disabled style="opacity:0.5;cursor:not-allowed">
              Sold Out
            </button>
          {%- endif -%}
        </div>

        <!-- Benefits -->
        <ul class="product-benefits">
          {%- if section.settings.benefit_1 != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.benefit_1 }}
            </li>
          {%- endif -%}
          {%- if section.settings.benefit_2 != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.benefit_2 }}
            </li>
          {%- endif -%}
          {%- if section.settings.benefit_3 != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.benefit_3 }}
            </li>
          {%- endif -%}
          {%- if section.settings.benefit_4 != blank -%}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.benefit_4 }}
            </li>
          {%- endif -%}
        </ul>

        <!-- Trust badges -->
        <div class="product-trust">
          <div class="product-trust-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            <span class="product-trust-item__label">{{ section.settings.trust_1_title | default: '30-Day Returns' }}</span>
            <span class="product-trust-item__sub">{{ section.settings.trust_1_sub | default: 'Easy returns' }}</span>
          </div>
          <div class="product-trust-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span class="product-trust-item__label">{{ section.settings.trust_2_title | default: 'Fast Shipping' }}</span>
            <span class="product-trust-item__sub">{{ section.settings.trust_2_sub | default: '7–10 days' }}</span>
          </div>
          <div class="product-trust-item">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span class="product-trust-item__label">{{ section.settings.trust_3_title | default: 'Secure Payment' }}</span>
            <span class="product-trust-item__sub">{{ section.settings.trust_3_sub | default: 'SSL protected' }}</span>
          </div>
        </div>

        <!-- Payment icons -->
        <div class="product-payment-icons">
          <span class="product-payment-icons__label">We accept:</span>
          {%- render 'payment-icons' -%}
        </div>

        <!-- Accordion -->
        <div style="margin-top:var(--space-8)">
          {%- if product.description != blank -%}
            <div class="accordion-item">
              <button class="accordion-trigger" aria-expanded="true" aria-controls="acc-desc">
                Description
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="accordion-body is-open" id="acc-desc">
                <div class="accordion-body__inner rte">{{ product.description }}</div>
              </div>
            </div>
          {%- endif -%}

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false" aria-controls="acc-shipping">
              Shipping & Returns
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="accordion-body" id="acc-shipping">
              <div class="accordion-body__inner">{{ section.settings.shipping_text | default: 'Free shipping on orders over $75. Standard delivery 7–10 business days. Easy 30-day returns.' }}</div>
            </div>
          </div>

          <div class="accordion-item">
            <button class="accordion-trigger" aria-expanded="false" aria-controls="acc-returns">
              Return Policy
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="accordion-body" id="acc-returns">
              <div class="accordion-body__inner">{{ section.settings.returns_text | default: 'Returns accepted within 30 days of delivery. Items must be unused and in original packaging. Contact us at info@bodyluxcare.com to initiate a return.' }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product main",
  "tag": "section",
  "class": "shopify-section--product",
  "settings": [
    { "type": "header", "content": "Product Benefits" },
    { "type": "text", "id": "benefit_1", "label": "Benefit 1", "default": "Premium quality, built to last" },
    { "type": "text", "id": "benefit_2", "label": "Benefit 2", "default": "Free shipping on orders over $75" },
    { "type": "text", "id": "benefit_3", "label": "Benefit 3", "default": "30-day hassle-free returns" },
    { "type": "text", "id": "benefit_4", "label": "Benefit 4", "default": "Secure checkout guaranteed" },
    { "type": "header", "content": "Trust Badges" },
    { "type": "text", "id": "trust_1_title", "label": "Badge 1 title", "default": "30-Day Returns" },
    { "type": "text", "id": "trust_1_sub", "label": "Badge 1 subtitle", "default": "Easy returns" },
    { "type": "text", "id": "trust_2_title", "label": "Badge 2 title", "default": "Fast Shipping" },
    { "type": "text", "id": "trust_2_sub", "label": "Badge 2 subtitle", "default": "7–10 days" },
    { "type": "text", "id": "trust_3_title", "label": "Badge 3 title", "default": "Secure Payment" },
    { "type": "text", "id": "trust_3_sub", "label": "Badge 3 subtitle", "default": "SSL protected" },
    { "type": "header", "content": "Policy Text" },
    { "type": "richtext", "id": "shipping_text", "label": "Shipping info" },
    { "type": "richtext", "id": "returns_text", "label": "Returns info" }
  ],
  "presets": [{ "name": "Product main" }]
}
{% endschema %}
