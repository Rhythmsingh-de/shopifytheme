
<section class="prod-page" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title | escape }}">
  <meta itemprop="description" content="{{ product.description | strip_html | escape }}">
  {% if product.featured_image %}
    <meta itemprop="image" content="{{ product.featured_image | image_url: width: 1200 }}">
  {% endif %}
  <div itemscope itemprop="offers" itemtype="https://schema.org/Offer">
    <meta itemprop="price" content="{{ product.price | divided_by: 100.0 }}">
    <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
    <meta itemprop="availability" content="{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}">
  </div>

  <div class="page-w">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" style="margin-bottom:20px;font-size:13px;color:#888;display:flex;gap:6px;align-items:center;flex-wrap:wrap">
      <a href="{{ routes.root_url }}" style="color:#888;transition:color .18s">Home</a>
      <span>›</span>
      {% if product.collections.first %}
        <a href="{{ product.collections.first.url }}" style="color:#888;transition:color .18s">{{ product.collections.first.title }}</a>
        <span>›</span>
      {% endif %}
      <span style="color:#1a1a1a;font-weight:600">{{ product.title }}</span>
    </nav>

    <div class="prod-grid">
      <!-- Gallery -->
      <div class="gallery-sticky">
        <div class="gallery-main" id="galleryMain">
          {% if product.images.size > 0 %}
            {{ product.images[0] | image_url: width: 1200 | image_tag:
               id: 'mainImg',
               loading: 'eager',
               fetchpriority: 'high',
               widths: '600,900,1200',
               sizes: '(max-width:1024px) 100vw,55vw',
               alt: product.title }}
          {% else %}
            <div style="width:100%;height:100%;background:#f0f0f0;display:flex;align-items:center;justify-content:center;color:#aaa;font-size:14px">No image</div>
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="gallery-thumbs" role="list">
            {% for img in product.images limit: 6 %}
              <button class="g-thumb{% if forloop.first %} active{% endif %}"
                      data-src="{{ img | image_url: width: 1200 }}"
                      data-srcset="{{ img | image_url: width: 600 }} 600w, {{ img | image_url: width: 1200 }} 1200w"
                      aria-label="View image {{ forloop.index }}"
                      role="listitem">
                {{ img | image_url: width: 128 | image_tag: alt: product.title, loading: 'lazy', width: 64, height: 64 }}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- Info -->
      <div class="prod-info">
        {% if product.vendor != blank %}
          <span class="label-eyebrow">{{ product.vendor }}</span>
        {% endif %}
        <h1 itemprop="name">{{ product.title }}</h1>

        <!-- Price -->
        <div class="prod-price-area">
          <span class="prod-price" id="prodPrice">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          {% if product.compare_at_price > product.price %}
            <span class="prod-was">{{ product.compare_at_price | money }}</span>
            <span class="prod-save">
              Save {{ product.compare_at_price | minus: product.price | money }}
            </span>
          {% endif %}
        </div>

        <!-- Stars mock (replace with review app) -->
        <div class="prod-stars">
          <span class="stars">★★★★★</span>
          <span class="count">4.9 ({{ product.metafields.reviews.rating_count | default: '0' }} reviews)</span>
        </div>

        <!-- Variants -->
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="variant-group">
              <div class="variant-label">
                {{ option.name }}:
                <span id="opt-val-{{ forloop.index0 }}">{{ option.selected_value }}</span>
              </div>
              <div class="variant-btns" data-option-index="{{ forloop.index0 }}">
                {% for value in option.values %}
                  <button class="v-btn{% if value == option.selected_value %} active{% endif %}"
                          data-value="{{ value }}"
                          data-option="{{ forloop.parentloop.index0 }}">
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}

        <!-- Trust strip -->
        <div class="trust-strip">
          <div class="trust-strip-item">
            <strong>Free Shipping</strong>
            <span>Orders $75+</span>
          </div>
          <div class="trust-strip-item">
            <strong>Easy Returns</strong>
            <span>30-day policy</span>
          </div>
          <div class="trust-strip-item">
            <strong>Secure Pay</strong>
            <span>Encrypted checkout</span>
          </div>
        </div>

        <!-- ATC -->
        <button class="prod-atc" id="prodAtc"
                data-variant="{{ product.selected_or_first_available_variant.id }}"
                {% unless product.available %}disabled style="opacity:.5;cursor:not-allowed"{% endunless %}>
          {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
        </button>
        <a href="{{ routes.checkout }}" class="prod-buy">Buy It Now</a>

        <!-- Description -->
        {% if product.description != blank %}
          <div class="prod-desc">{{ product.description }}</div>
        {% endif %}

        <!-- Accordions -->
        <div style="margin-top:20px">
          {% for block in section.blocks %}
            <div class="acc-item" {{ block.shopify_attributes }}>
              <button class="acc-btn" aria-expanded="false">
                {{ block.settings.heading }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div class="acc-body">{{ block.settings.content }}</div>
            </div>
          {% endfor %}
        </div>
      </div><!-- /prod-info -->
    </div>
  </div>
</section>

<script>
(function(){
  // Gallery thumbs
  document.querySelectorAll('.g-thumb').forEach(function(btn){
    btn.addEventListener('click', function(){
      var img = document.getElementById('mainImg');
      if(img){ img.src = this.dataset.src; img.srcset = this.dataset.srcset||''; }
      document.querySelectorAll('.g-thumb').forEach(function(b){ b.classList.remove('active'); });
      this.classList.add('active');
    });
  });

  // Variant selector
  var variants = {{ product.variants | json }};
  var selected = {};
  {% for option in product.options_with_values %}
    selected[{{ forloop.index0 }}] = {{ option.selected_value | json }};
  {% endfor %}

  function updateVariant(){
    var match = variants.find(function(v){
      return v.options.every(function(opt, i){ return opt === selected[i]; });
    });
    if(!match) match = variants[0];
    var priceEl = document.getElementById('prodPrice');
    if(priceEl && match){
      priceEl.textContent = formatMoney(match.price);
    }
    var atcBtn = document.getElementById('prodAtc');
    if(atcBtn && match){
      atcBtn.dataset.variant = match.id;
      atcBtn.disabled = !match.available;
      atcBtn.textContent = match.available ? 'Add to Cart' : 'Sold Out';
      atcBtn.style.opacity = match.available ? '' : '0.5';
      // dataLayer
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'view_item', ecommerce: {
        currency: '{{ cart.currency.iso_code }}',
        value: match.price / 100,
        items: [{ item_id: match.id, item_name: {{ product.title | json }}, price: match.price / 100 }]
      }});
    }
  }

  function formatMoney(cents){
    return '{{ cart.currency.symbol }}' + (cents/100).toFixed(2);
  }

  document.querySelectorAll('.variant-btns').forEach(function(group){
    group.querySelectorAll('.v-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        var idx = parseInt(this.dataset.option);
        selected[idx] = this.dataset.value;
        group.querySelectorAll('.v-btn').forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        var lbl = document.getElementById('opt-val-'+idx);
        if(lbl) lbl.textContent = this.dataset.value;
        updateVariant();
      });
    });
  });

  // ATC
  document.getElementById('prodAtc')?.addEventListener('click', function(){
    var variantId = this.dataset.variant;
    if(!variantId) return;
    var btn = this;
    btn.textContent = 'Adding…';
    btn.disabled = true;
    fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json','X-Requested-With':'XMLHttpRequest'},
      body: JSON.stringify({id: variantId, quantity: 1})
    }).then(function(r){ return r.json(); }).then(function(item){
      btn.textContent = '✓ Added!';
      btn.classList.add('added');
      // update badge
      return fetch('/cart.js');
    }).then(function(r){ return r.json(); }).then(function(cart){
      var badge = document.getElementById('cartBadge');
      var cnt = document.getElementById('drawerCount');
      if(badge){ badge.textContent = cart.item_count; badge.style.display = cart.item_count > 0 ? 'flex' : 'none'; }
      if(cnt){ cnt.textContent = cart.item_count; }
      document.getElementById('cartDrawer').classList.add('open');
      document.body.style.overflow = 'hidden';
      // dataLayer
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: 'add_to_cart' });
      setTimeout(function(){ btn.textContent = 'Add to Cart'; btn.classList.remove('added'); btn.disabled = false; }, 2200);
    }).catch(function(){
      btn.textContent = 'Error – try again'; btn.disabled = false;
    });
  });

  // Accordions
  document.querySelectorAll('.acc-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var item = this.closest('.acc-item');
      var open = item.classList.toggle('open');
      this.setAttribute('aria-expanded', open);
    });
  });
})();
</script>

{% schema %}
{
  "name": "Product Page",
  "blocks": [{
    "type":"accordion","name":"Accordion",
    "settings":[
      {"type":"text","id":"heading","label":"Heading","default":"Shipping & Returns"},
      {"type":"richtext","id":"content","label":"Content","default":"<p>Free standard shipping on orders over $75. Easy 30-day returns on all full-price items.</p>"}
    ]
  }],
  "presets":[{
    "name":"Product Page",
    "blocks":[
      {"type":"accordion","settings":{"heading":"Shipping & Returns","content":"<p>Free standard shipping on orders over $75. Returns accepted within 30 days.</p>"}},
      {"type":"accordion","settings":{"heading":"Size & Fit","content":"<p>Model is 5'9\" and wears a size S. See our <a href='/pages/size-guide'>size guide</a> for full measurements.</p>"}},
      {"type":"accordion","settings":{"heading":"Materials & Care","content":"<p>Crafted from premium sustainable materials. Machine wash cold, lay flat to dry.</p>"}}
    ]
  }]
}
{% endschema %}
