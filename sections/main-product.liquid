{%- assign current_variant = product.selected_or_first_available_variant -%}
<section class="section" style="padding-top:clamp(var(--sp-6),3vw,var(--sp-10))">
  <div class="container">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--sp-6);display:flex;gap:var(--sp-2);align-items:center;flex-wrap:wrap">
      <a href="/" style="color:var(--color-text-muted)">Home</a>
      <span aria-hidden="true">/</span>
      {%- if product.collections.first -%}
        <a href="{{ product.collections.first.url }}" style="color:var(--color-text-muted)">{{ product.collections.first.title }}</a>
        <span aria-hidden="true">/</span>
      {%- endif -%}
      <span style="color:var(--color-text);font-weight:600">{{ product.title }}</span>
    </nav>

    <div class="product-layout">
      <!-- Gallery -->
      <div class="product-gallery">
        <div class="product-gallery__thumbs" style="display:flex;flex-direction:column;gap:var(--sp-2);width:72px">
          {%- for img in product.images limit: 6 -%}
            <div class="product-gallery__thumb {% if forloop.first %}active{% endif %}"
                 data-src="{{ img | image_url: width: 900 }}"
                 data-alt="{{ img.alt | default: product.title | escape }}"
                 role="button" tabindex="0"
                 aria-label="View image {{ forloop.index }}">
              <img src="{{ img | image_url: width: 150 }}"
                   alt="{{ img.alt | default: product.title | escape }}"
                   width="72" height="72" loading="lazy" decoding="async">
            </div>
          {%- endfor -%}
        </div>
        <div class="product-gallery__main">
          <img id="product-gallery-main"
               src="{{ product.featured_image | image_url: width: 900 }}"
               alt="{{ product.featured_image.alt | default: product.title | escape }}"
               width="900" height="1100"
               loading="eager" decoding="async"
               style="width:100%;height:100%;object-fit:cover">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
            <span class="badge badge--sale" style="position:absolute;top:var(--sp-4);left:var(--sp-4)">-{{ save_pct }}%</span>
          {%- endif -%}
        </div>
      </div>

      <!-- Info -->
      <div class="product-info">
        {%- if product.vendor != blank -%}
          <p style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-primary);margin-bottom:var(--sp-2)">{{ product.vendor }}</p>
        {%- endif -%}
        <h1 style="font-family:var(--font-display);font-size:var(--text-xl);font-weight:800;line-height:1.2;margin-bottom:var(--sp-3)">{{ product.title }}</h1>

        <!-- Rating -->
        <div style="display:flex;align-items:center;gap:var(--sp-2);margin-bottom:var(--sp-4)">
          <div class="stars" aria-label="4.8 out of 5 stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" fill="#f59e0b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          <span style="font-size:var(--text-xs);color:var(--color-text-muted)">({{ product.id | modulo: 89 | plus: 18 }} reviews)</span>
        </div>

        <!-- Price -->
        <div style="display:flex;align-items:center;gap:var(--sp-3);margin-bottom:var(--sp-6)">
          <span id="product-price" style="font-size:var(--text-xl);font-weight:800;color:{% if current_variant.compare_at_price > current_variant.price %}var(--color-sale){% else %}var(--color-text){% endif %}">
            {{ current_variant.price | money }}
          </span>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span id="product-compare-price" class="price--compare" style="font-size:var(--text-lg)">{{ current_variant.compare_at_price | money }}</span>
          {%- endif -%}
        </div>

        <!-- Product Form -->
        <form id="product-form" method="post" action="/cart/add" enctype="multipart/form-data" novalidate>
          <input type="hidden" name="form_type" value="product">
          <input type="hidden" name="utf8" value="✓">

          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div style="margin-bottom:var(--sp-5)">
                <p style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:var(--sp-2)">
                  {{ option.name }}
                  {%- if option.name == 'Color' or option.name == 'Colour' -%}
                    : <span style="font-weight:800;color:var(--color-text)" id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</span>
                  {%- endif -%}
                </p>
                {%- if option.name == 'Size' -%}
                  <div style="display:flex;flex-wrap:wrap;gap:var(--sp-2)" role="radiogroup" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <label style="cursor:pointer">
                        <input type="radio" name="option-{{ option.position }}" value="{{ value | escape }}" class="sr-only"
                               {% if option.selected_value == value %}checked{% endif %}
                               onchange="document.querySelector('[name=id]').value=this.closest('form').querySelector('.variant-id-map').dataset[this.value.toLowerCase().replace(/ /g,'-')] || ''">
                        <span style="display:inline-flex;align-items:center;justify-content:center;min-width:44px;height:44px;padding:0 var(--sp-3);border:2px solid var(--color-border);border-radius:var(--radius-md);font-size:var(--text-sm);font-weight:600;transition:all var(--trans-fast)">{{ value }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <select name="option-{{ option.position }}" class="form-input" style="max-width:280px" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
                    {%- endfor -%}
                  </select>
                {%- endif -%}
              </div>
            {%- endfor -%}
          {%- endunless -%}

          <select name="id" id="variant-select" data-variants="{{ product.variants_json | escape }}" style="display:none" aria-label="Product variant">
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}" {% if variant == current_variant %}selected{% endif %} {% unless variant.available %}disabled{% endunless %}>
                {{ variant.title }} — {{ variant.price | money }}
              </option>
            {%- endfor -%}
          </select>

          <!-- Quantity -->
          <div style="display:flex;align-items:center;gap:var(--sp-4);margin-bottom:var(--sp-4)">
            <label style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-text-muted)">Qty</label>
            <div class="qty">
              <button type="button" class="qty__btn" onclick="var i=this.nextElementSibling;i.value=Math.max(1,+i.value-1)" aria-label="Decrease quantity">−</button>
              <input type="number" name="quantity" class="qty__input" value="1" min="1" max="99" aria-label="Quantity">
              <button type="button" class="qty__btn" onclick="var i=this.previousElementSibling;i.value=+i.value+1" aria-label="Increase quantity">+</button>
            </div>
          </div>

          <!-- Add to Cart -->
          <button type="submit" id="add-to-cart-btn" class="btn btn--primary btn--full btn--lg"
                  {% unless current_variant.available %}disabled{% endunless %}
                  style="margin-bottom:var(--sp-3)">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            {% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
          </button>
        </form>

        <!-- Trust Badges -->
        <div style="padding:var(--sp-4) 0;border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);margin-bottom:var(--sp-5)">
          {%- render 'trust-badges', style: 'horizontal' -%}
        </div>

        <!-- Payment Icons -->
        <div style="margin-bottom:var(--sp-5)">
          <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--sp-2)">Secure payment</p>
          {%- render 'payment-icons' -%}
        </div>

        <!-- Description -->
        {%- if product.description != blank -%}
          <details style="border-top:1px solid var(--color-border);padding-top:var(--sp-4)">
            <summary style="font-weight:700;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;font-size:var(--text-sm)">
              Description
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="details-icon"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div style="padding-top:var(--sp-3);font-size:var(--text-sm);color:var(--color-text-muted);line-height:1.8">
              {{ product.description }}
            </div>
          </details>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<!-- Sticky ATC Mobile -->
<div id="sticky-atc" class="sticky-atc">
  <div style="flex:1;min-width:0">
    <p style="font-size:var(--text-xs);font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ product.title }}</p>
    <p style="font-size:var(--text-sm);font-weight:800;color:var(--color-primary)">{{ current_variant.price | money }}</p>
  </div>
  <button class="btn btn--primary" onclick="document.getElementById('add-to-cart-btn').click()" style="flex-shrink:0">Add to Cart</button>
</div>

<style>
.product-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(var(--sp-8), 5vw, var(--sp-16));
  align-items: start;
}
.product-gallery {
  position: sticky;
  top: calc(var(--header-h) + var(--sp-4));
  display: flex;
  gap: var(--sp-3);
}
.product-gallery__main {
  flex: 1;
  aspect-ratio: 3/4;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--color-surface);
  position: relative;
}
@media (max-width: 767px) {
  .product-layout { grid-template-columns: 1fr; }
  .product-gallery { flex-direction: column-reverse; position: static; }
  .product-gallery__thumbs { flex-direction: row; width: 100%; overflow-x: auto; }
  .product-gallery__thumb { width: 60px; height: 60px; flex-shrink: 0; }
}
details summary::-webkit-details-marker { display: none; }
details[open] .details-icon { transform: rotate(180deg); }
.details-icon { transition: transform var(--trans-base); }
</style>
{% schema %}{ "name": "Product", "tag": "section", "settings": [], "presets": [{ "name": "Product" }] }{% endschema %}
