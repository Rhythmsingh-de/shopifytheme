{%- liquid
  assign first_variant = product.selected_or_first_available_variant
  assign price = first_variant.price
  assign compare_price = first_variant.compare_at_price
  assign is_sale = false
  if compare_price > price
    assign is_sale = true
    assign saving_pct = compare_price | minus: price | times: 100 | divided_by: compare_price
  endif
  assign align = section.settings.info_align | default: 'left'
  assign atc_label = section.settings.atc_label | default: settings.conversion_primary_cta_label | default: 'Add to Cart'
  assign buy_label = section.settings.buy_label | default: settings.conversion_fast_checkout_label | default: settings.conversion_buy_now_label | default: 'Buy Now'
  assign cta_button_mode = settings.conversion_checkout_button_mode | default: 'both'
  assign fast_checkout_destination = settings.fast_checkout_destination | default: 'checkout'
  assign fast_checkout_suffix = ''
  if fast_checkout_destination == 'cart'
    assign fast_checkout_suffix = '?storefront=true'
  endif
  assign show_cart_button = true
  assign show_buy_now = section.settings.show_buy_now
  if settings.conversion_show_fast_checkout == false or cta_button_mode == 'cart_only'
    assign show_buy_now = false
  endif
  if cta_button_mode == 'checkout_only' and settings.conversion_show_fast_checkout
    assign show_cart_button = false
  endif
  if show_cart_button == false and show_buy_now == false
    assign show_cart_button = true
  endif
-%}

<section class="section-spacing product-page-section" data-product-detail data-variants="{{ product.variants | json | escape }}" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="product-page-grid">

      <!-- ── Media column ── -->
      <div class="product-media-stack">
        <div class="product-media-main" id="ProductMediaMain">
          {%- if product.featured_image != blank -%}
            {%- assign main_img_alt = product.featured_image.alt | default: product.title | escape -%}
            {{ product.featured_image | image_url: width: 900 | image_tag: id: 'ProductMainImage', widths: '450,900,1200', loading: 'eager', decoding: 'async', width: 900, height: 900, alt: main_img_alt }}
          {%- else -%}
            <div class="product-media-placeholder" aria-label="{{ product.title | escape }}">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="product-media-thumbs" role="list" aria-label="Product images">
            {%- for image in product.images limit: 6 -%}
              <button
                class="product-media-thumb{% if forloop.first %} is-active{% endif %}"
                data-src="{{ image | image_url: width: 900 }}"
                data-target="ProductMainImage"
                aria-label="View image {{ forloop.index }} of {{ product.images.size }}"
                role="listitem">
                {%- assign thumb_alt = image.alt | default: product.title | escape -%}
                {{ image | image_url: width: 144 | image_tag: widths: '72,144', loading: 'lazy', decoding: 'async', width: 72, height: 72, alt: thumb_alt }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <!-- ── Info column ── -->
      <div class="product-info product-info--{{ align }}">

        {%- if product.vendor != blank -%}
          <p class="product-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="product-info__title">{{ product.title }}</h1>

        {%- if first_variant.sku != blank -%}
          <p class="product-info__sku">SKU: <span>{{ first_variant.sku }}</span></p>
        {%- endif -%}

        {%- if product.metafields.reviews.rating.value != blank -%}
          <div class="product-info__rating">
            {%- assign rating = product.metafields.reviews.rating.value | round -%}
            <div class="product-stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}
                <svg width="15" height="15" viewBox="0 0 24 24"
                  fill="{% if i <= rating %}var(--color-gold){% else %}none{% endif %}"
                  stroke="var(--color-gold)" stroke-width="1.5" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              {%- endfor -%}
            </div>
            {%- if product.metafields.reviews.rating_count.value != blank -%}
              <span class="product-info__rating-count">({{ product.metafields.reviews.rating_count.value }} reviews)</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="product-info__price-row" style="display:flex; align-items:center; flex-wrap:wrap; gap:10px; margin-bottom:var(--space-3);">
          <div class="product-info__price">
            <span class="product-info__price-now{% if is_sale %} is-sale{% endif %}">{{ price | money }}</span>
            {%- if is_sale -%}
              <span class="product-info__price-was">{{ compare_price | money }}</span>
            {%- endif -%}
          </div>

          {%- if is_sale and settings.card_show_sale_badge and section.settings.show_sale_badge -%}
            <span class="badge badge--sale">Save {{ saving_pct }}%</span>
          {%- endif -%}

          {%- if settings.card_show_new_badge -%}
            {%- if product.tags contains 'new' -%}
              <span class="badge badge--new" style="background:var(--color-primary); color:var(--color-primary-text);">New</span>
            {%- elsif product.tags contains 'bestseller' -%}
              <span class="badge badge--bestseller" style="background:var(--color-gold); color:#fff;">Bestseller</span>
            {%- endif -%}
          {%- endif -%}
        </div>

        {%- if product.has_only_default_variant == false -%}
          <div class="product-options">
            {%- for option in product.options_with_values -%}
              <div class="product-option">
                <p class="product-option__label">
                  {{ option.name }}:
                  <strong id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</strong>
                </p>

                {%- if option.name == 'Color' or option.name == 'Colour' -%}
                  <div class="product-option__swatches" role="radiogroup" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <button
                        class="option-swatch option-swatch--color{% if value == option.selected_value %} is-active{% endif %}"
                        data-option-name="{{ option.name | escape }}"
                        data-option-value="{{ value | escape }}"
                        style="--swatch-color:{{ value | downcase | replace: ' ', '' }}"
                        aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}"
                        aria-label="{{ value | escape }}">
                      </button>
                    {%- endfor -%}
                  </div>
                {%- else -%}
                  <div class="product-option__swatches product-option__swatches--pills" role="radiogroup" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <button
                        class="option-swatch option-swatch--pill{% if value == option.selected_value %} is-active{% endif %}"
                        data-option-name="{{ option.name | escape }}"
                        data-option-value="{{ value | escape }}"
                        aria-pressed="{% if value == option.selected_value %}true{% else %}false{% endif %}"
                        aria-label="{{ value | escape }}">
                        {{ value }}
                      </button>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Qty + ATC -->
        <div class="product-add-to-cart">
          <div class="product-qty-row">
            <div class="product-qty" data-qty-stepper>
              <button class="product-qty__btn" data-qty-minus aria-label="Decrease quantity">&#8722;</button>
              <input class="product-qty__val" type="number" data-qty-input
                value="1" min="1" max="99" readonly aria-label="Quantity">
              <button class="product-qty__btn" data-qty-plus aria-label="Increase quantity">&#43;</button>
            </div>
            <span class="product-stock-label">
              {%- if first_variant.available -%}
                <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><circle cx="5" cy="5" r="5" fill="#1d6b44"/></svg>
                In stock
              {%- else -%}
                <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><circle cx="5" cy="5" r="5" fill="#e8260d"/></svg>
                Out of stock
              {%- endif -%}
            </span>
          </div>

          {%- if first_variant.available -%}
            {%- if show_cart_button -%}
              <button
                class="btn btn--primary btn--full btn--lg"
                id="ProductAddToCart"
                data-add-to-cart
                data-variant-id="{{ first_variant.id }}"
                data-qty="1"
                aria-label="Add {{ product.title | escape }} to cart">
                <span class="atc-btn-text">{{ atc_label | escape }} &mdash; {{ price | money }}</span>
              </button>
            {%- endif -%}
            {%- if show_buy_now -%}
              <a href="{{ routes.cart_url }}/{{ first_variant.id }}:1{{ fast_checkout_suffix }}"
                class="btn btn--ghost btn--full btn--lg product-fast-checkout"
                data-buy-now
                data-checkout-destination="{{ fast_checkout_destination }}"
                data-variant-id="{{ first_variant.id }}">
                {{ buy_label | escape }}
              </a>
            {%- endif -%}
            {%- if settings.conversion_microcopy != blank -%}
              <p class="product-cta-microcopy">{{ settings.conversion_microcopy | escape }}</p>
            {%- endif -%}
          {%- else -%}
            <button class="btn btn--primary btn--full btn--lg" disabled aria-disabled="true">Sold Out</button>
          {%- endif -%}
        </div>

        <!-- Benefits checklist -->
        {%- liquid
          assign benefit_1 = section.settings.benefit_1 | default: settings.product_benefit_1
          assign benefit_2 = section.settings.benefit_2 | default: settings.product_benefit_2
          assign benefit_3 = section.settings.benefit_3 | default: settings.product_benefit_3
          assign benefit_4 = section.settings.benefit_4 | default: settings.product_benefit_4
          assign has_benefits = false
        -%}
        {%- if benefit_1 != blank or benefit_2 != blank or benefit_3 != blank or benefit_4 != blank -%}
          {%- assign has_benefits = true -%}
        {%- endif -%}
        {%- if section.settings.show_benefits and has_benefits -%}
          <ul class="product-benefits" aria-label="Product benefits">
            {%- for i in (1..4) -%}
              {%- liquid
                assign benefit_text = blank
                case i
                  when 1
                    assign benefit_text = benefit_1
                  when 2
                    assign benefit_text = benefit_2
                  when 3
                    assign benefit_text = benefit_3
                  when 4
                    assign benefit_text = benefit_4
                endcase
              -%}
              {%- if benefit_text != blank -%}
                <li>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                    stroke="var(--color-primary)" stroke-width="2.5" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  {{ benefit_text | escape }}
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        <!-- Trust icons row -->
        {%- if section.settings.show_trust -%}
          <div class="product-trust" aria-label="Guarantees">
            <div class="product-trust-item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              <div>
                <strong>{{ section.settings.trust_1_title | default: settings.trust_returns_title | default: '14-Day Returns' }}</strong>
                <span>{{ section.settings.trust_1_sub | default: settings.trust_returns_sub | default: 'Easy returns' }}</span>
              </div>
            </div>
            <div class="product-trust-item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <div>
                <strong>{{ section.settings.trust_2_title | default: settings.trust_shipping_title | default: 'Fast Shipping' }}</strong>
                <span>{{ section.settings.trust_2_sub | default: settings.trust_shipping_sub | default: '7–10 days' }}</span>
              </div>
            </div>
            <div class="product-trust-item">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              <div>
                <strong>{{ section.settings.trust_3_title | default: settings.trust_secure_title | default: 'Secure Payment' }}</strong>
                <span>{{ section.settings.trust_3_sub | default: settings.trust_secure_sub | default: 'SSL protected' }}</span>
              </div>
            </div>
          </div>
        {%- endif -%}

        <!-- Payment icons -->
        {%- if section.settings.show_payment_icons -%}
          <div class="product-payment-icons">
            <span class="product-payment-icons__label">We accept:</span>
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <!-- Accordion tabs -->
        <div class="product-accordions">
          {%- if product.description != blank -%}
            <details class="product-accordion">
              <summary class="product-accordion__summary">
                {{ section.settings.tab_desc_label | default: 'Description' }}
                <svg class="product-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="product-accordion__body rte">{{ product.description }}</div>
            </details>
          {%- endif -%}

          {%- if section.settings.tab_shipping_content != blank -%}
            <details class="product-accordion">
              <summary class="product-accordion__summary">
                {{ section.settings.tab_shipping_label | default: 'Shipping & Returns' }}
                <svg class="product-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="product-accordion__body rte">{{ section.settings.tab_shipping_content }}</div>
            </details>
          {%- endif -%}

          {%- if section.settings.tab_policy_content != blank -%}
            <details class="product-accordion">
              <summary class="product-accordion__summary">
                {{ section.settings.tab_policy_label | default: 'Return Policy' }}
                <svg class="product-accordion__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="product-accordion__body rte">{{ section.settings.tab_policy_content }}</div>
            </details>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>
</section>

<style>
.product-page-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-12);
  align-items: start;
}
@media (max-width: 768px) {
  .product-page-grid { grid-template-columns: 1fr; gap: var(--space-8); }
}
.product-media-main {
  border-radius: var(--card-radius, var(--radius-xl));
  overflow: hidden;
  background: var(--color-surface);
  aspect-ratio: 1;
}
.product-media-main img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
}
.product-media-placeholder {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-surface);
  color: var(--color-text-muted);
}
.product-media-thumbs {
  display: flex;
  gap: var(--space-2);
  margin-top: var(--space-3);
  flex-wrap: wrap;
}
.product-media-thumb {
  width: 72px; height: 72px;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 2px solid transparent;
  transition: border-color var(--transition);
  flex-shrink: 0;
}
.product-media-thumb.is-active,
.product-media-thumb:hover { border-color: var(--color-text); }
.product-media-thumb img { width: 100%; height: 100%; object-fit: cover; }

.product-info { display: flex; flex-direction: column; gap: var(--space-4); }
.product-info--center { align-items: center; text-align: center; }
.product-info--right  { align-items: flex-end; text-align: right; }

.product-info__vendor {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.product-info__title {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 2.5vw, 2.25rem);
  font-weight: 700;
  line-height: 1.15;
  color: var(--color-text);
}
.product-info__sku {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}
.product-info__rating {
  display: flex;
  align-items: center;
  gap: var(--space-2);
}
.product-stars { display: flex; gap: 2px; }
.product-info__rating-count {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}
.product-info__price {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
}
.product-info__price-now {
  font-size: var(--text-xl);
  font-weight: 800;
  color: var(--color-text);
}
.product-info__price-now.is-sale { color: var(--color-sale); }
.product-info__price-was {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.product-option { margin-bottom: var(--space-4); }
.product-option__label {
  font-size: var(--text-sm);
  font-weight: 600;
  margin-bottom: var(--space-2);
  color: var(--color-text);
}
.product-option__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}
.option-swatch {
  padding: 8px 16px;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md);
  font-size: var(--text-sm);
  font-weight: 500;
  cursor: pointer;
  transition: border-color var(--transition), background var(--transition);
  color: var(--color-text);
  background: var(--color-bg);
}
.option-swatch.is-active {
  border-color: var(--color-text);
  background: var(--color-text);
  color: var(--color-bg);
}
.option-swatch:hover:not(.is-active) { border-color: var(--color-text-muted); }

.option-swatch--color {
  width: 36px;
  height: 36px;
  border-radius: var(--radius-full, 9999px);
  padding: 0;
  border: 3px solid transparent;
  background: var(--swatch-color, #ccc);
  transition: border-color var(--transition), transform var(--transition);
}
.option-swatch--color[style*="teal"]    { background: #009688; }
.option-swatch--color[style*="black"]   { background: #111111; }
.option-swatch--color[style*="gray"],
.option-swatch--color[style*="grey"]    { background: #9e9e9e; }
.option-swatch--color[style*="red"]     { background: #e53935; }
.option-swatch--color[style*="blue"]    { background: #1e88e5; }
.option-swatch--color[style*="green"]   { background: #43a047; }
.option-swatch--color[style*="white"]   { background: #f5f5f5; border: 3px solid #e5e5e5; }
.option-swatch--color[style*="orange"]  { background: #fb8c00; }

.option-swatch--color.is-active {
  border-color: var(--color-text);
  transform: scale(1.1);
  background: var(--swatch-color, #ccc);
}
.option-swatch--color:hover:not(.is-active) {
  border-color: var(--color-text-muted);
}

.product-qty-row {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-bottom: var(--space-3);
}
.product-qty {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.product-qty__btn {
  width: 40px; height: 44px;
  font-size: 1.2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text);
  transition: background var(--transition);
}
.product-qty__btn:hover { background: var(--color-surface); }
.product-qty__val {
  width: 52px;
  height: 44px;
  text-align: center;
  font-size: var(--text-sm);
  font-weight: 700;
  border: none;
  border-left: 1.5px solid var(--color-border);
  border-right: 1.5px solid var(--color-border);
  background: transparent;
  color: var(--color-text);
  -moz-appearance: textfield;
}
.product-qty__val::-webkit-outer-spin-button,
.product-qty__val::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.product-stock-label {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  font-weight: 500;
}

.product-add-to-cart { display: flex; flex-direction: column; gap: var(--space-2); }
.product-cta-microcopy {
  margin: 2px 0 0;
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 700;
  line-height: 1.45;
  text-align: center;
}

.product-benefits {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding: var(--space-4);
  background: var(--color-surface);
  border-radius: var(--radius-md);
}
.product-benefits li {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--color-text);
}

.product-trust {
  display: flex;
  gap: var(--space-4);
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-border);
}
.product-trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-1);
  flex: 1;
  color: var(--color-text-muted);
}
.product-trust-item strong {
  font-size: var(--text-xs);
  font-weight: 700;
  color: var(--color-text);
  display: block;
}
.product-trust-item span {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}

.product-payment-icons {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-2);
}
.product-payment-icons__label {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-right: var(--space-1);
}
.payment-icon { height: 22px; width: auto; border-radius: 3px; }

.product-accordions { border-top: 1px solid var(--color-border); margin-top: var(--space-4); }
.product-accordion {
  border-bottom: 1px solid var(--color-border);
}
.product-accordion__summary {
  list-style: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-4) 0;
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
  cursor: pointer;
  user-select: none;
}
.product-accordion__summary::-webkit-details-marker { display: none; }
.product-accordion__chevron {
  flex-shrink: 0;
  transition: transform var(--transition);
}
.product-accordion[open] .product-accordion__chevron { transform: rotate(180deg); }
.product-accordion__body {
  padding-bottom: var(--space-5);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  line-height: 1.7;
}
.product-accordion__body p { max-width: 100%; }

@media (max-width: 480px) {
  .product-trust { flex-direction: column; align-items: flex-start; text-align: left; }
  .product-trust-item { flex-direction: row; text-align: left; }
}
</style>



<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "url": {{ shop.url | append: product.url | json }},
  "image": [{{ product.featured_image | image_url: width: 1200 | json }}],
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price | money_without_currency }}",
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "url": {{ shop.url | append: product.url | json }},
    "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31"
  }
  {%- if product.metafields.reviews.rating.value != blank -%}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.reviews.rating.value }}",
    "reviewCount": "{{ product.metafields.reviews.rating_count.value | default: 1 }}"
  }
  {%- endif -%}
}
</script>

