
<section class="hero" style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="hero-grid">

      <div class="hero-left" style="background:{{ section.settings.hero_bg_color }};">
        {%- if section.settings.hero_bg_image != blank -%}
          <img class="hero-left-bg"
               src="{{ section.settings.hero_bg_image | image_url: width: 1200 }}"
               alt=""
               width="1200" height="700"
               loading="eager">
        {%- endif -%}
        <div class="hero-content">
          {%- if section.settings.tag != blank -%}
            <div class="hero-tag">{{ section.settings.tag }}</div>
          {%- endif -%}
          <h1>
            {{ section.settings.heading }}
            {%- if section.settings.heading_highlight != blank -%}
              <em>{{ section.settings.heading_highlight }}</em>
            {%- endif -%}
          </h1>
          <p class="hero-sub">{{ section.settings.subheading }}</p>
          <div class="hero-ctas">
            {%- if section.settings.btn1_label != blank -%}
              <a class="btn btn-white" href="{{ section.settings.btn1_url }}" data-track="hero_cta_primary">
                {{ section.settings.btn1_label }}
              </a>
            {%- endif -%}
            {%- if section.settings.btn2_label != blank -%}
              <a class="btn btn-outline-white" href="{{ section.settings.btn2_url }}" data-track="hero_cta_secondary">
                {{ section.settings.btn2_label }}
              </a>
            {%- endif -%}
          </div>
        </div>
        <div class="hero-trust">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_item' -%}
              <div class="hero-trust-item" {{ block.shopify_attributes }}>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
                {{ block.settings.text }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="hero-right">
        {%- for block in section.blocks -%}
          {%- if block.type == 'hero_card' -%}
            <a class="hero-card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <img src="{{ block.settings.image | image_url: width: 800 }}"
                     alt="{{ block.settings.title | escape }}"
                     width="800" height="500"
                     loading="lazy">
              {%- else -%}
                <div style="width:100%;height:100%;background:var(--surface-alt);min-height:200px;"></div>
              {%- endif -%}
              <div class="hero-card-overlay"></div>
              <div class="hero-card-content">
                <div class="hero-card-title">{{ block.settings.title }}</div>
                <div class="hero-card-sub">{{ block.settings.subtitle }}</div>
                <span class="hero-card-pill">{{ block.settings.cta }} →</span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "tag", "label": "Tag / eyebrow text", "default": "✦ New arrivals just dropped" },
    { "type": "textarea", "id": "heading", "label": "Heading line 1", "default": "Style that speaks," },
    { "type": "text", "id": "heading_highlight", "label": "Heading highlighted line (accent color)", "default": "for every occasion." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Women's fashion, men's essentials, fine jewelry, pet toys & home decor — curated for modern American life." },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "btn1_label", "label": "Primary button label", "default": "Shop Best Sellers" },
    { "type": "url", "id": "btn1_url", "label": "Primary button URL" },
    { "type": "text", "id": "btn2_label", "label": "Secondary button label", "default": "View New Arrivals" },
    { "type": "url", "id": "btn2_url", "label": "Secondary button URL" },
    { "type": "header", "content": "Design" },
    { "type": "image_picker", "id": "hero_bg_image", "label": "Background image" },
    { "type": "color", "id": "hero_bg_color", "label": "Background color", "default": "#111111" },
    { "type": "range", "id": "padding_top", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 40 }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Free U.S. shipping $75+" }
      ]
    },
    {
      "type": "hero_card",
      "name": "Hero card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Women's Fashion" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "New season styles" },
        { "type": "text", "id": "cta", "label": "CTA text", "default": "Shop Now" },
        { "type": "url", "id": "url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "Free U.S. shipping $75+" } },
        { "type": "trust_item", "settings": { "text": "30-day easy returns" } },
        { "type": "trust_item", "settings": { "text": "Secure checkout" } },
        { "type": "hero_card", "settings": { "title": "Women's Fashion", "subtitle": "New season styles", "cta": "Shop Now" } },
        { "type": "hero_card", "settings": { "title": "Men's Essentials", "subtitle": "Clean, sharp looks", "cta": "Shop Now" } }
      ]
    }
  ]
}
{% endschema %}
