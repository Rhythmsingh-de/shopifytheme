<section class="lifestyle-banner reveal" style="position:relative;overflow:hidden;min-height:{{ section.settings.height | default: '500px' }}">
  {%- if section.settings.image != blank -%}
    <img src="{{ section.settings.image | image_url: width: 2000 }}"
         alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
         width="2000" height="800"
         loading="lazy" decoding="async"
         style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.focal_point | default: 'center' }}">
  {%- else -%}
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,var(--color-deep) 0%,#0a1a0e 100%)"></div>
  {%- endif -%}
  <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.55 }}) 0%,rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.25 }}) 100%)"></div>
  <div class="container" style="position:relative;z-index:1;display:flex;align-items:{{ section.settings.content_position | default: 'center' }};min-height:{{ section.settings.height | default: '500px' }};padding-block:var(--sp-16)">
    <div style="max-width:600px;{% if section.settings.align == 'center' %}margin:0 auto;text-align:center;{% elsif section.settings.align == 'right' %}margin-left:auto;text-align:right;{% endif %}">
      {%- if section.settings.eyebrow != blank -%}
        <p style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-accent-lite);margin-bottom:var(--sp-3)">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3.5rem);font-weight:800;color:#fff;line-height:1.15;margin-bottom:var(--sp-4)">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p style="font-size:var(--text-lg);color:rgba(255,255,255,0.82);margin-bottom:var(--sp-8);max-width:48ch">{{ section.settings.subheading }}</p>
      {%- endif -%}
      <div style="display:flex;flex-wrap:wrap;gap:var(--sp-3);{% if section.settings.align == 'center' %}justify-content:center;{% elsif section.settings.align == 'right' %}justify-content:flex-end;{% endif %}">
        {%- if section.settings.cta1_text != blank -%}
          <a href="{{ section.settings.cta1_url | default: '/collections/all' }}" class="btn btn--primary btn--lg">{{ section.settings.cta1_text }}</a>
        {%- endif -%}
        {%- if section.settings.cta2_text != blank -%}
          <a href="{{ section.settings.cta2_url | default: '/collections/all' }}" class="btn btn--outline-white btn--lg">{{ section.settings.cta2_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Lifestyle Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image",           "label": "Background image" },
    { "type": "select",       "id": "focal_point",     "label": "Image focal point", "options": [{"value":"center","label":"Center"},{"value":"top","label":"Top"},{"value":"bottom","label":"Bottom"},{"value":"left","label":"Left"},{"value":"right","label":"Right"}], "default": "center" },
    { "type": "range",        "id": "overlay_opacity", "label": "Overlay darkness", "min": 0.1, "max": 0.85, "step": 0.05, "default": 0.55 },
    { "type": "text",         "id": "height",          "label": "Section min height (px)", "default": "520px" },
    { "type": "select",       "id": "align",           "label": "Content alignment", "options": [{"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}], "default": "left" },
    { "type": "text",         "id": "eyebrow",         "label": "Eyebrow",           "default": "Premium Lifestyle" },
    { "type": "text",         "id": "heading",         "label": "Heading",           "default": "Elevate Every Moment" },
    { "type": "textarea",     "id": "subheading",      "label": "Subheading",        "default": "From self-care rituals to luxury home essentials — crafted for the life you deserve." },
    { "type": "text",         "id": "cta1_text",       "label": "Primary CTA text",  "default": "Shop Collection" },
    { "type": "url",          "id": "cta1_url",        "label": "Primary CTA link" },
    { "type": "text",         "id": "cta2_text",       "label": "Secondary CTA text","default": "Learn More" },
    { "type": "url",          "id": "cta2_url",        "label": "Secondary CTA link" }
  ],
  "presets": [{ "name": "Lifestyle Banner" }]
}
{% endschema %}
