<section class="section contact-form-section" id="contact">
  <div class="container" style="max-width:800px">
    <div class="section-head reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title | default: "Get In Touch" }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div style="display:grid;grid-template-columns:{% if section.settings.show_info %}1fr 1fr{% else %}1fr{% endif %};gap:clamp(var(--sp-8),4vw,var(--sp-16));align-items:start" class="contact-layout">
      <div class="reveal">
        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div style="background:var(--color-success-bg,#d4edda);border:1px solid var(--color-success,#437a22);border-radius:var(--radius-md);padding:var(--sp-4);margin-bottom:var(--sp-6);color:var(--color-success,#437a22);font-weight:600">
              ✓ Thank you! We'll be in touch within 24 hours.
            </div>
          {%- endif -%}
          {%- if form.errors -%}
            <div style="background:#fde8e8;border:1px solid var(--color-error);border-radius:var(--radius-md);padding:var(--sp-4);margin-bottom:var(--sp-6);color:var(--color-error)">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}
          <div style="display:flex;flex-direction:column;gap:var(--sp-4)">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-4)">
              <div class="form-group">
                <label class="form-label" for="ContactFormName">Name</label>
                <input type="text" id="ContactFormName" name="contact[name]" value="{{ form.name }}" class="form-input" placeholder="{{ section.settings.name_placeholder | default: 'Your name' }}" autocomplete="name">
              </div>
              <div class="form-group">
                <label class="form-label" for="ContactFormEmail">Email <span style="color:var(--color-error)">*</span></label>
                <input type="email" id="ContactFormEmail" name="contact[email]" value="{{ form.email }}" class="form-input" placeholder="{{ section.settings.email_placeholder | default: 'your@email.com' }}" required autocomplete="email">
              </div>
            </div>
            <div class="form-group">
              <label class="form-label" for="ContactFormSubject">Subject</label>
              <select id="ContactFormSubject" name="contact[subject]" class="form-input">
                {%- for block in section.blocks -%}
                  {%- if block.type == 'subject' -%}
                    <option value="{{ block.settings.value }}">{{ block.settings.label }}</option>
                  {%- endif -%}
                {%- else -%}
                  <option value="General Inquiry">General Inquiry</option>
                  <option value="Order Support">Order Support</option>
                  <option value="Returns &amp; Refunds">Returns &amp; Refunds</option>
                  <option value="Product Question">Product Question</option>
                  <option value="Other">Other</option>
                {%- endfor -%}
              </select>
            </div>
            <div class="form-group">
              <label class="form-label" for="ContactFormMessage">Message <span style="color:var(--color-error)">*</span></label>
              <textarea id="ContactFormMessage" name="contact[body]" rows="{{ section.settings.rows | default: 5 }}" class="form-input" placeholder="{{ section.settings.message_placeholder | default: 'How can we help you?' }}" required style="resize:vertical">{{ form.body }}</textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              {{ section.settings.button_text | default: "Send Message" }}
            </button>
          </div>
        {%- endform -%}
      </div>

      {%- if section.settings.show_info -%}
        <div class="contact-info reveal" style="display:flex;flex-direction:column;gap:var(--sp-6)">
          {%- if section.settings.info_heading != blank -%}
            <h3 style="font-family:var(--font-display);font-size:var(--text-lg);font-weight:700">{{ section.settings.info_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.info_text != blank -%}
            <p style="color:var(--color-text-muted);line-height:1.7">{{ section.settings.info_text }}</p>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <div style="display:flex;gap:var(--sp-3);align-items:flex-start">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" style="flex-shrink:0;margin-top:2px" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <div>
                <p style="font-weight:600;font-size:var(--text-sm)">Email Us</p>
                <a href="mailto:{{ section.settings.email }}" style="color:var(--color-primary);font-size:var(--text-sm)">{{ section.settings.email }}</a>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.response_time != blank -%}
            <div style="display:flex;gap:var(--sp-3);align-items:flex-start">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" style="flex-shrink:0;margin-top:2px" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <div>
                <p style="font-weight:600;font-size:var(--text-sm)">Response Time</p>
                <p style="color:var(--color-text-muted);font-size:var(--text-sm)">{{ section.settings.response_time }}</p>
              </div>
            </div>
          {%- endif -%}
          {%- if section.settings.show_trading_name == false -%}
            {%- comment -%} Trading details hidden per store owner preference — share only on request {%- endcomment -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>
<style>
@media (max-width:767px) {
  .contact-layout { grid-template-columns: 1fr !important; }
}
</style>
{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    { "type": "text",     "id": "eyebrow",           "label": "Eyebrow",              "default": "Support" },
    { "type": "text",     "id": "title",             "label": "Title",                "default": "Get In Touch" },
    { "type": "textarea", "id": "subtitle",          "label": "Subtitle",             "default": "We're here to help. Send us a message and we'll respond within 24 hours." },
    { "type": "text",     "id": "button_text",       "label": "Button text",          "default": "Send Message" },
    { "type": "range",    "id": "rows",              "label": "Textarea rows",        "min": 3, "max": 10, "step": 1, "default": 5 },
    { "type": "text",     "id": "name_placeholder",  "label": "Name placeholder",     "default": "Your full name" },
    { "type": "text",     "id": "email_placeholder", "label": "Email placeholder",    "default": "your@email.com" },
    { "type": "text",     "id": "message_placeholder","label": "Message placeholder", "default": "How can we help you today?" },
    { "type": "header",   "content": "Contact Info Panel" },
    { "type": "checkbox", "id": "show_info",         "label": "Show contact info",    "default": true },
    { "type": "text",     "id": "info_heading",      "label": "Info heading",         "default": "We'd Love to Hear From You" },
    { "type": "textarea", "id": "info_text",         "label": "Info body text",       "default": "Questions about your order, products, or anything else? Our customer happiness team is standing by." },
    { "type": "text",     "id": "email",             "label": "Contact email",        "default": "info@bodyluxcare.com" },
    { "type": "text",     "id": "response_time",     "label": "Response time text",   "default": "Within 24 hours, Monday – Friday" },
    { "type": "checkbox", "id": "show_trading_name", "label": "Show trading/address details", "default": false }
  ],
  "blocks": [{ "type": "subject", "name": "Subject Option", "settings": [
    { "type": "text", "id": "label", "label": "Option label", "default": "General Inquiry" },
    { "type": "text", "id": "value", "label": "Option value", "default": "General Inquiry" }
  ]}],
  "presets": [{ "name": "Contact Form" }]
}
{% endschema %}
