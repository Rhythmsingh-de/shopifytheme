{%- style -%}
  #ContactSection-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #ContactSection-{{ section.id }} .contact-container {
    max-width: {{ section.settings.max_width }}px;
  }
{%- endstyle -%}

<section class="section contact-form-section" id="ContactSection-{{ section.id }}">
  <div class="container contact-container">
    
    <div class="section-head reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="section-title">{{ section.settings.title | default: "Get In Touch" }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="section-subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
      {%- if page.content != blank -%}
        <div class="contact-page-content rte">
          {{ page.content }}
        </div>
      {%- endif -%}
    </div>

    <div class="contact-layout {% if section.settings.show_info %}contact-layout--split{% endif %}">
      
      <div class="contact-form__card reveal">
        {%- form 'contact', id: 'ContactForm' -%}
          {%- if form.posted_successfully? -%}
            <div class="contact-form__alert contact-form__alert--success">
              ✓ Thank you! We'll respond within 24 hours.
            </div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="contact-form__alert contact-form__alert--error">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="contact-form__fields">
            <div class="contact-form__row">
              <div class="form-field">
                <input 
                  type="text" 
                  id="ContactFormName" 
                  name="contact[name]" 
                  value="{{ form.name }}" 
                  class="form-input" 
                  placeholder=" " 
                  autocomplete="name">
                <label class="form-label" for="ContactFormName">Name</label>
              </div>

              <div class="form-field">
                <input 
                  type="email" 
                  id="ContactFormEmail" 
                  name="contact[email]" 
                  value="{{ form.email }}" 
                  class="form-input" 
                  placeholder=" " 
                  required 
                  autocomplete="email">
                <label class="form-label" for="ContactFormEmail">Email <span class="required">*</span></label>
              </div>
            </div>

            <div class="form-field form-field--select">
              <label class="form-label form-label--static" for="ContactFormSubject">Subject</label>
              <select id="ContactFormSubject" name="contact[subject]" class="form-input" required>
                {%- for block in section.blocks -%}
                  {%- if block.type == 'subject' -%}
                    <option value="{{ block.settings.value }}">{{ block.settings.label }}</option>
                  {%- endif -%}
                {%- else -%}
                  <option value="General Inquiry">General Inquiry</option>
                  <option value="Order Support">Order Support</option>
                  <option value="Returns &amp; Refunds">Returns &amp; Refunds</option>
                  <option value="Product Question">Product Question</option>
                  <option value="Other">Other</option>
                {%- endfor -%}
              </select>
              <div class="select-chevron">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>

            <div class="form-field">
              <textarea 
                id="ContactFormMessage" 
                name="contact[body]" 
                rows="{{ section.settings.rows | default: 5 }}" 
                class="form-input" 
                placeholder=" " 
                required>{{ form.body }}</textarea>
              <label class="form-label" for="ContactFormMessage">Message <span class="required">*</span></label>
            </div>

            <button type="submit" class="btn btn--primary btn--full contact-form__submit">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="margin-right: var(--sp-2);"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              {{ section.settings.button_text | default: "Send Message" }}
            </button>
          </div>
        {%- endform -%}
      </div>

      {%- if section.settings.show_info -%}
        <div class="contact-info reveal">
          {%- if section.settings.info_heading != blank -%}
            <h3 class="contact-info__heading">{{ section.settings.info_heading }}</h3>
          {%- endif -%}
          {%- if section.settings.info_text != blank -%}
            <p class="contact-info__text">{{ section.settings.info_text }}</p>
          {%- endif -%}
          
          <div class="contact-info__items">
            {%- if section.settings.email != blank -%}
              <div class="contact-info__item">
                <div class="contact-info__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div class="contact-info__content">
                  <p class="contact-info__label">Email Us</p>
                  <a href="mailto:{{ section.settings.email }}" class="contact-info__link">{{ section.settings.email }}</a>
                </div>
              </div>
            {%- endif -%}

            {%- if section.settings.response_time != blank -%}
              <div class="contact-info__item">
                <div class="contact-info__icon">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div class="contact-info__content">
                  <p class="contact-info__label">Response Time</p>
                  <p class="contact-info__val">{{ section.settings.response_time }}</p>
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
.section-eyebrow {
  display: inline-block;
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--color-deco, #1d6b44);
  margin-bottom: var(--sp-3);
}
.section-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 900;
  letter-spacing: -.03em;
  color: var(--color-text);
  line-height: 1.1;
}
.section-subtitle {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  margin-top: var(--sp-3);
  max-width: 60ch;
  line-height: 1.65;
}
.section-head {
  margin-bottom: clamp(var(--sp-6), 4vw, var(--sp-10));
}

.contact-container {
  max-width: 900px;
  margin: 0 auto;
}
.contact-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(var(--sp-6), 4vw, var(--sp-12));
  align-items: start;
}
.contact-layout--split {
  grid-template-columns: 1.2fr 0.8fr;
}

@media (max-width: 768px) {
  .contact-layout--split {
    grid-template-columns: 1fr;
  }
}

/* Glassmorphism Card Style */
.contact-form__card {
  background: var(--color-surface, #ffffff);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-lg, 16px);
  padding: clamp(var(--sp-6), 4vw, var(--sp-10));
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
}

.contact-form__fields {
  display: flex;
  flex-direction: column;
  gap: var(--sp-6);
}

.contact-form__row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-5);
}

@media (max-width: 480px) {
  .contact-form__row {
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }
}

/* Floating Label Animation style */
.form-field {
  position: relative;
  width: 100%;
}

.form-field .form-input {
  width: 100%;
  padding: 22px 16px 6px;
  font-size: var(--text-base);
  font-family: inherit;
  background: var(--color-surface, #ffffff);
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md, 8px);
  color: var(--color-text);
  outline: none;
  height: 52px;
  transition: border-color var(--trans-base), box-shadow var(--trans-base);
  -webkit-appearance: none;
  appearance: none;
}

.form-field textarea.form-input {
  height: auto;
  resize: vertical;
  min-height: 140px;
  padding-top: 22px;
}

.form-field .form-input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(0,0,0,0.03);
}

.form-field .form-label {
  position: absolute;
  left: 16px;
  top: 50%;
  transform: translateY(-50%);
  font-size: var(--text-base);
  color: var(--color-text-muted);
  pointer-events: none;
  transition: transform 0.2s ease, top 0.2s ease, font-size 0.2s ease, color 0.2s ease;
  transform-origin: left;
}

.form-field textarea.form-input ~ .form-label {
  top: 24px;
}

/* Float behavior */
.form-field .form-input:focus ~ .form-label,
.form-field .form-input:not(:placeholder-shown) ~ .form-label {
  top: 10px;
  transform: translateY(0) scale(0.75);
  color: var(--color-primary);
}

/* Select overrides */
.form-field--select {
  cursor: pointer;
  display: flex;
  flex-direction: column;
}
.form-field--select .form-input {
  padding: 14px 16px;
  padding-right: 40px;
  height: 52px;
}
.form-field .form-label--static {
  position: static;
  transform: none;
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-muted);
  margin-bottom: 6px;
  pointer-events: auto;
}
.select-chevron {
  position: absolute;
  right: 16px;
  bottom: 19px;
  pointer-events: none;
  color: var(--color-text-muted);
  display: flex;
  align-items: center;
}

.required {
  color: var(--color-sale, #e8260d);
  margin-left: 2px;
}

.contact-form__submit {
  min-height: 48px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-radius: var(--btn-radius);
  transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
}
.contact-form__submit:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}
.contact-page-content {
  margin-top: var(--sp-4);
  line-height: 1.8;
  color: var(--color-text-muted);
  font-size: var(--text-base);
}

/* Success / Error Alerts */
.contact-form__alert {
  border-radius: var(--radius-md, 8px);
  padding: var(--sp-4);
  margin-bottom: var(--sp-2);
  font-size: var(--text-sm);
  font-weight: 600;
}
.contact-form__alert--success {
  background: var(--color-deco-light, #e6f4ed);
  border: 1.5px solid var(--color-deco, #1d6b44);
  color: var(--color-deco, #1d6b44);
}
.contact-form__alert--error {
  background: var(--color-sale-bg, #ffeeed);
  border: 1.5px solid var(--color-sale, #e8260d);
  color: var(--color-sale, #e8260d);
}

/* Contact Info Column styles */
.contact-info {
  display: flex;
  flex-direction: column;
  gap: var(--sp-6);
  padding: var(--sp-4) 0;
}
.contact-info__heading {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  color: var(--color-text);
}
.contact-info__text {
  color: var(--color-text-muted);
  line-height: 1.7;
  font-size: var(--text-base);
}
.contact-info__items {
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
}
.contact-info__item {
  display: flex;
  gap: var(--sp-3);
  align-items: flex-start;
}
.contact-info__icon {
  flex-shrink: 0;
  color: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: var(--radius-md, 8px);
  background: var(--color-surface, #f9f9f9);
  border: 1px solid var(--color-border);
}
.contact-info__content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.contact-info__label {
  font-weight: 700;
  font-size: var(--text-xs);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-muted);
}
.contact-info__link {
  color: var(--color-primary);
  font-weight: 600;
  font-size: var(--text-sm);
  text-decoration: none;
  transition: color var(--trans-base);
}
.contact-info__link:hover {
  text-decoration: underline;
}
.contact-info__val {
  color: var(--color-text);
  font-weight: 500;
  font-size: var(--text-sm);
}
</style>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    { "type": "text",     "id": "eyebrow",           "label": "Eyebrow",              "default": "Support" },
    { "type": "text",     "id": "title",             "label": "Title",                "default": "Get In Touch" },
    { "type": "textarea", "id": "subtitle",          "label": "Subtitle",             "default": "We're here to help. Send us a message and we'll respond within 24 hours." },
    { "type": "text",     "id": "button_text",       "label": "Button text",          "default": "Send Message" },
    { "type": "range",    "id": "rows",              "label": "Textarea rows",        "min": 3, "max": 10, "step": 1, "default": 5 },
    { "type": "text",     "id": "name_placeholder",  "label": "Name placeholder",     "default": "Your full name" },
    { "type": "text",     "id": "email_placeholder", "label": "Email placeholder",    "default": "your@email.com" },
    { "type": "text",     "id": "message_placeholder","label": "Message placeholder", "default": "How can we help you today?" },
    { "type": "header",   "content": "Contact Info Panel" },
    { "type": "checkbox", "id": "show_info",         "label": "Show contact info",    "default": true },
    { "type": "text",     "id": "info_heading",      "label": "Info heading",         "default": "We'd Love to Hear From You" },
    { "type": "textarea", "id": "info_text",         "label": "Info body text",       "default": "Questions about your order, products, or anything else? Our customer happiness team is standing by." },
    { "type": "text",     "id": "email",             "label": "Contact email",        "default": "info@bodyluxcare.com" },
    { "type": "text",     "id": "response_time",     "label": "Response time text",   "default": "Within 24 hours, Monday – Friday" },
    { "type": "checkbox", "id": "show_trading_name", "label": "Show trading/address details", "default": false },
    { "type": "header",   "content": "Section Spacing & Styles" },
    { "type": "range",    "id": "padding_top",       "label": "Padding Top",          "min": 0, "max": 120, "step": 4, "default": 60, "unit": "px" },
    { "type": "range",    "id": "padding_bottom",    "label": "Padding Bottom",       "min": 0, "max": 120, "step": 4, "default": 60, "unit": "px" },
    { "type": "range",    "id": "max_width",         "label": "Container Max Width",  "min": 600, "max": 1200, "step": 50, "default": 900, "unit": "px" }
  ],
  "blocks": [{ "type": "subject", "name": "Subject Option", "settings": [
    { "type": "text", "id": "label", "label": "Option label", "default": "General Inquiry" },
    { "type": "text", "id": "value", "label": "Option value", "default": "General Inquiry" }
  ]}],
  "presets": [{ "name": "Contact Form" }]
}
{% endschema %}
