<section class="section email-capture-section" style="background:{{ section.settings.bg_color | default: 'var(--color-text)' }};color:{{ section.settings.text_color | default: 'var(--color-text-inverse)' }};padding-top:{{ section.settings.padding_top | default: 80 }}px;padding-bottom:{{ section.settings.padding_bottom | default: 80 }}px;">
  <div class="container" style="max-width:680px;text-align:center">
    {%- if section.settings.eyebrow != blank -%}
      <p style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-accent-lite, #ffeed2);margin-bottom:var(--sp-3)" class="reveal">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 style="font-family:var(--font-display);font-size:clamp(1.6rem,4vw,2.5rem);font-weight:800;color:var(--color-text-inverse);line-height:1.2;margin-bottom:var(--sp-3)" class="reveal">{{ section.settings.title | default: "Get 10% Off Your First Order" }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p style="color:rgba(255,255,255,0.82);margin-bottom:var(--sp-6);font-size:var(--text-base)" class="reveal">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <form class="email-form reveal" method="post" action="/contact#newsletter" accept-charset="UTF-8" novalidate>
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <div class="email-form__wrap">
        <label for="email-capture-input" class="sr-only">Email address</label>
        <input type="email" id="email-capture-input" name="contact[email]" placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}" class="email-form__input" required autocomplete="email">
        <button type="submit" class="btn btn--primary">
          {{ section.settings.button_text | default: "Get My Discount" }}
        </button>
      </div>
      <p id="email-capture-msg" style="margin-top:var(--sp-3);font-size:var(--text-sm);min-height:1.5em;color:rgba(255,255,255,0.78)"></p>
    </form>
    {%- if section.settings.disclaimer != blank -%}
      <p style="font-size:var(--text-xs);color:rgba(255,255,255,0.55);margin-top:var(--sp-4)" class="reveal">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>
<style>
.email-form__wrap {
  display:flex;gap:var(--sp-2);flex-wrap:wrap;justify-content:center;
}
.email-form__input {
  flex:1;min-width:220px;max-width:340px;
  height:52px;padding:0 var(--sp-4);
  border:2px solid rgba(255,255,255,0.2);
  border-radius:var(--radius-full);
  background:rgba(255,255,255,0.08);
  color:var(--color-text-inverse);font-size:var(--text-base);
  transition:border-color var(--trans-fast),background var(--trans-fast);
}
.email-form__input::placeholder { color:rgba(255,255,255,0.6); }
.email-form__input:focus {
  outline:none;border-color:var(--color-accent, var(--color-primary));
  background:rgba(255,255,255,0.16);
}
</style>
{% schema %}
{
  "name": "Email Capture",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow",          "default": "Exclusive Offer" },
    { "type": "text",     "id": "title",        "label": "Heading",          "default": "Get 10% Off Your First Order" },
    { "type": "textarea", "id": "subtitle",     "label": "Subtitle",         "default": "Join the BodyLuxCare family and be the first to hear about new arrivals, exclusive deals, and wellness tips." },
    { "type": "text",     "id": "placeholder",  "label": "Input placeholder","default": "Enter your email address" },
    { "type": "text",     "id": "button_text",  "label": "Button text",      "default": "Claim My 10% Off" },
    { "type": "text",     "id": "disclaimer",   "label": "Disclaimer text",  "default": "No spam ever. Unsubscribe anytime. By subscribing you agree to our Privacy Policy." },
    { "type": "header",   "content": "Design Customization" },
    { "type": "color",    "id": "bg_color",     "label": "Background color", "default": "#1a1a1a" },
    { "type": "color",    "id": "text_color",   "label": "Text color",       "default": "#ffffff" },
    { "type": "range",    "id": "padding_top",  "label": "Padding Top",      "min": 20, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "range",    "id": "padding_bottom","label": "Padding Bottom",   "min": 20, "max": 120, "step": 4, "default": 80, "unit": "px" }
  ],
  "presets": [{ "name": "Email Capture" }]
}
{% endschema %}
