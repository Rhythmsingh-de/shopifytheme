<section class="section email-capture-section" style="background:var(--color-deep);color:#fff">
  <div class="container" style="max-width:680px;text-align:center">
    {%- if section.settings.eyebrow != blank -%}
      <p style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--color-accent-lite);margin-bottom:var(--sp-3)" class="reveal">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 style="font-family:var(--font-display);font-size:clamp(1.6rem,4vw,2.5rem);font-weight:800;color:#fff;line-height:1.2;margin-bottom:var(--sp-3)" class="reveal">{{ section.settings.title | default: "Get 10% Off Your First Order" }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p style="color:rgba(255,255,255,0.72);margin-bottom:var(--sp-6);font-size:var(--text-base)" class="reveal">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    <form class="email-form reveal" onsubmit="BLC.handleEmailCapture(event,this)" novalidate>
      <div class="email-form__wrap">
        <label for="email-capture-input" class="sr-only">Email address</label>
        <input type="email" id="email-capture-input" name="email" placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}" class="email-form__input" required autocomplete="email">
        <button type="submit" class="btn btn--primary">
          {{ section.settings.button_text | default: "Get My Discount" }}
        </button>
      </div>
      <p id="email-capture-msg" style="margin-top:var(--sp-3);font-size:var(--text-sm);min-height:1.5em"></p>
    </form>
    {%- if section.settings.disclaimer != blank -%}
      <p style="font-size:var(--text-xs);color:rgba(255,255,255,0.45);margin-top:var(--sp-4)" class="reveal">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>
<style>
.email-form__wrap {
  display:flex;gap:var(--sp-2);flex-wrap:wrap;justify-content:center;
}
.email-form__input {
  flex:1;min-width:220px;max-width:340px;
  height:52px;padding:0 var(--sp-4);
  border:2px solid rgba(255,255,255,0.2);
  border-radius:var(--radius-full);
  background:rgba(255,255,255,0.1);
  color:#fff;font-size:var(--text-base);
  transition:border-color var(--trans-fast),background var(--trans-fast);
}
.email-form__input::placeholder { color:rgba(255,255,255,0.5); }
.email-form__input:focus {
  outline:none;border-color:var(--color-accent);
  background:rgba(255,255,255,0.18);
}
</style>
{% schema %}
{
  "name": "Email Capture",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",      "label": "Eyebrow",          "default": "Exclusive Offer" },
    { "type": "text",     "id": "title",        "label": "Heading",          "default": "Get 10% Off Your First Order" },
    { "type": "textarea", "id": "subtitle",     "label": "Subtitle",         "default": "Join the BodyLuxCare family and be the first to hear about new arrivals, exclusive deals, and wellness tips." },
    { "type": "text",     "id": "placeholder",  "label": "Input placeholder","default": "Enter your email address" },
    { "type": "text",     "id": "button_text",  "label": "Button text",      "default": "Claim My 10% Off" },
    { "type": "text",     "id": "disclaimer",   "label": "Disclaimer text",  "default": "No spam ever. Unsubscribe anytime. By subscribing you agree to our Privacy Policy." }
  ],
  "presets": [{ "name": "Email Capture" }]
}
{% endschema %}
