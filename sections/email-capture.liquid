<section class="section email-capture-section" 
  style="
    background: {{ section.settings.bg_color | default: 'var(--color-surface)' }};
    color: {{ section.settings.text_color | default: 'var(--color-text)' }};
    padding-top: {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  ">
  <div class="container" style="max-width: {{ section.settings.max_width | default: 680 }}px; text-align: center;">
    
    {%- if section.settings.eyebrow != blank -%}
      <p class="email-capture__eyebrow reveal" style="color: {{ section.settings.accent_color | default: 'var(--color-primary)' }}">
        {{ section.settings.eyebrow }}
      </p>
    {%- endif -%}

    <h2 class="email-capture__heading reveal">
      {{ section.settings.title | default: "Get 10% Off Your First Order" }}
    </h2>

    {%- if section.settings.subtitle != blank -%}
      <p class="email-capture__subtitle reveal">
        {{ section.settings.subtitle }}
      </p>
    {%- endif -%}

    {%- form 'customer', id: 'EmailCaptureForm', class: 'email-form reveal' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      
      <div class="email-form__wrap">
        <label for="EmailCaptureInput" class="sr-only">Email address</label>
        <input 
          type="email" 
          id="EmailCaptureInput" 
          name="contact[email]" 
          placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}" 
          class="email-form__input" 
          value="{{ customer.email }}"
          required 
          autocomplete="email"
          aria-required="true"
        >
        <button type="submit" class="btn btn--primary email-form__submit">
          {{ section.settings.button_text | default: "Get My Discount" }}
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <div class="email-capture-msg success">
          ✓ {{ section.settings.success_message | default: "Thank you! Check your inbox for a discount code." }}
        </div>
      {%- elsif form.errors -%}
        <div class="email-capture-msg error">
          {{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}
        </div>
      {%- endif -%}
    {%- endform -%}

    {%- if section.settings.disclaimer != blank -%}
      <p class="email-capture__disclaimer reveal">
        {{ section.settings.disclaimer }}
      </p>
    {%- endif -%}

  </div>
</section>

<style>
.email-capture-section {
  position: relative;
  overflow: hidden;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.email-capture__eyebrow {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: var(--sp-3);
}
.email-capture__heading {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 4vw, 2.75rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: var(--sp-3);
  color: inherit;
}
.email-capture__subtitle {
  color: inherit;
  opacity: 0.85;
  margin-bottom: var(--sp-6);
  font-size: var(--text-base);
  max-width: 55ch;
  margin-inline: auto;
  line-height: 1.6;
}
.email-form {
  margin-inline: auto;
  max-width: 500px;
}
.email-form__wrap {
  display: flex;
  gap: var(--sp-2);
  flex-wrap: wrap;
  justify-content: center;
}
.email-form__input {
  flex: 1;
  min-width: 240px;
  height: 52px;
  padding: 0 var(--sp-4);
  border: 1.5px solid color-mix(in oklab, currentColor 15%, transparent);
  border-radius: var(--radius-pill, var(--radius-full, 9999px));
  background: color-mix(in oklab, currentColor 4%, transparent);
  color: inherit;
  font-size: var(--text-base);
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.email-form__input::placeholder {
  color: color-mix(in oklab, currentColor 60%, transparent);
}
.email-form__input:focus {
  border-color: currentColor;
  box-shadow: 0 0 0 3px color-mix(in oklab, currentColor 12%, transparent);
}
.email-form__submit {
  height: 52px;
  padding-inline: var(--sp-6);
  font-weight: 700;
  white-space: nowrap;
}
.email-capture-msg {
  margin-top: var(--sp-4);
  font-size: var(--text-sm);
  font-weight: 600;
  border-radius: var(--radius-md);
  padding: var(--sp-3) var(--sp-4);
  text-align: center;
}
.email-capture-msg.success {
  background: var(--color-success-bg, #e6f4ed);
  color: var(--color-success, #1d6b44);
  border: 1px solid color-mix(in oklab, var(--color-success) 20%, transparent);
}
.email-capture-msg.error {
  background: #fde8e8;
  color: var(--color-error, #e8260d);
  border: 1px solid color-mix(in oklab, var(--color-error) 20%, transparent);
}
.email-capture__disclaimer {
  font-size: var(--text-xs);
  opacity: 0.6;
  margin-top: var(--sp-4);
  line-height: 1.5;
  max-width: 60ch;
  margin-inline: auto;
}
</style>

{% schema %}
{
  "name": "Email Capture",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "eyebrow",          "label": "Eyebrow",               "default": "Exclusive Offer" },
    { "type": "text",     "id": "title",            "label": "Heading",               "default": "Get 10% Off Your First Order" },
    { "type": "textarea", "id": "subtitle",         "label": "Subtitle",              "default": "Join the BodyLuxCare family and be the first to hear about new arrivals, exclusive deals, and wellness tips." },
    { "type": "text",     "id": "placeholder",      "label": "Input placeholder",     "default": "Enter your email address" },
    { "type": "text",     "id": "button_text",      "label": "Button text",           "default": "Claim My 10% Off" },
    { "type": "text",     "id": "success_message",  "label": "Success Message",       "default": "Thank you! Check your inbox for a discount code." },
    { "type": "text",     "id": "disclaimer",       "label": "Disclaimer text",       "default": "No spam ever. Unsubscribe anytime. By subscribing you agree to our Privacy Policy." },
    { "type": "range",    "id": "max_width",        "label": "Section Content Max Width","min": 400, "max": 900, "step": 50, "default": 700, "unit": "px" },
    { "type": "header",   "content": "Colors & Spacing" },
    { "type": "color",    "id": "bg_color",         "label": "Background color",      "default": "#1a1a1a" },
    { "type": "color",    "id": "text_color",       "label": "Text color",            "default": "#ffffff" },
    { "type": "color",    "id": "accent_color",     "label": "Eyebrow Accent color",  "default": "#ffeed2" },
    { "type": "range",    "id": "padding_top",      "label": "Padding Top",           "min": 20, "max": 120, "step": 4, "default": 80, "unit": "px" },
    { "type": "range",    "id": "padding_bottom",   "label": "Padding Bottom",        "min": 20, "max": 120, "step": 4, "default": 80, "unit": "px" }
  ],
  "presets": [{ "name": "Email Capture" }]
}
{% endschema %}
