
{%- assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0 -%}
<section class="hero-bombas{% if section.settings.text_dark %} hero-bombas--light{% endif %}">
  {% if section.settings.image != blank %}
    {{ section.settings.image | image_url: width: 2000 | image_tag:
       loading: 'eager',
       fetchpriority: 'high',
       widths: '750,1100,1500,2000',
       sizes: '100vw',
       alt: section.settings.heading,
       class: 'hero-bombas__img' }}
  {% else %}
    <img class="hero-bombas__img"
         src="https://images.unsplash.com/photo-1483985988355-763728e1935b?w=2000&q=80&auto=format&fit=crop"
         alt="Fashion hero" width="2000" height="900" loading="eager">
  {% endif %}

  <div class="hero-bombas__overlay"
       style="background:linear-gradient(105deg, rgba(0,0,0,{{ overlay_opacity }}) 0%, rgba(0,0,0,{{ overlay_opacity | times: 0.3 }}) 100%)">
  </div>

  <div class="page-w hero-bombas__content">
    <div class="hero-bombas__inner">
      {% if section.settings.eyebrow != blank %}
        <span class="label-eyebrow" style="color:rgba(255,255,255,.65)">
          {{ section.settings.eyebrow }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1>{{ section.settings.heading }}</h1>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="hero-bombas__sub">{{ section.settings.subheading }}</p>
      {% endif %}

      <div class="hero-bombas__ctas">
        {% if section.settings.cta1_label != blank %}
          <a href="{{ section.settings.cta1_url }}" class="btn btn-white btn-lg">
            {{ section.settings.cta1_label }}
          </a>
        {% endif %}
        {% if section.settings.cta2_label != blank %}
          <a href="{{ section.settings.cta2_url }}" class="btn btn-outline-white btn-lg">
            {{ section.settings.cta2_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {"type":"image_picker","id":"image","label":"Background image"},
    {"type":"range","id":"overlay_opacity","min":0,"max":80,"step":5,"unit":"%","label":"Dark overlay","default":45},
    {"type":"checkbox","id":"text_dark","label":"Use dark text (light image)","default":false},
    {"type":"text","id":"eyebrow","label":"Eyebrow label","default":"New Collection · Summer 2025"},
    {"type":"text","id":"heading","label":"Heading","default":"Style That Feels As Good As It Looks"},
    {"type":"textarea","id":"subheading","label":"Subheading","default":"Premium clothing, jewellery & gifts — thoughtfully made for women, men, and the ones they love."},
    {"type":"text","id":"cta1_label","label":"Primary button label","default":"Shop Women"},
    {"type":"url","id":"cta1_url","label":"Primary button URL"},
    {"type":"text","id":"cta2_label","label":"Secondary button label","default":"Shop Men"},
    {"type":"url","id":"cta2_url","label":"Secondary button URL"}
  ],
  "presets":[{"name":"Hero Banner"}]
}
{% endschema %}
