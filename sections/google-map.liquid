{%- if section.settings.enabled -%}
<section id="GoogleMap-{{ section.id }}" class="google-map section-spacing" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="google-map__grid">
      <div class="google-map__copy">
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading | escape }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="rte">{{ section.settings.text }}</div>{%- endif -%}
      </div>
      <div class="google-map__frame">
        {%- if section.settings.map_embed_url != blank -%}
          <iframe src="{{ section.settings.map_embed_url }}" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="{{ section.settings.heading | escape }}"></iframe>
        {%- else -%}
          <div class="google-map__fallback">
            <strong>{{ section.settings.fallback_title | escape }}</strong>
            <p>{{ section.settings.fallback_text | escape }}</p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
#GoogleMap-{{ section.id }} .google-map__grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(20px,4vw,48px); align-items: center; }
#GoogleMap-{{ section.id }} .google-map__copy h2 { font-family: var(--font-display); font-size: var(--text-xl); }
#GoogleMap-{{ section.id }} .google-map__copy .rte { color: var(--color-text-muted); margin-top: var(--sp-3); }
#GoogleMap-{{ section.id }} .google-map__frame { min-height: {{ section.settings.map_height }}px; overflow: hidden; border-radius: var(--card-radius); background: var(--color-surface); border: 1px solid var(--color-border); }
#GoogleMap-{{ section.id }} iframe { width: 100%; height: {{ section.settings.map_height }}px; border: 0; display: block; }
#GoogleMap-{{ section.id }} .google-map__fallback { display: grid; place-content: center; min-height: {{ section.settings.map_height }}px; padding: var(--sp-6); text-align: center; color: var(--color-text-muted); }
@media (max-width: 780px) { #GoogleMap-{{ section.id }} .google-map__grid { grid-template-columns: 1fr; } }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Google Map",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Visit us" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Add your address, opening hours, or pickup instructions.</p>" },
    { "type": "url", "id": "map_embed_url", "label": "Google Maps embed URL", "info": "Use a Google Maps share/embed URL. Leave blank to show fallback text." },
    { "type": "range", "id": "map_height", "label": "Map height", "min": 260, "max": 640, "step": 20, "default": 420, "unit": "px" },
    { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Map embed not configured" },
    { "type": "textarea", "id": "fallback_text", "label": "Fallback text", "default": "Add a Google Maps embed URL in this section's settings." }
  ],
  "presets": [{ "name": "Google Map" }]
}
{% endschema %}
