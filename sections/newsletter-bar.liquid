<section class="newsletter-bar" style="background:{{ section.settings.bg_color | default: 'var(--color-surface-2, #f5f3f0)' }};color:{{ section.settings.text_color | default: 'var(--color-text, #111111)' }};">
  <div class="page-w">
    {% if section.settings.eyebrow != blank %}
      <span class="label-eyebrow" style="display:block;margin-bottom:10px">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
    {% form 'customer', id: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-form">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input class="newsletter-input"
               type="email"
               name="contact[email]"
               id="newsletter-email"
               placeholder="{{ section.settings.placeholder }}"
               required
               autocomplete="email">
        <button class="btn btn-black" type="submit">{{ section.settings.button }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="color:#2e7d32;font-size:14px;font-weight:600;margin-top:12px">✓ {{ section.settings.success_msg }}</p>
      {%- elsif form.errors -%}
        <p style="color:#c62828;font-size:14px;margin-top:12px">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>
      {%- endif -%}
    {% endform %}
    {% if section.settings.privacy_note != blank %}
      <p style="font-size:12px;color:#aaa;margin-top:12px">{{ section.settings.privacy_note }}</p>
    {% endif %}
  </div>
</section>

<style>
.newsletter-bar {
  padding: clamp(48px, 6vw, 80px) 0;
  text-align: center;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.newsletter-bar h2 {
  font-family: var(--font-display, inherit);
  font-size: clamp(1.8rem, 4vw, 2.5rem);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: var(--sp-2, 8px);
}
.newsletter-bar p {
  opacity: 0.85;
  max-width: 55ch;
  margin: 0 auto var(--sp-6, 24px);
  font-size: var(--text-sm, 14px);
  line-height: 1.6;
}
.newsletter-form {
  display: flex;
  gap: var(--sp-2, 8px);
  max-width: 480px;
  margin: 0 auto;
  flex-wrap: wrap;
  justify-content: center;
}
.newsletter-input {
  flex: 1;
  min-width: 240px;
  height: 48px;
  padding: 0 var(--sp-4, 16px);
  border: 1.5px solid var(--color-border, #ddd);
  border-radius: var(--radius-btn, var(--radius-full, 9999px));
  background: var(--color-surface, #fff);
  color: var(--color-text, #111);
  outline: none;
  transition: border-color var(--transition, 180ms ease);
}
.newsletter-input:focus {
  border-color: var(--color-primary, #111);
}
.newsletter-bar .btn {
  height: 48px;
  padding-inline: var(--sp-6, 24px);
  font-weight: 700;
  border-radius: var(--radius-btn, var(--radius-full, 9999px));
  background: var(--color-primary, #111);
  color: var(--color-text-inverse, #fff);
  border: none;
  cursor: pointer;
  transition: background var(--transition, 180ms ease);
}
.newsletter-bar .btn:hover {
  background: var(--color-primary-hover, #333);
}
.label-eyebrow {
  font-size: var(--text-xs, 12px);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  opacity: 0.7;
}
</style>

{% schema %}
{
  "name": "Newsletter Bar",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Stay in the loop"},
    {"type":"text","id":"heading","label":"Heading","default":"Join the Community"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Be first to know about new arrivals, exclusive offers, and our latest giving campaigns."},
    {"type":"text","id":"placeholder","label":"Input placeholder","default":"Enter your email address"},
    {"type":"text","id":"button","label":"Button text","default":"Subscribe"},
    {"type":"text","id":"success_msg","label":"Success message","default":"You're in! Check your inbox for a welcome gift."},
    {"type":"text","id":"privacy_note","label":"Privacy note","default":"No spam. Unsubscribe anytime. We respect your privacy."},
    {"type":"header","content":"Design Customization"},
    {"type":"color","id":"bg_color","label":"Background color","default":"#f5f3f0"},
    {"type":"color","id":"text_color","label":"Text color","default":"#111111"}
  ],
  "presets":[{"name":"Newsletter Bar"}]
}
{% endschema %}
