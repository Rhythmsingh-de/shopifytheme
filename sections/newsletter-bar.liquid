
<section class="newsletter-bar">
  <div class="page-w">
    {% if section.settings.eyebrow != blank %}
      <span class="label-eyebrow" style="display:block;margin-bottom:10px">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.subtext }}</p>
    {% form 'customer', id: 'newsletter-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-form">
        <label for="newsletter-email" class="sr-only">Email address</label>
        <input class="newsletter-input"
               type="email"
               name="contact[email]"
               id="newsletter-email"
               placeholder="{{ section.settings.placeholder }}"
               required
               autocomplete="email">
        <button class="btn btn-black" type="submit">{{ section.settings.button }}</button>
      </div>
      {%- if form.posted_successfully? -%}
        <p style="color:#2e7d32;font-size:14px;font-weight:600;margin-top:12px">✓ {{ section.settings.success_msg }}</p>
      {%- elsif form.errors -%}
        <p style="color:#c62828;font-size:14px;margin-top:12px">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>
      {%- endif -%}
    {% endform %}
    {% if section.settings.privacy_note != blank %}
      <p style="font-size:12px;color:#aaa;margin-top:12px">{{ section.settings.privacy_note }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Bar",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Stay in the loop"},
    {"type":"text","id":"heading","label":"Heading","default":"Join the Community"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"Be first to know about new arrivals, exclusive offers, and our latest giving campaigns."},
    {"type":"text","id":"placeholder","label":"Input placeholder","default":"Enter your email address"},
    {"type":"text","id":"button","label":"Button text","default":"Subscribe"},
    {"type":"text","id":"success_msg","label":"Success message","default":"You're in! Check your inbox for a welcome gift."},
    {"type":"text","id":"privacy_note","label":"Privacy note","default":"No spam. Unsubscribe anytime. We respect your privacy."}
  ],
  "presets":[{"name":"Newsletter Bar"}]
}
{% endschema %}
