<main id="main-content" class="section">
  <div class="container container--narrow">
    <h1 style="font-family:var(--font-display);font-size:var(--text-xl);font-weight:800;margin-bottom:var(--sp-6)">{{ page.title }}</h1>
    <div style="font-size:var(--text-base);line-height:1.8;color:var(--color-text)">{{ page.content }}</div>
  </div>
</main>
{% schema %}{ "name": "Page", "tag": "section", "settings": [], "presets": [{ "name": "Page" }] }{% endschema %}
