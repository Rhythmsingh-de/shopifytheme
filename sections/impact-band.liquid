
<section class="impact-band">
  <div class="page-w">
    {% if section.settings.eyebrow != blank %}
      <span class="label-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    <h2>{{ section.settings.heading }}</h2>
    <p class="impact-band__sub">{{ section.settings.subtext }}</p>
    {% if section.settings.cta_label != blank %}
      <a href="{{ section.settings.cta_url }}" class="btn btn-white">{{ section.settings.cta_label }}</a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Impact Band",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our Promise"},
    {"type":"text","id":"heading","label":"Heading","default":"One Purchased = One Donated"},
    {"type":"textarea","id":"subtext","label":"Subtext","default":"For every item you buy, we donate one to someone in need. Over 100 million items donated and counting."},
    {"type":"text","id":"cta_label","label":"Button text","default":"Learn About Our Mission"},
    {"type":"url","id":"cta_url","label":"Button URL"}
  ],
  "presets":[{"name":"Impact Band"}]
}
{% endschema %}
