<section class="lifestyle-split{% if section.settings.reverse_layout %} lifestyle-split--reversed{% endif %}"
  {{ section.shopify_attributes }}>

  <div class="lifestyle-split__content{% if section.settings.dark_content %} lifestyle-split__content--dark{% endif %}">
    {%- if section.settings.eyebrow != blank -%}
      <span class="section-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2 class="section-title" style="margin-bottom:var(--space-4)">{{ section.settings.heading | default: 'Crafted for Real Life' }}</h2>
    {%- if section.settings.text != blank -%}
      <p class="section-subtitle">{{ section.settings.text }}</p>
    {%- endif -%}
    {%- if section.settings.cta_label != blank -%}
      <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn btn--primary btn--lg" style="margin-top:var(--space-8);align-self:flex-start">
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>

  <div class="lifestyle-split__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 900 | image_tag:
        loading: 'lazy',
        width: 900, height: 700,
        alt: section.settings.heading | default: 'Lifestyle'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "Lifestyle split",
  "tag": "section",
  "class": "shopify-section--lifestyle",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our Story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafted for Real Life" },
    { "type": "textarea", "id": "text", "label": "Body text", "default": "We believe luxury should be accessible. Every product in our collection is chosen for quality, comfort, and style — from women's fashion to home décor and pet essentials." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop the Collection" },
    { "type": "url", "id": "cta_url", "label": "Button link" },
    { "type": "checkbox", "id": "reverse_layout", "label": "Reverse layout (image left)", "default": false },
    { "type": "checkbox", "id": "dark_content", "label": "Dark background on text side", "default": false }
  ],
  "presets": [{
    "name": "Lifestyle split",
    "settings": {
      "eyebrow": "Our Story",
      "heading": "Crafted for Real Life",
      "text": "We believe luxury should be accessible. Every product in our collection is chosen for quality, comfort, and style.",
      "cta_label": "Shop the Collection"
    }
  }]
}
{% endschema %}
