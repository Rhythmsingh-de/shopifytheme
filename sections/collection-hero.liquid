<div class="collection-hero" style="background:var(--color-surface);padding:clamp(var(--sp-8),5vw,var(--sp-16)) 0;text-align:center">
  <div class="container">
    {%- if collection.image -%}
      <div style="position:relative;border-radius:var(--radius-2xl);overflow:hidden;max-height:320px;margin-bottom:var(--sp-6)">
        <img src="{{ collection.image | image_url: width: 1600 }}"
             alt="{{ collection.image.alt | default: collection.title | escape }}"
             width="1600" height="320"
             style="width:100%;height:320px;object-fit:cover"
             loading="eager" decoding="async">
        <div style="position:absolute;inset:0;background:rgba(13,35,24,0.4);display:flex;align-items:center;justify-content:center">
          <h1 style="font-family:var(--font-display);font-size:var(--text-2xl);font-weight:800;color:#fff">{{ collection.title }}</h1>
        </div>
      </div>
    {%- else -%}
      <h1 style="font-family:var(--font-display);font-size:var(--text-2xl);font-weight:800;margin-bottom:var(--sp-3)">{{ collection.title }}</h1>
    {%- endif -%}
    {%- if collection.description != blank -%}
      <p style="color:var(--color-text-muted);max-width:64ch;margin:0 auto;font-size:var(--text-base)">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</div>
{% schema %}{ "name": "Collection Hero", "tag": "section", "settings": [], "presets": [{ "name": "Collection Hero" }] }{% endschema %}
