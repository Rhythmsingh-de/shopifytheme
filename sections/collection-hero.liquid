{%- liquid
  assign show_description = section.settings.show_description
  assign hero_image = section.settings.image
  if hero_image == blank and section.settings.use_collection_image
    assign hero_image = collection.image
  endif
-%}

<section id="CollectionHero-{{ section.id }}" class="collection-hero collection-hero--{{ section.settings.layout }}" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="collection-hero__grid">
      <div class="collection-hero__copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="collection-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h1 class="collection-hero__title">{{ collection.title | escape }}</h1>
        {%- if show_description and collection.description != blank -%}
          <div class="collection-hero__desc rte">{{ collection.description }}</div>
        {%- elsif section.settings.fallback_text != blank -%}
          <p class="collection-hero__desc">{{ section.settings.fallback_text | escape }}</p>
        {%- endif -%}
        {%- if settings.collection_show_trust_bar and settings.collection_trust_text != blank -%}
          <p class="collection-hero__trust">{{ settings.collection_trust_text | escape }}</p>
        {%- endif -%}
      </div>

      {%- if hero_image != blank and section.settings.layout != 'text_only' -%}
        <div class="collection-hero__media">
          {%- assign hero_image_alt = hero_image.alt | default: collection.title | escape -%}
          {{ hero_image | image_url: width: 900 | image_tag:
            widths: '360,540,720,900',
            sizes: '(min-width: 900px) 42vw, 100vw',
            loading: 'eager',
            decoding: 'async',
            class: 'collection-hero__image',
            alt: hero_image_alt
          }}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
#CollectionHero-{{ section.id }} {
  padding: clamp(40px, 7vw, 84px) 0 clamp(28px, 5vw, 56px);
  background: {{ section.settings.bg_color }};
  color: {{ section.settings.text_color }};
  border-bottom: 1px solid var(--color-border);
}
#CollectionHero-{{ section.id }} .collection-hero__grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(280px, 0.95fr);
  gap: clamp(28px, 5vw, 64px);
  align-items: center;
}
#CollectionHero-{{ section.id }}.collection-hero--text_only .collection-hero__grid {
  grid-template-columns: 1fr;
  max-width: 760px;
}
#CollectionHero-{{ section.id }} .collection-hero__copy {
  display: grid;
  gap: 14px;
}
#CollectionHero-{{ section.id }} .collection-hero__eyebrow {
  color: {{ section.settings.accent_color }};
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
}
#CollectionHero-{{ section.id }} .collection-hero__title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: 1.02;
  font-weight: 900;
  letter-spacing: 0;
}
#CollectionHero-{{ section.id }} .collection-hero__desc {
  max-width: 62ch;
  color: color-mix(in oklab, currentColor 72%, transparent);
  font-size: var(--text-base);
  line-height: 1.7;
}
#CollectionHero-{{ section.id }} .collection-hero__trust {
  display: inline-flex;
  width: fit-content;
  margin-top: 6px;
  padding: 8px 12px;
  border: 1px solid color-mix(in oklab, currentColor 15%, transparent);
  border-radius: var(--radius-full);
  color: color-mix(in oklab, currentColor 72%, transparent);
  font-size: var(--text-xs);
  font-weight: 700;
}
#CollectionHero-{{ section.id }} .collection-hero__media {
  aspect-ratio: 4 / 3;
  overflow: hidden;
  border-radius: var(--card-radius);
  background: var(--color-surface);
}
#CollectionHero-{{ section.id }} .collection-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
@media (max-width: 820px) {
  #CollectionHero-{{ section.id }} .collection-hero__grid {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Collection Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop the edit" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [
      { "value": "split", "label": "Text and image" },
      { "value": "text_only", "label": "Text only" }
    ], "default": "split" },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "textarea", "id": "fallback_text", "label": "Fallback intro text", "default": "Premium picks selected for quality, comfort, and everyday use." },
    { "type": "checkbox", "id": "use_collection_image", "label": "Use collection image", "default": true },
    { "type": "image_picker", "id": "image", "label": "Custom image" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#e8260d" }
  ],
  "presets": [
    { "name": "Collection Hero" }
  ]
}
{% endschema %}
