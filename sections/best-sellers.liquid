{%- comment -%} BodyLuxCare v3.0.0 — Product Grid Section
  Replaces: best-sellers, featured-products, new-arrivals, new-arrivals-tabs
  Usage: Add to any page via Theme Editor. Change "Section label" to set badge text.
{%- endcomment -%}

{%- liquid
  assign coll = collections[section.settings.collection]
  assign limit = section.settings.products_to_show | default: 4
  assign cols_d = section.settings.columns_desktop | default: '4'
  assign badge_text = section.settings.badge_text
  assign bg = section.settings.bg_color | default: 'var(--color-bg)'
  assign text_color = section.settings.text_color | default: 'var(--color-text)'
-%}

<section
  id="ProductGrid-{{ section.id }}"
  class="product-grid-section reveal"
  style="background:{{ bg }};padding:clamp(40px,6vw,80px) 0;"
  {{ section.shopify_attributes }}>

  <div class="container">

    {%- comment -%} Section header {%- endcomment -%}
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="product-grid-section__head" style="color:{{ text_color }};text-align:{{ section.settings.text_align | default: 'center' }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="product-grid-section__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="product-grid-section__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="product-grid-section__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Product grid {%- endcomment -%}
    <div
      class="product-grid-section__grid"
      style="--pgrid-cols:{{ cols_d }};"
      role="list"
      aria-label="{{ section.settings.heading | default: 'Products' }}">

      {%- if coll != blank -%}
        {%- for product in coll.products limit: limit -%}
          <div role="listitem" class="product-grid-section__item reveal" style="transition-delay:{{ forloop.index0 | times: 60 }}ms">
            {%- render 'product-card', product: product, badge_override: badge_text -%}
          </div>
        {%- else -%}
          <p class="product-grid-section__empty">No products found in this collection.</p>
        {%- endfor -%}

      {%- else -%}
        {%- comment -%} Placeholder cards for Theme Editor preview {%- endcomment -%}
        {%- for i in (1..4) -%}
          <div role="listitem" class="product-grid-section__item reveal" style="transition-delay:{{ forloop.index0 | times: 60 }}ms">
            <article class="prod-card">
              <a href="/collections/all">
                <div class="prod-card__media">
                  {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg prod-card__placeholder' }}
                  {%- if badge_text != blank -%}
                    <span class="prod-card__badge">{{ badge_text }}</span>
                  {%- endif -%}
                </div>
                <div class="prod-card__body">
                  <div class="prod-card__meta">{{ section.settings.mock_type | default: 'Premium Collection' }}</div>
                  <div class="prod-card__name">{{ section.settings.mock_name | default: 'Sample Product' }}</div>
                  <div class="prod-card__price-row">
                    <span class="prod-card__price">$49.99</span>
                  </div>
                </div>
              </a>
            </article>
          </div>
        {%- endfor -%}
      {%- endif -%}

    </div>

    {%- if section.settings.view_all_label != blank -%}
      <div class="product-grid-section__cta">
        <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="btn btn--outline">
          {{ section.settings.view_all_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
.product-grid-section__head {
  margin-bottom: clamp(24px, 4vw, 48px);
}
.product-grid-section__eyebrow {
  font-size: var(--text-xs, 0.75rem);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-deco, #1d6b44);
  margin-bottom: 8px;
}
.product-grid-section__heading {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 800;
  line-height: 1.1;
  margin-bottom: 12px;
}
.product-grid-section__sub {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  max-width: 56ch;
  margin-inline: auto;
  line-height: 1.6;
}
.product-grid-section__grid {
  display: grid;
  grid-template-columns: repeat(var(--pgrid-cols, 4), 1fr);
  gap: var(--sp-5, 20px);
}
.product-grid-section__empty {
  grid-column: 1 / -1;
  text-align: center;
  color: var(--color-text-muted);
  padding: 40px;
}
.product-grid-section__cta {
  text-align: center;
  margin-top: clamp(24px, 4vw, 40px);
}

/* Responsive breakpoints */
@media (max-width: 1023px) {
  .product-grid-section__grid {
    grid-template-columns: repeat(2, 1fr) !important;
  }
}
@media (max-width: 480px) {
  .product-grid-section__grid {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: var(--sp-3, 12px) !important;
  }
  .product-grid-section__sub { margin-inline: 0; }
}
</style>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "class": "section-product-grid",
  "settings": [
    { "type": "header", "content": "Section Header" },
    { "type": "text", "id": "eyebrow",    "label": "Eyebrow label",  "default": "Customer Favourites",
      "info": "Small uppercase text above heading. E.g. 'New Arrivals', 'This Week Only'" },
    { "type": "text", "id": "heading",    "label": "Heading",        "default": "Best Sellers" },
    { "type": "text", "id": "subheading", "label": "Subheading (optional)" },
    { "type": "select", "id": "text_align", "label": "Header alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" }
      ], "default": "center" },
    { "type": "header", "content": "Products" },
    { "type": "collection", "id": "collection", "label": "Collection",
      "info": "Pick any collection. Leave blank to show placeholder cards in editor." },
    { "type": "range",  "id": "products_to_show", "label": "Products to show", "min": 2, "max": 12, "step": 2, "default": 4 },
    { "type": "select", "id": "columns_desktop",  "label": "Columns (desktop)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ], "default": "4" },
    { "type": "text", "id": "badge_text", "label": "Product badge label",
      "info": "Text shown on each card e.g. 'Best Seller', 'New', 'Sale'. Leave blank for none." },
    { "type": "header", "content": "View All Button" },
    { "type": "text", "id": "view_all_label", "label": "Button label",  "default": "View All" },
    { "type": "url",  "id": "view_all_url",   "label": "Button link" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color",   "label": "Background color" },
    { "type": "color", "id": "text_color", "label": "Heading text color" },
    { "type": "header", "content": "Placeholder (shown in editor with no collection)" },
    { "type": "text", "id": "mock_type", "label": "Mock product type", "default": "Premium Collection" },
    { "type": "text", "id": "mock_name", "label": "Mock product name", "default": "Luxury Product" }
  ],
  "presets": [
    {
      "name": "Best Sellers",
      "settings": { "eyebrow": "Customer Favourites", "heading": "Best Sellers", "badge_text": "Best Seller", "columns_desktop": "4" }
    },
    {
      "name": "New Arrivals",
      "settings": { "eyebrow": "Just Landed", "heading": "New Arrivals", "badge_text": "New", "columns_desktop": "4" }
    },
    {
      "name": "Featured Products",
      "settings": { "eyebrow": "Handpicked For You", "heading": "Featured Products", "badge_text": "", "columns_desktop": "3" }
    },
    {
      "name": "This Week's Picks",
      "settings": { "eyebrow": "Weekly Drop", "heading": "This Week\u2019s Picks", "badge_text": "This Week", "columns_desktop": "4" }
    }
  ]
}
{% endschema %}
