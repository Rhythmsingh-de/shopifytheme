{%- comment -%} BodyLuxCare — Promo / Lifestyle Banner Section {%- endcomment -%}
<section class="promo-banner reveal" style="position:relative;overflow:hidden;min-height:{{ section.settings.min_height | default: 480 }}px;display:flex;align-items:center;background:{{ section.settings.bg_color | default: '#0d2318' }}">

  {%- if section.settings.image != blank -%}
    <div style="position:absolute;inset:0;z-index:0">
      <img src="{{ section.settings.image | image_url: width: 1800 }}"
           alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
           width="1800" height="900" loading="lazy"
           style="width:100%;height:100%;object-fit:cover;object-position:{{ section.settings.focal_point | default: 'center' }}">
      <div style="position:absolute;inset:0;background:rgba(0,0,0,{{ section.settings.overlay | default: 0.45 }})"></div>
    </div>
  {%- else -%}
    <div style="position:absolute;inset:0;z-index:0;background:linear-gradient(135deg,#0d2318 0%,#1a4a2e 60%,#0d2318 100%)"></div>
  {%- endif -%}

  <div style="position:relative;z-index:1;width:100%;max-width:1280px;margin:0 auto;padding:clamp(40px,6vw,80px) clamp(16px,4vw,48px);text-align:{{ section.settings.text_align | default: 'center' }}">
    {%- if section.settings.eyebrow != blank -%}
      <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:{{ section.settings.accent_color | default: '#7dc98f' }};margin-bottom:14px">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2 style="font-family:var(--font-display);font-size:clamp(1.8rem,4vw,3.2rem);font-weight:800;color:#fff;margin-bottom:16px;line-height:1.1">{{ section.settings.heading | default: 'Elevate Every Moment' }}</h2>
    {%- if section.settings.text != blank -%}
      <p style="font-size:clamp(1rem,1.5vw,1.15rem);color:rgba(255,255,255,0.75);margin-bottom:36px;max-width:560px;{% if section.settings.text_align == 'center' %}margin-inline:auto{% endif %}">{{ section.settings.text }}</p>
    {%- endif -%}
    <div style="display:flex;flex-wrap:wrap;gap:12px;justify-content:{{ section.settings.text_align | default: 'center' }};{% if section.settings.text_align == 'left' %}justify-content:flex-start{% endif %}">
      {%- if section.settings.cta_1_label != blank -%}
        <a href="{{ section.settings.cta_1_url | default: '/collections/all' }}" class="btn" style="background:#fff;color:#0d2318;font-weight:700;min-width:160px">{{ section.settings.cta_1_label }}</a>
      {%- endif -%}
      {%- if section.settings.cta_2_label != blank -%}
        <a href="{{ section.settings.cta_2_url | default: '/collections/all' }}" class="btn" style="background:transparent;color:#fff;border:2px solid rgba(255,255,255,0.6);font-weight:700;min-width:160px" onmouseover="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,0.1)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.6)';this.style.background='transparent'">{{ section.settings.cta_2_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "class": "section-promo-banner",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow label","default":"Explore More"},
    {"type":"text","id":"heading","label":"Heading","default":"Elevate Every Moment"},
    {"type":"textarea","id":"text","label":"Subtext","default":"From self-care rituals to luxury home essentials — discover products that make every day feel special."},
    {"type":"image_picker","id":"image","label":"Background image"},
    {"type":"color","id":"bg_color","label":"Background colour (no image)","default":"#0d2318"},
    {"type":"color","id":"accent_color","label":"Eyebrow accent colour","default":"#7dc98f"},
    {"type":"range","id":"overlay","label":"Image overlay opacity","min":0,"max":0.9,"step":0.05,"default":0.45},
    {"type":"range","id":"min_height","label":"Min height (px)","min":300,"max":700,"step":20,"default":480},
    {"type":"select","id":"text_align","label":"Text alignment","options":[{"value":"center","label":"Center"},{"value":"left","label":"Left"}],"default":"center"},
    {"type":"select","id":"focal_point","label":"Image focal point","options":[{"value":"center","label":"Center"},{"value":"top","label":"Top"},{"value":"bottom","label":"Bottom"}],"default":"center"},
    {"type":"text","id":"cta_1_label","label":"Button 1 label","default":"Shop Women"},
    {"type":"url","id":"cta_1_url","label":"Button 1 link"},
    {"type":"text","id":"cta_2_label","label":"Button 2 label","default":"Shop Home"},
    {"type":"url","id":"cta_2_url","label":"Button 2 link"}
  ],
  "presets":[{"name":"Promo Banner"}]
}
{% endschema %}
