
<section class="section{{ ' section-alt' if section.settings.bg == 'white' }}"
  style="padding-top:{{ section.settings.padding_top }}px;padding-bottom:{{ section.settings.padding_bottom }}px;{% if section.settings.bg == 'custom' %}background:{{ section.settings.custom_bg }};{% endif %}">
  <div class="page-width">
    <div class="section-hd-row">
      <div>
        <h2 style="color:{{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p>{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a class="btn btn-outline btn-sm" href="{{ section.settings.view_all_url }}" data-track="categories_view_all">
          {{ section.settings.view_all_label }} →
        </a>
      {%- endif -%}
    </div>
    <div class="cat-grid" style="grid-template-columns:repeat({{ section.settings.columns }},1fr);">
      {%- for block in section.blocks -%}
        <a class="cat-card" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 600 }}"
                 alt="{{ block.settings.name | escape }}"
                 width="600" height="800"
                 loading="lazy">
          {%- else -%}
            <div style="width:100%;height:100%;background:{{ block.settings.fallback_color }};"></div>
          {%- endif -%}
          <div class="cat-card-overlay"></div>
          <div class="cat-card-body">
            <div class="cat-name">{{ block.settings.name }}</div>
            {%- if block.settings.subtitle != blank -%}
              <div class="cat-sub">{{ block.settings.subtitle }}</div>
            {%- endif -%}
            <span class="cat-btn">{{ block.settings.cta | default: 'Shop Now' }} →</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category grid",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by Category" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#111111" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Find exactly what you're looking for" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View all" },
    { "type": "url", "id": "view_all_url", "label": "View all URL" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "columns", "min": 2, "max": 6, "step": 1, "label": "Columns (desktop)", "default": 5 },
    { "type": "select", "id": "bg", "label": "Background", "options": [
      { "value": "default", "label": "Default" },
      { "value": "white", "label": "White" },
      { "value": "custom", "label": "Custom color" }
    ], "default": "default" },
    { "type": "color", "id": "custom_bg", "label": "Custom background color", "default": "#f2ede6" },
    { "type": "range", "id": "padding_top", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 60 },
    { "type": "range", "id": "padding_bottom", "min": 20, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 60 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category image" },
        { "type": "color", "id": "fallback_color", "label": "Fallback color (no image)", "default": "#e8e0d4" },
        { "type": "text", "id": "name", "label": "Category name", "default": "Women's Fashion" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "New arrivals" },
        { "type": "text", "id": "cta", "label": "CTA text", "default": "Shop Now" },
        { "type": "url", "id": "url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category grid",
      "blocks": [
        { "type": "category", "settings": { "name": "Women's Fashion", "subtitle": "New & trending", "cta": "Shop Women" } },
        { "type": "category", "settings": { "name": "Men's Style", "subtitle": "Sharp & clean", "cta": "Shop Men" } },
        { "type": "category", "settings": { "name": "Jewelry", "subtitle": "Fine & delicate", "cta": "Shop Jewelry" } },
        { "type": "category", "settings": { "name": "Pet Toys", "subtitle": "Fun for all pets", "cta": "Shop Pets" } },
        { "type": "category", "settings": { "name": "Home Decor", "subtitle": "Elevate your space", "cta": "Shop Home" } }
      ]
    }
  ]
}
{% endschema %}
