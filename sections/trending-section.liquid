
<section class="trending-strip">
  <div class="page-w">
    <div class="trending-strip__head" style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:12px">
      <div>
        <span class="label-eyebrow" style="display:block;margin-bottom:6px">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_url }}" class="btn btn-outline btn-sm">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
    <div class="trending-strip__scroll" style="margin-top:28px">
      {% assign coll = collections[section.settings.collection] %}
      {% if coll != blank %}
        {% for product in coll.products limit: 4 %}
          <article class="prod-card">
            <a href="{{ product.url }}">
              <div class="prod-card__media">
                {% if product.featured_image %}
                  {{ product.featured_image | image_url: width: 600 | image_tag:
                     loading: 'lazy', widths: '300,450,600',
                     sizes: '(max-width:640px) 50vw,280px',
                     alt: product.title }}
                {% else %}
                  <img src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600&q=75&auto=format&fit=crop"
                       alt="{{ product.title }}" width="300" height="375" loading="lazy">
                {% endif %}
                <span class="prod-card__badge badge-best">Trending</span>
              </div>
              <div class="prod-card__meta">{{ product.type }}</div>
              <div class="prod-card__name">{{ product.title }}</div>
              <div class="prod-card__price-row">
                <span class="prod-card__price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="prod-card__was">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
            </a>
            <button class="atc-btn" data-variant="{{ product.first_available_variant.id }}" data-product="{{ product.handle }}" aria-label="Add {{ product.title }} to cart">
              Add to Cart
            </button>
          </article>
        {% else %}
          <p style="color:#888;font-size:14px;grid-column:1/-1">Select a collection in theme editor.</p>
        {% endfor %}
      {% else %}
        <p style="color:#888;font-size:14px;grid-column:1/-1">Select a collection in the theme editor to show trending products.</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trending Section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Don't Miss Out"},
    {"type":"text","id":"heading","label":"Heading","default":"Trending Right Now"},
    {"type":"collection","id":"collection","label":"Collection"},
    {"type":"text","id":"cta_label","label":"Button label","default":"View All Trending"},
    {"type":"url","id":"cta_url","label":"Button URL"}
  ],
  "presets":[{"name":"Trending Section"}]
}
{% endschema %}
