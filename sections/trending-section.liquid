
<section class="trending-strip">
  <div class="page-w">
    <div class="trending-strip__head" style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:12px">
      <div>
        <span class="label-eyebrow" style="display:block;margin-bottom:6px">{{ section.settings.eyebrow }}</span>
        <h2>{{ section.settings.heading }}</h2>
      </div>
      {% if section.settings.cta_label != blank %}
        <a href="{{ section.settings.cta_url }}" class="btn btn-outline btn-sm">{{ section.settings.cta_label }}</a>
      {% endif %}
    </div>
    <div class="trending-strip__scroll product-grid product-grid--4" style="margin-top:28px">
      {% assign coll = collections[section.settings.collection] %}
      {% if coll != blank %}
        {% for product in coll.products limit: 4 %}
          {%- render 'product-card', product: product, index: forloop.index0 -%}
        {% else %}
          <p style="color:#888;font-size:14px;grid-column:1/-1">Select a collection in theme editor.</p>
        {% endfor %}
      {% else %}
        <p style="color:#888;font-size:14px;grid-column:1/-1">Select a collection in the theme editor to show trending products.</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trending Section",
  "settings": [
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Don't Miss Out"},
    {"type":"text","id":"heading","label":"Heading","default":"Trending Right Now"},
    {"type":"collection","id":"collection","label":"Collection"},
    {"type":"text","id":"cta_label","label":"Button label","default":"View All Trending"},
    {"type":"url","id":"cta_url","label":"Button URL"}
  ],
  "presets":[{"name":"Trending Section"}]
}
{% endschema %}
