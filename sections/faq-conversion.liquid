<section class="section">
  <div class="page-width">
    <div class="section-head">
      <div>
        <h2>FAQ</h2>
        <p>Answer the final objections before checkout.</p>
      </div>
    </div>
    <div class="faq">
      <div class="faq-item open"><button class="faq-question" data-faq-question>Do you ship only in the United States?</button><div class="faq-answer">Yes. This theme is written for a U.S.-only storefront with USD pricing and domestic shipping language.</div></div>
      <div class="faq-item"><button class="faq-question" data-faq-question>Can I change the brand name and colors?</button><div class="faq-answer">Yes. Replace the placeholder branding, product imagery, and policy pages with your store content.</div></div>
      <div class="faq-item"><button class="faq-question" data-faq-question>Does this theme support product pages built for conversion?</button><div class="faq-answer">Yes. The included product template places reviews, shipping, returns, and clear CTA areas near the purchase action.</div></div>
    </div>
  </div>
</section>
{% schema %}
{ "name": "FAQ conversion", "settings": [], "presets": [{"name": "FAQ conversion"}] }
{% endschema %}
