{%- if section.settings.enabled -%}
<section
  id="PromoPopup-{{ section.id }}"
  class="promo-popup"
  data-promo-popup
  data-popup-id="{{ section.id }}"
  data-delay="{{ section.settings.delay | times: 1000 }}"
  data-frequency="{{ section.settings.frequency }}"
  hidden
  {{ section.shopify_attributes }}>
  <div class="promo-popup__overlay" data-promo-popup-close></div>
  <div class="promo-popup__dialog" role="dialog" aria-modal="true" aria-label="{{ section.settings.heading | escape }}">
    <button class="promo-popup__close" type="button" data-promo-popup-close aria-label="{{ 'accessibility.close' | t | default: 'Close' }}">&times;</button>
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 720 | image_tag: class: 'promo-popup__image', loading: 'lazy', alt: section.settings.heading }}
    {%- endif -%}
    <div class="promo-popup__content">
      {%- if section.settings.eyebrow != blank -%}<p class="promo-popup__eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading | escape }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p>{{ section.settings.text | escape }}</p>{%- endif -%}
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}<a class="btn btn--primary" href="{{ section.settings.button_link }}">{{ section.settings.button_label | escape }}</a>{%- endif -%}
    </div>
  </div>
</section>

<style>
#PromoPopup-{{ section.id }}.promo-popup { position: fixed; inset: 0; z-index: 970; opacity: 0; pointer-events: none; transition: opacity var(--transition); }
#PromoPopup-{{ section.id }}.is-visible { opacity: 1; pointer-events: auto; }
#PromoPopup-{{ section.id }} .promo-popup__overlay { position: absolute; inset: 0; background: rgba(0,0,0,.54); }
#PromoPopup-{{ section.id }} .promo-popup__dialog { position: relative; display: grid; grid-template-columns: {% if section.settings.image != blank %}0.95fr 1fr{% else %}1fr{% endif %}; width: min(760px, calc(100vw - 28px)); margin: 8vh auto; overflow: hidden; border-radius: var(--card-radius); background: var(--color-bg); color: var(--color-text); box-shadow: var(--shadow-lg); }
#PromoPopup-{{ section.id }} .promo-popup__close { position: absolute; top: 10px; right: 10px; z-index: 2; width: 44px; height: 44px; border-radius: var(--radius-full); background: var(--color-bg); font-size: 28px; }
#PromoPopup-{{ section.id }} .promo-popup__image { width: 100%; height: 100%; min-height: 320px; object-fit: cover; }
#PromoPopup-{{ section.id }} .promo-popup__content { display: grid; align-content: center; gap: var(--sp-3); padding: clamp(24px,5vw,48px); }
#PromoPopup-{{ section.id }} .promo-popup__eyebrow { color: var(--color-secondary); font-size: var(--text-xs); font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
#PromoPopup-{{ section.id }} h2 { font-family: var(--font-display); font-size: var(--text-xl); line-height: 1.1; }
#PromoPopup-{{ section.id }} p { color: var(--color-text-muted); }
@media (max-width: 680px) { #PromoPopup-{{ section.id }} .promo-popup__dialog { grid-template-columns: 1fr; margin-top: 14px; } }
</style>
{%- endif -%}

{% schema %}
{
  "name": "Promo Popup",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable popup", "default": false },
    { "type": "select", "id": "frequency", "label": "Frequency", "options": [
      { "value": "once", "label": "Show once per visitor" },
      { "value": "always", "label": "Show every page load" }
    ], "default": "once" },
    { "type": "range", "id": "delay", "label": "Delay", "min": 1, "max": 20, "step": 1, "default": 4, "unit": "s" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Limited offer" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Save on your first order" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use this popup for a launch offer, newsletter prompt, or campaign message." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Shop now" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [{ "name": "Promo Popup" }]
}
{% endschema %}
