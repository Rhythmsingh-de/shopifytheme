<section class="section-spacing--sm" {{ section.shopify_attributes }}>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <div class="section-header section-header--center">
        {%- if section.settings.eyebrow != blank -%}<span class="section-eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="category-strip__grid">
      {%- for block in section.blocks -%}
        <a class="cat-card reveal" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <div class="cat-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: class: 'cat-tile__img', loading: 'lazy', width: 400, height: 500, alt: block.settings.label }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'cat-tile__placeholder' }}
            {%- endif -%}
          </div>
          <span class="cat-card__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name":"Category strip","tag":"section","class":"shopify-section--categories","max_blocks":8,
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Shop by Category"},
    {"type":"text","id":"heading","label":"Heading","default":"Find Your Perfect Match"}
  ],
  "blocks":[{
    "type":"category","name":"Category",
    "settings":[
      {"type":"image_picker","id":"image","label":"Image"},
      {"type":"text","id":"label","label":"Label","default":"Women"},
      {"type":"url","id":"url","label":"Link"}
    ]
  }],
  "presets":[{"name":"Category strip","blocks":[
    {"type":"category","settings":{"label":"Women"}},
    {"type":"category","settings":{"label":"Men"}},
    {"type":"category","settings":{"label":"Jewellery"}},
    {"type":"category","settings":{"label":"Pet Toys"}},
    {"type":"category","settings":{"label":"Home Decor"}}
  ]}]
}
{% endschema %}
