{%- comment -%} BodyLuxCare Hero Section — v3 clean {%- endcomment -%}

<section class="blc-hero" style="
  position:relative;
  overflow:hidden;
  min-height:{{ section.settings.min_height | default: 600 }}px;
  background:{{ section.settings.bg_color | default: '#0d2318' }};
  display:flex;
  align-items:center;
">

  {%- if section.settings.bg_image != blank -%}
    <div style="position:absolute;inset:0;z-index:0">
      <img
        src="{{ section.settings.bg_image | image_url: width: 1800 }}"
        alt="{{ section.settings.bg_image.alt | default: 'Hero background' | escape }}"
        width="1800" height="900"
        loading="eager" decoding="async"
        style="width:100%;height:100%;object-fit:cover;object-position:center"
      >
      <div style="position:absolute;inset:0;background:rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.5 }})"></div>
    </div>
  {%- else -%}
    <div style="position:absolute;inset:0;z-index:0;background:linear-gradient(135deg,#0d2318 0%,#1a4a2e 50%,#0d2318 100%)"></div>
  {%- endif -%}

  <div style="position:relative;z-index:1;width:100%;max-width:1280px;margin:0 auto;padding:clamp(48px,8vw,96px) clamp(16px,4vw,48px)">
    <div style="max-width:640px">

      {%- if section.settings.eyebrow != blank -%}
        <p style="
          font-size:0.75rem;
          font-weight:700;
          letter-spacing:0.12em;
          text-transform:uppercase;
          color:{{ section.settings.accent_color | default: '#7dc98f' }};
          margin-bottom:16px;
        ">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 style="
        font-family:var(--font-display,'Playfair Display',serif);
        font-size:clamp(2.2rem,5vw,4rem);
        font-weight:800;
        line-height:1.1;
        color:{{ section.settings.heading_color | default: '#ffffff' }};
        margin-bottom:20px;
        letter-spacing:-0.01em;
      ">
        {{ section.settings.heading | default: 'Luxury Wellness for You, Your Home & Your Pets' }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <p style="
          font-size:clamp(1rem,1.5vw,1.2rem);
          color:{{ section.settings.subheading_color | default: 'rgba(255,255,255,0.8)' }};
          margin-bottom:36px;
          line-height:1.6;
          max-width:500px;
        ">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center">
        {%- if section.settings.cta1_label != blank -%}
          <a
            href="{{ section.settings.cta1_link | default: '/collections/all' }}"
            style="
              display:inline-flex;align-items:center;justify-content:center;
              padding:14px 32px;
              background:{{ section.settings.cta1_bg | default: '#ffffff' }};
              color:{{ section.settings.cta1_color | default: '#0d2318' }};
              font-weight:700;font-size:0.95rem;letter-spacing:0.02em;
              border-radius:{{ section.settings.btn_radius | default: '9999px' }};
              text-decoration:none;min-height:52px;
              transition:transform 180ms ease,box-shadow 180ms ease;
              box-shadow:0 4px 20px rgba(0,0,0,0.2);
            "
            onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 28px rgba(0,0,0,0.3)'"
            onmouseout="this.style.transform='';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.2)'"
          >{{ section.settings.cta1_label }}</a>
        {%- endif -%}

        {%- if section.settings.cta2_label != blank -%}
          <a
            href="{{ section.settings.cta2_link | default: '/collections/women' }}"
            style="
              display:inline-flex;align-items:center;justify-content:center;
              padding:14px 32px;
              background:transparent;
              color:#ffffff;
              font-weight:700;font-size:0.95rem;letter-spacing:0.02em;
              border-radius:{{ section.settings.btn_radius | default: '9999px' }};
              border:2px solid rgba(255,255,255,0.6);
              text-decoration:none;min-height:52px;
              transition:all 180ms ease;
            "
            onmouseover="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,0.1)'"
            onmouseout="this.style.borderColor='rgba(255,255,255,0.6)';this.style.background='transparent'"
          >{{ section.settings.cta2_label }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_text != blank -%}
        <p style="margin-top:24px;font-size:0.8rem;color:rgba(255,255,255,0.55)">{{ section.settings.trust_text }}</p>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
@media (max-width:600px){
  .blc-hero { min-height:480px !important; }
}
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "shopify-section-hero",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "New Collection 2026" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Luxury Wellness for You, Your Home & Your Pets" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium products designed for comfort, beauty, recovery, and everyday luxury." },
    { "type": "text", "id": "trust_text", "label": "Trust line (below buttons)", "default": "Free shipping $75+ · 30-day returns · Secure checkout" },
    { "type": "header", "content": "Primary Button" },
    { "type": "text", "id": "cta1_label", "label": "Button 1 label", "default": "Shop Now" },
    { "type": "url", "id": "cta1_link", "label": "Button 1 link" },
    { "type": "color", "id": "cta1_bg", "label": "Button 1 background", "default": "#ffffff" },
    { "type": "color", "id": "cta1_color", "label": "Button 1 text color", "default": "#0d2318" },
    { "type": "header", "content": "Secondary Button" },
    { "type": "text", "id": "cta2_label", "label": "Button 2 label", "default": "View Collections" },
    { "type": "url", "id": "cta2_link", "label": "Button 2 link" },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay opacity", "min": 0.0, "max": 0.9, "step": 0.1, "default": 0.5 },
    { "type": "color", "id": "bg_color", "label": "Background color (no image)", "default": "#0d2318" },
    { "type": "header", "content": "Typography" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#ffffff" },
    { "type": "color", "id": "subheading_color", "label": "Subheading color", "default": "#cccccc" },
    { "type": "color", "id": "accent_color", "label": "Eyebrow accent color", "default": "#7dc98f" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "min_height", "label": "Min height (px)", "min": 300, "max": 900, "step": 50, "default": 600 },
    { "type": "select", "id": "btn_radius", "label": "Button style", "options": [{"value":"9999px","label":"Pill"},{"value":"8px","label":"Rounded"},{"value":"4px","label":"Square"}], "default": "9999px" }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "heading": "Luxury Wellness for You, Your Home & Your Pets",
        "subheading": "Premium products designed for comfort, beauty, recovery, and everyday luxury.",
        "cta1_label": "Shop Now",
        "cta2_label": "View Collections",
        "eyebrow": "New Collection 2026",
        "trust_text": "Free shipping $75+ · 30-day returns · Secure checkout"
      }
    }
  ]
}
{% endschema %}
