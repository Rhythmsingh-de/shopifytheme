{%- liquid
  assign align = section.settings.content_align | default: 'left'
  assign storefront_mode = settings.storefront_mode | default: 'single_product'
  assign primary_product = settings.primary_product
  assign primary_collection = settings.primary_collection
  assign hero_product = section.settings.hero_product
  if hero_product == blank and primary_product != blank
    assign hero_product = primary_product
  endif
  if hero_product == blank
    assign hero_product = product
  endif
  assign hero_fv = hero_product.selected_or_first_available_variant
  assign hero_price = hero_fv.price
  assign hero_compare = hero_fv.compare_at_price
  assign hero_is_sale = false
  if hero_compare > hero_price
    assign hero_is_sale = true
    assign hero_save_pct = hero_compare | minus: hero_price | times: 100 | divided_by: hero_compare
  endif
  assign hero_cta_primary = section.settings.cta1_link
  if hero_cta_primary == blank and hero_product != blank
    assign hero_cta_primary = hero_product.url
  elsif hero_cta_primary == blank and primary_collection != blank
    assign hero_cta_primary = primary_collection.url
  endif
  if hero_cta_primary == blank
    assign hero_cta_primary = routes.all_products_collection_url
  endif
  assign hero_cta_secondary = section.settings.cta2_link
  if hero_cta_secondary == blank and storefront_mode == 'multi_product' and primary_collection != blank
    assign hero_cta_secondary = primary_collection.url
  elsif hero_cta_secondary == blank
    assign hero_cta_secondary = routes.all_products_collection_url
  endif
  assign hero_offer_enabled = settings.weekly_offer_enabled
  assign hero_offer_label = settings.weekly_offer_label
  if settings.offer_countdown_mode == 'upcoming_sale' and settings.upcoming_sale_enabled
    assign hero_offer_enabled = true
    assign hero_offer_label = settings.upcoming_sale_label
  endif
-%}

{%- if section.settings.bg_image != blank -%}
  {{ section.settings.bg_image | image_url: width: 1800 | preload_tag: as: 'image' }}
{%- elsif hero_product != blank and hero_product.featured_image != blank -%}
  {{ hero_product.featured_image | image_url: width: 900 | preload_tag: as: 'image' }}
{%- endif -%}

<section
  id="HeroSection-{{ section.id }}"
  class="blc-hero blc-hero--{{ section.settings.layout | default: 'split' }} blc-hero--{{ section.settings.color_scheme | default: 'dark' }}"
  {% if hero_product != blank %}data-product-detail data-variants="{{ hero_product.variants | json | escape }}"{% endif %}
  {{ section.shopify_attributes }}
>

  {%- if section.settings.layout == 'full' -%}
    <div class="blc-hero__bg">
      {%- if section.settings.bg_image != blank -%}
        <img
          src="{{ section.settings.bg_image | image_url: width: 1800 }}"
          alt="{{ section.settings.bg_image.alt | default: 'Hero background' | escape }}"
          width="1800" height="900"
          loading="eager" decoding="async"
          class="blc-hero__bg-img{% if section.settings.mobile_bg_image != blank %} blc-hero__bg-img--desktop{% endif %}">
        {%- if section.settings.mobile_bg_image != blank -%}
          <img
            src="{{ section.settings.mobile_bg_image | image_url: width: 800 }}"
            alt="{{ section.settings.mobile_bg_image.alt | default: 'Hero mobile' | escape }}"
            width="800" height="1000"
            loading="eager" decoding="async"
            class="blc-hero__bg-img blc-hero__bg-img--mobile">
        {%- endif -%}
      {%- else -%}
        <div class="blc-hero__bg--gradient"></div>
      {%- endif -%}
      {%- if section.settings.show_overlay -%}
        <div class="blc-hero__overlay" style="--overlay-opacity:{{ section.settings.overlay_opacity | default: 0.5 }}"></div>
      {%- endif -%}
    </div>

    <div class="container">
      <div class="blc-hero__content blc-hero__content--{{ align }}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="blc-hero__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h1 class="blc-hero__heading">{{ section.settings.heading | default: 'Luxury Wellness for You' }}</h1>
        {%- if section.settings.subheading != blank -%}
          <p class="blc-hero__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if hero_product != blank and section.settings.show_price -%}
          <div class="blc-hero__price-row reveal">
            <span class="blc-hero__price{% if hero_is_sale %} blc-hero__price--sale{% endif %}" data-price-now>{{ hero_price | money }}</span>
            <span class="blc-hero__price-was" data-price-compare{% unless hero_is_sale %} style="display:none;"{% endunless %}>{{ hero_compare | money }}</span>
            <span class="blc-hero__price-save" data-sale-badge{% unless hero_is_sale %} style="display:none;"{% endunless %}>Save {{ hero_save_pct }}%</span>
          </div>
        {%- endif -%}
        {%- render 'hero-product-controls',
          product: hero_product,
          variant: hero_fv,
          show_options: section.settings.show_variant_picker,
          show_quantity: section.settings.show_quantity_selector
        -%}
        {%- if section.settings.show_buttons -%}
          <div class="blc-hero__btns">
            {%- render 'hero-cta-buttons',
              mode: section.settings.cta_button_mode,
              product: hero_product,
              variant: hero_fv,
              primary_label: section.settings.cta1_label,
              secondary_label: section.settings.cta2_label,
              cart_label: section.settings.hero_cart_label,
              checkout_label: section.settings.hero_checkout_label,
              primary_link: hero_cta_primary,
              secondary_link: hero_cta_secondary,
              primary_class: 'btn btn--hero-primary',
              secondary_class: 'btn btn--hero-ghost',
              show_icon: section.settings.cta1_icon
            -%}
          </div>
        {%- endif -%}
        {%- if section.settings.trust_text != blank -%}
          <p class="blc-hero__trust">{{ section.settings.trust_text }}</p>
        {%- endif -%}
      </div>
    </div>

  {%- else -%}
    {%- comment -%}Split layout{%- endcomment -%}
    <div class="blc-hero__split {% if section.settings.media_position == 'right' %}blc-hero__split--media-right{% endif %}">

      <div class="blc-hero__split-media" style="background:{{ section.settings.split_media_bg | default: '#0d2318' }}">
        {%- if section.settings.bg_image != blank -%}
          <img
            src="{{ section.settings.bg_image | image_url: width: 900 }}"
            alt="{{ section.settings.bg_image.alt | default: 'Product image' | escape }}"
            width="900" height="1100"
            loading="eager" decoding="async"
            class="blc-hero__split-img">
        {%- elsif hero_product != blank and hero_product.featured_image != blank -%}
          {%- assign prod_img_alt = hero_product.featured_image.alt | default: hero_product.title | escape -%}
          <img
            src="{{ hero_product.featured_image | image_url: width: 900 }}"
            srcset="{{ hero_product.featured_image | image_url: width: 450 }} 450w, {{ hero_product.featured_image | image_url: width: 900 }} 900w, {{ hero_product.featured_image | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 768px) 100vw, 50vw"
            width="900"
            height="1100"
            loading="eager"
            decoding="async"
            class="blc-hero__split-img"
            alt="{{ prod_img_alt }}"
            data-main-image>
        {%- else -%}
          <div class="blc-hero__split-placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if hero_offer_enabled and hero_offer_label != blank -%}
          <div class="blc-hero__offer-badge">
            <span class="blc-hero__offer-dot"></span>
            {{ hero_offer_label | escape }}
          </div>
        {%- endif -%}

        {%- if hero_is_sale and section.settings.show_sale_ribbon and settings.sale_stripe_enabled -%}
          <div class="blc-hero__ribbon{% if settings.sale_stripe_animate %} blc-hero__ribbon--animate{% endif %}">
            <span>{{ settings.sale_stripe_text | default: 'Sale' | escape }}{% if settings.sale_stripe_show_savings %} - Save {{ hero_save_pct }}%{% endif %}</span>
          </div>
        {%- endif -%}

        {%- comment -%}Floating highlight cards overlay (PeakFlow layout) {%- endcomment -%}
        {%- if section.blocks.size > 0 -%}
          <div class="blc-hero__highlights">
            {%- for block in section.blocks -%}
              {%- if block.type == 'highlight' -%}
                <div class="blc-hero__highlight reveal" style="transition-delay: {{ forloop.index0 | times: 100 }}ms;" {{ block.shopify_attributes }}>
                  <div class="blc-hero__highlight-icon">
                    {%- case block.settings.icon -%}
                      {%- when 'hydration' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2C6 9 4 13 4 16a8 8 0 0 0 16 0c0-3-2-7-8-14z"/></svg>
                      {%- when 'display' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                      {%- when 'battery' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="2" y="7" width="16" height="10" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/></svg>
                      {%- when 'weight' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.31M15 8a6 6 0 0 0-6 6"/><path d="M3.82 19.31a10.32 10.32 0 0 0 9.4-8.19"/></svg>
                      {%- when 'shield' -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                      {%- else -%}
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {%- endcase -%}
                  </div>
                  <div class="blc-hero__highlight-text">
                    <div class="blc-hero__highlight-title">{{ block.settings.title }}</div>
                    {%- if block.settings.subtitle != blank -%}
                      <div class="blc-hero__highlight-sub">{{ block.settings.subtitle }}</div>
                    {%- endif -%}
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="blc-hero__split-content" style="background:{{ section.settings.split_content_bg | default: '#faf9f7' }}">
        <div class="blc-hero__split-inner">

          {%- if section.settings.best_seller_text != blank or section.settings.best_seller_stars -%}
            <div class="blc-hero__badge-row reveal">
              {%- if section.settings.best_seller_text != blank -%}
                <span class="blc-hero__badge-text">{{ section.settings.best_seller_text }}</span>
              {%- endif -%}
              {%- if section.settings.best_seller_stars -%}
                <div class="blc-hero__badge-stars">
                  {%- for i in (1..5) -%}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="#f5a623" stroke="#f5a623" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- endfor -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.eyebrow != blank and section.settings.best_seller_text == blank -%}
            <p class="blc-hero__eyebrow reveal" style="color:{{ section.settings.accent_color | default: '#1d6b44' }}">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          <h1 class="blc-hero__heading blc-hero__heading--split reveal" style="color:{{ section.settings.heading_color | default: '#111111' }}">
            {{ section.settings.heading | default: "This Week's Drop" }}
          </h1>

          {%- if section.settings.subheading != blank -%}
            <p class="blc-hero__sub blc-hero__sub--split reveal" style="color:{{ section.settings.subheading_color | default: '#444444' }}">{{ section.settings.subheading }}</p>
          {%- endif -%}

          {%- if hero_product != blank and section.settings.show_price -%}
            <div class="blc-hero__price-row reveal">
              <span class="blc-hero__price{% if hero_is_sale %} blc-hero__price--sale{% endif %}" data-price-now>{{ hero_price | money }}</span>
              <span class="blc-hero__price-was" data-price-compare{% unless hero_is_sale %} style="display:none;"{% endunless %}>{{ hero_compare | money }}</span>
              <span class="blc-hero__price-save" data-sale-badge{% unless hero_is_sale %} style="display:none;"{% endunless %}>Save {{ hero_save_pct }}%</span>
            </div>
          {%- endif -%}

          {%- render 'hero-product-controls',
            product: hero_product,
            variant: hero_fv,
            show_options: section.settings.show_variant_picker,
            show_quantity: section.settings.show_quantity_selector
          -%}

          {%- if section.settings.show_buttons -%}
            <div class="blc-hero__btns reveal">
              {%- capture hero_primary_style -%}background:{{ section.settings.cta1_bg | default: '#1a1a1a' }};color:{{ section.settings.cta1_color | default: '#ffffff' }}{%- endcapture -%}
              {%- render 'hero-cta-buttons',
                mode: section.settings.cta_button_mode,
                product: hero_product,
                variant: hero_fv,
                primary_label: section.settings.cta1_label,
                secondary_label: section.settings.cta2_label,
                cart_label: section.settings.hero_cart_label,
                checkout_label: section.settings.hero_checkout_label,
                primary_link: hero_cta_primary,
                secondary_link: hero_cta_secondary,
                primary_class: 'btn btn--hero-primary-dark',
                secondary_class: 'btn btn--hero-ghost-dark',
                primary_style: hero_primary_style,
                show_icon: section.settings.cta1_icon
              -%}
            </div>
          {%- endif -%}

          {%- if section.settings.trust_text != blank -%}
            <p class="blc-hero__trust blc-hero__trust--split reveal">{{ section.settings.trust_text }}</p>
          {%- endif -%}

          {%- if section.settings.show_countdown -%}
            <div class="reveal">
              {%- render 'offer-countdown',
                id: section.id,
                variant: 'boxed',
                label: section.settings.countdown_label,
                end_datetime: section.settings.countdown_end,
                days_label: 'Days',
                hours_label: 'Hours',
                mins_label: 'Min',
                secs_label: 'Sec'
              -%}
            </div>
          {%- endif -%}

        </div>
      </div>
    </div>
  {%- endif -%}

</section>

<style>
.blc-hero { position: relative; overflow: hidden; width: 100%; }

/* Full-bleed */
.blc-hero--full {
  min-height: {{ section.settings.min_height | default: 600 }}px;
  display: flex; align-items: center;
}
.blc-hero--dark  { background: {{ section.settings.bg_color | default: '#0d2318' }}; }
.blc-hero--light { background: #f7f6f2; }
.blc-hero__bg { position: absolute; inset: 0; z-index: 0; }
.blc-hero__bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
.blc-hero__bg-img--mobile { display: none; }
@media (max-width: 768px) {
  .blc-hero__bg-img--desktop { display: none; }
  .blc-hero__bg-img--mobile  { display: block; }
}
.blc-hero__bg--gradient { background: linear-gradient(135deg, #0d2318 0%, #1a4a2e 50%, #0d2318 100%); }
.blc-hero__overlay { position: absolute; inset: 0; background: rgba(0,0,0,var(--overlay-opacity,0.5)); }

.blc-hero__content {
  position: relative; z-index: 1;
  max-width: 680px;
  padding-block: clamp(48px, 8vw, 96px);
}
.blc-hero__content--left   { margin-right: auto; text-align: left; }
.blc-hero__content--center { margin-inline: auto; text-align: center; }
.blc-hero__content--right  { margin-left: auto; text-align: right; }
.blc-hero__content--center .blc-hero__btns { justify-content: center; }
.blc-hero__content--right  .blc-hero__btns { justify-content: flex-end; }

/* Split */
.blc-hero--split { min-height: clamp(480px, 70vh, 820px); }
.blc-hero__split { display: grid; grid-template-columns: 1fr 1fr; min-height: inherit; }

.blc-hero__split-media { position: relative; overflow: hidden; }
.blc-hero__split-img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center top;
  display: block;
  transition: transform 8s ease;
}
.blc-hero--split:hover .blc-hero__split-img { transform: scale(1.04); }
.blc-hero__split-placeholder {
  width: 100%; height: 100%; min-height: 400px;
  display: flex; align-items: center; justify-content: center;
  background: #1a2e1c; color: rgba(255,255,255,0.35);
}

/* Floating Highlights styling */
.blc-hero__highlights {
  position: absolute;
  right: 24px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 16px;
  z-index: 12;
  pointer-events: none;
}
.blc-hero__highlight {
  display: flex;
  align-items: center;
  gap: 12px;
  background: var(--color-surface, #ffffff);
  border: 1px solid var(--color-border, #dddbd7);
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  border-radius: var(--radius-md, 12px);
  padding: 12px 18px;
  width: 220px;
  pointer-events: auto;
  transition: transform 0.3s ease;
}
.blc-hero__highlight:hover {
  transform: translateX(-4px);
}
.blc-hero__highlight-icon {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--color-deco-light, #e6f4ed);
  color: var(--color-deco, #1d6b44);
  display: flex;
  align-items: center;
  justify-content: center;
}
.blc-hero__highlight-title {
  font-weight: 700;
  font-size: 13px;
  color: var(--color-text, #111111);
  line-height: 1.2;
}
.blc-hero__highlight-sub {
  font-size: 10px;
  color: var(--color-text-muted, #666666);
  margin-top: 2px;
}

@media (max-width: 991px) {
  .blc-hero__highlights { right: 16px; }
  .blc-hero__highlight { width: 190px; padding: 10px 14px; }
}

@media (max-width: 768px) {
  .blc-hero__highlights {
    position: relative;
    top: auto; right: auto;
    transform: none;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    padding: 16px;
    background: var(--color-bg);
    width: 100%;
  }
  .blc-hero__highlight {
    width: auto;
    flex: 1 1 150px;
  }
}

.blc-hero__offer-badge {
  position: absolute; top: 24px; left: 24px; z-index: 10;
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.25);
  color: #fff; font-size: 11px; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 8px 14px; border-radius: 9999px;
}
.blc-hero__offer-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 0 3px rgba(74,222,128,0.35);
  animation: hero-dot-pulse 2s ease-in-out infinite;
}
@keyframes hero-dot-pulse {
  0%,100% { box-shadow: 0 0 0 3px rgba(74,222,128,0.35); }
  50%      { box-shadow: 0 0 0 7px rgba(74,222,128,0.1); }
}
.blc-hero__ribbon {
  position: absolute; bottom: 18px; left: 0;
  background: var(--color-sale, #e8260d); color: #fff;
  font-size: 12px; font-weight: 800;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 9px 26px 9px 18px;
  clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 50%, calc(100% - 14px) 100%, 0 100%);
  transform: skewY(-4deg);
  transform-origin: left center;
  box-shadow: 0 12px 28px rgba(0,0,0,0.16);
  overflow: hidden;
}
.blc-hero__ribbon span {
  display: inline-block;
  transform: skewY(4deg);
}
.blc-hero__ribbon::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(100deg, transparent 0%, rgba(255,255,255,0.3) 45%, transparent 70%);
  transform: translateX(-130%);
}
.blc-hero__ribbon--animate {
  animation: sale-stripe-bend 3.8s ease-in-out infinite;
}
.blc-hero__ribbon--animate::after {
  animation: sale-stripe-shine 3.8s ease-in-out infinite;
}
@keyframes sale-stripe-bend {
  0%,100% { transform: skewY(-4deg) translateX(0); }
  50% { transform: skewY(3deg) translateX(5px); }
}
@keyframes sale-stripe-shine {
  0%,40% { transform: translateX(-130%); }
  72%,100% { transform: translateX(130%); }
}

.blc-hero__split-content {
  display: flex; align-items: center;
  padding: clamp(32px, 5vw, 80px);
}
.blc-hero__split-inner {
  max-width: 480px; width: 100%;
  display: flex; flex-direction: column; gap: 20px;
}

/* Badge Row styling */
.blc-hero__badge-row {
  display: inline-flex;
  align-items: center;
  gap: 10px;
}
.blc-hero__badge-text {
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-secondary, #e8260d);
  background: var(--color-sale-bg, #fff1f0);
  padding: 4px 10px;
  border-radius: var(--radius-sm, 4px);
}
.blc-hero__badge-stars {
  display: flex;
  align-items: center;
  gap: 2px;
}

.blc-hero__heading {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 4rem);
  font-weight: 800; line-height: 1.1; letter-spacing: -0.01em;
}
.blc-hero--dark  .blc-hero__heading { color: {{ section.settings.heading_color | default: '#ffffff' }}; }
.blc-hero--light .blc-hero__heading { color: var(--color-text); }
.blc-hero__heading--split {
  font-size: clamp(2rem, 3.5vw, 3.5rem);
  letter-spacing: -0.02em;
}
.blc-hero__sub {
  font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.6; max-width: 520px;
}
.blc-hero--dark  .blc-hero__sub { color: {{ section.settings.subheading_color | default: 'rgba(255,255,255,0.8)' }}; }
.blc-hero--light .blc-hero__sub { color: var(--color-text-muted); }
.blc-hero__sub--split { max-width: 42ch; }

.blc-hero__eyebrow {
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
}

.blc-hero__price-row { display: flex; align-items: center; flex-wrap: wrap; gap: 10px; }
.blc-hero__price { font-size: clamp(1.6rem, 2.5vw, 2.2rem); font-weight: 800; font-variant-numeric: tabular-nums; }
.blc-hero__price--sale { color: var(--color-sale, #e8260d); }
.blc-hero__price-was { font-size: 1rem; color: var(--color-text-muted); text-decoration: line-through; }
.blc-hero__price-save {
  background: var(--color-sale-bg, #fff1f0); color: var(--color-sale, #e8260d);
  font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: 9999px;
}
.blc-hero--full.blc-hero--dark .blc-hero__price-was { color: rgba(255,255,255,0.68); }

.blc-hero__options {
  display: grid;
  gap: 12px;
  max-width: 440px;
}
.blc-hero__content--center .blc-hero__options,
.blc-hero__content--center .blc-hero__purchase-row {
  margin-inline: auto;
}
.blc-hero__content--right .blc-hero__options,
.blc-hero__content--right .blc-hero__purchase-row {
  margin-left: auto;
}
.blc-hero__option { margin: 0; }
.blc-hero__option-label {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 8px;
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}
.blc-hero__option-label strong {
  color: var(--color-text);
  font-weight: 800;
}
.blc-hero__swatches {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.blc-hero__swatch {
  width: 34px;
  height: 34px;
  padding: 0;
  border-radius: 50%;
  background: var(--swatch-color, #d1d5db);
  border: 2px solid color-mix(in oklab, var(--color-border) 80%, #000 10%);
}
.blc-hero__swatch[style*="black"] { background: #111111; }
.blc-hero__swatch[style*="white"] { background: #ffffff; }
.blc-hero__swatch[style*="grey"],
.blc-hero__swatch[style*="gray"] { background: #9ca3af; }
.blc-hero__swatch[style*="red"] { background: #dc2626; }
.blc-hero__swatch[style*="blue"] { background: #2563eb; }
.blc-hero__swatch[style*="navy"] { background: #1f2a44; }
.blc-hero__swatch[style*="green"] { background: #16a34a; }
.blc-hero__swatch[style*="pink"] { background: #ec4899; }
.blc-hero__swatch[style*="purple"] { background: #7c3aed; }
.blc-hero__swatch[style*="orange"] { background: #f97316; }
.blc-hero__swatch[style*="yellow"] { background: #facc15; }
.blc-hero__swatch[style*="brown"] { background: #8b5e34; }
.blc-hero__swatch[style*="beige"] { background: #d6c4a6; }
.blc-hero__swatch.is-active {
  box-shadow: 0 0 0 2px var(--color-bg), 0 0 0 4px var(--color-text);
}
.blc-hero__pill {
  min-height: 38px;
  padding: 8px 14px;
  border-radius: var(--radius-pill);
  background: var(--color-bg);
  color: var(--color-text);
}
.blc-hero__purchase-row {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
}
.blc-hero__qty {
  width: fit-content;
  background: var(--color-bg);
}
.blc-hero__stock {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 6px 10px;
  border-radius: 9999px;
  background: var(--color-deco-light, #e6f4ed);
  color: var(--color-deco, #1d6b44);
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.blc-hero__stock.is-sold-out {
  background: var(--color-sale-bg, #fff1f0);
  color: var(--color-sale, #e8260d);
}
.blc-hero--full .blc-hero__price-row,
.blc-hero--full .blc-hero__options,
.blc-hero--full .blc-hero__purchase-row {
  margin-top: 16px;
}
.blc-hero--full.blc-hero--dark .blc-hero__option-label,
.blc-hero--full.blc-hero--dark .blc-hero__option-label strong {
  color: #fff;
}
.blc-hero--full.blc-hero--dark .blc-hero__pill {
  background: rgba(255,255,255,0.12);
  border-color: rgba(255,255,255,0.36);
  color: #fff;
}
.blc-hero--full.blc-hero--dark .blc-hero__pill.is-active {
  background: #fff;
  color: #111;
}

.blc-hero__btns { display: flex; flex-wrap: wrap; gap: var(--sp-3); align-items: center; }

.btn--hero-primary,
.btn--hero-primary-dark {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 14px 32px; min-height: 52px;
  font-weight: 700; font-size: var(--text-sm); letter-spacing: 0.02em;
  border-radius: var(--btn-radius, 9999px); text-decoration: none;
  border: none; cursor: pointer;
  gap: 8px;
  transition: transform var(--trans-base), box-shadow var(--trans-base);
}
.btn--hero-primary {
  background: {{ section.settings.cta1_bg | default: '#ffffff' }};
  color: {{ section.settings.cta1_color | default: '#0d2318' }};
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
}
.btn--hero-primary:hover,
.btn--hero-primary-dark:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.22);
}

.btn--hero-ghost,
.btn--hero-ghost-dark {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 14px 32px; min-height: 52px; background: transparent;
  font-weight: 700; font-size: var(--text-sm); letter-spacing: 0.02em;
  border-radius: var(--btn-radius, 9999px); text-decoration: none;
  transition: border-color var(--trans-base), background var(--trans-base), color var(--trans-base);
}
.btn--hero-ghost     { color: #fff; border: 2px solid rgba(255,255,255,0.6); }
.btn--hero-ghost:hover     { border-color: #fff; background: rgba(255,255,255,0.1); }
.btn--hero-ghost-dark      { color: var(--color-text); border: 2px solid var(--color-border); }
.btn--hero-ghost-dark:hover { border-color: var(--color-text); background: var(--color-surface); }

.blc-hero__trust { font-size: var(--text-xs); }
.blc-hero--dark  .blc-hero__trust { color: rgba(255,255,255,0.55); }
.blc-hero--light .blc-hero__trust { color: var(--color-text-muted); }
.blc-hero__trust--split { color: var(--color-text-faint); }

@media (min-width: 769px) {
  .blc-hero__split--media-right .blc-hero__split-media {
    order: 2;
  }
  .blc-hero__split--media-right .blc-hero__split-content {
    order: 1;
  }
}

@media (max-width: 768px) {
  .blc-hero__split {
    grid-template-columns: 1fr;
    grid-template-rows: clamp(280px, 50vw, 420px) auto;
  }
  .blc-hero__split-content { padding: 28px 20px 36px; }
  .blc-hero__split-inner   { max-width: 100%; }
  .blc-hero__options { max-width: 100%; }
  .blc-hero__purchase-row { align-items: flex-start; }
  .blc-hero__btns { flex-direction: column; align-items: stretch; }
  .blc-hero__btns .btn--hero-primary,
  .blc-hero__btns .btn--hero-primary-dark,
  .blc-hero__btns .btn--hero-ghost,
  .blc-hero__btns .btn--hero-ghost-dark { width: 100%; justify-content: center; }
  .blc-hero--full { min-height: 480px; }
}
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "shopify-section-hero",
  "settings": [
    { "type": "header", "content": "Layout" },
    { "type": "select", "id": "layout", "label": "Hero layout",
      "options": [
        { "value": "split", "label": "Split — product image, content" },
        { "value": "full",  "label": "Full bleed — image background" }
      ], "default": "split" },
    { "type": "select", "id": "media_position", "label": "Media position (Desktop)",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ], "default": "right" },
    { "type": "header", "content": "Star Badge Row" },
    { "type": "text",     "id": "best_seller_text", "label": "Badge label text", "default": "BEST SELLER" },
    { "type": "checkbox", "id": "best_seller_stars", "label": "Show 5 star rating", "default": true },
    { "type": "header", "content": "Content" },
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow text (if no badge)",  "default": "New Weekly Drop" },
    { "type": "textarea", "id": "heading",    "label": "Heading",       "default": "This Week's Drop" },
    { "type": "textarea", "id": "subheading", "label": "Subheading",    "default": "Premium products designed for comfort, beauty, and everyday luxury." },
    { "type": "text",     "id": "trust_text", "label": "Trust line (below buttons)", "default": "Free shipping $75+ \u00b7 30-day returns \u00b7 Secure checkout" },
    { "type": "header", "content": "Product" },
    { "type": "product",  "id": "hero_product",    "label": "Featured product" },
    { "type": "checkbox", "id": "show_price",      "label": "Show product price",       "default": true },
    { "type": "checkbox", "id": "show_variant_picker", "label": "Show color / size options", "default": true },
    { "type": "checkbox", "id": "show_quantity_selector", "label": "Show quantity selector", "default": true },
    { "type": "checkbox", "id": "show_sale_ribbon","label": "Show sale ribbon on image", "default": true },
    { "type": "header", "content": "Countdown Timer" },
    { "type": "checkbox", "id": "show_countdown",   "label": "Show countdown timer",    "default": false,
      "info": "Reads offer end date from Theme Settings > Weekly Offer." },
    { "type": "text",     "id": "countdown_label", "label": "Countdown label",          "default": "Offer ends in" },
    { "type": "text",     "id": "countdown_end",   "label": "Custom countdown end (ISO 8601)", "info": "Leave blank to use Theme Settings > Weekly Offer countdown source." },
    { "type": "header", "content": "CTA Buttons" },
    { "type": "checkbox", "id": "show_buttons", "label": "Show CTA buttons", "default": true },
    { "type": "select", "id": "cta_button_mode", "label": "Button action",
      "info": "Product actions use this section product first, then Theme Settings > Storefront Mode > Primary product.",
      "options": [
        { "value": "checkout_permalink", "label": "Direct checkout product" },
        { "value": "cart_permalink", "label": "Open cart with product" },
        { "value": "cart_and_checkout", "label": "Show cart and checkout buttons" },
        { "value": "add_to_cart", "label": "Add product to cart" },
        { "value": "custom_links", "label": "Use custom links" }
      ],
      "default": "checkout_permalink" },
    { "type": "text",     "id": "hero_checkout_label", "label": "Checkout button label", "default": "Buy Now" },
    { "type": "text",     "id": "hero_cart_label",     "label": "Cart button label",     "default": "Add to Cart" },
    { "type": "text",     "id": "cta1_label", "label": "Custom button 1 label", "default": "Buy Now" },
    { "type": "url",      "id": "cta1_link",  "label": "Button 1 link" },
    { "type": "checkbox", "id": "cta1_icon",  "label": "Show shopping cart icon", "default": true },
    { "type": "color",    "id": "cta1_bg",    "label": "Button 1 background", "default": "#1a1a1a" },
    { "type": "color",    "id": "cta1_color", "label": "Button 1 text color", "default": "#ffffff" },
    { "type": "text",     "id": "cta2_label", "label": "Custom button 2 label",      "default": "Learn More" },
    { "type": "url",      "id": "cta2_link",  "label": "Button 2 link" },
    { "type": "header", "content": "Colors (Split)" },
    { "type": "color", "id": "split_media_bg",   "label": "Image panel background",   "default": "#0d2318" },
    { "type": "color", "id": "split_content_bg", "label": "Content panel background", "default": "#faf9f7" },
    { "type": "color", "id": "heading_color",    "label": "Heading color",             "default": "#111111" },
    { "type": "color", "id": "subheading_color", "label": "Subheading color",          "default": "#555555" },
    { "type": "color", "id": "accent_color",     "label": "Eyebrow / accent color",    "default": "#1d6b44" },
    { "type": "header", "content": "Background / Full-bleed Mode" },
    { "type": "image_picker", "id": "bg_image",        "label": "Background / product image" },
    { "type": "image_picker", "id": "mobile_bg_image", "label": "Mobile background (optional)" },
    { "type": "select", "id": "color_scheme", "label": "Full-bleed color scheme",
      "options": [
        { "value": "dark",  "label": "Dark"  },
        { "value": "light", "label": "Light" }
      ], "default": "dark" },
    { "type": "color",    "id": "bg_color",       "label": "Background color (no image)", "default": "#0d2318" },
    { "type": "checkbox", "id": "show_overlay",   "label": "Show overlay (full-bleed)",   "default": true },
    { "type": "range",    "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 9, "step": 1, "default": 5, "unit": "/10" },
    { "type": "range",    "id": "min_height",      "label": "Min height (full-bleed, px)", "min": 300, "max": 900, "step": 50, "default": 600 },
    { "type": "header", "content": "Alignment (Full-bleed)" },
    { "type": "select", "id": "content_align", "label": "Content alignment",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ], "default": "left" }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Feature Highlight",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Tracks Hydration" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Real-time reminders" },
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "hydration", "label": "Hydration / Drop" },
          { "value": "display", "label": "Smart Display" },
          { "value": "battery", "label": "Battery Life" },
          { "value": "weight", "label": "Weight / Leaf" },
          { "value": "shield", "label": "Security Shield" }
        ], "default": "hydration" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "layout": "split",
        "media_position": "right",
        "heading": "This Week's Drop",
        "subheading": "Premium products designed for comfort, beauty, recovery, and everyday luxury.",
        "cta_button_mode": "checkout_permalink",
        "cta1_label": "Buy Now",
        "cta2_label": "Learn More",
        "eyebrow": "New Weekly Drop",
        "trust_text": "Free shipping $75+ \u00b7 30-day returns \u00b7 Secure checkout",
        "show_price": true,
        "show_buttons": true
      }
    }
  ]
}
{% endschema %}
