{%- assign align = section.settings.content_align | default: 'left' -%}

<section class="blc-hero blc-hero--{{ section.settings.color_scheme | default: 'dark' }}" {{ section.shopify_attributes }}>

  {%- if section.settings.bg_image != blank -%}
    <div class="blc-hero__bg">
      <img
        src="{{ section.settings.bg_image | image_url: width: 1800 }}"
        alt="{{ section.settings.bg_image.alt | default: 'Hero background' | escape }}"
        width="1800" height="900"
        loading="eager" decoding="async"
        class="blc-hero__bg-img">
      <div class="blc-hero__overlay" style="--overlay-opacity:{{ section.settings.overlay_opacity | default: 0.5 }}"></div>
    </div>
  {%- else -%}
    <div class="blc-hero__bg blc-hero__bg--gradient"></div>
  {%- endif -%}

  <div class="container">
    <div class="blc-hero__content blc-hero__content--{{ align }}">

      {%- if section.settings.eyebrow != blank -%}
        <p class="blc-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      <h1 class="blc-hero__heading">{{ section.settings.heading | default: 'Luxury Wellness for You, Your Home &amp; Your Pets' }}</h1>

      {%- if section.settings.subheading != blank -%}
        <p class="blc-hero__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <div class="blc-hero__btns">
        {%- if section.settings.cta1_label != blank -%}
          <a href="{{ section.settings.cta1_link | default: '/collections/all' }}" class="btn btn--hero-primary">{{ section.settings.cta1_label }}</a>
        {%- endif -%}
        {%- if section.settings.cta2_label != blank -%}
          <a href="{{ section.settings.cta2_link | default: '/collections/all' }}" class="btn btn--hero-ghost">{{ section.settings.cta2_label }}</a>
        {%- endif -%}
      </div>

      {%- if section.settings.trust_text != blank -%}
        <p class="blc-hero__trust">{{ section.settings.trust_text }}</p>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
.blc-hero {
  position: relative;
  overflow: hidden;
  min-height: {{ section.settings.min_height | default: 600 }}px;
  display: flex;
  align-items: center;
}
.blc-hero--dark { background: {{ section.settings.bg_color | default: '#0d2318' }}; }
.blc-hero--light { background: #f7f6f2; }

.blc-hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.blc-hero__bg-img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
}
.blc-hero__bg--gradient {
  background: linear-gradient(135deg, #0d2318 0%, #1a4a2e 50%, #0d2318 100%);
}
.blc-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0, var(--overlay-opacity, 0.5));
}

.blc-hero__content {
  position: relative;
  z-index: 1;
  max-width: 680px;
  padding-block: clamp(48px, 8vw, 96px);
}
.blc-hero__content--left  { margin-right: auto; text-align: left; }
.blc-hero__content--center { margin-inline: auto; text-align: center; }
.blc-hero__content--right { margin-left: auto; text-align: right; }

.blc-hero__content--center .blc-hero__btns { justify-content: center; }
.blc-hero__content--right  .blc-hero__btns { justify-content: flex-end; }

.blc-hero__eyebrow {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: {{ section.settings.accent_color | default: '#7dc98f' }};
  margin-bottom: var(--sp-4);
}
.blc-hero__heading {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 4rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.01em;
  margin-bottom: var(--sp-5);
}
.blc-hero--dark .blc-hero__heading { color: {{ section.settings.heading_color | default: '#ffffff' }}; }
.blc-hero--light .blc-hero__heading { color: var(--color-text); }

.blc-hero__sub {
  font-size: clamp(1rem, 1.5vw, 1.2rem);
  line-height: 1.6;
  max-width: 520px;
  margin-bottom: var(--sp-8);
}
.blc-hero--dark .blc-hero__sub { color: {{ section.settings.subheading_color | default: 'rgba(255,255,255,0.8)' }}; }
.blc-hero--light .blc-hero__sub { color: var(--color-text-muted); }

.blc-hero__btns {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-3);
  align-items: center;
}
.btn--hero-primary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 32px;
  min-height: 52px;
  background: {{ section.settings.cta1_bg | default: '#ffffff' }};
  color: {{ section.settings.cta1_color | default: '#0d2318' }};
  font-weight: 700;
  font-size: var(--text-sm);
  letter-spacing: 0.02em;
  border-radius: var(--btn-radius, 9999px);
  text-decoration: none;
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  transition: transform var(--trans-base), box-shadow var(--trans-base);
}
.btn--hero-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(0,0,0,0.3);
}
.btn--hero-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 32px;
  min-height: 52px;
  background: transparent;
  color: #ffffff;
  font-weight: 700;
  font-size: var(--text-sm);
  letter-spacing: 0.02em;
  border-radius: var(--btn-radius, 9999px);
  border: 2px solid rgba(255,255,255,0.6);
  text-decoration: none;
  transition: border-color var(--trans-base), background var(--trans-base);
}
.btn--hero-ghost:hover {
  border-color: #ffffff;
  background: rgba(255,255,255,0.1);
}
.blc-hero__trust {
  margin-top: var(--sp-6);
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.55);
}
.blc-hero--light .blc-hero__trust { color: var(--color-text-muted); }

@media (max-width: 600px) {
  .blc-hero { min-height: 480px; }
  .blc-hero__btns { flex-direction: column; align-items: stretch; }
  .blc-hero__btns .btn--hero-primary,
  .blc-hero__btns .btn--hero-ghost { width: 100%; justify-content: center; }
}
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "shopify-section-hero",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "New Collection 2026" },
    { "type": "textarea", "id": "heading", "label": "Heading", "default": "Luxury Wellness for You, Your Home & Your Pets" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium products designed for comfort, beauty, recovery, and everyday luxury." },
    { "type": "text", "id": "trust_text", "label": "Trust line (below buttons)", "default": "Free shipping $75+ \u00b7 30-day returns \u00b7 Secure checkout" },
    { "type": "header", "content": "Layout & Alignment" },
    { "type": "select", "id": "content_align", "label": "Content alignment", "options": [
      { "value": "left",   "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right",  "label": "Right" }
    ], "default": "left" },
    { "type": "range", "id": "min_height", "label": "Min height (px)", "min": 300, "max": 900, "step": 50, "default": 600 },
    { "type": "select", "id": "color_scheme", "label": "Color scheme", "options": [
      { "value": "dark",  "label": "Dark (text on image)" },
      { "value": "light", "label": "Light (text on white)" }
    ], "default": "dark" },
    { "type": "header", "content": "Primary Button" },
    { "type": "text", "id": "cta1_label", "label": "Button 1 label", "default": "Shop Now" },
    { "type": "url",  "id": "cta1_link",  "label": "Button 1 link" },
    { "type": "color", "id": "cta1_bg",   "label": "Button 1 background", "default": "#ffffff" },
    { "type": "color", "id": "cta1_color", "label": "Button 1 text color", "default": "#0d2318" },
    { "type": "header", "content": "Secondary Button" },
    { "type": "text", "id": "cta2_label", "label": "Button 2 label", "default": "View Collections" },
    { "type": "url",  "id": "cta2_link",  "label": "Button 2 link" },
    { "type": "header", "content": "Background" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image" },
    { "type": "range", "id": "overlay_opacity", "label": "Image overlay opacity", "min": 0, "max": 9, "step": 1, "default": 5, "unit": "/10" },
    { "type": "color", "id": "bg_color", "label": "Background color (no image)", "default": "#0d2318" },
    { "type": "header", "content": "Typography Colors" },
    { "type": "color", "id": "heading_color",    "label": "Heading color",    "default": "#ffffff" },
    { "type": "color", "id": "subheading_color", "label": "Subheading color", "default": "#cccccc" },
    { "type": "color", "id": "accent_color",     "label": "Eyebrow color",    "default": "#7dc98f" }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "settings": {
        "heading": "Luxury Wellness for You, Your Home & Your Pets",
        "subheading": "Premium products designed for comfort, beauty, recovery, and everyday luxury.",
        "cta1_label": "Shop Now",
        "cta2_label": "View Collections",
        "eyebrow": "New Collection 2026",
        "trust_text": "Free shipping $75+ \u00b7 30-day returns \u00b7 Secure checkout",
        "content_align": "left",
        "color_scheme": "dark"
      }
    }
  ]
}
{% endschema %}
