<style>
.hero {
  position: relative; overflow: hidden;
  min-height: {{ section.settings.height | default: 90 }}vh;
  display: flex; align-items: center;
  background: #1a1a1a;
}
.hero__bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center;
  background-repeat: no-repeat;
  transition: transform 8s ease-out;
}
.hero__bg img { width: 100%; height: 100%; object-fit: cover; }
.hero__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(105deg, rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.5 }}) 0%, rgba(0,0,0,{{ section.settings.overlay_opacity | default: 0.5 | times: 0.6 }}) 60%, transparent 100%);
}
.hero__content {
  position: relative; z-index: 2;
  color: #fff; max-width: 640px;
  padding: clamp(var(--sp-10), 8vw, var(--sp-24));
}
.hero__eyebrow {
  display: inline-flex; align-items: center; gap: var(--sp-2);
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.25);
  border-radius: var(--radius-full);
  padding: 6px 14px; margin-bottom: var(--sp-5);
  backdrop-filter: blur(4px);
}
.hero__eyebrow::before {
  content: ''; width: 6px; height: 6px;
  background: var(--color-primary); border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%,100% { opacity:1; transform:scale(1); }
  50% { opacity:0.6; transform:scale(1.4); }
}
.hero__title {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5.5vw, 5rem);
  font-weight: 700; line-height: 1.08;
  margin-bottom: var(--sp-5);
  text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}
.hero__sub {
  font-size: clamp(var(--text-base), 1.6vw, var(--text-lg));
  opacity: 0.88; line-height: 1.6;
  margin-bottom: var(--sp-8);
  max-width: 48ch;
}
.hero__ctas {
  display: flex; flex-wrap: wrap; gap: var(--sp-3);
  align-items: center;
}
.hero__badge {
  position: absolute; bottom: var(--sp-8); right: var(--sp-8);
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  border-radius: var(--radius-xl);
  padding: var(--sp-3) var(--sp-5);
  color: #fff; text-align: center;
  font-size: var(--text-xs);
}
.hero__badge-icon { font-size: 1.4rem; margin-bottom: 2px; }
.hero__badge-title { font-weight: 700; font-size: var(--text-sm); }
.hero__badge-sub { opacity: 0.75; }
.hero__scroll {
  position: absolute; bottom: var(--sp-6); left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: var(--sp-1);
  color: rgba(255,255,255,0.6); font-size: var(--text-xs); letter-spacing: 0.08em;
  animation: bounce-scroll 2s ease-in-out infinite;
}
@keyframes bounce-scroll {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(6px); }
}
.hero__scroll svg { width: 20px; height: 20px; }
@media (max-width: 768px) {
  .hero { min-height: {{ section.settings.height | default: 90 | times: 0.75 | round }}vh; min-height: 75vh; }
  .hero__content { padding: var(--sp-8) var(--sp-5); max-width: 100%; }
  .hero__badge { display: none; }
}
</style>

<section class="hero" aria-label="Hero banner">
  <div class="hero__bg">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}"
           srcset="{{ section.settings.image | image_url: width: 750 }} 750w,
                   {{ section.settings.image | image_url: width: 1200 }} 1200w,
                   {{ section.settings.image | image_url: width: 2000 }} 2000w"
           sizes="100vw"
           alt="{{ section.settings.heading | default: 'Hero image' | escape }}"
           width="2000" height="1200"
           loading="eager" fetchpriority="high">
    {%- else -%}
      <img src="https://picsum.photos/seed/fashion-luxury/2000/1200"
           alt="Luxury lifestyle products" width="2000" height="1200" loading="eager">
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__content reveal reveal--left">
    {%- if section.settings.eyebrow != blank -%}
      <div class="hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}

    <h1 class="hero__title">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        Luxury Wellness for You, Your Home &amp; Pets
      {%- endif -%}
    </h1>

    {%- if section.settings.subtext != blank -%}
      <p class="hero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="hero__ctas">
      {%- if section.settings.cta_1_text != blank -%}
        <a href="{{ section.settings.cta_1_url | default: '/collections/all' }}" class="btn btn--white btn--lg">
          {{ section.settings.cta_1_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.cta_2_text != blank -%}
        <a href="{{ section.settings.cta_2_url | default: '/collections/all' }}" class="btn btn--outline" style="border-color:rgba(255,255,255,0.5);color:#fff">
          {{ section.settings.cta_2_text }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_badge -%}
    <div class="hero__badge reveal">
      <div class="hero__badge-icon">{{ section.settings.badge_icon | default: '⭐' }}</div>
      <div class="hero__badge-title">{{ section.settings.badge_title | default: '4.9/5 Rating' }}</div>
      <div class="hero__badge-sub">{{ section.settings.badge_sub | default: '10,000+ happy customers' }}</div>
    </div>
  {%- endif -%}

  <div class="hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero background image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "New Collection 2026" },
    { "type": "text", "id": "heading", "label": "Main headline", "default": "Luxury Wellness for You, Your Home & Pets" },
    { "type": "textarea", "id": "subtext", "label": "Subheadline", "default": "Premium products designed for comfort, beauty, and everyday luxury." },
    { "type": "text", "id": "cta_1_text", "label": "Primary CTA text", "default": "Shop Now" },
    { "type": "url", "id": "cta_1_url", "label": "Primary CTA link" },
    { "type": "text", "id": "cta_2_text", "label": "Secondary CTA text", "default": "Explore All" },
    { "type": "url", "id": "cta_2_url", "label": "Secondary CTA link" },
    { "type": "range", "id": "height", "label": "Hero height (%vh)", "min": 50, "max": 100, "step": 5, "default": 90 },
    { "type": "range", "id": "overlay_opacity", "label": "Dark overlay opacity", "min": 0.1, "max": 0.8, "step": 0.05, "default": 0.45 },
    { "type": "checkbox", "id": "show_badge", "label": "Show trust badge", "default": true },
    { "type": "text", "id": "badge_icon", "label": "Badge icon (emoji)", "default": "⭐" },
    { "type": "text", "id": "badge_title", "label": "Badge title", "default": "4.9/5 Rating" },
    { "type": "text", "id": "badge_sub", "label": "Badge subtext", "default": "10,000+ happy customers" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
