{%- if section.settings.enabled -%}
<section
  id="ProductRecommendations-{{ section.id }}"
  class="product-recommendations section-spacing"
  data-product-recommendations
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-limit="{{ section.settings.product_limit }}"
  style="--pr-cols: {{ section.settings.columns_desktop }}; --pr-mobile-cols: {{ section.settings.columns_mobile }};"
  {{ section.shopify_attributes }}>
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h2 class="product-recommendations__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if recommendations.performed and recommendations.products_count > 0 -%}
      <div class="product-recommendations__grid">
        {%- for recommended_product in recommendations.products limit: section.settings.product_limit -%}
          {%- render 'product-card', product: recommended_product, index: forloop.index0 -%}
        {%- endfor -%}
      </div>
    {%- elsif section.settings.fallback_collection != blank -%}
      <div class="product-recommendations__grid">
        {%- for fallback_product in section.settings.fallback_collection.products limit: section.settings.product_limit -%}
          {%- render 'product-card', product: fallback_product, index: forloop.index0 -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
#ProductRecommendations-{{ section.id }} .product-recommendations__title {
  margin-bottom: clamp(20px, 4vw, 36px);
  font-family: var(--font-display);
  font-size: var(--text-xl);
}
#ProductRecommendations-{{ section.id }} .product-recommendations__grid {
  display: grid;
  grid-template-columns: repeat(var(--pr-cols), minmax(0, 1fr));
  gap: clamp(14px, 2vw, 24px);
}
@media (max-width: 640px) {
  #ProductRecommendations-{{ section.id }} .product-recommendations__grid {
    grid-template-columns: repeat(var(--pr-mobile-cols), minmax(0, 1fr));
  }
}
</style>
{%- endif -%}

{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "Enable section", "default": true },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You may also like" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "collection", "id": "fallback_collection", "label": "Fallback collection" },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "select", "id": "columns_mobile", "label": "Mobile columns", "options": [
      { "value": "1", "label": "1 column" },
      { "value": "2", "label": "2 columns" }
    ], "default": "2" }
  ],
  "presets": [{ "name": "Product Recommendations" }]
}
{% endschema %}
