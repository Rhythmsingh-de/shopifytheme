<section class="section">
  <div class="page-width" style="max-width:480px;">
    <h1 style="font-size:clamp(28px,4vw,42px);font-weight:900;letter-spacing:-.04em;margin:0 0 24px;">Log in</h1>
    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <div style="display:grid;gap:14px;margin-bottom:20px;">
        <div>
          <label for="CustomerEmail">Email</label>
          <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" style="width:100%;padding:12px 14px;border:1px solid #dfd7cc;border-radius:12px;margin-top:6px;">
        </div>
        <div>
          <label for="CustomerPassword">Password</label>
          <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" style="width:100%;padding:12px 14px;border:1px solid #dfd7cc;border-radius:12px;margin-top:6px;">
        </div>
      </div>
      <button class="btn btn-primary" type="submit" style="width:100%;">Log in</button>
    {% endform %}
    <p style="margin-top:16px;text-align:center;"><a href="{{ routes.account_register_url }}">Create account</a> · <a href="{{ routes.account_recover_url }}">Forgot password?</a></p>
  </div>
</section>
{% schema %}
{ "name": "Login", "settings": [] }
{% endschema %}
