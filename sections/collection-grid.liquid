<section class="section collection-grid-section">
  <div class="container">
    {%- if section.settings.eyebrow != blank or section.settings.title != blank -%}
      <div class="section-head reveal">
        {%- if section.settings.eyebrow != blank -%}
          <p class="section-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="section-title">{{ section.settings.title }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="coll-grid" style="--cols:{{ section.settings.columns | default: 4 }}">
      {%- for block in section.blocks -%}
        {%- assign col = collections[block.settings.collection] -%}
        <a href="{{ block.settings.url | default: col.url | default: '/collections/all' }}"
           class="coll-card reveal"
           style="transition-delay:{{ forloop.index0 | times: 80 }}ms;aspect-ratio:{{ section.settings.card_ratio | default: '3/4' }}"
           {{ block.shopify_attributes }}>
          {%- if col.image != blank -%}
            <img src="{{ col.image | image_url: width: 800 }}"
                 alt="{{ col.title | escape }}"
                 width="800" height="1067"
                 loading="lazy" decoding="async"
                 class="coll-card__img">
          {%- elsif block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}"
                 alt="{{ block.settings.name | escape }}"
                 width="800" height="1067"
                 loading="lazy" decoding="async"
                 class="coll-card__img">
          {%- else -%}
            <img src="https://picsum.photos/seed/{{ block.settings.name | handle }}/800/1067"
                 alt="{{ block.settings.name }}"
                 width="800" height="1067"
                 loading="lazy" decoding="async"
                 class="coll-card__img">
          {%- endif -%}
          <div class="coll-card__overlay"></div>
          <div class="coll-card__body">
            {%- if block.settings.tag != blank -%}
              <span class="coll-card__tag">{{ block.settings.tag }}</span>
            {%- endif -%}
            <h3 class="coll-card__name">{{ block.settings.name | default: col.title }}</h3>
            <span class="coll-card__cta">
              {{ block.settings.cta | default: 'Shop Now' }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </span>
          </div>
        </a>
      {%- else -%}
        {%- assign demo = 'Women,Men,Jewelry,Home Decor' | split: ',' -%}
        {%- assign demo_seeds = 'fashion-women,fashion-men,jewelry-luxury,home-decor' | split: ',' -%}
        {%- for d in demo -%}
          <a href="/collections/{{ d | handle }}" class="coll-card reveal" style="transition-delay:{{ forloop.index0 | times: 80 }}ms;aspect-ratio:3/4">
            <img src="https://picsum.photos/seed/{{ demo_seeds[forloop.index0] }}/800/1067" alt="{{ d }}" width="800" height="1067" loading="lazy" class="coll-card__img">
            <div class="coll-card__overlay"></div>
            <div class="coll-card__body">
              <h3 class="coll-card__name">{{ d }}</h3>
              <span class="coll-card__cta">Shop Now <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
            </div>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>
<style>
.section-head { text-align: center; margin-bottom: clamp(var(--sp-8),4vw,var(--sp-12)); }
.section-eyebrow {
  font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--color-primary);
  margin-bottom: var(--sp-2);
}
.section-title {
  font-family: var(--font-display);
  font-size: var(--text-xl); color: var(--color-text);
}
.coll-grid {
  display: grid;
  grid-template-columns: repeat(var(--cols,4), 1fr);
  gap: clamp(var(--sp-3),2vw,var(--sp-5));
}
.coll-card {
  position: relative; overflow: hidden;
  border-radius: var(--radius-card);
  display: block; text-decoration: none;
  cursor: pointer;
}
.coll-card__img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.6s var(--ease-out);
}
.coll-card:hover .coll-card__img { transform: scale(1.06); }
.coll-card__overlay {
  position: absolute; inset: 0;
  background: linear-gradient(0deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
  transition: background 0.4s var(--ease-out);
}
.coll-card:hover .coll-card__overlay {
  background: linear-gradient(0deg, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.25) 55%, transparent 100%);
}
.coll-card__body {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: var(--sp-5) var(--sp-4);
  color: #fff;
  transform: translateY(4px);
  transition: transform 0.35s var(--ease-out);
}
.coll-card:hover .coll-card__body { transform: translateY(0); }
.coll-card__tag {
  display: inline-block;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  background: var(--color-primary); color: #fff;
  border-radius: var(--radius-full);
  padding: 3px 10px; margin-bottom: var(--sp-2);
}
.coll-card__name {
  font-family: var(--font-display);
  font-size: clamp(var(--text-base),2vw,var(--text-lg));
  font-weight: 700; line-height: 1.2;
  margin-bottom: var(--sp-2);
}
.coll-card__cta {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: var(--text-xs); font-weight: 700;
  letter-spacing: 0.06em; text-transform: uppercase;
  opacity: 0;
  transform: translateY(6px);
  transition: opacity 0.3s var(--ease-out), transform 0.3s var(--ease-out);
}
.coll-card:hover .coll-card__cta { opacity: 1; transform: translateY(0); }
@media (max-width:1023px) { .coll-grid { --cols: 2 !important; } }
@media (max-width:640px)  { .coll-grid { --cols: 2 !important; gap: var(--sp-2); } }
</style>
{% schema %}
{
  "name": "Collection Grid",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label", "default": "Shop by Category" },
    { "type": "text", "id": "title", "label": "Section title", "default": "Find Your Style" },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "select", "id": "card_ratio", "label": "Card aspect ratio", "options": [
      { "value": "1/1", "label": "Square" },
      { "value": "3/4", "label": "Portrait (3:4)" },
      { "value": "4/5", "label": "Portrait (4:5)" },
      { "value": "16/9", "label": "Landscape (16:9)" }
    ], "default": "3/4" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Override image" },
        { "type": "text", "id": "tag", "label": "Badge label", "default": "New" },
        { "type": "text", "id": "name", "label": "Card title", "default": "Women's Style" },
        { "type": "text", "id": "cta", "label": "CTA text", "default": "Shop Now" },
        { "type": "url", "id": "url", "label": "Override link" }
      ]
    }
  ],
  "presets": [{ "name": "Collection Grid" }]
}
{% endschema %}
