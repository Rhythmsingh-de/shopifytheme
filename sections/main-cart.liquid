{%- liquid
  assign cart_count = cart.item_count
  assign free_threshold = settings.free_shipping_threshold
  if free_threshold == blank
    assign free_threshold = 0
  endif
  assign free_threshold_cents = free_threshold | times: 100
  assign free_shipping_unlocked = false
  if free_threshold == 0 or cart.total_price >= free_threshold_cents
    assign free_shipping_unlocked = true
  endif
  if free_threshold > 0
    assign remaining_cents = free_threshold_cents | minus: cart.total_price
    assign progress_pct = cart.total_price | times: 100 | divided_by: free_threshold_cents
    if progress_pct > 100
      assign progress_pct = 100
    endif
  else
    assign remaining_cents = 0
    assign progress_pct = 100
  endif
-%}

<section class="section-spacing" {{ section.shopify_attributes }}>
  <div class="container">
    <h1 class="cart-page__title">{{ 'cart.title' | t | default: 'Your Cart' }}</h1>

    {%- if cart_count > 0 -%}

      <!-- Free shipping progress -->
      <div class="cart-shipping-bar" aria-live="polite">
        <div class="cart-shipping-bar__text">
          {%- if free_shipping_unlocked -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-deco)" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>🎉 You've unlocked <strong>free shipping</strong>!</span>
          {%- else -%}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Add <strong>{{ remaining_cents | money }}</strong> more for free shipping</span>
          {%- endif -%}
        </div>
        <div class="cart-shipping-bar__track" role="progressbar"
          aria-valuenow="{{ progress_pct }}"
          aria-valuemin="0"
          aria-valuemax="100"
          aria-label="Free shipping progress">
          <div class="cart-shipping-bar__fill"
            style="width:{{ progress_pct }}%"
            data-progress="{{ progress_pct }}"></div>
        </div>
      </div>

      <div class="cart-layout">

        <!-- Items column -->
        <div class="cart-items" id="CartItems">
          {%- for item in cart.items -%}
            <div class="cart-item" data-key="{{ item.key }}">
              <a href="{{ item.url }}" class="cart-item__img-link" aria-label="View {{ item.product.title | escape }}" tabindex="-1">
                {%- if item.image != blank -%}
                  <img
                    src="{{ item.image | image_url: width: 180 }}"
                    alt="{{ item.image.alt | default: item.product.title | escape }}"
                    width="90" height="90"
                    loading="lazy" decoding="async">
                {%- else -%}
                  <div class="cart-item__img-placeholder">{{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                {%- endif -%}
              </a>

              <div class="cart-item__info">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                {%- if item.selling_plan_allocation != blank -%}
                  <p class="cart-item__selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                {%- endif -%}

                <div class="cart-item__row">
                  <div class="cart-qty" data-cart-qty data-key="{{ item.key }}" data-line="{{ forloop.index }}">
                    <button class="cart-qty__btn" data-qty-dec aria-label="Decrease quantity">&minus;</button>
                    <input class="cart-qty__val" type="number" value="{{ item.quantity }}"
                      min="0" max="99" readonly aria-label="Quantity for {{ item.product.title | escape }}">
                    <button class="cart-qty__btn" data-qty-inc aria-label="Increase quantity">&plus;</button>
                  </div>

                  <div class="cart-item__price-wrap">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <span class="cart-item__price cart-item__price--sale">{{ item.final_line_price | money }}</span>
                      <span class="cart-item__price cart-item__price--was">{{ item.original_line_price | money }}</span>
                    {%- else -%}
                      <span class="cart-item__price">{{ item.final_line_price | money }}</span>
                    {%- endif -%}
                  </div>

                  <button class="cart-item__remove"
                    data-remove-item
                    data-key="{{ item.key }}"
                    aria-label="Remove {{ item.product.title | escape }} from cart">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <polyline points="3 6 5 6 21 6"/>
                      <path d="M19 6l-1 14H6L5 6"/>
                      <path d="M10 11v6M14 11v6"/>
                      <path d="M9 6V4h6v2"/>
                    </svg>
                  </button>
                </div>

                {%- if item.message != blank -%}
                  <p class="cart-item__message">{{ item.message }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        <!-- Summary column -->
        <aside class="cart-summary" aria-label="Order summary">

          <!-- Upsell -->
          {%- if settings.cart_show_upsell -%}
            {%- assign upsell_title = section.settings.upsell_title | default: settings.cart_upsell_title | default: 'You might also like' -%}
            {%- if section.settings.upsell_product != blank -%}
              {%- assign upsell = section.settings.upsell_product -%}
              <div class="cart-upsell">
                <p class="cart-upsell__title">{{ upsell_title }}</p>
                <div class="cart-upsell__card">
                  {%- if upsell.featured_image != blank -%}
                    <img
                      src="{{ upsell.featured_image | image_url: width: 120 }}"
                      alt="{{ upsell.featured_image.alt | default: upsell.title | escape }}"
                      width="60" height="60"
                      loading="lazy" decoding="async">
                  {%- endif -%}
                  <div class="cart-upsell__info">
                    <a href="{{ upsell.url }}" class="cart-upsell__name">{{ upsell.title }}</a>
                    <p class="cart-upsell__price">{{ upsell.price | money }}</p>
                  </div>
                  {%- if upsell.available -%}
                    <button
                      class="btn btn--sm btn--primary"
                      data-add-to-cart
                      data-variant-id="{{ upsell.selected_or_first_available_variant.id }}"
                      data-qty="1"
                      aria-label="Add {{ upsell.title | escape }} to cart">
                      Add
                    </button>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}

          <!-- Order total -->
          <div class="cart-summary__totals">
            {%- if cart.cart_level_discount_applications.size > 0 -%}
              {%- for discount in cart.cart_level_discount_applications -%}
                <div class="cart-summary__row">
                  <span>{{ discount.title }}</span>
                  <span class="cart-summary__discount">&minus;{{ discount.total_allocated_amount | money }}</span>
                </div>
              {%- endfor -%}
            {%- endif -%}
            <div class="cart-summary__row cart-summary__row--subtotal">
              <span>Subtotal</span>
              <span id="CartSubtotal">{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-summary__tax-note">Taxes and shipping calculated at checkout</p>
          </div>

          <!-- Trust strip -->
          <div class="cart-trust">
            <div class="cart-trust-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              <span>{{ settings.trust_secure_title | default: 'Secure Checkout' }}</span>
            </div>
            <div class="cart-trust-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              <span>{{ settings.trust_returns_title | default: '30-Day Returns' }}</span>
            </div>
            <div class="cart-trust-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{{ settings.trust_shipping_title | default: 'International Shipping' }}</span>
            </div>
          </div>

          <!-- Checkout CTA -->
          {%- form 'cart', cart -%}
            <button type="submit" name="checkout"
              class="btn btn--primary btn--full btn--lg"
              aria-label="Proceed to checkout">
              Checkout &mdash; {{ cart.total_price | money }}
            </button>
          {%- endform -%}

          {%- if additional_checkout_buttons -%}
            <div class="cart-dynamic-btns">
              {{ content_for_additional_checkout_buttons }}
            </div>
          {%- endif -%}

          <!-- Payment icons -->
          <div class="cart-payment-icons">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'payment-icon' }}
            {%- endfor -%}
          </div>

        </aside>
      </div>

    {%- else -%}

      <!-- Empty state -->
      <div class="cart-empty">
        <div class="cart-empty__icon">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.3" aria-hidden="true">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
        </div>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven't added anything yet. Start exploring our collections.</p>
        <a href="/collections/all" class="btn btn--primary">Start Shopping</a>
      </div>

    {%- endif -%}
  </div>
</section>

<style>
.cart-page__title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  margin-bottom: var(--sp-6);
}
.cart-shipping-bar {
  background: var(--color-deco-light, #e6f4ed);
  border-radius: var(--radius-md);
  padding: var(--sp-3) var(--sp-4);
  margin-bottom: var(--sp-8);
}
.cart-shipping-bar__text {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-size: var(--text-sm);
  color: var(--color-text);
  margin-bottom: var(--sp-2);
}
.cart-shipping-bar__track {
  height: 6px;
  background: rgba(0,0,0,0.1);
  border-radius: var(--radius-full);
  overflow: hidden;
}
.cart-shipping-bar__fill {
  height: 100%;
  background: var(--color-deco, #1d6b44);
  border-radius: var(--radius-full);
  transition: width 0.6s cubic-bezier(0.16,1,0.3,1);
}
.cart-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--sp-12);
  align-items: start;
}
@media (max-width: 900px) {
  .cart-layout { grid-template-columns: 1fr; }
}

/* Cart items */
.cart-items { display: flex; flex-direction: column; gap: var(--sp-4); }
.cart-item {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: var(--sp-4);
  padding: var(--sp-4);
  background: var(--color-surface);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
}
.cart-item__img-link img {
  width: 90px; height: 90px;
  object-fit: cover;
  border-radius: var(--radius-sm);
}
.cart-item__img-placeholder {
  width: 90px; height: 90px;
  background: var(--color-surface-2);
  border-radius: var(--radius-sm);
}
.cart-item__title {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}
.cart-item__title:hover { text-decoration: underline; }
.cart-item__variant, .cart-item__selling-plan {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: 2px;
}
.cart-item__row {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-top: var(--sp-3);
  flex-wrap: wrap;
}
.cart-qty {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.cart-qty__btn {
  width: 34px; height: 36px;
  font-size: 1.1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text);
  transition: background var(--trans-base);
}
.cart-qty__btn:hover { background: var(--color-surface-2); }
.cart-qty__val {
  width: 40px; height: 36px;
  text-align: center;
  font-size: var(--text-xs);
  font-weight: 700;
  border: none;
  border-left: 1.5px solid var(--color-border);
  border-right: 1.5px solid var(--color-border);
  background: transparent;
  color: var(--color-text);
  -moz-appearance: textfield;
}
.cart-qty__val::-webkit-outer-spin-button,
.cart-qty__val::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.cart-item__price-wrap { display: flex; flex-direction: column; gap: 2px; margin-left: auto; text-align: right; }
.cart-item__price { font-size: var(--text-sm); font-weight: 700; color: var(--color-text); }
.cart-item__price--sale { color: var(--color-sale); }
.cart-item__price--was { font-size: var(--text-xs); color: var(--color-text-muted); text-decoration: line-through; font-weight: 400; }
.cart-item__remove {
  color: var(--color-text-muted);
  width: 32px; height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  transition: color var(--trans-base), background var(--trans-base);
}
.cart-item__remove:hover { color: var(--color-sale); background: var(--color-sale-bg); }
.cart-item__message { font-size: var(--text-xs); color: var(--color-sale); margin-top: var(--sp-1); }

/* Summary */
.cart-summary {
  position: sticky;
  top: 100px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--sp-5);
}

/* Upsell */
.cart-upsell {
  padding-bottom: var(--sp-5);
  border-bottom: 1px solid var(--color-border);
}
.cart-upsell__title {
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-text-muted);
  margin-bottom: var(--sp-3);
}
.cart-upsell__card {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}
.cart-upsell__card img {
  width: 60px; height: 60px;
  object-fit: cover;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
}
.cart-upsell__info { flex: 1; }
.cart-upsell__name {
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text);
  display: block;
}
.cart-upsell__price {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: 2px;
}
.btn--sm {
  padding: 7px 14px;
  font-size: var(--text-xs);
  min-height: 34px;
}

/* Totals */
.cart-summary__totals { display: flex; flex-direction: column; gap: var(--sp-2); }
.cart-summary__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}
.cart-summary__row--subtotal {
  font-size: var(--text-base);
  font-weight: 700;
  color: var(--color-text);
  padding-top: var(--sp-2);
  border-top: 1px solid var(--color-border);
}
.cart-summary__discount { color: var(--color-deco); font-weight: 600; }
.cart-summary__tax-note {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  margin-top: var(--sp-1);
}

/* Trust strip */
.cart-trust {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  padding: var(--sp-3) 0;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.cart-trust-item {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}

/* Dynamic checkout */
.cart-dynamic-btns { display: flex; flex-direction: column; gap: var(--sp-2); margin-top: var(--sp-2); }

/* Payment icons */
.cart-payment-icons {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: var(--sp-2);
  padding-top: var(--sp-2);
}
.payment-icon { height: 22px; width: auto; border-radius: 3px; }

/* Empty state */
.cart-empty {
  text-align: center;
  padding: var(--sp-24) var(--sp-4);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-4);
}
.cart-empty__icon {
  color: var(--color-text-muted);
  opacity: 0.4;
}
.cart-empty h2 {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  color: var(--color-text);
}
.cart-empty p {
  font-size: var(--text-base);
  color: var(--color-text-muted);
  max-width: 38ch;
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 24px;
  min-height: 48px;
  font-size: var(--text-sm);
  font-weight: 700;
  border-radius: var(--btn-radius, 9999px);
  text-decoration: none;
  transition: transform var(--trans-base), box-shadow var(--trans-base), background var(--trans-base);
  cursor: pointer;
  border: none;
  font-family: var(--font-body);
}
.btn--primary {
  background: var(--color-primary, #111);
  color: var(--color-primary-text, #fff);
}
.btn--primary:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-md);
}
.btn--ghost {
  background: transparent;
  color: var(--color-text);
  border: 1.5px solid var(--color-border);
}
.btn--ghost:hover { border-color: var(--color-text); }
.btn--full { width: 100%; }
.btn--lg { padding: 16px 32px; min-height: 56px; font-size: var(--text-base); }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  /* Qty stepper on cart page */
  document.querySelectorAll('[data-cart-qty]').forEach(function (wrap) {
    var key  = wrap.dataset.key;
    var line = parseInt(wrap.dataset.line);
    var inp  = wrap.querySelector('.cart-qty__val');
    wrap.querySelector('[data-qty-dec]').addEventListener('click', function () {
      var q = Math.max(0, parseInt(inp.value) - 1);
      inp.value = q;
      updateCartLine(line, q);
    });
    wrap.querySelector('[data-qty-inc]').addEventListener('click', function () {
      var q = parseInt(inp.value) + 1;
      inp.value = q;
      updateCartLine(line, q);
    });
  });

  /* Remove item */
  document.querySelectorAll('[data-remove-item]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var line = this.closest('[data-key]');
      var lineIndex = Array.from(document.querySelectorAll('.cart-item')).indexOf(line) + 1;
      updateCartLine(lineIndex, 0);
    });
  });

  function updateCartLine(line, qty) {
    fetch('{{ routes.cart_change_url }}.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty })
    })
    .then(function (r) { return r.json(); })
    .then(function () { location.reload(); });
  }

  /* Add upsell to cart */
  document.querySelectorAll('[data-add-to-cart]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var variantId = this.dataset.variantId;
      var qty = parseInt(this.dataset.qty) || 1;
      btn.disabled = true;
      btn.textContent = 'Adding...';
      fetch('{{ routes.cart_add_url }}.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      })
      .then(function (r) { return r.json(); })
      .then(function () { location.reload(); })
      .catch(function () { btn.disabled = false; btn.textContent = 'Add'; });
    });
  });
});
</script>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "upsell_product", "label": "Upsell product (shown in cart summary)" },
    { "type": "text", "id": "upsell_title", "label": "Upsell section title", "default": "You might also like" }
  ]
}
{% endschema %}
