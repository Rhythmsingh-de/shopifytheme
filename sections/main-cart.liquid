{%- liquid
  assign free_shipping_threshold = section.settings.free_shipping_threshold
  assign remaining = free_shipping_threshold | minus: cart.total_price | divided_by: 100.0
-%}
<section class="main-cart section-spacing" id="main-cart">
  <div class="container">
    <h1 class="page-title">Your Cart
      {%- if cart.item_count > 0 -%}
        <span class="cart-page__count">({{ cart.item_count }} item{{ cart.item_count | plural: '', 's' }})</span>
      {%- endif -%}
    </h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true" class="cart-empty-state__icon"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
        <h2>Your cart is empty</h2>
        <p>Looks like you haven\'t added anything yet.</p>
        <a href="/" class="btn btn--primary btn--lg">Continue Shopping &rarr;</a>
      </div>

    {%- else -%}
      <div class="cart-page-grid">

        <!-- Items column -->
        <div class="cart-items-col">

          {%- if free_shipping_threshold > 0 -%}
            {%- assign progress = cart.total_price | times: 100 | divided_by: free_shipping_threshold | at_most: 100 -%}
            <div class="cart-fs-bar">
              {%- if remaining > 0 -%}
                <p class="cart-fs-bar__label">Add <strong>{{ remaining | money }}</strong> more for <strong>free shipping</strong> 🚚</p>
              {%- else -%}
                <p class="cart-fs-bar__label cart-fs-bar__label--unlocked">✔️ You\'ve unlocked <strong>Free Shipping!</strong></p>
              {%- endif -%}
              <div class="cart-fs-bar__track"><div class="cart-fs-bar__fill" style="width:{{ progress }}%"></div></div>
            </div>
          {%- endif -%}

          {%- for item in cart.items -%}
            <div class="cart-item" data-line="{{ forloop.index }}" data-key="{{ item.key }}">
              <a href="{{ item.url }}" class="cart-item__img-wrap">
                <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" width="80" height="80" loading="lazy" class="cart-item__img">
              </a>
              <div class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__name">{{ item.product.title }}</a>
                {%- unless item.variant.title == 'Default Title' -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="cart-item__unit-price">{{ item.price | money }} each</p>
              </div>
              <div class="cart-item__right">
                <div class="qty-stepper">
                  <button class="qty-stepper__btn qty__btn--minus" aria-label="Decrease quantity" data-dir="down">&#8722;</button>
                  <input class="qty-stepper__val" type="number" value="{{ item.quantity }}" min="0" data-qty-input aria-label="Quantity">
                  <button class="qty-stepper__btn qty__btn--plus" aria-label="Increase quantity" data-dir="up">&#43;</button>
                </div>
                <p class="cart-item__line-price">{{ item.final_line_price | money }}</p>
                <button class="cart-item__del" data-key="{{ item.key }}" data-line="{{ forloop.index }}" aria-label="Remove {{ item.title | escape }}">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </div>
            </div>
          {%- endfor -%}

          <!-- Upsell block -->
          {%- if section.settings.upsell_product != blank -%}
            {%- assign up = section.settings.upsell_product -%}
            {%- assign up_variant = up.selected_or_first_available_variant -%}
            <div class="cart-upsell">
              <p class="cart-upsell__eyebrow">👍 Customers also love</p>
              <div class="cart-upsell__inner">
                {%- if up.featured_image -%}
                  <img src="{{ up.featured_image | image_url: width: 120 }}" alt="{{ up.title | escape }}" width="60" height="60" loading="lazy" class="cart-upsell__img">
                {%- endif -%}
                <div class="cart-upsell__info">
                  <p class="cart-upsell__name">{{ up.title }}</p>
                  <p class="cart-upsell__price">{{ up_variant.price | money }}</p>
                </div>
                <button class="btn btn--primary btn--sm" onclick="BLC.addToCart({{ up_variant.id }}, 1, this)" data-product-id="{{ up.id }}">Add</button>
              </div>
            </div>
          {%- endif -%}

        </div>

        <!-- Summary column -->
        <div class="cart-summary">
          <h2 class="cart-summary__heading">Order Summary</h2>

          <div class="cart-summary__lines">
            <div class="cart-summary__row">
              <span>Subtotal</span>
              <span id="cart-page-subtotal">{{ cart.total_price | money }}</span>
            </div>
            <div class="cart-summary__row">
              <span>Shipping</span>
              <span style="color:var(--color-deco)">Calculated at checkout</span>
            </div>
            {%- if cart.total_discounts > 0 -%}
              <div class="cart-summary__row cart-summary__row--savings">
                <span>You save</span>
                <span>&minus;{{ cart.total_discounts | money }}</span>
              </div>
            {%- endif -%}
          </div>

          <div class="cart-summary__total">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>

          <!-- Trust badges -->
          <div class="cart-trust-strip">
            <div class="cart-trust-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              <span>{{ settings.trust_secure_title | default: 'Secure Checkout' }}</span>
            </div>
            <div class="cart-trust-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
              <span>{{ settings.trust_returns_title | default: '30-Day Money Back' }}</span>
            </div>
            <div class="cart-trust-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              <span>{{ settings.trust_shipping_title | default: 'International Shipping' }}</span>
            </div>
          </div>

          <a href="/checkout" class="btn btn--primary btn--full btn--lg cart-checkout-btn">Proceed to Checkout &rarr;</a>

          <!-- Payment icons -->
          <div class="cart-payment-icons">
            <span>We accept:</span>
            {%- render 'payment-icons' -%}
          </div>

          <a href="/" class="cart-continue">&#8592; Continue shopping</a>
        </div>

      </div>
    {%- endif -%}
  </div>
</section>

<style>
.main-cart { padding: var(--sp-16) 0; }
.page-title { font-family: var(--font-display); font-size: var(--text-xl); font-weight: 700; margin-bottom: var(--sp-8); }
.cart-page__count { font-size: var(--text-base); font-weight: 400; color: var(--color-text-muted); margin-left: var(--sp-2); }

/* Empty state */
.cart-empty-state { display:flex;flex-direction:column;align-items:center;text-align:center;padding:var(--sp-20) var(--sp-8); }
.cart-empty-state__icon { color:var(--color-text-faint,#aaa);margin-bottom:var(--sp-6); }
.cart-empty-state h2 { font-size:var(--text-xl);margin-bottom:var(--sp-2); }
.cart-empty-state p { color:var(--color-text-muted);margin-bottom:var(--sp-8); }

/* Grid */
.cart-page-grid { display:grid;grid-template-columns:1fr 380px;gap:var(--sp-10);align-items:start; }
@media (max-width: 900px) { .cart-page-grid { grid-template-columns:1fr; } }

/* Free shipping bar */
.cart-fs-bar { background:var(--color-deco-light,#e6f4ed);border-radius:var(--radius-lg);padding:var(--sp-3) var(--sp-4);margin-bottom:var(--sp-6); }
.cart-fs-bar__label { font-size:var(--text-sm);color:var(--color-text);margin-bottom:var(--sp-2); }
.cart-fs-bar__label--unlocked { color:var(--color-deco,#1d6b44);font-weight:600; }
.cart-fs-bar__track { background:rgba(0,0,0,0.1);border-radius:9999px;height:6px;overflow:hidden; }
.cart-fs-bar__fill { background:var(--color-deco,#1d6b44);height:100%;border-radius:9999px;transition:width 0.4s ease; }

/* Cart items */
.cart-item { display:grid;grid-template-columns:80px 1fr auto;gap:var(--sp-4);align-items:center;padding:var(--sp-5) 0;border-bottom:1px solid var(--color-border,#ddd); }
.cart-item__img-wrap { border-radius:var(--radius-md);overflow:hidden;flex-shrink:0; }
.cart-item__img { border-radius:var(--radius-md);object-fit:cover; }
.cart-item__name { font-size:var(--text-sm);font-weight:600;color:var(--color-text);transition:color 180ms; }
.cart-item__name:hover { color:var(--color-secondary,#e8260d); }
.cart-item__variant { font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--sp-1); }
.cart-item__unit-price { font-size:var(--text-xs);color:var(--color-text-muted);margin-top:var(--sp-1); }
.cart-item__right { display:flex;flex-direction:column;align-items:flex-end;gap:var(--sp-2); }
.cart-item__line-price { font-size:var(--text-sm);font-weight:700; }
.cart-item__del { display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;color:var(--color-text-muted);transition:background 180ms,color 180ms; }
.cart-item__del:hover { background:var(--color-error-bg,#fdf2f2);color:var(--color-error,#c0392b); }

/* Qty stepper */
.qty-stepper { display:flex;align-items:center;border:1px solid var(--color-border);border-radius:var(--radius-md);overflow:hidden; }
.qty-stepper__btn { width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;color:var(--color-text-muted);background:none;border:none;cursor:pointer;transition:background 180ms; }
.qty-stepper__btn:hover { background:var(--color-surface-2,#f5f3f0); }
.qty-stepper__val { width:40px;text-align:center;border:none;outline:none;font-size:var(--text-sm);font-weight:600;background:none;-moz-appearance:textfield; }
.qty-stepper__val::-webkit-outer-spin-button,.qty-stepper__val::-webkit-inner-spin-button { -webkit-appearance:none; }

/* Upsell */
.cart-upsell { background:var(--color-surface-2,#f5f3f0);border-radius:var(--radius-lg);padding:var(--sp-4);margin-top:var(--sp-4); }
.cart-upsell__eyebrow { font-size:var(--text-xs);font-weight:700;color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:var(--sp-3); }
.cart-upsell__inner { display:flex;align-items:center;gap:var(--sp-3); }
.cart-upsell__img { border-radius:var(--radius-sm);object-fit:cover; }
.cart-upsell__info { flex:1; }
.cart-upsell__name { font-size:var(--text-sm);font-weight:600; }
.cart-upsell__price { font-size:var(--text-sm);color:var(--color-text-muted); }

/* Summary */
.cart-summary { background:var(--color-surface,#fff);border:1px solid var(--color-border);border-radius:var(--radius-xl);padding:var(--sp-6);position:sticky;top:100px; }
.cart-summary__heading { font-size:var(--text-lg);font-weight:700;margin-bottom:var(--sp-5); }
.cart-summary__lines { display:flex;flex-direction:column;gap:var(--sp-2);padding-bottom:var(--sp-4);border-bottom:1px solid var(--color-border);margin-bottom:var(--sp-4); }
.cart-summary__row { display:flex;justify-content:space-between;align-items:center;font-size:var(--text-sm); }
.cart-summary__row--savings { color:var(--color-deco,#1d6b44);font-weight:600; }
.cart-summary__total { display:flex;justify-content:space-between;align-items:center;font-size:var(--text-base);font-weight:700;margin-bottom:var(--sp-5); }

/* Trust strip */
.cart-trust-strip { display:flex;flex-direction:column;gap:var(--sp-2);padding:var(--sp-4);background:var(--color-deco-light,#e6f4ed);border-radius:var(--radius-md);margin-bottom:var(--sp-5); }
.cart-trust-item { display:flex;align-items:center;gap:var(--sp-2);font-size:var(--text-xs);color:var(--color-deco,#1d6b44);font-weight:500; }
.cart-trust-item svg { flex-shrink:0; }

.cart-checkout-btn { font-size:var(--text-base);font-weight:700;letter-spacing:.02em; }

.cart-payment-icons { display:flex;align-items:center;gap:var(--sp-2);flex-wrap:wrap;margin-top:var(--sp-4);font-size:var(--text-xs);color:var(--color-text-muted); }
.cart-continue { display:block;text-align:center;margin-top:var(--sp-3);font-size:var(--text-sm);color:var(--color-text-muted);transition:color 180ms; }
.cart-continue:hover { color:var(--color-text); }
</style>

{% schema %}
{
  "name": "Cart",
  "settings": [
    { "type": "product", "id": "upsell_product", "label": "Upsell product", "info": "Shown in cart to encourage one more purchase." },
    { "type": "number", "id": "free_shipping_threshold", "label": "Free shipping threshold (cents)", "default": 5000, "info": "e.g. 5000 = $50.00. Set 0 to hide the bar." }
  ]
}
{% endschema %}
