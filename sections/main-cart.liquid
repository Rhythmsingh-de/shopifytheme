<section class="main-cart">
  <div class="container">
    <h1 class="page-title">Your Cart</h1>
    {%- if cart.item_count == 0 -%}
      <p class="cart-empty">Your cart is empty. <a href="/">Continue shopping →</a></p>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="cart-item">
          <img src="{{ item.image | image_url: width: 100 }}" alt="{{ item.title }}" width="100" height="100">
          <div class="cart-item__info">
            <p class="cart-item__title">{{ item.title }}</p>
            <p class="cart-item__price">{{ item.final_price | money }}</p>
          </div>
        </div>
      {%- endfor -%}
      <div class="cart-total">
        <strong>Total: {{ cart.total_price | money }}</strong>
      </div>
      <a href="/checkout" class="fp__cta" style="display:inline-block; margin-top:24px; padding:18px 48px; text-decoration:none;">Checkout</a>
    {%- endif -%}
  </div>
</section>

<style>
  .main-cart { padding: 80px 0; }
  .page-title { font-size: 2rem; font-weight: 700; margin-bottom: 40px; }
  .cart-empty { color: var(--text-muted); font-size: 1rem; }
  .cart-empty a { color: var(--accent-color); }
  .cart-item { display: flex; gap: 24px; padding: 24px 0; border-bottom: 1px solid #f0f0f0; }
  .cart-item img { border-radius: var(--border-radius); object-fit: cover; }
  .cart-item__title { font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
  .cart-item__price { color: var(--text-muted); font-size: 0.95rem; }
  .cart-total { padding: 24px 0; font-size: 1.2rem; }
</style>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
