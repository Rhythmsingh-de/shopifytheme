{%- liquid
  assign products_per_page = section.settings.products_per_page | default: settings.collection_products_per_page | default: 24
  assign desktop_columns = section.settings.columns_desktop | default: settings.collection_columns_desktop | default: 4
  assign mobile_columns = section.settings.columns_mobile | default: settings.collection_columns_mobile | default: 2
  assign show_sort = section.settings.show_sort
  if show_sort == nil
    assign show_sort = settings.collection_show_sort
  endif
  assign show_filters = section.settings.show_filters
  if show_filters == nil
    assign show_filters = settings.collection_show_filters
  endif
-%}

<section
  id="MainCollection-{{ section.id }}"
  class="main-collection"
  style="--collection-cols: {{ desktop_columns }}; --collection-mobile-cols: {{ mobile_columns }};"
  {{ section.shopify_attributes }}>
  <div class="container">
    <div class="main-collection__toolbar">
      <div>
        <p class="main-collection__count">
          {{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}
        </p>
        {%- if settings.collection_show_trust_bar and settings.collection_trust_text != blank -%}
          <p class="main-collection__trust">{{ settings.collection_trust_text | escape }}</p>
        {%- endif -%}
      </div>

      {%- if show_sort and collection.products_count > 0 -%}
        <form class="main-collection__sort" method="get">
          {%- for filter in collection.filters -%}
            {%- if filter.active_values.size > 0 -%}
              {%- for value in filter.active_values -%}
                <input type="hidden" name="{{ value.param_name }}" value="{{ value.value }}">
              {%- endfor -%}
            {%- endif -%}
          {%- endfor -%}
          <label for="SortBy-{{ section.id }}" class="main-collection__sort-label">Sort</label>
          <select id="SortBy-{{ section.id }}" name="sort_by" class="main-collection__sort-select" onchange="this.form.submit()">
            {%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value | escape }}"{% if option.value == sort_by %} selected{% endif %}>{{ option.name | escape }}</option>
            {%- endfor -%}
          </select>
        </form>
      {%- endif -%}
    </div>

    {%- if show_filters and collection.filters.size > 0 -%}
      <form class="collection-filters" method="get">
        <div class="collection-filters__groups">
          {%- for filter in collection.filters -%}
            <details class="collection-filter" {% if filter.active_values.size > 0 %}open{% endif %}>
              <summary class="collection-filter__summary">
                <span>{{ filter.label | escape }}</span>
                {%- if filter.active_values.size > 0 -%}
                  <span class="collection-filter__count">{{ filter.active_values.size }}</span>
                {%- endif -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="collection-filter__body">
                {%- case filter.type -%}
                  {%- when 'list' -%}
                    {%- for value in filter.values -%}
                      <label class="collection-filter__check">
                        <input type="checkbox" name="{{ value.param_name }}" value="{{ value.value }}" {% if value.active %}checked{% endif %} {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                        <span>{{ value.label | escape }}</span>
                        <small>{{ value.count }}</small>
                      </label>
                    {%- endfor -%}
                  {%- when 'price_range' -%}
                    <div class="collection-filter__price">
                      <label>
                        <span>From</span>
                        <input name="{{ filter.min_value.param_name }}" type="number" min="0" {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}>
                      </label>
                      <label>
                        <span>To</span>
                        <input name="{{ filter.max_value.param_name }}" type="number" min="0" {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}>
                      </label>
                    </div>
                {%- endcase -%}
              </div>
            </details>
          {%- endfor -%}
        </div>
        <div class="collection-filters__actions">
          <button type="submit" class="btn btn--primary btn--sm">Apply filters</button>
          {%- if collection.url != blank -%}
            <a class="btn btn--ghost btn--sm" href="{{ collection.url }}">Clear</a>
          {%- endif -%}
        </div>
      </form>
    {%- endif -%}

    {%- paginate collection.products by products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <div class="collection-grid">
          {%- for product in collection.products -%}
            {%- render 'product-card', product: product, index: forloop.index0 -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="collection-pagination" role="navigation" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="btn btn--ghost btn--sm">Previous</a>
            {%- endif -%}
            <span>{{ paginate.current_page }} / {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="btn btn--primary btn--sm">Next</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <div class="main-collection__empty">
          <h2>{{ section.settings.empty_title | escape }}</h2>
          <p>{{ section.settings.empty_text | escape }}</p>
          {%- if settings.collection_show_empty_state_cta -%}
            <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary">{{ section.settings.empty_cta | escape }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

<style>
#MainCollection-{{ section.id }} {
  padding: clamp(36px, 6vw, 80px) 0;
}
#MainCollection-{{ section.id }} .main-collection__toolbar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--space-4);
  margin-bottom: clamp(20px, 4vw, 36px);
}
#MainCollection-{{ section.id }} .main-collection__count {
  color: var(--color-text);
  font-weight: 800;
}
#MainCollection-{{ section.id }} .main-collection__trust {
  margin-top: 4px;
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 700;
}
#MainCollection-{{ section.id }} .main-collection__sort {
  display: flex;
  align-items: center;
  gap: 10px;
}
#MainCollection-{{ section.id }} .main-collection__sort-label {
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: .08em;
  text-transform: uppercase;
}
#MainCollection-{{ section.id }} .main-collection__sort-select,
#MainCollection-{{ section.id }} .collection-filter input {
  min-height: 44px;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bg);
  color: var(--color-text);
  font: inherit;
}
#MainCollection-{{ section.id }} .main-collection__sort-select {
  padding: 0 36px 0 12px;
}
#MainCollection-{{ section.id }} .collection-filters {
  display: grid;
  gap: 16px;
  margin-bottom: clamp(24px, 4vw, 40px);
  padding: 16px;
  border: 1px solid var(--color-border);
  border-radius: var(--card-radius);
  background: var(--color-surface);
}
#MainCollection-{{ section.id }} .collection-filters__groups {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}
#MainCollection-{{ section.id }} .collection-filter {
  min-width: min(220px, 100%);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bg);
}
#MainCollection-{{ section.id }} .collection-filter__summary {
  display: flex;
  align-items: center;
  gap: 8px;
  justify-content: space-between;
  min-height: 44px;
  padding: 0 12px;
  cursor: pointer;
  font-size: var(--text-sm);
  font-weight: 800;
  list-style: none;
}
#MainCollection-{{ section.id }} .collection-filter__summary::-webkit-details-marker {
  display: none;
}
#MainCollection-{{ section.id }} .collection-filter[open] .collection-filter__summary svg {
  transform: rotate(180deg);
}
#MainCollection-{{ section.id }} .collection-filter__count {
  margin-left: auto;
  min-width: 20px;
  height: 20px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  background: var(--color-primary);
  color: var(--color-primary-text);
  font-size: 11px;
}
#MainCollection-{{ section.id }} .collection-filter__body {
  display: grid;
  gap: 8px;
  padding: 0 12px 12px;
}
#MainCollection-{{ section.id }} .collection-filter__check {
  display: flex;
  align-items: center;
  gap: 8px;
  min-height: 36px;
  color: var(--color-text);
  font-size: var(--text-sm);
}
#MainCollection-{{ section.id }} .collection-filter__check input {
  width: 18px;
  height: 18px;
  min-height: 0;
}
#MainCollection-{{ section.id }} .collection-filter__check small {
  margin-left: auto;
  color: var(--color-text-muted);
}
#MainCollection-{{ section.id }} .collection-filter__price {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}
#MainCollection-{{ section.id }} .collection-filter__price label {
  display: grid;
  gap: 4px;
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 700;
}
#MainCollection-{{ section.id }} .collection-filter__price input {
  width: 100%;
  padding: 0 10px;
}
#MainCollection-{{ section.id }} .collection-filters__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
#MainCollection-{{ section.id }} .collection-grid {
  display: grid;
  grid-template-columns: repeat(var(--collection-cols), minmax(0, 1fr));
  gap: clamp(16px, 2vw, 28px);
}
#MainCollection-{{ section.id }} .collection-pagination {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  margin-top: clamp(28px, 5vw, 48px);
}
#MainCollection-{{ section.id }} .collection-pagination span {
  color: var(--color-text-muted);
  font-size: var(--text-sm);
  font-weight: 800;
}
#MainCollection-{{ section.id }} .main-collection__empty {
  display: grid;
  justify-items: center;
  gap: 14px;
  text-align: center;
  padding: clamp(48px, 8vw, 96px) 16px;
  border: 1px solid var(--color-border);
  border-radius: var(--card-radius);
  background: var(--color-surface);
}
#MainCollection-{{ section.id }} .main-collection__empty h2 {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
}
#MainCollection-{{ section.id }} .main-collection__empty p {
  color: var(--color-text-muted);
  max-width: 48ch;
}
@media (max-width: 900px) {
  #MainCollection-{{ section.id }} .collection-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}
@media (max-width: 680px) {
  #MainCollection-{{ section.id }} .main-collection__toolbar {
    align-items: stretch;
    flex-direction: column;
  }
  #MainCollection-{{ section.id }} .main-collection__sort {
    justify-content: space-between;
  }
  #MainCollection-{{ section.id }} .main-collection__sort-select {
    flex: 1;
  }
  #MainCollection-{{ section.id }} .collection-grid {
    grid-template-columns: repeat(var(--collection-mobile-cols), minmax(0, 1fr));
    gap: 14px;
  }
}
@media (max-width: 360px) {
  #MainCollection-{{ section.id }} .collection-grid {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "Collection",
  "tag": "section",
  "settings": [
    { "type": "range", "id": "products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "range", "id": "columns_desktop", "label": "Desktop columns", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_mobile", "label": "Mobile columns", "min": 1, "max": 2, "step": 1, "default": 2 },
    { "type": "checkbox", "id": "show_sort", "label": "Show sort selector", "default": true },
    { "type": "checkbox", "id": "show_filters", "label": "Show filters", "default": true },
    { "type": "text", "id": "empty_title", "label": "Empty title", "default": "No products found" },
    { "type": "textarea", "id": "empty_text", "label": "Empty text", "default": "Try clearing filters or browse all products." },
    { "type": "text", "id": "empty_cta", "label": "Empty CTA label", "default": "Browse all products" }
  ]
}
{% endschema %}
