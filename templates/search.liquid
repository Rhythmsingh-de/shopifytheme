{% layout 'theme' %}
<main id="main-content" class="section">
  <div class="container">
    <div class="section-head">
      <h1 style="font-family:var(--font-display);font-size:var(--text-xl)">
        {% if search.performed %}
          {% if search.results_count == 0 %}No results for "{{ search.terms }}"{% else %}{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for "{{ search.terms }}"{% endif %}
        {% else %}Search{% endif %}
      </h1>
    </div>
    <form action="/search" method="get" style="margin-bottom:var(--sp-10)">
      <input type="hidden" name="type" value="product">
      <div style="display:flex;gap:var(--sp-3);max-width:600px;margin:0 auto">
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products..." class="form-input" style="flex:1" aria-label="Search">
        <button type="submit" class="btn btn--primary">Search</button>
      </div>
    </form>
    {% if search.performed and search.results_count > 0 %}
      <div class="prod-grid" style="--cols:4">
        {% for result in search.results %}
          {% if result.object_type == 'product' %}
            {% assign product = result %}
            {% render 'product-card', product: product, index: forloop.index0 %}
          {% endif %}
        {% endfor %}
      </div>
    {% elsif search.performed %}
      <div style="text-align:center;padding:var(--sp-16) 0">
        <p style="color:var(--color-text-muted);margin-bottom:var(--sp-6)">Try different keywords or browse our collections.</p>
        <a href="/collections/all" class="btn btn--primary">Browse All Products</a>
      </div>
    {% endif %}
  </div>
</main>
