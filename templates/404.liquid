{% layout 'theme' %}
<main id="main-content" class="section" style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center">
  <div class="container" style="max-width:560px">
    <p style="font-size:clamp(5rem,15vw,9rem);font-weight:900;font-family:var(--font-display);line-height:1;color:var(--color-border);margin-bottom:var(--sp-4)">404</p>
    <h1 style="font-family:var(--font-display);font-size:var(--text-xl);margin-bottom:var(--sp-3)">Page Not Found</h1>
    <p style="color:var(--color-text-muted);margin-bottom:var(--sp-8)">The page you're looking for has moved or doesn't exist. Let's get you back on track.</p>
    <div style="display:flex;gap:var(--sp-3);justify-content:center;flex-wrap:wrap">
      <a href="/" class="btn btn--primary btn--lg">Back to Home</a>
      <a href="/collections/all" class="btn btn--outline btn--lg">Shop All</a>
    </div>
  </div>
</main>
