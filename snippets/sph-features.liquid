{%- liquid
  # SPH-01: accept only explicitly passed variables (section, blocks, storefront_mode, feature_blocks, fallback_features)
  # SPH-03: replace at_most with precomputed feature_blocks count passed in, or count here with limit logic
  assign _blocks = feature_blocks | default: section.blocks
  assign _show   = section.settings.show_features | default: false

  assign _count = 0
  for block in _blocks
    if block.type == 'feature'
      assign _count = _count | plus: 1
    endif
  endfor
-%}

{%- if _show and _count > 0 -%}
{%- liquid
  assign _cols = _count
  if _cols > 3
    assign _cols = 3
  endif
-%}
<section class="sph-features" aria-label="Key features">
  <div class="container">
    <div class="sph-features__grid" style="grid-template-columns: repeat({{ _cols }}, 1fr);">
      {%- assign _rendered = 0 -%}
      {%- for block in _blocks -%}
        {%- if block.type == 'feature' and _rendered < 3 -%}
          {%- assign feature_icon = block.settings.icon -%}
          <div class="sph-features__item" {{ block.shopify_attributes }}>
            <div class="sph-features__icon" aria-hidden="true">
              {%- render 'sph-icon', icon: feature_icon, size: 40 -%}
            </div>
            <strong class="sph-features__title">{{ block.settings.title }}</strong>
            {%- if block.settings.subtitle != blank -%}
              <span class="sph-features__sub">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </div>
          {%- assign _rendered = _rendered | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
