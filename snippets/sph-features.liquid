{%- liquid
  assign feature_blocks = 0
  for block in section.blocks
    if block.type == 'feature'
      assign feature_blocks = feature_blocks | plus: 1
    endif
  endfor
-%}

{%- if section.settings.show_features and feature_blocks > 0 -%}
<section class="sph-features" aria-label="Key features">
  <div class="container">
    <div class="sph-features__grid" style="grid-template-columns: repeat({{ feature_blocks | at_most: 3 }}, 1fr);">
      {%- for block in section.blocks -%}
        {%- if block.type == 'feature' -%}
          <div class="sph-features__item" {{ block.shopify_attributes }}>
            <div class="sph-features__icon" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'water' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6 9 4 13 4 16a8 8 0 0 0 16 0c0-3-2-7-8-14z"/></svg>
                {%- when 'leaf' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 8C8 10 5.9 16.17 3.82 19.31M15 8a6 6 0 0 0-6 6"/><path d="M3.82 19.31a10.32 10.32 0 0 0 9.4-8.19"/></svg>
                {%- when 'bag' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                {%- when 'shield' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {%- when 'truck' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- when 'star' -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 8 12 12 14 14"/></svg>
              {%- endcase -%}
            </div>
            <strong class="sph-features__title">{{ block.settings.title }}</strong>
            {%- if block.settings.subtitle != blank -%}
              <span class="sph-features__sub">{{ block.settings.subtitle }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>
{%- endif -%}
