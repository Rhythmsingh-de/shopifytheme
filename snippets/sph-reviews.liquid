{%- liquid
  assign _section = section
  assign _blocks  = blocks
  assign _sp      = sp
  assign _visible = visible_reviews_count | default: 3
  assign _cycling = review_slider_cycling
  assign _interval = review_slider_interval | default: 4
-%}
<div class="sph-reviews">
  {%- if _section.settings.reviews_title != blank -%}
    <h2 class="sph-section-title">{{ _section.settings.reviews_title | escape }}</h2>
  {%- endif -%}

  {%- assign review_blocks = 0 -%}
  {%- for block in _blocks -%}
    {%- if block.type == 'review' -%}
      {%- assign review_blocks = review_blocks | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if review_blocks > 0 -%}
    <div
      class="sph-review-cards"
      data-cycling="{{ _cycling | json }}"
      data-interval="{{ _interval | times: 1000 }}"
      data-visible="{{ _visible }}">
      {%- for block in _blocks -%}
        {%- if block.type == 'review' -%}
          <div class="sph-review-card" {{ block.shopify_attributes }}>
            <div class="sph-review-card__head">
              {%- if block.settings.avatar != blank -%}
                {{ block.settings.avatar | image_url: width: 80 | image_tag: class: 'sph-review-card__avatar', loading: 'lazy', width: 40, height: 40, alt: block.settings.name }}
              {%- else -%}
                <div class="sph-review-card__avatar sph-review-card__avatar--initials" aria-hidden="true">
                  {{ block.settings.name | upcase | truncate: 2, '' }}
                </div>
              {%- endif -%}
              <div>
                <span class="sph-review-card__name">{{ block.settings.name | escape }}</span>
                <div class="sph-review-card__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {%- assign r = block.settings.rating | default: 5 | plus: 0 -%}
                  {%- for i in (1..5) -%}
                    <svg width="12" height="12" viewBox="0 0 24 24"
                      fill="{% if i <= r %}var(--color-gold, #c8941a){% else %}none{% endif %}"
                      stroke="var(--color-gold, #c8941a)" stroke-width="1.5" aria-hidden="true">
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                    </svg>
                  {%- endfor -%}
                </div>
              </div>
            </div>
            {%- if block.settings.images != blank -%}
              <div class="sph-review-card__imgs">
                {{ block.settings.images | image_url: width: 120 | image_tag: loading: 'lazy', width: 60, height: 60, alt: '' }}
              </div>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="sph-review-card__body">{{ block.settings.body | escape }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%}SPH-12: proper ARIA live-status region for ATC response (not on button){%- endcomment -%}
    <p class="visually-hidden" data-atc-status role="status" aria-live="polite" aria-atomic="true"></p>
  {%- endif -%}
</div>
