{%- liquid
  assign tracking_mode = settings.tracking_mode | default: 'consent'
-%}

{%- comment -%}
  Tracking mode override — controlled from theme settings:
  Compliance & Tracking > Tracking mode
  Values: consent (default) | always_on | always_off
{%- endcomment -%}

<script>
window.BLC = window.BLC || {};
window.BLC.trackingMode = {{ tracking_mode | json }};

(function() {
  var mode = window.BLC.trackingMode;

  function readConsent() {
    var cookies = document.cookie.split(';');
    for (var i = 0; i < cookies.length; i++) {
      var c = cookies[i].trim();
      if (c.indexOf('blc_cookie_consent=') === 0) return c.split('=')[1];
    }
    return null;
  }

  function writeConsent(value) {
    var d = new Date();
    d.setDate(d.getDate() + 365);
    var exp = '; expires=' + d.toUTCString() + '; path=/; SameSite=Lax';
    document.cookie = 'blc_cookie_consent=' + value + exp;
    document.cookie = 'blc_cookie=' + (value === 'accepted' ? '1' : '0') + exp;
  }

  function setShopifyConsent(granted) {
    if (window.Shopify && window.Shopify.customerPrivacy) {
      try {
        window.Shopify.customerPrivacy.setTrackingConsent({
          analytics: !!granted,
          marketing: !!granted,
          preferences: !!granted
        }, function() {});
      } catch (e) {}
    }
  }

  function resolveConsent() {
    if (mode === 'always_on')  return 'accepted';
    if (mode === 'always_off') return 'declined';
    return readConsent(); /* null = not yet decided */
  }

  window.BLC.isTrackingAllowed = function() {
    var c = resolveConsent();
    return c === 'accepted';
  };

  window.BLC.acceptCookies = function() {
    writeConsent('accepted');
    setShopifyConsent(true);
    if (typeof gtag === 'function') {
      gtag('consent', 'update', {
        ad_storage: 'granted',
        analytics_storage: 'granted',
        ad_user_data: 'granted',
        ad_personalization: 'granted'
      });
    }
    if (window.dataLayer) window.dataLayer.push({ event: 'cookie_consent', consent_choice: 'accepted', consent_timestamp: new Date().toISOString() });
    var el = document.getElementById('cookie-consent');
    if (el) hideBanner(el);
  };

  window.BLC.declineCookies = function() {
    writeConsent('declined');
    setShopifyConsent(false);
    if (typeof gtag === 'function') {
      gtag('consent', 'update', {
        ad_storage: 'denied',
        analytics_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied'
      });
    }
    if (window.dataLayer) window.dataLayer.push({ event: 'cookie_consent', consent_choice: 'declined', consent_timestamp: new Date().toISOString() });
    var el = document.getElementById('cookie-consent');
    if (el) hideBanner(el);
  };

  function hideBanner(el) {
    document.documentElement.classList.remove('cookie-consent-open');
    el.classList.add('is-hidden');
    setTimeout(function() { el.setAttribute('hidden', ''); }, 380);
  }

  /* Emit resolved consent to dataLayer immediately */
  var resolved = resolveConsent();
  if (resolved === 'accepted') {
    setShopifyConsent(true);
  } else if (resolved === 'declined') {
    setShopifyConsent(false);
  }

  /* Expose for GTM/datalayer.js to gate events */
  window.BLC.consentResolved = resolved;

})();
</script>

{%- if settings.gdpr_cookie_banner and tracking_mode == 'consent' -%}
<div id="cookie-consent" class="cookie-consent" role="dialog" aria-modal="true" aria-label="Cookie consent" aria-live="polite" hidden>
  <div class="cookie-consent__inner">
    <div class="cookie-consent__text">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" class="cookie-consent__icon"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p>{{ settings.cookie_text | default: 'We use cookies to enhance your browsing experience, serve personalised content and analyse traffic.' }}
        {%- if settings.privacy_policy_url != blank -%}
          <a href="{{ settings.privacy_policy_url }}" class="cookie-consent__link">Privacy Policy</a>.
        {%- else -%}
          <a href="/policies/privacy-policy" class="cookie-consent__link">Privacy Policy</a>.
        {%- endif -%}
      </p>
    </div>
    <div class="cookie-consent__actions">
      <button id="cookie-accept" class="btn btn--primary btn--sm" aria-label="Accept all cookies">Accept All</button>
      <button id="cookie-decline" class="btn btn--ghost btn--sm" aria-label="Decline non-essential cookies">Decline</button>
    </div>
  </div>
</div>

<style>
.cookie-consent {
  position: fixed;
  bottom: var(--sp-4, 1rem);
  left: 50%;
  transform: translateX(-50%) translateY(0);
  z-index: 9999;
  width: min(760px, calc(100vw - 32px));
  background: var(--color-surface, #fff);
  border: 1px solid var(--color-border, #ddd);
  border-radius: var(--radius-xl, 16px);
  box-shadow: 0 8px 40px rgba(0,0,0,0.14);
  padding: var(--sp-4, 1rem) var(--sp-5, 1.25rem);
  transition: opacity 0.35s ease, transform 0.35s ease;
}
.cookie-consent[hidden] { display: none !important; }
.cookie-consent.is-hidden { opacity: 0; transform: translateX(-50%) translateY(24px); pointer-events: none; }
html.cursor-active.cookie-consent-open .cursor-dot,
html.cursor-active.cookie-consent-open .cursor-ring {
  opacity: 0 !important;
}
html.cursor-active .cookie-consent,
html.cursor-active .cookie-consent * {
  cursor: auto !important;
}
html.cursor-active .cookie-consent button,
html.cursor-active .cookie-consent a {
  cursor: pointer !important;
}
.cookie-consent__inner { display: flex; align-items: center; gap: var(--sp-5, 1.25rem); flex-wrap: wrap; }
.cookie-consent__icon { flex-shrink: 0; color: var(--color-deco, #1d6b44); }
.cookie-consent__text { display: flex; align-items: flex-start; gap: var(--sp-2, 0.5rem); flex: 1; font-size: var(--text-xs, 0.8125rem); color: var(--color-text-muted, #6b7280); }
.cookie-consent__text p { max-width: none; }
.cookie-consent__link { color: var(--color-deco, #1d6b44); text-decoration: underline; }
.cookie-consent__actions { display: flex; gap: var(--sp-2, 0.5rem); flex-shrink: 0; }
@media (max-width: 480px) {
  .cookie-consent__inner { flex-direction: column; align-items: stretch; }
  .cookie-consent__actions { width: 100%; }
  .cookie-consent__actions .btn { flex: 1; justify-content: center; }
}
</style>

<script>
(function() {
  var el = document.getElementById('cookie-consent');
  if (!el) return;

  /* Already resolved via override or prior consent — remove banner */
  var existing = (document.cookie.split(';').map(function(c){return c.trim();}).filter(function(c){return c.indexOf('blc_cookie_consent=')===0;})[0] || '').split('=')[1];
  if (existing === 'accepted' || existing === 'declined') {
    document.documentElement.classList.remove('cookie-consent-open');
    el.remove();
    return;
  }

  /* Show after short delay */
  setTimeout(function() {
    el.removeAttribute('hidden');
    document.documentElement.classList.add('cookie-consent-open');
    void el.offsetWidth;
  }, 900);

  document.getElementById('cookie-accept').addEventListener('click', function() {
    window.BLC.acceptCookies();
  });

  document.getElementById('cookie-decline').addEventListener('click', function() {
    window.BLC.declineCookies();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && !el.hasAttribute('hidden')) window.BLC.declineCookies();
  });
})();
</script>
{%- endif -%}
