{%- if settings.gdpr_cookie_banner -%}
<div id="cookie-consent" class="cookie-consent hidden" role="dialog" aria-label="Cookie consent" aria-live="polite">
  <div class="cookie-consent__inner">
    <div class="cookie-consent__text">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" style="flex-shrink:0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p>{{ settings.cookie_text | default: "We use cookies to enhance your experience, analyze traffic, and serve personalized content. By continuing you agree to our" }}
        <a href="{{ settings.privacy_policy_url | default: '/policies/privacy-policy' }}" style="color:var(--color-primary);text-decoration:underline">Privacy Policy</a>.
      </p>
    </div>
    <div class="cookie-consent__actions">
      <button onclick="BLC.acceptCookies()" class="btn btn--primary btn--sm">Accept All</button>
      <button onclick="BLC.declineCookies()" class="btn btn--ghost btn--sm">Decline</button>
    </div>
  </div>
</div>
<style>
.cookie-consent {
  position: fixed; bottom: var(--sp-4); left: 50%; transform: translateX(-50%);
  z-index: 950; width: min(760px, calc(100vw - 32px));
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-lg);
  padding: var(--sp-4) var(--sp-5);
  transition: opacity 0.3s, transform 0.3s;
}
.cookie-consent.hidden { opacity: 0; pointer-events: none; transform: translateX(-50%) translateY(20px); }
.cookie-consent__inner { display: flex; align-items: center; gap: var(--sp-5); flex-wrap: wrap; }
.cookie-consent__text  { display: flex; align-items: flex-start; gap: var(--sp-2); flex: 1; font-size: var(--text-xs); color: var(--color-text-muted); }
.cookie-consent__text p { max-width: none; }
.cookie-consent__actions { display: flex; gap: var(--sp-2); flex-shrink: 0; }
</style>
<script>
(function(){
  var el = document.getElementById('cookie-consent');
  if (!el) return;
  var accepted = document.cookie.indexOf('blc_cookie=1') > -1;
  if (accepted) { el.remove(); return; }
  el.classList.remove('hidden');
})();
</script>
{%- endif -%}
