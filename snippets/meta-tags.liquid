{% comment %} SEO meta tags — included in layout/theme.liquid <head> {% endcomment %}
{%- liquid
  assign og_title       = page_title
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_image       = ''
  if product.featured_image
    assign og_image = product.featured_image | image_url: width: 1200
  elsif collection.image
    assign og_image = collection.image | image_url: width: 1200
  elsif page.image
    assign og_image = page.image | image_url: width: 1200
  elsif settings.og_default_image
    assign og_image = settings.og_default_image | image_url: width: 1200
  endif
-%}
<title>{{ og_title }}{% unless request.page_type == 'index' %} – {{ shop.name }}{% endunless %}</title>
<meta name="description" content="{{ og_description | strip_html | truncate: 160 }}">
<link rel="canonical" href="{{ canonical_url }}">
<!-- Open Graph -->
<meta property="og:type"        content="{% if request.page_type == 'product' %}product{% else %}website{% endif %}">
<meta property="og:title"       content="{{ og_title | escape }}">
<meta property="og:description" content="{{ og_description | strip_html | truncate: 200 | escape }}">
<meta property="og:url"         content="{{ canonical_url }}">
<meta property="og:site_name"   content="{{ shop.name | escape }}">
{%- if og_image != '' -%}
<meta property="og:image"       content="https:{{ og_image }}">
<meta property="og:image:width" content="1200">
{%- endif -%}
{%- if request.page_type == 'product' -%}
<meta property="og:price:amount"   content="{{ product.price | divided_by: 100.0 }}">
<meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}
<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image">
<meta name="twitter:title"       content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | strip_html | truncate: 200 | escape }}">
{%- if og_image != '' -%}
<meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}
<!-- Google / Structured Data -->
{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "url": {{ canonical_url | json }},
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  "image": [
    {%- for img in product.images limit: 3 -%}
      "https:{{ img | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "offers": {
    "@type": "Offer",
    "price": {{ product.price | divided_by: 100.0 }},
    "priceCurrency": {{ cart.currency.iso_code | json }},
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "url": {{ canonical_url | json }},
    "seller": { "@type": "Organization", "name": {{ shop.name | json }} }
  }
}
</script>
{%- endif -%}
<!-- Google Compliance: Privacy Policy link in head -->
{%- if settings.google_site_verification != blank -%}
<meta name="google-site-verification" content="{{ settings.google_site_verification }}">
{%- endif -%}
