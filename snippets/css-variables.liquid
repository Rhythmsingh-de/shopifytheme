{%- comment -%}
  css-variables.liquid
  Outputs the :root CSS custom-property block.
  Rendered once in layout/theme.liquid <head>.
{%- endcomment -%}
<style>
  :root {
    /* ── Surfaces ── */
    --color-bg:           {{ settings.color_bg           | default: '#faf9f7' }};
    --color-surface:      {{ settings.color_surface      | default: '#ffffff' }};
    --color-surface-2:    {{ settings.color_surface_2    | default: '#f5f3f0' }};
    --color-border:       {{ settings.color_border       | default: '#dddbd7' }};

    /* ── Text ── */
    --color-text:         {{ settings.color_text         | default: '#1a1a1a' }};
    --color-text-muted:   {{ settings.color_text_muted   | default: '#6b7280' }};
    --color-text-faint:   color-mix(in oklab, {{ settings.color_text | default: '#1a1a1a' }} 35%, {{ settings.color_bg | default: '#faf9f7' }});
    --color-text-inverse: {{ settings.color_btn_primary_text | default: '#ffffff' }};

    /* ── Buttons / Primary ── */
    --color-primary:        {{ settings.color_btn_primary_bg   | default: '#1a1a1a' }};
    --color-primary-hover:  color-mix(in oklab, {{ settings.color_btn_primary_bg | default: '#1a1a1a' }} 80%, #000000);
    --color-primary-active: color-mix(in oklab, {{ settings.color_btn_primary_bg | default: '#1a1a1a' }} 65%, #000000);
    --color-primary-text:   {{ settings.color_btn_primary_text | default: '#ffffff' }};
    --color-secondary:      {{ settings.color_secondary        | default: '#e8260d' }};

    /* ── Sale ── */
    --color-sale:    {{ settings.color_sale    | default: '#e8260d' }};
    --color-sale-bg: {{ settings.color_sale_bg | default: '#fff1f0' }};

    /* ── Accent ── */
    --color-gold:    #c8941a;
    --color-success: #1d6b44;

    /* ── Deco (trust / urgency) ── */
    --color-deco:       {{ settings.color_deco       | default: '#1d6b44' }};
    --color-deco-light: {{ settings.color_deco_light | default: '#e6f4ed' }};

    /* ── Header / Footer ── */
    --color-header-bg:   {{ settings.color_header_bg   | default: '#ffffff' }};
    --color-header-text: {{ settings.color_header_text | default: '#1a1a1a' }};
    --color-footer-bg:   {{ settings.color_footer_bg   | default: '#111111' }};
    --color-footer-text: {{ settings.color_footer_text | default: '#cccccc' }};

    /* ── Typography ── */
    {%- if settings.font_display != blank -%}
      --font-display:        {{ settings.font_display.family | json }}, Georgia, serif;
      --font-display-weight: {{ settings.font_display.weight }};
      --font-display-style:  {{ settings.font_display.style }};
      {%- assign _display_face = settings.font_display | font_face -%}
    {%- else -%}
      --font-display:        'Playfair Display', Georgia, serif;
      --font-display-weight: 400;
      --font-display-style:  normal;
    {%- endif -%}
    {%- if settings.font_body != blank -%}
      --font-body:        {{ settings.font_body.family | json }}, system-ui, sans-serif;
      --font-body-weight: {{ settings.font_body.weight }};
      --font-body-style:  {{ settings.font_body.style }};
    {%- else -%}
      --font-body:        'Work Sans', system-ui, sans-serif;
      --font-body-weight: 400;
      --font-body-style:  normal;
    {%- endif -%}
    --font-size-base: {{ settings.body_font_size | default: 16 }}px;

    /* ── Layout ── */
    --max-width:     {{ settings.container_max_width  | default: 1280 }}px;
    --card-radius:   {{ settings.card_border_radius   | default: 12 }}px;
    --btn-radius:    {{ settings.button_border_radius | default: '9999px' }};
    --header-height: 72px;

    /* ── Radius scale ── */
    --radius-sm:   4px;
    --radius-md:   8px;
    --radius-lg:   {{ settings.card_border_radius | default: 12 }}px;
    --radius-xl:   {{ settings.card_border_radius | default: 12 | plus: 4 }}px;
    --radius-full: 9999px;

    /* ── Spacing scale ── */
    --space-1:  0.25rem;  --sp-1:  0.25rem;
    --space-2:  0.5rem;   --sp-2:  0.5rem;
    --space-3:  0.75rem;  --sp-3:  0.75rem;
    --space-4:  1rem;     --sp-4:  1rem;
    --space-5:  1.25rem;  --sp-5:  1.25rem;
    --space-6:  1.5rem;   --sp-6:  1.5rem;
    --space-8:  2rem;     --sp-8:  2rem;
    --space-10: 2.5rem;   --sp-10: 2.5rem;
    --space-12: 3rem;     --sp-12: 3rem;
    --space-16: 4rem;     --sp-16: 4rem;
    --space-20: 5rem;     --sp-20: 5rem;
    --space-24: 6rem;     --sp-24: 6rem;
    --space-32: 8rem;     --sp-32: 8rem;

    /* ── Type scale ── */
    --text-xs:   0.75rem;
    --text-sm:   0.875rem;
    --text-base: 1rem;
    --text-lg:   1.125rem;
    --text-xl:   1.25rem;
    --text-2xl:  1.5rem;
    --text-3xl:  1.875rem;
    --text-4xl:  2.25rem;
  }

  {%- if settings.font_display != blank -%}
    {{ settings.font_display | font_face }}
    {{ settings.font_display | font_modify: 'weight', 'bolder' | font_face }}
  {%- endif -%}
  {%- if settings.font_body != blank -%}
    {{ settings.font_body | font_face }}
    {{ settings.font_body | font_modify: 'weight', 'bolder' | font_face }}
  {%- endif -%}
</style>
