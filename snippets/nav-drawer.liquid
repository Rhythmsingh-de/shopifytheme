<div id="nav-overlay" class="nav-overlay" aria-hidden="true"></div>

<nav id="nav-drawer" class="nav-drawer" role="dialog" aria-modal="true" aria-label="Main navigation" aria-hidden="true">
  <div class="nav-drawer__header">
    <a href="{{ routes.root_url }}" onclick="BLC.closeNav()" aria-label="{{ shop.name }} home">
      <span style="font-family:var(--font-display);font-weight:700;font-size:var(--text-lg)">{{ shop.name | escape }}</span>
    </a>
    <button
      id="mobileNavClose"
      onclick="BLC.closeNav()"
      aria-label="Close menu"
      class="nav-drawer__close-btn">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="nav-drawer__links">
    {%- for link in mobile_menu.links -%}
      {%- if link.links != blank -%}
        <div class="nav-drawer__group">
          <button
            class="nav-drawer__link nav-drawer__toggle"
            aria-expanded="false"
            aria-controls="NavDrawerSubmenu-{{ forloop.index }}"
            onclick="BLC.toggleNavGroup(this)">
            <span>{{ link.title | escape }}</span>
            <svg class="nav-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="nav-drawer__sub" id="NavDrawerSubmenu-{{ forloop.index }}">
            {%- for child_link in link.links -%}
              <a href="{{ child_link.url }}" class="nav-drawer__sub-link{% if child_link.active %} is-active{% endif %}" onclick="BLC.closeNav()">{{ child_link.title | escape }}</a>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        <a href="{{ link.url }}" class="nav-drawer__link{% if link.active %} is-active{% endif %}" onclick="BLC.closeNav()">{{ link.title | escape }}</a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if show_language_switcher -%}
    <div class="nav-drawer__language">
      {%- render 'language-switcher', style: 'drawer' -%}
    </div>
  {%- endif -%}

  {%- if show_account_links -%}
    <div class="nav-drawer__footer">
      {%- if customer -%}
        <a href="{{ routes.account_url }}" class="btn btn--outline btn--full" onclick="BLC.closeNav()">My Account</a>
        <a href="{{ routes.account_logout_url }}" class="btn btn--ghost btn--full" style="margin-top:8px" onclick="BLC.closeNav()">Sign Out</a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}" class="btn btn--outline btn--full" onclick="BLC.closeNav()">Sign In</a>
        <a href="{{ routes.account_register_url }}" class="btn btn--primary btn--full" style="margin-top:8px" onclick="BLC.closeNav()">Create Account</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</nav>

<style>
.nav-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 750;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.nav-overlay.is-open {
  opacity: 1;
  pointer-events: auto;
}
.nav-drawer {
  position: fixed; top: 0; left: 0; bottom: 0;
  width: min(360px, 92vw);
  background: var(--color-bg);
  z-index: 800;
  transform: translateX(-100%);
  transition: transform 0.35s var(--ease-out);
  display: flex; flex-direction: column;
  overflow: hidden;
  box-shadow: 8px 0 48px rgba(0,0,0,0.18);
}
.nav-drawer.open,
.nav-drawer.is-open {
  transform: translateX(0);
}

.nav-drawer__close-btn {
  width: 44px; height: 44px; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-text); background: none; border: none; cursor: pointer;
  transition: background var(--trans-fast), color var(--trans-fast);
  flex-shrink: 0;
}
.nav-drawer__close-btn:hover { background: var(--color-surface); color: var(--color-primary); }

.nav-drawer__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--sp-4) var(--sp-5);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0; min-height: 68px;
}

.nav-drawer__links {
  flex: 1; overflow-y: auto; padding: var(--sp-2) 0;
  -webkit-overflow-scrolling: touch;
}

.nav-drawer__link {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: var(--sp-3) var(--sp-5);
  font-size: var(--text-base); font-weight: 600;
  color: var(--color-text); background: none; border: none;
  border-bottom: 1px solid var(--color-border);
  text-align: left; cursor: pointer; text-decoration: none;
  transition: background var(--trans-fast), color var(--trans-fast);
  min-height: 52px;
}
.nav-drawer__link:last-child { border-bottom: none; }
.nav-drawer__link:hover, .nav-drawer__link:active {
  background: var(--color-surface); color: var(--color-primary);
}
.nav-drawer__link--sale { color: var(--color-sale) !important; }
.nav-drawer__link--sale:hover { background: #fef2f2; }

.nav-chevron {
  flex-shrink: 0;
  transition: transform 0.25s var(--ease-out);
}
.nav-drawer__toggle[aria-expanded="true"] .nav-chevron { transform: rotate(180deg); }

/* Accordion sub-menu */
.nav-drawer__sub {
  max-height: 0; overflow: hidden;
  transition: max-height 0.35s var(--ease-out);
  background: var(--color-surface);
}
.nav-drawer__sub.open { max-height: 500px; }

.nav-drawer__sub-link {
  display: block;
  padding: 10px var(--sp-5) 10px calc(var(--sp-5) + 12px);
  font-size: var(--text-sm); color: var(--color-text-muted);
  border-bottom: 1px solid var(--color-border);
  text-decoration: none;
  transition: color var(--trans-fast), background var(--trans-fast);
  min-height: 44px; display: flex; align-items: center;
}
.nav-drawer__sub-link:last-child { border-bottom: none; }
.nav-drawer__sub-link:hover { color: var(--color-primary); background: var(--color-bg); }
.nav-drawer__sub-link--all {
  font-weight: 700; color: var(--color-primary) !important;
  font-size: var(--text-xs); letter-spacing: 0.05em; text-transform: uppercase;
}

.nav-drawer__language {
  padding: var(--sp-4) var(--sp-5);
  border-top: 1px solid var(--color-border);
  flex-shrink: 0;
}
.language-switcher--drawer .language-switcher__form { margin: 0; }
.language-switcher--drawer .language-switcher__options {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 6px;
  padding: 4px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-full);
  background: var(--color-surface);
}
.language-switcher--drawer .language-switcher__button {
  min-height: 40px;
  border-radius: var(--radius-full);
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: 0.04em;
}
.language-switcher--drawer .language-switcher__button.is-active {
  background: var(--color-primary);
  color: var(--color-primary-text);
}

.nav-drawer__footer {
  padding: var(--sp-4) var(--sp-5);
  border-top: 1px solid var(--color-border);
  flex-shrink: 0;
}
</style>
