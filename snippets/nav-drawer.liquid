<style>
.nav-drawer {
  position: fixed; top: 0; left: 0; bottom: 0;
  width: min(360px, 92vw);
  background: var(--color-bg);
  z-index: 800;
  transform: translateX(-100%);
  transition: transform 0.35s var(--ease-out);
  display: flex; flex-direction: column;
  overflow: hidden;
  box-shadow: 8px 0 48px rgba(0,0,0,0.18);
}
.nav-drawer.open { transform: translateX(0); }

.nav-drawer__close-btn {
  width: 44px; height: 44px; border-radius: var(--radius-md);
  display: flex; align-items: center; justify-content: center;
  color: var(--color-text); background: none; border: none; cursor: pointer;
  transition: background var(--trans-fast), color var(--trans-fast);
  flex-shrink: 0;
}
.nav-drawer__close-btn:hover { background: var(--color-surface); color: var(--color-primary); }

.nav-drawer__header {
  display: flex; align-items: center; justify-content: space-between;
  padding: var(--sp-4) var(--sp-5);
  border-bottom: 1px solid var(--color-border);
  flex-shrink: 0; min-height: 68px;
}

.nav-drawer__links {
  flex: 1; overflow-y: auto; padding: var(--sp-2) 0;
  -webkit-overflow-scrolling: touch;
}

.nav-drawer__link {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: var(--sp-3) var(--sp-5);
  font-size: var(--text-base); font-weight: 600;
  color: var(--color-text); background: none; border: none;
  border-bottom: 1px solid var(--color-border);
  text-align: left; cursor: pointer; text-decoration: none;
  transition: background var(--trans-fast), color var(--trans-fast);
  min-height: 52px;
}
.nav-drawer__link:last-child { border-bottom: none; }
.nav-drawer__link:hover, .nav-drawer__link:active {
  background: var(--color-surface); color: var(--color-primary);
}
.nav-drawer__link--sale { color: var(--color-sale) !important; }
.nav-drawer__link--sale:hover { background: #fef2f2; }

.nav-chevron {
  flex-shrink: 0;
  transition: transform 0.25s var(--ease-out);
}
.nav-drawer__toggle[aria-expanded="true"] .nav-chevron { transform: rotate(180deg); }

/* Accordion sub-menu — max-height animation */
.nav-drawer__sub {
  max-height: 0; overflow: hidden;
  transition: max-height 0.35s var(--ease-out);
  background: var(--color-surface);
}
.nav-drawer__sub.open { max-height: 500px; }

.nav-drawer__sub-link {
  display: block;
  padding: 10px var(--sp-5) 10px calc(var(--sp-5) + 12px);
  font-size: var(--text-sm); color: var(--color-text-muted);
  border-bottom: 1px solid var(--color-border);
  text-decoration: none;
  transition: color var(--trans-fast), background var(--trans-fast);
  min-height: 44px; display: flex; align-items: center;
}
.nav-drawer__sub-link:last-child { border-bottom: none; }
.nav-drawer__sub-link:hover { color: var(--color-primary); background: var(--color-bg); }
.nav-drawer__sub-link--all {
  font-weight: 700; color: var(--color-primary) !important;
  font-size: var(--text-xs); letter-spacing: 0.05em; text-transform: uppercase;
}

.nav-drawer__footer {
  padding: var(--sp-4) var(--sp-5);
  border-top: 1px solid var(--color-border);
  flex-shrink: 0;
}
</style>

<script>
// Ensure BOTH IDs resolve to closeNav — fixes mobileClose vs mobileNavClose bug
document.addEventListener('DOMContentLoaded', function() {
  // Primary ID on element: mobileNavClose (set via id attribute)
  // Secondary alias: register mobileClose as synthetic reference
  const closeBtn = document.getElementById('mobileNavClose');
  if (closeBtn && !document.getElementById('mobileClose')) {
    // Mirror the element so getElementById('mobileClose') also works
    closeBtn.setAttribute('id', 'mobileNavClose');
    // Register both via event listeners directly (no DOM id conflict)
    closeBtn.addEventListener('click', BLC.closeNav);
  }
  // Also attach listener to any element with data-also-id="mobileClose"
  document.querySelectorAll('[data-also-id="mobileClose"]').forEach(el => {
    el.addEventListener('click', BLC.closeNav);
  });
});
</script>
