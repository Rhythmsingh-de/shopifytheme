<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Search" aria-hidden="true">
  <div class="search-modal__backdrop" onclick="BLC.closeSearch()"></div>
  <div class="search-modal__box">
    <form action="/search" method="get" role="search" class="search-modal__form">
      <input type="hidden" name="type" value="product">
      <div class="search-modal__input-wrap">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="search-modal__icon" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="search" name="q" id="search-input" placeholder="Search products, collections..." autocomplete="off" class="search-modal__input" aria-label="Search">
        <button type="button" onclick="BLC.closeSearch()" class="search-modal__clear" aria-label="Close search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>
      <button type="submit" class="btn btn--primary">Search</button>
    </form>
    <div id="search-suggestions" class="search-modal__suggestions">
      <p style="font-size:var(--text-xs);font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-text-muted);margin-bottom:var(--sp-3)">Popular Searches</p>
      <div class="search-tags">
        <a href="/search?q=jewelry" class="search-tag">Jewelry</a>
        <a href="/search?q=dress" class="search-tag">Dresses</a>
        <a href="/search?q=home+decor" class="search-tag">Home Decor</a>
        <a href="/search?q=pet+toys" class="search-tag">Pet Toys</a>
        <a href="/search?q=accessories" class="search-tag">Accessories</a>
        <a href="/search?q=sale" class="search-tag" style="color:var(--color-sale);border-color:var(--color-sale)">Sale</a>
      </div>
    </div>
  </div>
</div>
<style>
