{%- liquid
  assign language_style = style | default: 'header'
  assign supported_locales = 'en,de' | split: ','
  assign visible_language_count = 0
  for language in localization.available_languages
    if supported_locales contains language.iso_code
      assign visible_language_count = visible_language_count | plus: 1
    endif
  endfor
  assign language_form_id = 'LocalizationForm-' | append: section.id | append: '-' | append: language_style
-%}

{%- if visible_language_count > 1 -%}
  <localization-form class="language-switcher language-switcher--{{ language_style }}">
    {%- form 'localization', id: language_form_id, class: 'language-switcher__form' -%}
      <span class="visually-hidden">{{ 'general.localization.language_label' | t | default: 'Language' }}</span>
      <div class="language-switcher__options" role="group" aria-label="{{ 'general.localization.language_label' | t | default: 'Language' }}">
        {%- for language in localization.available_languages -%}
          {%- if supported_locales contains language.iso_code -%}
            <button
              type="submit"
              name="locale_code"
              value="{{ language.iso_code }}"
              class="language-switcher__button{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
              {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}
              data-language-switcher-button
              data-locale-code="{{ language.iso_code }}">
              {{ language.iso_code | upcase }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endform -%}
  </localization-form>

  <script>
    (function () {
      var form = document.getElementById({{ language_form_id | json }});
      if (!form) return;
      form.addEventListener('click', function (event) {
        var button = event.target.closest('[data-language-switcher-button]');
        if (!button) return;
        try {
          window.localStorage.setItem({{ settings.language_auto_redirect_storage_key | default: 'blc_language_checked' | json }}, 'manual:' + button.dataset.localeCode);
        } catch (e) {}
      });
    })();
  </script>
{%- endif -%}
