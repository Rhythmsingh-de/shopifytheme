{%- liquid
  assign language_style = style | default: 'header'
  assign supported_locales = 'en,de' | split: ','
  assign visible_language_count = 0
  for language in localization.available_languages
    if supported_locales contains language.iso_code
      assign visible_language_count = visible_language_count | plus: 1
    endif
  endfor
  assign language_form_id = 'LocalizationForm-' | append: section.id | append: '-' | append: language_style
  assign currency_form_id = 'CurrencyForm-' | append: section.id | append: '-' | append: language_style
-%}

{%- if visible_language_count > 1 -%}
  <localization-form class="language-switcher language-switcher--{{ language_style }}">
    {%- form 'localization', id: language_form_id, class: 'language-switcher__form' -%}
      <span class="visually-hidden">{{ 'general.localization.language_label' | t | default: 'Language' }}</span>
      <div class="language-switcher__options" role="group" aria-label="{{ 'general.localization.language_label' | t | default: 'Language' }}">
        {%- for language in localization.available_languages -%}
          {%- if supported_locales contains language.iso_code -%}
            <button
              type="submit"
              name="locale_code"
              value="{{ language.iso_code }}"
              class="language-switcher__button{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
              {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}
              data-language-switcher-button
              data-locale-code="{{ language.iso_code }}">
              {{ language.iso_code | upcase }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endform -%}
  </localization-form>

  <script>
    (function () {
      var form = document.getElementById({{ language_form_id | json }});
      if (!form) return;
      form.addEventListener('click', function (event) {
        var button = event.target.closest('[data-language-switcher-button]');
        if (!button) return;
        try {
          window.localStorage.setItem({{ settings.language_auto_redirect_storage_key | default: 'blc_language_checked' | json }}, 'manual:' + button.dataset.localeCode);
        } catch (e) {}
      });
    })();
  </script>
{%- endif -%}

{%- if localization.available_currencies.size > 1 -%}
  <localization-form class="currency-switcher currency-switcher--{{ language_style }}">
    {%- form 'localization', id: currency_form_id, class: 'currency-switcher__form' -%}
      <span class="visually-hidden">{{ 'general.localization.currency_label' | t | default: 'Currency' }}</span>
      <div class="currency-switcher__wrapper">
        <label for="{{ currency_form_id }}-select" class="visually-hidden">{{ 'general.localization.currency_label' | t | default: 'Currency' }}</label>
        <select
          id="{{ currency_form_id }}-select"
          name="currency_code"
          class="currency-switcher__select"
          aria-label="{{ 'general.localization.currency_label' | t | default: 'Currency' }}"
          onchange="this.closest('form').submit()">
          {%- for currency in localization.available_currencies -%}
            <option
              value="{{ currency.iso_code }}"
              {% if currency.iso_code == localization.currency.iso_code %}selected{% endif %}>
              {{ currency.iso_code }} {{ currency.symbol }}
            </option>
          {%- endfor -%}
        </select>
        <svg class="currency-switcher__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
    {%- endform -%}
  </localization-form>
{%- endif -%}

<style>
.currency-switcher { display: inline-flex; }
.currency-switcher__wrapper {
  position: relative;
  display: inline-flex;
  align-items: center;
}
.currency-switcher__select {
  appearance: none;
  -webkit-appearance: none;
  background: transparent;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md, 6px);
  padding: 4px 28px 4px 10px;
  font-size: var(--text-xs);
  font-family: inherit;
  font-weight: 600;
  color: var(--color-text);
  cursor: pointer;
  outline: none;
  transition: border-color 0.2s;
}
.currency-switcher__select:hover,
.currency-switcher__select:focus-visible {
  border-color: var(--color-primary);
}
.currency-switcher__chevron {
  position: absolute;
  right: 8px;
  pointer-events: none;
  color: var(--color-text-muted);
}
</style>
