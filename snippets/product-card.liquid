{%- assign card_product = product -%}
{%- assign card_index = index | default: 0 -%}

<div class="prod-card reveal"
  style="transition-delay:{{ card_index | times: 60 }}ms"
  data-product-id="{{ card_product.id }}"
  data-product-title="{{ card_product.title | escape }}"
  data-product-type="{{ card_product.type | escape }}"
  data-price="{{ card_product.price | divided_by: 100.0 }}">

  <div class="prod-card__media">
    <a href="{{ card_product.url }}" tabindex="-1" aria-hidden="true">
      {%- if card_product.featured_image -%}
        <img src="{{ card_product.featured_image | image_url: width: 600 }}"
             alt="{{ card_product.featured_image.alt | default: card_product.title | escape }}"
             width="600" height="750"
             loading="lazy" decoding="async"
             class="prod-card__img prod-card__img--primary">
        {%- if settings.card_hover_second_image and card_product.images.size > 1 -%}
          <img src="{{ card_product.images[1] | image_url: width: 600 }}"
               alt="{{ card_product.images[1].alt | default: card_product.title | escape }}"
               width="600" height="750"
               loading="lazy" decoding="async"
               class="prod-card__img prod-card__img--hover">
        {%- endif -%}
      {%- else -%}
        <div class="prod-card__img prod-card__img--primary prod-card__no-img" aria-label="{{ card_product.title | escape }}">
          <svg viewBox="0 0 100 120" width="64" height="76" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="10" y="20" width="80" height="90" rx="6" fill="currentColor" opacity="0.08"/>
            <rect x="24" y="8" width="52" height="20" rx="4" fill="currentColor" opacity="0.12"/>
            <rect x="30" y="50" width="40" height="4" rx="2" fill="currentColor" opacity="0.18"/>
            <rect x="30" y="62" width="28" height="4" rx="2" fill="currentColor" opacity="0.12"/>
          </svg>
        </div>
      {%- endif -%}
    </a>

    <div class="prod-card__badges">
      {%- if card_product.compare_at_price > card_product.price -%}
        {%- assign savings = card_product.compare_at_price | minus: card_product.price | times: 100 | divided_by: card_product.compare_at_price -%}
        {%- if settings.card_show_sale_badge -%}
          <span class="badge badge--sale">-{{ savings }}%</span>
        {%- endif -%}
      {%- elsif settings.card_show_new_badge -%}
        {%- if card_product.tags contains 'new' -%}
          <span class="badge badge--new">New</span>
        {%- elsif card_product.tags contains 'bestseller' -%}
          <span class="badge badge--bestseller">Bestseller</span>
        {%- endif -%}
      {%- endif -%}
    </div>

  </div>

  <div class="prod-card__info">
    {%- if settings.card_show_vendor and card_product.vendor != blank -%}
      <p class="prod-card__vendor">{{ card_product.vendor }}</p>
    {%- endif -%}

    <h3 class="prod-card__title">
      <a href="{{ card_product.url }}">{{ card_product.title }}</a>
    </h3>

    {%- if settings.card_show_rating -%}
      {%- assign rating_value = card_product.metafields.reviews.rating.value -%}
      {%- assign rating_count = card_product.metafields.reviews.rating_count.value -%}
      {%- if rating_value != blank and rating_count != blank -%}
        <div class="prod-card__rating" aria-label="{{ rating_value }} out of 5 stars">
          <span class="stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              {%- if i <= rating_value -%}
                <svg viewBox="0 0 24 24" width="12" height="12" fill="var(--color-sale)" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" width="12" height="12" fill="var(--color-border)" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endif -%}
            {%- endfor -%}
          </span>
          <span class="prod-card__rating-count">({{ rating_count }})</span>
        </div>
      {%- endif -%}
    {%- endif -%}

    <div class="prod-card__price">
      <span class="prod-card__price--current">{{ card_product.price | money }}</span>
      {%- if card_product.compare_at_price > card_product.price -%}
        <span class="prod-card__price--compare">{{ card_product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    </div>

    {%- if settings.card_quick_add -%}
      <div class="prod-card__quick-actions" data-product-detail data-variants="{{ card_product.variants | json | escape }}">
        {%- if card_product.variants.size > 1 -%}
          <div class="prod-card__select-wrapper">
            <select class="prod-card__select" data-card-variant-selector aria-label="Select variant for {{ card_product.title | escape }}">
              {%- for variant in card_product.variants -%}
                <option value="{{ variant.id }}" {% unless variant.available %}disabled{% endunless %}>
                  {{ variant.title }} &mdash; {{ variant.price | money }} {% unless variant.available %}(Sold Out){% endunless %}
                </option>
              {%- endfor -%}</select>
          </div>
        {%- endif -%}

        <div class="prod-card__buttons">
          <button class="btn btn--primary btn--sm prod-card__btn-atc atc-btn"
                  data-add-to-cart
                  data-variant-id="{{ card_product.variants.first.id }}"
                  data-qty="1"
                  aria-label="Add {{ card_product.title | escape }} to cart"
                  {% unless card_product.variants.first.available %}disabled aria-disabled="true"{% endunless %}>
            <span class="atc-btn-text">{% if card_product.variants.first.available %}Add to Cart{% else %}Sold Out{% endif %}</span>
          </button>
          {%- if card_product.variants.first.available -%}
            <a href="/checkout?variant={{ card_product.variants.first.id }}&quantity=1"
               class="btn btn--ghost btn--sm prod-card__btn-buy"
               data-card-buy-now
               aria-label="Buy {{ card_product.title | escape }} now">
              Buy Now
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.prod-card {
  display: flex;
  flex-direction: column;
  background: var(--color-bg);
  border-radius: var(--card-radius);
  overflow: hidden;
  transition: box-shadow var(--trans-slow), transform var(--trans-slow);
}
.prod-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-4px);
}
.prod-card__media {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
  background: var(--color-surface);
  border-radius: var(--card-radius) var(--card-radius) 0 0;
}
.prod-card__img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: opacity 0.4s var(--ease-out), transform 0.5s var(--ease-out);
  position: absolute;
  inset: 0;
}
.prod-card__img--hover { opacity: 0; }
.prod-card:hover .prod-card__img--primary { opacity: 0; transform: scale(1.03); }
.prod-card:hover .prod-card__img--hover { opacity: 1; }
.prod-card:hover .prod-card__img--primary:only-child { opacity: 1; transform: scale(1.03); }
.prod-card__no-img {
  background: var(--color-surface);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text-muted);
  position: absolute;
  inset: 0;
}
.prod-card__badges {
  position: absolute;
  top: var(--sp-3);
  left: var(--sp-3);
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  pointer-events: none;
}


.prod-card__info {
  padding: var(--sp-3) var(--sp-4) var(--sp-4);
  display: flex;
  flex-direction: column;
  gap: var(--sp-1);
  flex: 1;
}
.prod-card__vendor {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-weight: 600;
}
.prod-card__title {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: var(--text-sm);
  line-height: 1.35;
}
.prod-card__title a { transition: color var(--trans-base); }
.prod-card__title a:hover { color: var(--color-primary); }
.prod-card__rating {
  display: flex;
  align-items: center;
  gap: var(--sp-1);
}
.prod-card__rating-count {
  font-size: var(--text-xs);
  color: var(--color-text-muted);
}
.stars { display: flex; gap: 2px; }
.prod-card__price {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  margin-top: auto;
  padding-top: var(--sp-1);
}
.prod-card__price--current {
  font-weight: 700;
  font-size: var(--text-base);
  color: var(--color-text);
}
.prod-card__price--compare {
  font-size: var(--text-sm);
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.prod-card__quick-actions {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2, 8px);
  margin-top: var(--sp-3, 12px);
}
.prod-card__select-wrapper {
  position: relative;
  width: 100%;
}
.prod-card__select {
  width: 100%;
  padding: 8px 12px;
  font-size: var(--text-xs, 12px);
  font-weight: 600;
  border: 1.5px solid var(--color-border);
  border-radius: var(--radius-md, 8px);
  background: var(--color-surface);
  color: var(--color-text);
  cursor: pointer;
  outline: none;
  font-family: inherit;
  transition: border-color var(--trans-base);
}
.prod-card__select:hover {
  border-color: var(--color-text);
}
.prod-card__buttons {
  display: flex;
  gap: var(--sp-2, 8px);
  width: 100%;
}
.prod-card__btn-atc, .prod-card__btn-buy {
  flex: 1;
  padding: 10px 12px;
  font-size: 11px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border-radius: var(--radius-md, 8px);
  min-height: 38px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s ease, background 0.15s ease;
}
.prod-card__btn-atc {
  background: var(--color-primary);
  color: var(--color-primary-text);
  border: none;
}
.prod-card__btn-atc:hover:not(:disabled) {
  background: var(--color-primary-hover);
  transform: translateY(-1px);
}
.prod-card__btn-buy {
  background: transparent;
  color: var(--color-primary);
  border: 2.5px solid var(--color-primary);
  text-decoration: none;
}
.prod-card__btn-buy:hover {
  background: var(--color-primary);
  color: var(--color-primary-text);
  transform: translateY(-1px);
}
</style>
