{% comment %}
  Usage:
    {% render 'trust-badges', style: 'horizontal' %}   — inline row (product page)
    {% render 'trust-badges', style: 'grid' %}         — 2×2 grid (cart/checkout)
  All text is editable via settings_schema theme settings (trust_* keys).
{% endcomment %}
{%- liquid
  assign tb_style   = style | default: 'horizontal'
  assign tb_return  = settings.trust_returns_title   | default: '30-Day Returns'
  assign tb_ship    = settings.trust_shipping_title | default: '7–10 Day Shipping'
  assign tb_secure  = settings.trust_secure_title   | default: 'Secure Payments'
  assign tb_quality = settings.trust_support_title  | default: 'Premium Quality'
-%}
<div class="trust-badges trust-badges--{{ tb_style }}" role="list">
  <div class="trust-badge" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M23 4 23 10 17 10"/><path d="M1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
    <span>{{ tb_return }}</span>
  </div>
  <div class="trust-badge" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    <span>{{ tb_ship }}</span>
  </div>
  <div class="trust-badge" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    <span>{{ tb_secure }}</span>
  </div>
  <div class="trust-badge" role="listitem">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    <span>{{ tb_quality }}</span>
  </div>
</div>
<style>
.trust-badges {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-4);
}
.trust-badges--horizontal {
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
}
.trust-badges--grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-3);
}
.trust-badge {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-size: var(--text-xs);
  font-weight: 600;
  color: var(--color-text-muted);
}
.trust-badge svg {
  width: 18px;
  height: 18px;
  flex-shrink: 0;
  color: var(--color-primary);
}
</style>
