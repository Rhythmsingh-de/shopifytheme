<div id="cartOverlay" class="cart-overlay" onclick="BLC.closeCart()" aria-hidden="true"></div>

<div id="cartDrawer" class="cart-drawer" role="dialog" aria-modal="true" aria-label="Shopping cart" aria-hidden="true">
  <div class="cart-drawer__header">
    <h2 style="font-family:var(--font-display);font-size:var(--text-lg);font-weight:700">Your Cart <span id="cartItemCount" style="font-size:var(--text-sm);font-weight:400;color:var(--color-text-muted)"></span></h2>
    <button id="cartDrawerClose" onclick="BLC.closeCart()" aria-label="Close cart" class="cart-drawer__close">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Free shipping progress bar -->
  <div id="freeShippingBar" class="fs-bar" style="padding:var(--sp-3) var(--sp-5);border-bottom:1px solid var(--color-border)">
    <div class="fs-bar__track" style="background:var(--color-surface-offset);border-radius:var(--radius-full);height:6px;overflow:hidden;margin-bottom:6px">
      <div class="fs-bar__fill" style="height:100%;background:var(--color-deco);border-radius:var(--radius-full);transition:width 0.4s ease;width:0%"></div>
    </div>
    <p class="fs-bar__label" style="font-size:var(--text-xs);color:var(--color-text-muted);text-align:center"></p>
  </div>

  <div id="cartItemsList" class="cart-drawer__items"></div>

  <div id="cartDrawerFoot" class="cart-drawer__footer" style="display:none">
    <div class="cart-subtotal-row" style="display:flex;justify-content:space-between;align-items:center;margin-bottom:var(--sp-3);font-weight:600;font-size:var(--text-base)">
      <span>Subtotal</span>
      <span id="cartSubtotal"></span>
    </div>
    <p style="font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:var(--sp-3)">Taxes and shipping calculated at checkout</p>
    {%- if settings.cart_show_note -%}
      <div class="cart-note-toggle" onclick="this.nextElementSibling.classList.toggle('open')" style="font-size:var(--text-sm);color:var(--color-primary);cursor:pointer;margin-bottom:var(--sp-2)">
        + Add order note
      </div>
      <div class="cart-note-field" style="overflow:hidden;max-height:0;transition:max-height 0.3s ease">
        <textarea id="cart-note" rows="2" placeholder="Special instructions..." style="width:100%;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:var(--sp-3);resize:vertical;margin-bottom:var(--sp-3);font-size:var(--text-sm)"></textarea>
      </div>
    {%- endif -%}
    {%- if settings.cart_show_upsell and settings.cart_drawer_upsell_product != blank -%}
      {%- assign drawer_upsell = settings.cart_drawer_upsell_product -%}
      <div class="cart-drawer__upsell">
        <p class="cart-drawer__upsell-title">{{ settings.cart_upsell_title | default: 'You might also like' | escape }}</p>
        <div class="cart-drawer__upsell-card">
          {%- if drawer_upsell.featured_image != blank -%}
            {{ drawer_upsell.featured_image | image_url: width: 120 | image_tag: width: 60, height: 60, loading: 'lazy', class: 'cart-drawer__upsell-img', alt: drawer_upsell.title }}
          {%- endif -%}
          <div class="cart-drawer__upsell-info">
            <a href="{{ drawer_upsell.url }}" class="cart-drawer__upsell-name">{{ drawer_upsell.title | escape }}</a>
            <span class="cart-drawer__upsell-price">{{ drawer_upsell.price | money }}</span>
          </div>
          {%- if drawer_upsell.available -%}
            <button class="btn btn--primary btn--sm" data-add-to-cart data-variant-id="{{ drawer_upsell.selected_or_first_available_variant.id }}" data-qty="1">
              {{ settings.conversion_primary_cta_label | default: 'Add' | escape }}
            </button>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    <form action="{{ routes.cart_url }}" method="post" style="margin:0">
      <button type="submit" name="checkout" class="btn btn--primary btn--full btn-checkout" style="display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:var(--sp-2)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        {{ settings.conversion_fast_checkout_label | default: 'Proceed to Checkout' | escape }}
      </button>
    </form>
    <a href="{{ routes.cart_url }}" class="btn btn--ghost btn--full">{{ 'cart.title' | t | default: 'View Full Cart' }}</a>
    {%- if settings.trust_show_payment_icons -%}
      <div class="payment-icons" style="display:flex;align-items:center;justify-content:center;gap:var(--sp-2);margin-top:var(--sp-3);flex-wrap:wrap;">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
.cart-overlay {
  position:fixed;inset:0;background:rgba(0,0,0,0.5);
  z-index:799;opacity:0;visibility:hidden;
  transition:opacity 0.35s ease,visibility 0.35s ease;
}
.cart-overlay.is-open{opacity:1;visibility:visible;}

.cart-drawer {
  position:fixed;top:0;right:0;bottom:0;
  width:min(420px,100vw);
  background:var(--color-bg);
  z-index:800;
  transform:translateX(100%);
  transition:transform 0.35s cubic-bezier(0.16,1,0.3,1);
  display:flex;flex-direction:column;
  box-shadow:-8px 0 48px rgba(0,0,0,0.15);
}
.cart-drawer.is-open{transform:translateX(0);}

.cart-drawer__header{
  display:flex;align-items:center;justify-content:space-between;
  padding:var(--sp-5);
  border-bottom:1px solid var(--color-border);
  flex-shrink:0;min-height:68px;
}
.cart-drawer__close{
  width:44px;height:44px;border-radius:var(--radius-md);
  display:flex;align-items:center;justify-content:center;
  color:var(--color-text);
  transition:background var(--trans-fast);
}
.cart-drawer__close:hover{background:var(--color-surface);}

.cart-drawer__items{
  flex:1;overflow-y:auto;padding:var(--sp-4) var(--sp-5);
  display:flex;flex-direction:column;gap:var(--sp-4);
}
.cart-drawer__footer{
  padding:var(--sp-4) var(--sp-5) var(--sp-6);
  border-top:1px solid var(--color-border);
  flex-shrink:0;
}
.cart-drawer__upsell {
  margin-bottom: var(--sp-4);
  padding: var(--sp-3);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-surface);
}
.cart-drawer__upsell-title {
  margin-bottom: var(--sp-2);
  color: var(--color-text-muted);
  font-size: var(--text-xs);
  font-weight: 800;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.cart-drawer__upsell-card {
  display: flex;
  align-items: center;
  gap: var(--sp-3);
}
.cart-drawer__upsell-img {
  width: 60px;
  height: 60px;
  object-fit: cover;
  border-radius: var(--radius-sm);
}
.cart-drawer__upsell-info { flex: 1; min-width: 0; }
.cart-drawer__upsell-name {
  display: block;
  overflow: hidden;
  color: var(--color-text);
  font-size: var(--text-sm);
  font-weight: 700;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cart-drawer__upsell-price {
  color: var(--color-text-muted);
  font-size: var(--text-xs);
}

/* Cart item */
.cart-item{display:flex;gap:var(--sp-3);}
.cart-item__img{width:80px;height:80px;border-radius:var(--radius-md);object-fit:cover;flex-shrink:0;background:var(--color-surface);}
.cart-item__body{flex:1;min-width:0;}
.cart-item__title{font-size:var(--text-sm);font-weight:600;line-height:1.3;margin-bottom:4px;color:var(--color-text);}
.cart-item__variant{font-size:var(--text-xs);color:var(--color-text-muted);margin-bottom:8px;}
.cart-item__row{display:flex;align-items:center;justify-content:space-between;gap:var(--sp-2);}
.cart-item__price{font-size:var(--text-sm);font-weight:700;color:var(--color-text);}
.cart-item__del{font-size:var(--text-xs);color:var(--color-text-muted);text-decoration:underline;background:none;border:none;cursor:pointer;padding:0;}
.cart-item__del:hover{color:var(--color-sale);}

/* Qty stepper */
.qty-stepper{display:flex;align-items:center;gap:0;border:1px solid var(--color-border);border-radius:var(--radius-md);overflow:hidden;}
.qty-stepper__btn{width:32px;height:32px;display:flex;align-items:center;justify-content:center;font-size:16px;line-height:1;background:none;border:none;cursor:pointer;color:var(--color-text);transition:background var(--trans-fast);}
.qty-stepper__btn:hover{background:var(--color-surface);}
.qty-stepper__val{width:32px;text-align:center;font-size:var(--text-sm);font-weight:600;border:none;outline:none;-moz-appearance:textfield;}
.qty-stepper__val::-webkit-outer-spin-button,.qty-stepper__val::-webkit-inner-spin-button{-webkit-appearance:none;}

/* Empty cart */
.cart-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:var(--sp-16) var(--sp-8);flex:1;}
.cart-empty svg{color:var(--color-text-faint);margin-bottom:var(--sp-4);}
.cart-empty h3{font-size:var(--text-base);font-weight:700;margin-bottom:var(--sp-2);}
.cart-empty p{font-size:var(--text-sm);color:var(--color-text-muted);margin-bottom:var(--sp-6);}

/* Note field open */
.cart-note-field.open{max-height:200px !important;}
</style>
