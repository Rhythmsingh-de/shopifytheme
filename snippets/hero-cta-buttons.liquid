{%- liquid
  assign cta_mode = mode | default: 'checkout_permalink'
  assign cta_product = product
  assign cta_variant = variant
  if cta_variant == blank and cta_product != blank
    assign cta_variant = cta_product.selected_or_first_available_variant
  endif

  assign cart_label_text = cart_label | default: settings.conversion_primary_cta_label | default: 'Add to Cart'
  assign checkout_label_text = checkout_label | default: settings.conversion_fast_checkout_label | default: settings.conversion_buy_now_label | default: 'Buy Now'
  assign primary_class_text = primary_class | default: 'btn btn--hero-primary'
  assign secondary_class_text = secondary_class | default: 'btn btn--hero-ghost'
  assign checkout_url = blank
  assign cart_url = blank

  if cta_variant != blank
    assign checkout_url = routes.cart_url | append: '/' | append: cta_variant.id | append: ':1'
    assign cart_url = checkout_url | append: '?storefront=true'
  endif
-%}

{%- if cta_mode == 'custom_links' or cta_variant == blank -%}
  {%- if primary_label != blank -%}
    <a href="{{ primary_link }}" class="{{ primary_class_text }}"{% if primary_style != blank %} style="{{ primary_style }}"{% endif %}>
      {%- if show_icon -%}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      {%- endif -%}
      <span>{{ primary_label | escape }}</span>
    </a>
  {%- endif -%}
  {%- if secondary_label != blank -%}
    <a href="{{ secondary_link }}" class="{{ secondary_class_text }}">
      {{ secondary_label | escape }}
    </a>
  {%- endif -%}
{%- elsif cta_variant.available == false -%}
  <button type="button" class="{{ primary_class_text }}"{% if primary_style != blank %} style="{{ primary_style }}"{% endif %} disabled aria-disabled="true">
    Sold Out
  </button>
{%- elsif cta_mode == 'cart_and_checkout' -%}
  <button
    type="button"
    class="{{ primary_class_text }}"
    {% if primary_style != blank %}style="{{ primary_style }}"{% endif %}
    data-add-to-cart
    data-variant-id="{{ cta_variant.id }}"
    data-qty="1"
    aria-label="Add {{ cta_product.title | escape }} to cart">
    {%- if show_icon -%}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    {%- endif -%}
    <span class="atc-btn-text">{{ cart_label_text | escape }}</span>
  </button>
  <a
    href="{{ checkout_url }}"
    class="{{ secondary_class_text }}"
    data-buy-now
    data-checkout-destination="checkout"
    data-variant-id="{{ cta_variant.id }}"
    aria-label="Checkout {{ cta_product.title | escape }}">
    {{ checkout_label_text | escape }}
  </a>
{%- elsif cta_mode == 'add_to_cart' -%}
  <button
    type="button"
    class="{{ primary_class_text }}"
    {% if primary_style != blank %}style="{{ primary_style }}"{% endif %}
    data-add-to-cart
    data-variant-id="{{ cta_variant.id }}"
    data-qty="1"
    aria-label="Add {{ cta_product.title | escape }} to cart">
    {%- if show_icon -%}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    {%- endif -%}
    <span class="atc-btn-text">{{ cart_label_text | escape }}</span>
  </button>
{%- elsif cta_mode == 'cart_permalink' -%}
  <a
    href="{{ cart_url }}"
    class="{{ primary_class_text }}"
    {% if primary_style != blank %}style="{{ primary_style }}"{% endif %}
    data-buy-now
    data-checkout-destination="cart"
    data-variant-id="{{ cta_variant.id }}"
    aria-label="Add {{ cta_product.title | escape }} to cart">
    {%- if show_icon -%}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    {%- endif -%}
    <span>{{ cart_label_text | escape }}</span>
  </a>
{%- else -%}
  <a
    href="{{ checkout_url }}"
    class="{{ primary_class_text }}"
    {% if primary_style != blank %}style="{{ primary_style }}"{% endif %}
    data-buy-now
    data-checkout-destination="checkout"
    data-variant-id="{{ cta_variant.id }}"
    aria-label="Checkout {{ cta_product.title | escape }}">
    {%- if show_icon -%}
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
    {%- endif -%}
    <span>{{ checkout_label_text | escape }}</span>
  </a>
{%- endif -%}
