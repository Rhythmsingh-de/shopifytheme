<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: #ffffff;
      color: #111111;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      display: flex; align-items: center; justify-content: center;
      min-height: 100vh; padding: 24px;
    }
    .pw {
      max-width: 440px; width: 100%; text-align: center;
    }
    .pw__logo { font-size: 1.4rem; font-weight: 700; margin-bottom: 48px; }
    .pw__heading { font-size: 2rem; font-weight: 700; margin-bottom: 16px; }
    .pw__sub { font-size: 0.95rem; color: #666; margin-bottom: 40px; }
    .pw__form { display: flex; flex-direction: column; gap: 12px; }
    .pw__input {
      width: 100%; padding: 14px 16px;
      border: 1px solid #e5e5e5; border-radius: 4px;
      font-size: 1rem; outline: none;
      transition: border-color 0.2s ease;
    }
    .pw__input:focus { border-color: #111; }
    .pw__btn {
      width: 100%; padding: 16px;
      background: #111; color: #fff;
      font-size: 0.9rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
      border-radius: 4px; cursor: pointer;
      transition: background 0.2s ease;
    }
    .pw__btn:hover { background: #333; }
  </style>
</head>
<body>
  <div class="pw">
    <div class="pw__logo">{{ shop.name }}</div>
    <h1 class="pw__heading">Coming Soon</h1>
    <p class="pw__sub">We're putting the finishing touches on something great.</p>
    {%- form 'storefront_password', class: 'pw__form' -%}
      <input
        type="password"
        name="password"
        class="pw__input"
        placeholder="Enter password"
        autocomplete="current-password"
      >
      <button type="submit" class="pw__btn">Enter Store</button>
    {%- endform -%}
  </div>
  {{ content_for_layout }}
  {{ content_for_footer }}
</body>
</html>
