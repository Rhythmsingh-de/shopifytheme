<!doctype html>
<!-- BLC-VERSION 20260606-v3 -->
<html lang="{{ request.locale.iso_code }}" data-theme="light">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,height=device-height">
  <meta name="theme-color" content="{{ settings.color_primary | default: '#1d5c3a' }}">

  <!-- Title & Meta -->
  <title>{% if page_title == shop.name %}{{ shop.name }} — {{ settings.seo_meta_description | truncate: 60 }}{% else %}{{ page_title }} {{ settings.seo_title_suffix }}{% endif %}</title>
  <meta name="description" content="{{ page_description | default: settings.seo_meta_description | escape }}">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 64 }}">
  {%- endif -%}

  {%- render 'meta-tags' -%}

  <!-- Open Graph -->
  {%- if settings.seo_og_enabled -%}
    <meta property="og:site_name" content="{{ shop.name }}">
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:title" content="{{ page_title | escape }}">
    <meta property="og:description" content="{{ page_description | default: settings.seo_meta_description | escape }}">
    <meta property="og:type" content="website">
    {%- if settings.seo_og_image != blank -%}
      <meta property="og:image" content="{{ settings.seo_og_image | image_url: width: 1200 }}">
    {%- elsif product.featured_image -%}
      <meta property="og:image" content="{{ product.featured_image | image_url: width: 1200 }}">
    {%- elsif collection.image -%}
      <meta property="og:image" content="{{ collection.image | image_url: width: 1200 }}">
    {%- endif -%}
    <meta name="twitter:card" content="summary_large_image">
  {%- endif -%}

  <!-- Fonts -->
  {{ settings.font_display | font_face: font_display: 'swap' }}
  {{ settings.font_body | font_face: font_display: 'swap' }}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Work+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- ═══════════════════════════════════════════
       GOOGLE TAG MANAGER — fires before consent
       (consent mode v2 defaults set below)
  ═══════════════════════════════════════════ -->
  {%- if settings.gtm_id != blank -%}
  <script>
    window.dataLayer = window.dataLayer || [];
    // Consent Mode v2 defaults — denied until user accepts
    function gtag(){dataLayer.push(arguments);}
    gtag('consent','default',{
      ad_storage:'denied',
      analytics_storage:'denied',
      ad_user_data:'denied',
      ad_personalization:'denied',
      wait_for_update: 500
    });
    // GTM loader
    (function(w,d,s,l,i){
      w[l]=w[l]||[];
      w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
      var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
      j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
      f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','{{ settings.gtm_id }}');
  </script>
  {%- endif -%}

  <!-- ═══════════════════════════════════════════
       GA4 DIRECT — only used when GTM is NOT set
  ═══════════════════════════════════════════ -->
  {%- if settings.ga4_id != blank and settings.gtm_id == blank -%}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ settings.ga4_id }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ settings.ga4_id }}', { send_page_view: false });
  </script>
  {%- endif -%}

  <!-- ═══════════════════════════════════════════
       META (FACEBOOK) PIXEL
       Gated by cookie consent — injected after
       user accepts (see cookie consent JS below)
  ═══════════════════════════════════════════ -->
  {%- if settings.pixel_id != blank -%}
  <script id="blc-meta-pixel-template" type="text/blc-tracking">
  !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
  n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}
  (window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
  fbq('init','{{ settings.pixel_id }}');
  fbq('track','PageView');
  {%- for line in settings.meta_pixel_custom_events.lines -%}{%- if line != blank -%}
  {{ line }}
  {%- endif -%}{%- endfor -%}
  </script>
  <noscript id="blc-meta-pixel-noscript">
    <img height="1" width="1" style="display:none"
      src="https://www.facebook.com/tr?id={{ settings.pixel_id }}&ev=PageView&noscript=1" alt="">
  </noscript>
  {%- endif -%}

  <!-- ═══════════════════════════════════════════
       TIKTOK PIXEL — gated by consent
  ═══════════════════════════════════════════ -->
  {%- if settings.tiktok_pixel_id != blank -%}
  <script id="blc-tiktok-pixel-template" type="text/blc-tracking">
  !function(w,d,t){w.TiktokAnalyticsObject=t;var ttq=w[t]=w[t]||[];
  ttq.methods=['page','track','identify','instances','debug','on','off','once','ready',
  'alias','group','enableCookie','disableCookie'];
  ttq.setAndDefer=function(t,e){t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}};
  for(var i=0;i<ttq.methods.length;i++)ttq.setAndDefer(ttq,ttq.methods[i]);
  ttq.instance=function(t){for(var e=ttq._i[t]||[],n=0;n<ttq.methods.length;n++)
  ttq.setAndDefer(e,ttq.methods[n]);return e};ttq.load=function(e,n){
  var i='https://analytics.tiktok.com/i18n/pixel/events.js';
  ttq._i=ttq._i||{};ttq._i[e]=[];ttq._i[e]._u=i;ttq._t=ttq._t||{};
  ttq._t[e]=+new Date;ttq._o=ttq._o||{};ttq._o[e]=n||{};
  var o=document.createElement('script');o.type='text/javascript';o.async=!0;
  o.src=i+'?sdkid='+e+'&lib='+t;var a=document.getElementsByTagName('script')[0];
  a.parentNode.insertBefore(o,a)};
  ttq.load('{{ settings.tiktok_pixel_id }}');
  ttq.page();}(window,document,'ttq');
  </script>
  {%- endif -%}

  <!-- ═══════════════════════════════════════════
       CUSTOM <HEAD> SCRIPTS (theme settings)
  ═══════════════════════════════════════════ -->
  {%- if settings.custom_head_scripts != blank -%}
    {{ settings.custom_head_scripts }}
  {%- endif -%}

  {{ content_for_header }}

  <!-- ═══════════════════════════════════════════
       BLC THEME SETTINGS → JS window object
  ═══════════════════════════════════════════ -->
  <script>
  window.blcSettings = {
    shopName: {{ shop.name | json }},
    currency: {{ cart.currency.iso_code | json }},
    cartType: {{ settings.cart_type | default: 'drawer' | json }},
    freeShippingThreshold: {{ settings.cart_free_shipping_threshold | default: 75 }},
    gtmId: {{ settings.gtm_id | json }},
    ga4Id: {{ settings.ga4_id | json }},
    pixelId: {{ settings.pixel_id | json }},
    tiktokPixelId: {{ settings.tiktok_pixel_id | json }},
    datalayerDebug: {{ settings.datalayer_debug | default: false | json }},
    cookieConsentEnabled: {{ settings.cookie_consent_enabled | default: true | json }},
    {%- if customer -%}
    customerId: {{ customer.id | json }},
    customerEmailHash: {{ customer.email | sha256 | json }},
    customerOrderCount: {{ customer.orders_count | json }},
    {%- endif -%}
    pageType: {{ request.page_type | json }}
  };
  </script>

  <style>
  /* ═══════════════════════════════════════════════
     BODYLUXCARE — Design Tokens (from theme settings)
  ═══════════════════════════════════════════════ */
  :root {
    --font-display: {{ settings.font_display.family | default: 'Playfair Display' }}, 'Playfair Display', Georgia, serif;
    --font-body:    {{ settings.font_body.family | default: 'Work Sans' }}, 'Work Sans', system-ui, sans-serif;
    --font-size-base: {{ settings.type_base_size | default: '16px' }};

    /* Color tokens — all driven from Theme > Colors in customizer */
    --color-bg:              {{ settings.color_bg | default: '#ffffff' }};
    --color-surface:         {{ settings.color_surface | default: '#f9f8f5' }};
    --color-text:            {{ settings.color_text | default: '#1a1a1a' }};
    --color-text-muted:      {{ settings.color_text_muted | default: '#6b7280' }};
    --color-primary:         {{ settings.color_primary | default: '#1d5c3a' }};
    --color-primary-hover:   {{ settings.color_primary_hover | default: '#164530' }};
    --color-sale:            {{ settings.color_sale | default: '#dc2626' }};
    --color-border:          {{ settings.color_border | default: '#e5e7eb' }};
    --color-header-bg:       {{ settings.color_header_bg | default: '#ffffff' }};
    --color-footer-bg:       {{ settings.color_footer_bg | default: '#111827' }};
    --color-footer-text:     {{ settings.color_footer_text | default: '#f9fafb' }};
    --color-gold:            #d97706;
    --color-surface-2:       color-mix(in oklch, var(--color-surface) 70%, var(--color-bg) 30%);
    --color-surface-offset:  color-mix(in oklch, var(--color-bg) 80%, var(--color-text) 5%);

    /* Type scale — fluid */
    --text-xs:   clamp(0.75rem,  0.7rem  + 0.25vw, 0.875rem);
    --text-sm:   clamp(0.875rem, 0.8rem  + 0.35vw, 1rem);
    --text-base: clamp(1rem,     0.95rem + 0.25vw, 1.125rem);
    --text-lg:   clamp(1.125rem, 1rem    + 0.75vw, 1.5rem);
    --text-xl:   clamp(1.5rem,   1.2rem  + 1.25vw, 2.25rem);
    --text-2xl:  clamp(2rem,     1.2rem  + 2.5vw,  3.5rem);
    --text-3xl:  clamp(2.5rem,   1rem    + 4vw,    5rem);

    /* Spacing — 4px grid */
    --sp-1:0.25rem;--sp-2:0.5rem;--sp-3:0.75rem;--sp-4:1rem;
    --sp-5:1.25rem;--sp-6:1.5rem;--sp-8:2rem;--sp-10:2.5rem;
    --sp-12:3rem;--sp-16:4rem;--sp-20:5rem;--sp-24:6rem;

    /* Radius from settings */
    --radius-btn:  {{ settings.btn_radius | default: '6px' }};
    --radius-card: {{ settings.card_radius | default: '8px' }};
    --radius-sm:   4px; --radius-md: 8px;
    --radius-lg:   12px; --radius-xl: 16px; --radius-full: 9999px;

    /* Shadows */
    --shadow-sm:  0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
    --shadow-md:  0 4px 12px rgba(0,0,0,.08),0 2px 4px rgba(0,0,0,.04);
    --shadow-lg:  0 12px 32px rgba(0,0,0,.12),0 4px 8px rgba(0,0,0,.06);
    --shadow-3d:  0 20px 60px rgba(0,0,0,.15),0 8px 16px rgba(0,0,0,.08);
    --shadow-card-hover: 0 24px 64px rgba(0,0,0,.16),0 8px 16px rgba(0,0,0,.08);

    /* Transitions */
    --trans-fast: 150ms cubic-bezier(0.16,1,0.3,1);
    --trans-base: 250ms cubic-bezier(0.16,1,0.3,1);
    --trans-slow: 400ms cubic-bezier(0.16,1,0.3,1);
    --ease-out:   cubic-bezier(0.16,1,0.3,1);

    /* Layout */
    --content-narrow:  640px;
    --content-default: 960px;
    --content-wide:    1280px;
  }

  /* ═══════════════════════════════════════════════
     BASE RESET
  ═══════════════════════════════════════════════ */
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  html{
    -webkit-font-smoothing:antialiased;
    -moz-osx-font-smoothing:grayscale;
    text-rendering:optimizeLegibility;
    scroll-behavior:smooth;
    scroll-padding-top:80px;
  }
  body{
    min-height:100dvh;
    font-family:var(--font-body);
    font-size:var(--font-size-base);
    color:var(--color-text);
    background:var(--color-bg);
    line-height:1.6;
  }
  img,video,svg{display:block;max-width:100%;height:auto}
  input,button,textarea,select{font:inherit;color:inherit}
  h1,h2,h3,h4,h5,h6{font-family:var(--font-display);line-height:1.15;text-wrap:balance}
  p,li{max-width:70ch;text-wrap:pretty}
  a{color:inherit;text-decoration:none}
  button{cursor:pointer;border:none;background:none}
  ul{list-style:none}
  ::selection{background:rgba(29,92,58,0.15)}
  :focus-visible{outline:2px solid var(--color-primary);outline-offset:3px;border-radius:var(--radius-sm)}
  @media(prefers-reduced-motion:reduce){
    *,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}
  }

  /* ═══════════════════════════════════════════════
     SKIP LINK
  ═══════════════════════════════════════════════ */
  .skip-link{
    position:absolute;top:-100px;left:var(--sp-4);
    background:var(--color-primary);color:#fff;
    padding:var(--sp-2) var(--sp-4);border-radius:var(--radius-md);
    font-weight:600;z-index:9999;transition:top var(--trans-fast);
  }
  .skip-link:focus{top:var(--sp-2)}

  /* ═══════════════════════════════════════════════
     LAYOUT UTILITIES
  ═══════════════════════════════════════════════ */
  .container{
    width:100%;max-width:var(--content-wide);
    margin-inline:auto;
    padding-inline:clamp(var(--sp-4),4vw,var(--sp-12));
  }
  .container--narrow{max-width:var(--content-narrow)}
  .container--default{max-width:var(--content-default)}
  .section{padding-block:clamp(var(--sp-10),5vw,var(--sp-20))}
  .section--sm{padding-block:clamp(var(--sp-6),3vw,var(--sp-12))}
  .section--lg{padding-block:clamp(var(--sp-16),7vw,var(--sp-24))}
  .section-header{margin-bottom:clamp(var(--sp-8),4vw,var(--sp-16))}
  .section-header--center{text-align:center}
  .section-eyebrow{
    display:inline-block;
    font-size:var(--text-xs);font-weight:700;
    letter-spacing:0.1em;text-transform:uppercase;
    color:var(--color-primary);margin-bottom:var(--sp-2);
  }
  .section-title{font-size:var(--text-xl);font-weight:700;color:var(--color-text)}

  /* ═══════════════════════════════════════════════
     BUTTONS
  ═══════════════════════════════════════════════ */
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:var(--sp-2);
    padding:0.75em 1.75em;
    font-family:var(--font-body);font-size:var(--text-sm);font-weight:600;
    letter-spacing:0.03em;border-radius:var(--radius-btn);
    border:2px solid transparent;cursor:pointer;
    transition:background var(--trans-fast),color var(--trans-fast),
               border-color var(--trans-fast),box-shadow var(--trans-fast),
               transform var(--trans-fast);
    text-decoration:none;white-space:nowrap;min-height:44px;
    position:relative;overflow:hidden;
  }
  .btn:hover{transform:translateY(-1px);box-shadow:var(--shadow-md)}
  .btn:active{transform:translateY(0)}
  .btn--primary{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
  .btn--primary:hover{background:var(--color-primary-hover);border-color:var(--color-primary-hover)}
  .btn--outline{background:transparent;color:var(--color-primary);border-color:var(--color-primary)}
  .btn--outline:hover{background:var(--color-primary);color:#fff}
  .btn--ghost{background:transparent;color:var(--color-text);border-color:var(--color-border)}
  .btn--ghost:hover{background:var(--color-surface);border-color:var(--color-text-muted)}
  .btn--white{background:#fff;color:var(--color-primary);border-color:#fff}
  .btn--white:hover{background:#f0f0f0}
  .btn--lg{padding:1em 2.25em;font-size:var(--text-base)}
  .btn--sm{padding:0.5em 1.25em;font-size:var(--text-xs);min-height:36px}
  .btn--full{width:100%}
  .btn[disabled],.btn[aria-disabled="true"]{opacity:.55;cursor:not-allowed;pointer-events:none}
  .btn--loading::after{
    content:'';width:16px;height:16px;
    border:2px solid rgba(255,255,255,.4);border-top-color:#fff;
    border-radius:50%;animation:spin .6s linear infinite;margin-left:var(--sp-2);
  }
  @keyframes spin{to{transform:rotate(360deg)}}

  /* ═══════════════════════════════════════════════
     BADGES
  ═══════════════════════════════════════════════ */
  .badge{
    display:inline-flex;align-items:center;
    padding:2px 8px;font-size:var(--text-xs);
    font-weight:700;letter-spacing:.06em;text-transform:uppercase;
    border-radius:var(--radius-full);
  }
  .badge--sale{background:var(--color-sale);color:#fff}
  .badge--new{background:var(--color-primary);color:#fff}
  .badge--trending{background:#7c3aed;color:#fff}
  .badge--bestseller{background:#d97706;color:#fff}

  /* ═══════════════════════════════════════════════
     SCROLL REVEAL
  ═══════════════════════════════════════════════ */
  .reveal{opacity:0;transform:translateY(24px);transition:opacity .6s var(--ease-out),transform .6s var(--ease-out)}
  .reveal.visible,.reveal.is-revealed{opacity:1;transform:translateY(0)}
  .reveal-delay-1{transition-delay:.1s}
  .reveal-delay-2{transition-delay:.2s}
  .reveal-delay-3{transition-delay:.3s}
  .reveal-delay-4{transition-delay:.4s}

  /* ═══════════════════════════════════════════════
     PRODUCT CARD — 3D tilt + polish
  ═══════════════════════════════════════════════ */
  .prod-card{
    background:var(--color-surface);
    border-radius:var(--radius-card);
    overflow:hidden;
    box-shadow:var(--shadow-sm);
    transition:transform var(--trans-slow),box-shadow var(--trans-slow);
    transform-style:preserve-3d;
    will-change:transform;
    display:flex;flex-direction:column;
  }
  @media(hover:hover){
    .prod-card:hover{box-shadow:var(--shadow-card-hover)}
  }
  .prod-card__media{
    position:relative;overflow:hidden;
    aspect-ratio:3/4;background:var(--color-surface-offset);
  }
  .prod-card__media img{
    width:100%;height:100%;object-fit:cover;
    transition:transform .6s var(--ease-out);
  }
  @media(hover:hover){.prod-card:hover .prod-card__media img{transform:scale(1.06)}}
  .prod-card__badge{
    position:absolute;top:var(--sp-3);left:var(--sp-3);
    padding:3px 10px;font-size:11px;font-weight:700;
    letter-spacing:.06em;text-transform:uppercase;
    border-radius:var(--radius-full);
  }
  .badge-sale{background:var(--color-sale);color:#fff}
  .badge-new{background:var(--color-primary);color:#fff}
  .badge-best{background:#d97706;color:#fff}
  .prod-card__body{padding:var(--sp-4) var(--sp-4) var(--sp-5);flex:1;display:flex;flex-direction:column}
  .prod-card__meta{font-size:var(--text-xs);color:var(--color-text-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:var(--sp-1)}
  .prod-card__name{font-family:var(--font-display);font-size:var(--text-sm);font-weight:600;color:var(--color-text);line-height:1.3;margin-bottom:var(--sp-2);flex:1}
  .prod-card__stars{display:flex;gap:2px;color:var(--color-gold);margin-bottom:var(--sp-2)}
  .prod-card__price-row{display:flex;align-items:center;gap:var(--sp-2);flex-wrap:wrap;margin-top:auto}
  .prod-card__price{font-weight:700;font-size:var(--text-sm);color:var(--color-text)}
  .prod-card__was{font-size:var(--text-xs);color:var(--color-text-muted);text-decoration:line-through}
  .prod-card__save{font-size:var(--text-xs);font-weight:700;color:var(--color-sale);background:rgba(220,38,38,.1);padding:2px 6px;border-radius:var(--radius-full)}
  .prod-card__atc{
    margin:0 var(--sp-4) var(--sp-4);
    width:calc(100% - 2*var(--sp-4));
    padding:.6em 1em;
    background:var(--color-primary);color:#fff;
    border-radius:var(--radius-btn);font-weight:600;font-size:var(--text-xs);
    border:none;cursor:pointer;min-height:40px;
    transition:background var(--trans-fast),transform var(--trans-fast),box-shadow var(--trans-fast);
    letter-spacing:.04em;
  }
  .prod-card__atc:hover{background:var(--color-primary-hover);transform:translateY(-1px);box-shadow:var(--shadow-md)}
  .atc-btn{
    margin:0 var(--sp-4) var(--sp-4);
    width:calc(100% - 2*var(--sp-4));
    padding:.6em 1em;
    background:var(--color-primary);color:#fff;
    border-radius:var(--radius-btn);font-weight:600;font-size:var(--text-xs);
    border:none;cursor:pointer;min-height:40px;
    transition:background var(--trans-fast),transform var(--trans-fast),box-shadow var(--trans-fast);
    letter-spacing:.04em;
  }
  .atc-btn:hover{background:var(--color-primary-hover);transform:translateY(-1px)}

  /* ═══════════════════════════════════════════════
     ACCORDION
  ═══════════════════════════════════════════════ */
  .accordion-item{border-bottom:1px solid var(--color-border)}
  .accordion-trigger{
    width:100%;display:flex;justify-content:space-between;align-items:center;
    padding:var(--sp-4) 0;font-weight:600;font-size:var(--text-base);
    color:var(--color-text);cursor:pointer;background:none;border:none;
    text-align:left;
  }
  .accordion-trigger svg{transition:transform var(--trans-fast);flex-shrink:0}
  .accordion-trigger[aria-expanded="true"] svg{transform:rotate(180deg)}
  .accordion-body{max-height:0;overflow:hidden;transition:max-height .35s var(--ease-out)}
  .accordion-body.is-open{max-height:1000px}
  .accordion-body__inner{padding-bottom:var(--sp-5);font-size:var(--text-base);color:var(--color-text-muted);line-height:1.7}

  /* ═══════════════════════════════════════════════
     TABS
  ═══════════════════════════════════════════════ */
  .tab-pills{display:flex;gap:var(--sp-2);flex-wrap:wrap}
  .tab-pill{
    padding:.4em 1.1em;border-radius:var(--radius-full);
    font-size:var(--text-sm);font-weight:600;
    border:2px solid var(--color-border);color:var(--color-text-muted);
    background:transparent;cursor:pointer;
    transition:all var(--trans-fast);
  }
  .tab-pill.active,.tab-pill[aria-selected="true"]{
    background:var(--color-primary);color:#fff;border-color:var(--color-primary);
  }
  .tab-pane{display:none}
  .tab-pane.active{display:block}

  /* ═══════════════════════════════════════════════
     PRODUCT GRID LAYOUTS
  ═══════════════════════════════════════════════ */
  .prod-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(min(260px,100%),1fr));
    gap:var(--sp-6);
  }
  @media(max-width:640px){
    .prod-grid{grid-template-columns:repeat(2,1fr);gap:var(--sp-3)}
  }
  .trending-strip__scroll{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(min(240px,100%),1fr));
    gap:var(--sp-5);
  }
  @media(max-width:640px){
    .trending-strip__scroll{grid-template-columns:repeat(2,1fr);gap:var(--sp-3)}
  }

  /* ═══════════════════════════════════════════════
     ANNOUNCEMENT BAR
  ═══════════════════════════════════════════════ */
  .announcement-bar{
    background:var(--color-announcement-bg, var(--color-primary));
    color:var(--color-announcement-text,#fff);
    text-align:center;font-size:var(--text-sm);font-weight:500;
    padding:var(--sp-2) var(--sp-4);
    position:relative;z-index:600;
  }
  .announcement-bar a{color:inherit;text-decoration:underline;text-underline-offset:2px}
  .announcement-bar__messages{position:relative;min-height:1.4em;display:flex;align-items:center;justify-content:center}
  .announcement-bar__msg{
    position:absolute;width:100%;text-align:center;
    opacity:0;transform:translateY(8px);
    transition:opacity .4s ease,transform .4s ease;
    pointer-events:none;
  }
  .announcement-bar__msg.is-active{
    opacity:1;transform:translateY(0);pointer-events:auto;position:relative;
  }

  /* ═══════════════════════════════════════════════
     COOKIE CONSENT BANNER
  ═══════════════════════════════════════════════ */
  #blc-cookie-banner{
    position:fixed;bottom:0;left:0;right:0;z-index:9998;
    background:#111;color:#f5f5f5;
    padding:var(--sp-4) var(--sp-6);
    display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:var(--sp-4);
    box-shadow:0 -4px 20px rgba(0,0,0,.3);
    border-top:1px solid rgba(255,255,255,.1);
    transition:transform .4s var(--ease-out);
  }
  #blc-cookie-banner.is-hidden{transform:translateY(110%)}
  #blc-cookie-banner p{font-size:var(--text-sm);line-height:1.5;margin:0;max-width:600px}
  #blc-cookie-banner a{color:#7dc98f;text-decoration:underline}
  .blc-cookie-btns{display:flex;gap:var(--sp-3);flex-wrap:wrap}
  .blc-cookie-btns button{
    padding:.5em 1.3em;border-radius:var(--radius-btn);font-weight:600;
    font-size:var(--text-sm);cursor:pointer;min-height:40px;border:2px solid transparent;
    transition:all var(--trans-fast);
  }
  #blc-cookie-accept{background:var(--color-primary);color:#fff;border-color:var(--color-primary)}
  #blc-cookie-accept:hover{background:var(--color-primary-hover)}
  #blc-cookie-decline{background:transparent;color:#aaa;border-color:#555}
  #blc-cookie-decline:hover{border-color:#999;color:#fff}

  /* ═══════════════════════════════════════════════
     PRODUCT PAGE GRID
  ═══════════════════════════════════════════════ */
  .product-page-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:clamp(var(--sp-8),5vw,var(--sp-16));
    align-items:start;
  }
  @media(max-width:768px){
    .product-page-grid{grid-template-columns:1fr;gap:var(--sp-8)}
  }
  .product-media-stack{position:relative}
  .product-media-main{
    aspect-ratio:1/1;border-radius:var(--radius-lg);overflow:hidden;
    background:var(--color-surface-offset);
  }
  .product-media-main img{width:100%;height:100%;object-fit:cover;transition:transform .5s var(--ease-out)}
  .product-media-thumbs{
    display:flex;gap:var(--sp-2);flex-wrap:wrap;margin-top:var(--sp-3);
  }
  .product-media-thumb{
    width:68px;height:68px;border-radius:var(--radius-md);overflow:hidden;
    border:2px solid transparent;cursor:pointer;
    transition:border-color var(--trans-fast);
    background:var(--color-surface-offset);flex-shrink:0;
  }
  .product-media-thumb img{width:100%;height:100%;object-fit:cover}
  .product-media-thumb.is-active{border-color:var(--color-primary)}
  .product-info{position:sticky;top:88px}
  .product-info__vendor{font-size:var(--text-xs);text-transform:uppercase;letter-spacing:.1em;color:var(--color-text-muted);margin-bottom:var(--sp-2)}
  .product-info__title{font-size:var(--text-xl);font-weight:700;line-height:1.2;margin-bottom:var(--sp-3)}
  .product-info__rating{display:flex;align-items:center;gap:var(--sp-2);margin-bottom:var(--sp-3)}
  .product-info__price{display:flex;align-items:center;gap:var(--sp-3);flex-wrap:wrap;margin-bottom:var(--sp-5)}
  .product-info__price-sale{font-size:var(--text-lg);font-weight:700;color:var(--color-sale)}
  .product-info__price-compare{font-size:var(--text-base);color:var(--color-text-muted);text-decoration:line-through}
  .product-info__price > span:first-child:not(.product-info__price-sale){font-size:var(--text-lg);font-weight:700}
  .product-options{margin-bottom:var(--sp-5)}
  .product-option__label{font-size:var(--text-sm);font-weight:600;margin-bottom:var(--sp-2)}
  .product-option__swatches{display:flex;gap:var(--sp-2);flex-wrap:wrap}
  .option-swatch{
    padding:.4em 1em;border:2px solid var(--color-border);border-radius:var(--radius-md);
    font-size:var(--text-sm);cursor:pointer;transition:all var(--trans-fast);background:var(--color-bg);
  }
  .option-swatch.is-active,.option-swatch[aria-pressed="true"]{border-color:var(--color-primary);background:var(--color-primary);color:#fff}
  .product-add-to-cart{margin-bottom:var(--sp-5)}
  .product-qty{
    display:flex;align-items:center;border:2px solid var(--color-border);
    border-radius:var(--radius-md);overflow:hidden;width:fit-content;
  }
  .product-qty__btn{
    width:40px;height:40px;display:flex;align-items:center;justify-content:center;
    font-size:1.2em;font-weight:500;cursor:pointer;
    background:var(--color-surface);color:var(--color-text);border:none;
    transition:background var(--trans-fast);
  }
  .product-qty__btn:hover{background:var(--color-surface-offset)}
  .product-qty__val{
    width:50px;text-align:center;border:none;
    border-left:2px solid var(--color-border);border-right:2px solid var(--color-border);
    padding:0;height:40px;font-weight:600;background:var(--color-bg);
  }
  .product-benefits{display:flex;flex-direction:column;gap:var(--sp-2);margin-bottom:var(--sp-5)}
  .product-benefits li{
    display:flex;align-items:center;gap:var(--sp-2);
    font-size:var(--text-sm);color:var(--color-text-muted);
  }
  .product-benefits li svg{color:var(--color-primary);flex-shrink:0}
  .product-trust{
    display:grid;grid-template-columns:repeat(3,1fr);gap:var(--sp-3);
    padding:var(--sp-5) 0;border-top:1px solid var(--color-border);
    border-bottom:1px solid var(--color-border);margin:var(--sp-5) 0;
  }
  .product-trust-item{display:flex;flex-direction:column;align-items:center;text-align:center;gap:var(--sp-1)}
  .product-trust-item svg{color:var(--color-primary)}
  .product-trust-item__label{font-size:var(--text-xs);font-weight:700;color:var(--color-text)}
  .product-trust-item__sub{font-size:10px;color:var(--color-text-muted)}
  .product-payment-icons{display:flex;align-items:center;gap:var(--sp-2);flex-wrap:wrap;margin-bottom:var(--sp-5)}
  .product-payment-icons__label{font-size:var(--text-xs);color:var(--color-text-muted);font-weight:500}
  .payment-icons{display:flex;align-items:center;gap:var(--sp-2);flex-wrap:wrap}
  .payment-icons svg,.payment-icons img{height:24px;width:auto;border-radius:4px}

  /* ═══════════════════════════════════════════════
     CART DRAWER
  ═══════════════════════════════════════════════ */
  .cart-drawer-overlay{
    position:fixed;inset:0;background:rgba(0,0,0,.5);
    z-index:800;opacity:0;pointer-events:none;transition:opacity var(--trans-base);
  }
  .cart-drawer-overlay.is-open{opacity:1;pointer-events:auto}
  .cart-drawer{
    position:fixed;top:0;right:0;bottom:0;width:min(420px,100%);
    background:var(--color-bg);z-index:801;
    display:flex;flex-direction:column;
    transform:translateX(100%);transition:transform var(--trans-slow);
    box-shadow:var(--shadow-lg);
  }
  .cart-drawer.is-open{transform:translateX(0)}
  .cart-drawer__header{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--sp-5) var(--sp-6);border-bottom:1px solid var(--color-border);
  }
  .cart-drawer__title{font-size:var(--text-lg);font-weight:700}
  .cart-drawer__close{
    width:40px;height:40px;border-radius:var(--radius-md);
    display:flex;align-items:center;justify-content:center;
    color:var(--color-text);cursor:pointer;transition:background var(--trans-fast);
  }
  .cart-drawer__close:hover{background:var(--color-surface)}
  .cart-drawer__body{flex:1;overflow-y:auto;padding:var(--sp-5) var(--sp-6);overscroll-behavior:contain}
  .cart-drawer__footer{
    padding:var(--sp-5) var(--sp-6);border-top:1px solid var(--color-border);
    background:var(--color-bg);
  }
  .cart-drawer__subtotal{
    display:flex;justify-content:space-between;align-items:center;
    font-weight:700;font-size:var(--text-base);margin-bottom:var(--sp-4);
  }
  .cart-item{
    display:grid;grid-template-columns:80px 1fr auto;gap:var(--sp-4);
    padding:var(--sp-4) 0;border-bottom:1px solid var(--color-border);
  }
  .cart-item:last-child{border-bottom:none}
  .cart-item__img{border-radius:var(--radius-md);overflow:hidden;aspect-ratio:1/1;background:var(--color-surface-offset)}
  .cart-item__img img{width:100%;height:100%;object-fit:cover}
  .cart-item__name{font-weight:600;font-size:var(--text-sm);line-height:1.3;margin-bottom:var(--sp-1)}
  .cart-item__variant{font-size:var(--text-xs);color:var(--color-text-muted)}
  .cart-item__price{font-weight:700;font-size:var(--text-sm)}
  .qty__controls{display:flex;align-items:center;gap:var(--sp-3);margin-top:var(--sp-2)}
  .qty__btn{
    width:28px;height:28px;border-radius:var(--radius-sm);
    border:1px solid var(--color-border);
    display:flex;align-items:center;justify-content:center;
    font-size:.9em;cursor:pointer;
    transition:background var(--trans-fast),border-color var(--trans-fast);
    color:var(--color-text);
  }
  .qty__btn:hover{background:var(--color-surface);border-color:var(--color-text-muted)}
  .qty__val{min-width:24px;text-align:center;font-weight:600;font-size:var(--text-sm)}
  .cart-item__del{
    color:var(--color-text-muted);font-size:var(--text-xs);
    cursor:pointer;padding:var(--sp-1);transition:color var(--trans-fast);
  }
  .cart-item__del:hover{color:var(--color-sale)}
  .fs-bar{margin-bottom:var(--sp-4)}
  .fs-bar__track{height:4px;background:var(--color-border);border-radius:var(--radius-full);overflow:hidden;margin-bottom:var(--sp-2)}
  .fs-bar__fill{height:100%;background:var(--color-primary);border-radius:var(--radius-full);transition:width .6s var(--ease-out)}
  .fs-bar__label{font-size:var(--text-xs);color:var(--color-text-muted);text-align:center}

  /* ═══════════════════════════════════════════════
     COLLECTION / SEARCH PAGES
  ═══════════════════════════════════════════════ */
  .collection-header{
    background:var(--color-surface-offset);
    padding:clamp(var(--sp-10),5vw,var(--sp-20)) var(--sp-4);
    text-align:center;
  }
  .collection-header h1{font-size:var(--text-2xl);font-weight:700}
  .collection-header p{color:var(--color-text-muted);margin-inline:auto;margin-top:var(--sp-3)}
  .collection-toolbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--sp-4) 0;flex-wrap:wrap;gap:var(--sp-3);
    border-bottom:1px solid var(--color-border);
  }
  .collection-count{font-size:var(--text-sm);color:var(--color-text-muted)}

  /* ═══════════════════════════════════════════════
     FORM ELEMENTS
  ═══════════════════════════════════════════════ */
  .form-field{display:flex;flex-direction:column;gap:var(--sp-1)}
  .form-label{font-size:var(--text-sm);font-weight:600;color:var(--color-text)}
  .form-input,.form-textarea,.form-select{
    width:100%;padding:.65em var(--sp-4);
    border:1.5px solid var(--color-border);border-radius:var(--radius-md);
    background:var(--color-bg);color:var(--color-text);
    font-size:var(--text-base);
    transition:border-color var(--trans-fast),box-shadow var(--trans-fast);
  }
  .form-input:focus,.form-textarea:focus,.form-select:focus{
    border-color:var(--color-primary);
    box-shadow:0 0 0 3px rgba(29,92,58,.12);
    outline:none;
  }
  .form-textarea{resize:vertical;min-height:120px}

  /* ═══════════════════════════════════════════════
     NAV DRAWER (mobile)
  ═══════════════════════════════════════════════ */
  #mobileNavOverlay{
    position:fixed;inset:0;background:rgba(0,0,0,.5);
    z-index:498;opacity:0;pointer-events:none;transition:opacity var(--trans-base);
  }
  #mobileNavOverlay.is-open{opacity:1;pointer-events:auto}
  #mobileNav{
    position:fixed;top:0;left:0;bottom:0;width:min(340px,90%);
    background:var(--color-bg);z-index:499;
    transform:translateX(-100%);transition:transform var(--trans-slow);
    overflow-y:auto;display:flex;flex-direction:column;
  }
  #mobileNav.is-open{transform:translateX(0)}
  .mobile-nav__header{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--sp-5) var(--sp-6);border-bottom:1px solid var(--color-border);
  }
  .mobile-nav__links{padding:var(--sp-4) var(--sp-6);flex:1}
  .mobile-nav__link{
    display:flex;align-items:center;justify-content:space-between;
    padding:var(--sp-4) 0;border-bottom:1px solid var(--color-border);
    font-weight:600;font-size:var(--text-base);color:var(--color-text);
    text-decoration:none;
  }
  .mobile-nav__link:last-child{border-bottom:none}
  .mobile-nav__sub{
    padding-left:var(--sp-4);display:none;
  }
  .mobile-nav__sub.is-open{display:block}
  .mobile-nav__sub a{
    display:block;padding:var(--sp-3) 0;
    font-size:var(--text-sm);color:var(--color-text-muted);
    border-bottom:1px solid var(--color-border);
  }
  .mobile-nav__sub a:last-child{border-bottom:none}

  /* ═══════════════════════════════════════════════
     SEARCH MODAL
  ═══════════════════════════════════════════════ */
  #searchModal{
    position:fixed;inset:0;z-index:700;
    background:rgba(0,0,0,.6);backdrop-filter:blur(4px);
    display:flex;align-items:flex-start;justify-content:center;
    padding-top:clamp(60px,10vh,120px);
    opacity:0;pointer-events:none;transition:opacity var(--trans-base);
  }
  #searchModal.is-open{opacity:1;pointer-events:auto}
  .search-modal__box{
    background:var(--color-bg);border-radius:var(--radius-xl);
    width:min(600px,calc(100% - 2rem));
    box-shadow:var(--shadow-lg);overflow:hidden;
  }
  .search-modal__inner{
    display:flex;align-items:center;gap:var(--sp-3);
    padding:var(--sp-4) var(--sp-5);
    border-bottom:1px solid var(--color-border);
  }
  .search-modal__input{
    flex:1;border:none;font-size:var(--text-lg);background:transparent;
    color:var(--color-text);outline:none;
  }
  .search-modal__input::placeholder{color:var(--color-text-muted)}

  /* ═══════════════════════════════════════════════
     FOOTER
  ═══════════════════════════════════════════════ */
  .site-footer{
    background:var(--color-footer-bg);color:var(--color-footer-text);
    padding-top:clamp(var(--sp-16),6vw,var(--sp-24));
  }
  .site-footer a{color:var(--color-footer-text);opacity:.7;transition:opacity var(--trans-fast)}
  .site-footer a:hover{opacity:1}
  .footer-grid{
    display:grid;
    grid-template-columns:2fr repeat(3,1fr);
    gap:clamp(var(--sp-8),4vw,var(--sp-12));
    padding-bottom:var(--sp-12);
  }
  @media(max-width:900px){.footer-grid{grid-template-columns:1fr 1fr;gap:var(--sp-8)}}
  @media(max-width:480px){.footer-grid{grid-template-columns:1fr}}
  .footer-brand__logo{font-family:var(--font-display);font-size:var(--text-xl);font-weight:700;margin-bottom:var(--sp-4)}
  .footer-brand__logo img{max-height:40px;width:auto}
  .footer-brand__about{font-size:var(--text-sm);opacity:.7;line-height:1.7;max-width:28ch;margin-bottom:var(--sp-5)}
  .footer-socials{display:flex;gap:var(--sp-3)}
  .footer-social{
    width:36px;height:36px;border-radius:var(--radius-full);
    border:1px solid rgba(255,255,255,.2);
    display:flex;align-items:center;justify-content:center;
    transition:background var(--trans-fast),border-color var(--trans-fast);
    color:var(--color-footer-text);
  }
  .footer-social:hover{background:var(--color-primary);border-color:var(--color-primary);opacity:1}
  .footer-col__title{
    font-size:var(--text-xs);font-weight:700;letter-spacing:.1em;
    text-transform:uppercase;margin-bottom:var(--sp-4);opacity:1;
    color:var(--color-footer-text);
  }
  .footer-col ul{display:flex;flex-direction:column;gap:var(--sp-2)}
  .footer-col li a{font-size:var(--text-sm)}
  .footer-bottom{
    border-top:1px solid rgba(255,255,255,.1);
    padding:var(--sp-5) 0;
    display:flex;align-items:center;justify-content:space-between;
    flex-wrap:wrap;gap:var(--sp-3);
  }
  .footer-bottom p,.footer-bottom a{font-size:var(--text-xs);opacity:.5}
  .footer-payment{display:flex;align-items:center;gap:var(--sp-2);flex-wrap:wrap}
  .footer-payment__icons{display:flex;gap:var(--sp-2);flex-wrap:wrap;align-items:center}
  .footer-payment__icons svg,.footer-payment__icons img{height:22px;width:auto;border-radius:3px;opacity:.8}

  /* ═══════════════════════════════════════════════
     MISC
  ═══════════════════════════════════════════════ */
  .section-spacing{padding-block:clamp(var(--sp-10),5vw,var(--sp-20))}
  .section-spacing--sm{padding-block:clamp(var(--sp-6),3vw,var(--sp-12))}
  .page-w{max-width:var(--content-wide);margin-inline:auto;padding-inline:clamp(var(--sp-4),4vw,var(--sp-12))}
  .label-eyebrow{font-size:var(--text-xs);font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--color-primary)}
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0}
  </style>
</head>

<body class="template-{{ request.page_type | replace: '/', '-' }}">

  <!-- GTM noscript fallback -->
  {%- if settings.gtm_id != blank -%}
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ settings.gtm_id }}"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  {%- endif -%}

  <!-- Custom body scripts -->
  {%- if settings.custom_body_scripts != blank -%}
    {{ settings.custom_body_scripts }}
  {%- endif -%}

  <!-- DataLayer — server-side events (before JS) -->
  {%- render 'datalayer' -%}

  <a href="#MainContent" class="skip-link">Skip to content</a>

  {%- render 'cookie-consent' -%}
  {%- sections 'header' -%}
  {%- render 'nav-drawer' -%}
  {%- render 'cart-drawer' -%}
  {%- render 'search-modal' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer' -%}

  <!-- ======= SCRIPTS ======= -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'datalayer.js' | asset_url }}" defer></script>

  {%- if settings.datalayer_debug -%}
  <script>
  document.addEventListener('DOMContentLoaded',function(){
    console.groupCollapsed('%c[BLC DataLayer Debug]','color:#1d5c3a;font-weight:700');
    console.table(window.dataLayer);
    console.groupEnd();
    // Watch future pushes
    var orig = window.dataLayer.push.bind(window.dataLayer);
    window.dataLayer.push = function(){
      var r = orig.apply(this, arguments);
      console.log('%c[DL push]','color:#7dc98f',arguments[0]);
      return r;
    };
  });
  </script>
  {%- endif -%}
</body>
</html>
