<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="{{ settings.bg_color | default: '#ffffff' }}">

  {{ content_for_header }}

  {% render 'meta-tags' %}

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --bg-color: {{ settings.bg_color | default: '#ffffff' }};
      --text-color: {{ settings.text_color | default: '#111111' }};
      --text-muted: {{ settings.text_muted | default: '#666666' }};
      --accent-color: {{ settings.accent_color | default: '#ff3c00' }};
      --accent-hover: {{ settings.accent_hover | default: '#e03500' }};
      --surface: {{ settings.surface_color | default: '#f7f7f7' }};
      --border-radius: {{ settings.border_radius | default: '4' }}px;
      --max-width: {{ settings.max_width | default: '1200' }}px;
      --transition: 0.2s ease;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      background-color: var(--bg-color);
      color: var(--text-color);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-weight: 400;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: inherit; text-decoration: none; }
    img { max-width: 100%; display: block; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; }
    .container {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 24px;
    }
    .visually-hidden {
      position: absolute;
      width: 1px; height: 1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
    }
  </style>

  {%- if settings.custom_css != blank -%}
    <style>{{ settings.custom_css }}</style>
  {%- endif -%}

  {% render 'datalayer' %}
</head>

<body>
  <a href="#MainContent" class="visually-hidden">Skip to content</a>

  {%- sections 'header-group' -%}

  {% render 'nav-drawer' %}
  {% render 'cart-drawer' %}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  {% render 'cookie-consent' %}

  <script>
    window.dataLayer = window.dataLayer || [];
    window.ShopEvents = window.ShopEvents || (function() {
      var listeners = {};
      return {
        on: function(event, fn) { (listeners[event] = listeners[event] || []).push(fn); },
        emit: function(event, data) { (listeners[event] || []).forEach(function(fn) { fn(data); }); }
      };
    })();
    window.trackEvent = function(payload) {
      window.dataLayer.push(payload);
      window.ShopEvents.emit('track', payload);
    };
  </script>

  {{ 'datalayer.js' | asset_url | script_tag }}
  {{ 'theme.js' | asset_url | script_tag }}

  {{ content_for_footer }}
</body>
</html>
