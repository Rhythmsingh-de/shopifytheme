/*
  BodyLuxCare — base.css.liquid v5.0
  Art direction: Premium Wellness × Luxury Living → Bombas-inspired clean conversion theme
  Palette: Warm ivory · Near-black · Emerald deco · Red-orange sale
  Shopify .css.liquid — settings injected as CSS vars
  ALL variable names unified: --color-* --font-* --sp-* --radius-* --shadow-*
*/

/* ══ RESET ══════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  scroll-behavior: smooth;
  scroll-padding-top: 80px;
  hanging-punctuation: first last;
}
body {
  min-height: 100dvh;
  font-family: var(--font-body, 'Work Sans', -apple-system, sans-serif);
  font-size: 16px;
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
}
img, picture, video, canvas, svg { display: block; max-width: 100%; height: auto; }
input, button, textarea, select { font: inherit; color: inherit; }
ul[role="list"], ol[role="list"] { list-style: none; }
h1,h2,h3,h4,h5,h6 { text-wrap: balance; line-height: 1.15; }
p, li { text-wrap: pretty; }
button { cursor: pointer; background: none; border: none; }
a { text-decoration: none; color: inherit; }
table { border-collapse: collapse; width: 100%; }

/* ══ CSS CUSTOM PROPERTIES — from Shopify settings ══ */
:root {
  /* ── Brand Colours ── */
  --color-primary:           {{ settings.color_primary         | default: '#1a1a1a' }};
  --color-primary-hover:     {{ settings.color_primary_hover   | default: '#333333' }};
  --color-secondary:         {{ settings.color_secondary       | default: '#e85d26' }};

  /* ── Sale — vivid urgency ── */
  --color-sale:              {{ settings.color_sale            | default: '#e8260d' }};
  --color-sale-bg:           {{ settings.color_sale_bg         | default: '#fff1f0' }};

  /* ── Deco Green — emerald luxury ── */
  --color-deco:              {{ settings.color_deco            | default: '#1d6b44' }};
  --color-deco-hover:        {{ settings.color_deco_hover      | default: '#155234' }};
  --color-deco-light:        {{ settings.color_deco_light      | default: '#e6f4ed' }};

  /* ── Page Surfaces ── */
  --color-bg:                {{ settings.color_bg              | default: '#faf9f7' }};
  --color-surface:           {{ settings.color_surface         | default: '#ffffff' }};
  --color-surface-2:         {{ settings.color_surface_2       | default: '#f5f3f0' }};
  --color-surface-offset:    {{ settings.color_surface_offset  | default: '#edeae6' }};
  --color-divider:           {{ settings.color_divider         | default: '#e4e2de' }};
  --color-border:            {{ settings.color_border          | default: '#dddbd7' }};

  /* ── Text ── */
  --color-text:              {{ settings.color_text            | default: '#1a1a1a' }};
  --color-text-muted:        {{ settings.color_text_muted      | default: '#6b7280' }};
  --color-text-faint:        {{ settings.color_text_faint      | default: '#aaaaaa' }};
  --color-text-inverse:      #ffffff;

  /* ── Buttons ── */
  --color-btn-bg:            {{ settings.color_btn_primary_bg   | default: '#1a1a1a' }};
  --color-btn-text:          {{ settings.color_btn_primary_text | default: '#ffffff' }};
  --radius-btn:              {{ settings.button_border_radius   | default: '9999px' }};

  /* ── Header ── */
  --color-header-bg:         {{ settings.color_header_bg        | default: '#ffffff' }};
  --color-header-text:       {{ settings.color_header_text      | default: '#1a1a1a' }};

  /* ── Footer ── */
  --color-footer-bg:         {{ settings.color_footer_bg        | default: '#111111' }};
  --color-footer-text:       {{ settings.color_footer_text      | default: '#cccccc' }};

  /* ── Success / Error ── */
  --color-success:           #1d6b44;
  --color-success-bg:        #e6f4ed;
  --color-error:             #c0392b;
  --color-error-bg:          #fdf2f2;

  /* ── Layout ── */
  --max-w:                   {{ settings.container_max_width   | default: 1280 }}px;
  --radius-card:             {{ settings.card_border_radius    | default: '12px' }};
  --radius-sm:               6px;
  --radius-md:               8px;
  --radius-lg:               12px;
  --radius-xl:               16px;
  --radius-full:             9999px;

  /* ── Spacing (4px grid) ── */
  --sp-1:  0.25rem;
  --sp-2:  0.5rem;
  --sp-3:  0.75rem;
  --sp-4:  1rem;
  --sp-5:  1.25rem;
  --sp-6:  1.5rem;
  --sp-8:  2rem;
  --sp-10: 2.5rem;
  --sp-12: 3rem;
  --sp-16: 4rem;
  --sp-20: 5rem;
  --sp-24: 6rem;

  /* ── Type scale (fluid) ── */
  --text-xs:   clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
  --text-sm:   clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
  --text-base: clamp(1rem, 0.95rem + 0.25vw, 1.125rem);
  --text-lg:   clamp(1.125rem, 1rem + 0.75vw, 1.5rem);
  --text-xl:   clamp(1.5rem, 1.2rem + 1.25vw, 2.25rem);
  --text-2xl:  clamp(2rem, 1.2rem + 2.5vw, 3.5rem);
  --text-3xl:  clamp(2.5rem, 1rem + 4vw, 5rem);

  /* ── Fonts ── */
  --font-display: {{ settings.font_display.family | default: 'Playfair Display' }}, Georgia, serif;
  --font-body:    {{ settings.font_body.family    | default: 'Work Sans' }}, -apple-system, sans-serif;

  /* ── 3-D tilt ── */
  --tilt-perspective: 900px;
  --tilt-max:         12deg;

  /* ── Shadows ── */
  --shadow-sm:   0 1px 3px rgba(0,0,0,.07), 0 1px 2px rgba(0,0,0,.04);
  --shadow-md:   0 4px 16px rgba(0,0,0,.09), 0 2px 6px rgba(0,0,0,.05);
  --shadow-lg:   0 12px 36px rgba(0,0,0,.13), 0 4px 12px rgba(0,0,0,.06);
  --shadow-xl:   0 24px 60px rgba(0,0,0,.16), 0 8px 20px rgba(0,0,0,.08);
  --shadow-3d:   0 20px 60px rgba(0,0,0,.18), 0 8px 20px rgba(0,0,0,.10), 0 0 0 1px rgba(0,0,0,.04);

  /* ── Easing ── */
  --ease-out: cubic-bezier(0.16,1,0.3,1);
  --t-fast:   160ms cubic-bezier(0.16,1,0.3,1);
  --t-med:    280ms cubic-bezier(0.16,1,0.3,1);
  --t-slow:   500ms cubic-bezier(0.16,1,0.3,1);
  --trans-base: 200ms ease;
  --trans-fast: 140ms ease;
}

/* ══ ACCESSIBILITY ════════════════════════════════════ */
.skip-link {
  position: absolute; left: -9999px; top: 8px;
  padding: 8px 16px; background: var(--color-deco); color: #fff;
  border-radius: 4px; font-size: 13px; font-weight: 700; z-index: 9999;
}
.skip-link:focus { left: 8px; }
:focus-visible { outline: 2px solid var(--color-deco); outline-offset: 3px; border-radius: 3px; }
.sr-only {
  position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
  overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border-width: 0;
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: .01ms !important;
    transition-duration: .01ms !important;
    animation-iteration-count: 1 !important;
  }
}

/* ══ LAYOUT ══════════════════════════════════════════ */
.page-w {
  max-width: var(--max-w);
  margin-inline: auto;
  padding-inline: clamp(16px, 4vw, 48px);
}
.page-w--narrow { max-width: 760px; margin-inline: auto; padding-inline: 20px; }

/* ══ ANNOUNCEMENT BAR ════════════════════════════════ */
#announcement-bar {
  overflow: hidden;
  max-height: 120px;
  transition: max-height 0.4s ease, opacity 0.3s ease;
}
#announcement-bar.hidden { max-height: 0; opacity: 0; }

.ann-bar-inner {
  display: flex; align-items: center; justify-content: center;
  gap: var(--sp-3); position: relative;
  min-height: 40px; padding: 0 var(--sp-8);
  font-size: 13px; font-weight: 600; letter-spacing: .03em;
}
.ann-msgs { position: relative; overflow: hidden; flex: 1; text-align: center; min-height: 24px; }
.ann-msg {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transform: translateY(8px);
  transition: opacity .4s ease, transform .4s ease;
  pointer-events: none; white-space: nowrap;
}
.ann-msg--active { opacity: 1; transform: translateY(0); pointer-events: auto; }
.ann-link {
  font-weight: 700; text-decoration: underline;
  text-underline-offset: 2px; color: inherit; margin-left: 4px;
}
.ann-nav { display: flex; gap: var(--sp-1); }
.ann-btn {
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.15); cursor: pointer;
  transition: background .15s; flex-shrink: 0;
}
.ann-btn:hover { background: rgba(255,255,255,.3); }
#ann-close {
  position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
  width: 28px; height: 28px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.15); cursor: pointer;
  opacity: .7; transition: opacity .15s, background .15s;
}
#ann-close:hover { opacity: 1; background: rgba(255,255,255,.3); }

/* ══ SITE HEADER ════════════════════════════════════ */
#site-header {
  position: sticky; top: 0; z-index: 200;
  background: var(--color-header-bg);
  border-bottom: 1px solid var(--color-border);
  transition: box-shadow var(--t-fast), background var(--t-fast), transform var(--t-fast);
}
#site-header.header--scrolled { box-shadow: var(--shadow-md); }
#site-header.header--hidden   { transform: translateY(-100%); }

/* Transparent on homepage hero */
{%- if settings.header_transparent -%}
.template-index #site-header:not(.header--scrolled) {
  background: transparent; border-bottom-color: transparent;
  position: absolute; width: 100%;
  --color-header-bg: transparent;
}
.template-index #site-header:not(.header--scrolled) .header-logo-text,
.template-index #site-header:not(.header--scrolled) .header-nav > a,
.template-index #site-header:not(.header--scrolled) .icon-btn { color: #fff; }
{%- endif -%}

.header-inner {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  height: {{ settings.header_height | default: 64 }}px;
  gap: var(--sp-4);
  padding-inline: clamp(16px, 3vw, 40px);
}
.header-left  { display: flex; align-items: center; }
.header-right { display: flex; align-items: center; justify-content: flex-end; gap: var(--sp-1); }

/* Logo */
.header-logo { display: flex; align-items: center; gap: var(--sp-2); text-decoration: none; }
.header-logo img {
  max-height: {{ settings.logo_height | default: 40 }}px;
  max-width: {{ settings.logo_width | default: 140 }}px;
  width: auto; height: auto; object-fit: contain; display: block;
}
.header-logo-text {
  font-family: var(--font-display);
  font-size: clamp(1.1rem, 2vw, 1.35rem);
  font-weight: 800; letter-spacing: -.03em;
  color: var(--color-header-text, var(--color-text));
}
.header-logo-text .accent { color: var(--color-deco); }

/* Desktop nav */
.header-nav { display: flex; align-items: center; gap: 2px; }
.header-nav > a, .nav-item > a {
  font-size: 13px; font-weight: 600; letter-spacing: .02em;
  color: var(--color-text); padding: 8px 12px; border-radius: 6px;
  display: flex; align-items: center; gap: 4px;
  transition: background var(--t-fast), color var(--t-fast);
  white-space: nowrap;
}
.header-nav > a:hover, .nav-item > a:hover { background: var(--color-surface-2); }
.nav-item > a[aria-expanded="true"] { color: var(--color-deco); }
.nav-link--sale { color: var(--color-sale) !important; font-weight: 800 !important; }

/* Mega dropdown */
.nav-item { position: relative; }
.nav-dropdown {
  position: absolute; top: calc(100% + 6px); left: 50%;
  transform: translateX(-50%) translateY(-8px);
  min-width: 500px; background: var(--color-surface);
  border: 1px solid var(--color-border); border-radius: 14px;
  padding: var(--sp-5); box-shadow: var(--shadow-xl);
  display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--sp-1);
  opacity: 0; visibility: hidden; pointer-events: none;
  transition: opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
  z-index: 300;
}
.nav-item:hover .nav-dropdown,
.nav-item:focus-within .nav-dropdown {
  opacity: 1; visibility: visible; pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}
.nd-col { display: flex; flex-direction: column; gap: 2px; }
.nd-head {
  font-size: 10px; font-weight: 800; letter-spacing: .1em; text-transform: uppercase;
  color: var(--color-text-muted); padding: 4px 10px 8px;
  border-bottom: 1px solid var(--color-border); margin-bottom: 4px;
}
.nd-col a {
  font-size: 13px; font-weight: 500; color: var(--color-text);
  padding: 7px 10px; border-radius: 7px;
  transition: background var(--t-fast), color var(--t-fast);
}
.nd-col a:hover { background: var(--color-deco-light); color: var(--color-deco); }
.dropdown-footer {
  border-top: 1px solid var(--color-border);
  margin-top: var(--sp-2); padding-top: var(--sp-2); grid-column: 1 / -1;
}
.dropdown-footer a {
  font-size: 11px; font-weight: 800; letter-spacing: .06em; text-transform: uppercase;
  color: var(--color-deco) !important;
}

/* Icon buttons */
.icon-btn {
  width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
  border-radius: 8px; color: var(--color-text); background: none; border: none;
  cursor: pointer; text-decoration: none; position: relative;
  transition: background var(--t-fast), color var(--t-fast);
}
.icon-btn:hover { background: var(--color-surface-2); color: var(--color-deco); }
.icon-btn svg { width: 20px; height: 20px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; display: block; }
[data-cart-count] {
  position: absolute; top: 5px; right: 5px;
  background: var(--color-deco); color: #fff;
  font-size: 9px; font-weight: 900;
  min-width: 16px; height: 16px; border-radius: 999px;
  display: flex; align-items: center; justify-content: center;
  padding: 0 3px; line-height: 1;
  border: 1.5px solid var(--color-header-bg);
}

/* Hamburger */
.hamburger, #mobileNavTrigger {
  display: none; flex-direction: column; justify-content: center; align-items: center;
  gap: 5px; width: 40px; height: 40px; border-radius: 8px;
  background: none; border: none; cursor: pointer;
  transition: background var(--t-fast);
}
.hamburger:hover, #mobileNavTrigger:hover { background: var(--color-surface-2); }
.ham-line {
  display: block; width: 20px; height: 2px;
  background: var(--color-text); border-radius: 2px;
  transition: transform .25s, opacity .25s;
}

/* Free shipping progress bar */
.fs-bar-wrap {
  padding: 12px var(--sp-6);
  border-top: 1px solid var(--color-border);
  display: flex; flex-direction: column; gap: 6px;
}
.fs-bar__label { font-size: 12px; font-weight: 600; color: var(--color-text-muted); text-align: center; }
.fs-bar__track {
  width: 100%; height: 4px; background: var(--color-surface-offset);
  border-radius: 999px; overflow: hidden;
}
.fs-bar__fill {
  height: 100%; border-radius: 999px;
  background: var(--color-deco);
  transition: width .6s var(--ease-out);
  width: 0%;
}

/* ══ BUTTONS ═════════════════════════════════════════ */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  font-family: var(--font-body); font-size: 14px; font-weight: 700; letter-spacing: .02em;
  padding: 12px 24px; border-radius: var(--radius-btn);
  border: 2px solid transparent; cursor: pointer;
  transition: background var(--t-fast), color var(--t-fast),
              border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  text-decoration: none; white-space: nowrap; line-height: 1;
  min-height: 44px;
}
.btn:hover { transform: translateY(-1px); }
.btn:active { transform: translateY(0); }
.btn:disabled { opacity: .55; cursor: not-allowed; transform: none !important; pointer-events: none; }

.btn--primary, .btn-primary, .btn-black {
  background: var(--color-btn-bg, #1a1a1a);
  color: var(--color-btn-text, #fff);
  border-color: var(--color-btn-bg, #1a1a1a);
}
.btn--primary:hover, .btn-primary:hover, .btn-black:hover { filter: brightness(.85); }

.btn--outline, .btn-outline {
  background: transparent; color: var(--color-text); border-color: var(--color-border);
}
.btn--outline:hover, .btn-outline:hover { background: var(--color-surface-2); border-color: var(--color-text-muted); }

.btn--deco, .btn-deco {
  background: var(--color-deco); color: #fff; border-color: var(--color-deco);
}
.btn--deco:hover, .btn-deco:hover { background: var(--color-deco-hover); border-color: var(--color-deco-hover); }

.btn--sale, .btn-sale {
  background: var(--color-sale); color: #fff; border-color: var(--color-sale);
  box-shadow: 0 4px 20px rgba(232,38,13,.28);
}
.btn--sale:hover, .btn-sale:hover { filter: brightness(.9); box-shadow: 0 6px 28px rgba(232,38,13,.38); }

.btn-white { background: #fff; color: #1a1a1a; border-color: #fff; }
.btn-white:hover { background: rgba(255,255,255,.88); }

.btn-outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,.7); }
.btn-outline-white:hover { background: rgba(255,255,255,.15); border-color: #fff; }

.btn--sm, .btn-sm { padding: 8px 16px; font-size: 13px; min-height: 36px; }
.btn--lg, .btn-lg { padding: 15px 32px; font-size: 15px; }
.btn--xl, .btn-xl { padding: 18px 40px; font-size: 16px; }
.btn--full, .btn-full { width: 100%; }

/* ATC button states */
.atc-btn.added   { background: var(--color-deco) !important; border-color: var(--color-deco) !important; }
.atc-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }

/* ══ SECTION PATTERNS ════════════════════════════════ */
.section-eyebrow {
  display: inline-block; font-size: var(--text-xs); font-weight: 800;
  letter-spacing: .12em; text-transform: uppercase; color: var(--color-deco);
  margin-bottom: var(--sp-3);
}
.section-title {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 900; letter-spacing: -.03em; color: var(--color-text);
  line-height: 1.1;
}
.section-subtitle {
  font-size: var(--text-base); color: var(--color-text-muted);
  margin-top: var(--sp-3); max-width: 60ch; line-height: 1.65;
}
.section-head { margin-bottom: clamp(var(--sp-6), 3.5vw, var(--sp-12)); }

/* ══ PRODUCT GRID ════════════════════════════════════ */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(min(230px, 100%), 1fr));
  gap: clamp(12px, 2vw, 24px);
}
.product-grid--2 { grid-template-columns: repeat(2, 1fr); }
.product-grid--3 { grid-template-columns: repeat(3, 1fr); }
.product-grid--4 { grid-template-columns: repeat(4, 1fr); }
@media (max-width: 1023px) {
  .product-grid--4 { grid-template-columns: repeat(2, 1fr); }
  .product-grid--3 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 639px) {
  .product-grid--4, .product-grid--3, .product-grid--2 { grid-template-columns: repeat(2, 1fr); }
}

/* ══ PRODUCT CARD — 3D tilt + badges ════════════════ */
.prod-card {
  position: relative; background: var(--color-surface);
  border-radius: var(--radius-card); overflow: hidden;
  display: flex; flex-direction: column;
  transform-style: preserve-3d; will-change: transform;
  box-shadow: var(--shadow-sm);
  transform: perspective(var(--tilt-perspective)) rotateX(0) rotateY(0) scale3d(1,1,1);
  transition: box-shadow var(--t-med), transform var(--t-med);
  cursor: pointer;
}
.prod-card:hover {
  box-shadow: var(--shadow-3d);
  transform: perspective(var(--tilt-perspective)) rotateX(2deg) rotateY(-2deg) scale3d(1.02,1.02,1);
}
.prod-card__media {
  position: relative; overflow: hidden;
  border-radius: var(--radius-card) var(--radius-card) 0 0;
  background: var(--color-surface-2);
  aspect-ratio: 4/5;
}
.prod-card__img,
.prod-card__img--primary {
  width: 100%; height: 100%; object-fit: cover; display: block;
  transition: opacity 0.35s ease, transform 0.6s var(--ease-out);
}
.prod-card:hover .prod-card__img--primary { transform: scale(1.06); }
.prod-card__img--hover {
  position: absolute; inset: 0; width: 100%; height: 100%;
  object-fit: cover; opacity: 0;
  transition: opacity 0.35s ease;
}
.prod-card:hover .prod-card__img--hover { opacity: 1; }

/* Shine overlay */
.prod-card::after {
  content: ''; position: absolute; inset: 0; z-index: 5; pointer-events: none;
  background: linear-gradient(135deg, rgba(255,255,255,.12) 0%, transparent 60%);
  opacity: 0; border-radius: var(--radius-card);
  transition: opacity var(--t-med);
}
.prod-card:hover::after { opacity: 1; }

/* Badges */
.prod-card__badges {
  position: absolute; top: 10px; left: 10px; z-index: 3;
  display: flex; flex-direction: column; gap: 4px;
}
.prod-card__badge {
  display: inline-block; padding: 3px 10px;
  border-radius: var(--radius-full);
  font-size: 10px; font-weight: 900; letter-spacing: .06em; text-transform: uppercase; line-height: 1.6;
}
.prod-card__badge--sale { background: var(--color-sale); color: #fff; animation: sale-pulse 2.4s ease-in-out infinite; }
.prod-card__badge--new  { background: var(--color-deco); color: #fff; }
.prod-card__badge--best { background: #f59e0b; color: #fff; }
.prod-card__badge--sold { background: var(--color-surface-offset); color: var(--color-text-muted); }
@keyframes sale-pulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(232,38,13,.35); }
  50%      { box-shadow: 0 0 0 8px rgba(232,38,13,0); }
}

/* Wishlist */
.prod-card__wish {
  position: absolute; top: 10px; right: 10px; z-index: 3;
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(255,255,255,.9); backdrop-filter: blur(4px);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; border: none;
  transition: background var(--t-fast), transform var(--t-fast);
  color: var(--color-text-muted);
}
.prod-card__wish:hover { background: #fff; transform: scale(1.1); color: var(--color-sale); }
.prod-card__wish.active { color: var(--color-sale); }
.prod-card__wish.active svg { fill: var(--color-sale); }

/* Quick-add */
.atc-btn.prod-card__atc {
  position: absolute; bottom: 10px; left: 10px; right: 10px; z-index: 4;
  opacity: 0; transform: translateY(8px);
  transition: opacity var(--t-med), transform var(--t-med);
  background: #1a1a1a; color: #fff; border-radius: var(--radius-btn);
  font-size: 13px; font-weight: 700; padding: 10px;
  text-align: center; border: none; cursor: pointer; width: calc(100% - 20px);
}
.prod-card:hover .atc-btn.prod-card__atc { opacity: 1; transform: translateY(0); }

/* Card body */
.prod-card__body { padding: 12px 14px 16px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
.prod-card__meta {
  font-size: 10px; font-weight: 800; letter-spacing: .08em;
  text-transform: uppercase; color: var(--color-text-muted);
}
.prod-card__name {
  font-size: 14px; font-weight: 700; color: var(--color-text);
  line-height: 1.3; display: -webkit-box;
  -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.prod-card__name:hover { color: var(--color-deco); }
.prod-card__price-row { display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
.prod-card__price { font-size: 15px; font-weight: 800; color: var(--color-text); }
.prod-card__price--sale { color: var(--color-sale); }
.prod-card__was { font-size: 12px; font-weight: 500; color: var(--color-text-muted); text-decoration: line-through; }
.prod-card__save {
  font-size: 10px; font-weight: 900; color: var(--color-sale);
  background: var(--color-sale-bg); padding: 2px 7px; border-radius: 999px;
}
.prod-card__avail { font-size: 11px; color: var(--color-text-muted); }
.prod-card__rating { display: flex; align-items: center; gap: 3px; font-size: 11px; color: var(--color-text-muted); }

/* Swatches */
.prod-card__swatches { display: flex; gap: 5px; flex-wrap: wrap; margin-top: var(--sp-2); }
.swatch {
  width: 18px; height: 18px; border-radius: 50%;
  border: 2px solid transparent; box-shadow: 0 0 0 1.5px var(--color-border);
  cursor: pointer; transition: box-shadow var(--t-fast);
}
.swatch:hover, .swatch.active { box-shadow: 0 0 0 2px var(--color-text); }

/* ══ CATEGORY TILE ════════════════════════════════════ */
.cat-tile {
  position: relative; overflow: hidden; border-radius: var(--radius-lg); display: block;
  aspect-ratio: 3/4; cursor: pointer; text-decoration: none;
  transition: transform var(--t-med), box-shadow var(--t-med);
}
.cat-tile:hover { transform: translateY(-4px) scale(1.01); box-shadow: var(--shadow-xl); }
.cat-tile img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .7s var(--ease-out);
}
.cat-tile:hover img { transform: scale(1.08); }
.cat-tile__body {
  position: absolute; inset: 0;
  display: flex; flex-direction: column; align-items: flex-start; justify-content: flex-end;
  padding: var(--sp-5);
  background: linear-gradient(to top, rgba(0,0,0,.6) 0%, rgba(0,0,0,0) 55%);
  border-radius: var(--radius-lg);
}
.cat-tile__name {
  font-family: var(--font-display); font-size: clamp(1rem, 2vw, 1.4rem);
  font-weight: 800; color: #fff; line-height: 1.15; margin-bottom: var(--sp-3);
  text-shadow: 0 1px 4px rgba(0,0,0,.3);
}
.cat-tile__btn {
  display: inline-flex; align-items: center; gap: var(--sp-2);
  padding: 8px 18px; background: #fff; color: var(--color-text);
  font-size: 13px; font-weight: 700; border-radius: var(--radius-full);
  transition: background var(--t-fast), color var(--t-fast), transform var(--t-fast);
}
.cat-tile:hover .cat-tile__btn {
  background: var(--color-deco); color: #fff; transform: translateY(-2px);
}

/* ══ FORM ELEMENTS ════════════════════════════════════ */
.form-label {
  display: block; font-size: 13px; font-weight: 700; color: var(--color-text);
  margin-bottom: var(--sp-2);
}
.form-input {
  width: 100%; padding: 12px 16px;
  border: 1.5px solid var(--color-border); border-radius: var(--radius-md);
  font-size: 14px; color: var(--color-text); background: var(--color-surface);
  outline: none; appearance: none;
  transition: border-color var(--t-fast), box-shadow var(--t-fast);
  min-height: 44px;
}
.form-input:focus {
  border-color: var(--color-deco);
  box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-deco) 15%, transparent);
}
.form-input::placeholder { color: var(--color-text-muted); }
.form-textarea { min-height: 120px; resize: vertical; }
.form-select { background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%236b7280' stroke-width='2' d='M2 5l6 6 6-6'/%3e%3c/svg%3e"); background-repeat: no-repeat; background-position: right 12px center; background-size: 14px; padding-right: 36px; cursor: pointer; }
.form-group { display: flex; flex-direction: column; gap: var(--sp-2); }
.form-error { color: var(--color-error); font-size: 12px; margin-top: var(--sp-1); }

/* ══ CART DRAWER ══════════════════════════════════════ */
.cart-drawer-overlay {
  position: fixed; inset: 0; z-index: 395;
  background: rgba(0,0,0,.45); backdrop-filter: blur(2px);
  opacity: 0; visibility: hidden;
  transition: opacity .3s ease, visibility .3s ease;
}
#cartOverlay.is-open { opacity: 1; visibility: visible; }

#cartDrawer {
  position: fixed; top: 0; right: 0; bottom: 0; z-index: 400;
  width: min(420px, 100vw);
  background: var(--color-surface); display: flex; flex-direction: column;
  transform: translateX(110%);
  transition: transform .35s var(--ease-out);
  box-shadow: -8px 0 40px rgba(0,0,0,.18);
}
#cartDrawer.is-open { transform: translateX(0); }
.cart-drawer__head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 24px; border-bottom: 1px solid var(--color-border); flex-shrink: 0;
}
.cart-drawer__title { font-size: 16px; font-weight: 800; color: var(--color-text); }
.cart-drawer__close {
  width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
  border-radius: 50%; cursor: pointer; font-size: 20px; line-height: 1;
  background: none; border: none; color: var(--color-text-muted);
  transition: background var(--t-fast);
}
.cart-drawer__close:hover { background: var(--color-surface-2); color: var(--color-text); }
.cart-drawer__body { flex: 1; overflow-y: auto; padding: 16px 24px; }
.cart-empty {
  text-align: center; padding: 48px 16px;
  display: flex; flex-direction: column; align-items: center; gap: 12px;
}
.cart-empty p { color: var(--color-text-muted); }
.cart-item {
  display: grid; grid-template-columns: 80px 1fr; gap: 12px;
  padding: 14px 0; border-bottom: 1px solid var(--color-border); align-items: start;
}
.cart-item__img { width: 80px; height: 100px; object-fit: cover; border-radius: 8px; flex-shrink: 0; }
.cart-item__img--placeholder { width: 80px; height: 100px; background: var(--color-surface-2); border-radius: 8px; }
.cart-item__body { display: flex; flex-direction: column; gap: 4px; }
.cart-item__title { font-size: 14px; font-weight: 700; color: var(--color-text); line-height: 1.3; }
.cart-item__variant { font-size: 12px; color: var(--color-text-muted); }
.cart-item__row { display: flex; align-items: center; justify-content: space-between; margin-top: 6px; }
.cart-item__price { font-size: 14px; font-weight: 800; color: var(--color-text); }
.cart-item__del {
  background: none; border: none; cursor: pointer; font-size: 12px; font-weight: 600;
  color: var(--color-text-muted); padding: 2px 4px;
  transition: color var(--t-fast); margin-top: 4px;
}
.cart-item__del:hover { color: var(--color-sale); }
.qty-stepper { display: flex; align-items: center; gap: 6px; }
.qty-stepper__btn {
  width: 28px; height: 28px; border-radius: 50%;
  border: 1.5px solid var(--color-border); background: none; cursor: pointer;
  font-size: 16px; line-height: 1; display: flex; align-items: center; justify-content: center;
  color: var(--color-text); transition: all var(--t-fast);
}
.qty-stepper__btn:hover { border-color: var(--color-text-muted); background: var(--color-surface-2); }
.qty-stepper__val {
  width: 28px; text-align: center; font-size: 14px; font-weight: 700;
  border: none; background: none; pointer-events: none;
}
.cart-drawer__foot { padding: 16px 24px; border-top: 1px solid var(--color-border); flex-shrink: 0; }
.cart-subtotal-row {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 15px; font-weight: 800; margin-bottom: 6px;
}
.cart-tax-note { font-size: 11px; color: var(--color-text-muted); margin-bottom: 14px; }
.btn-checkout {
  display: flex; align-items: center; justify-content: center;
  width: 100%; padding: 16px; text-align: center;
  background: var(--color-deco); color: #fff;
  border-radius: var(--radius-btn); font-size: 15px; font-weight: 800;
  text-decoration: none; border: none; cursor: pointer; margin-bottom: 8px;
  transition: filter var(--t-fast), transform var(--t-fast);
}
.btn-checkout:hover { filter: brightness(.9); transform: translateY(-1px); }
.btn-continue {
  display: block; width: 100%; padding: 12px; text-align: center;
  background: none; border: 1.5px solid var(--color-border);
  border-radius: var(--radius-btn); font-size: 13px; font-weight: 600;
  color: var(--color-text-muted); cursor: pointer;
  transition: border-color var(--t-fast), color var(--t-fast);
}
.btn-continue:hover { border-color: var(--color-text-muted); color: var(--color-text); }

/* ══ NAV DRAWER (mobile) ═════════════════════════════ */
#nav-overlay {
  position: fixed; inset: 0; z-index: 295;
  background: rgba(0,0,0,.45); backdrop-filter: blur(2px);
  opacity: 0; visibility: hidden;
  transition: opacity .3s ease, visibility .3s ease;
}
#nav-overlay.is-open { opacity: 1; visibility: visible; }

#nav-drawer {
  position: fixed; top: 0; left: 0; bottom: 0; z-index: 300;
  width: min(340px, 92vw); background: var(--color-surface);
  display: flex; flex-direction: column;
  transform: translateX(-110%);
  transition: transform .35s var(--ease-out);
  box-shadow: 8px 0 40px rgba(0,0,0,.15);
  overflow-y: auto;
}
#nav-drawer.is-open { transform: translateX(0); }
.nav-drawer__head {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 20px; border-bottom: 1px solid var(--color-border);
}
.nav-drawer__logo {
  font-family: var(--font-display); font-size: 18px; font-weight: 800;
  color: var(--color-text);
}
#mobileNavClose {
  width: 36px; height: 36px; display: flex; align-items: center; justify-content: center;
  border-radius: 50%; background: none; border: none; cursor: pointer;
  font-size: 20px; color: var(--color-text-muted);
  transition: background var(--t-fast);
}
#mobileNavClose:hover { background: var(--color-surface-2); color: var(--color-text); }
.nav-drawer__body { padding: var(--sp-4) 0; flex: 1; }
.nav-drawer__link {
  display: flex; align-items: center; justify-content: space-between;
  padding: 13px 20px; font-size: 15px; font-weight: 600;
  color: var(--color-text); text-decoration: none;
  transition: background var(--t-fast), color var(--t-fast);
  border-bottom: 1px solid var(--color-divider);
}
.nav-drawer__link:hover { background: var(--color-surface-2); color: var(--color-deco); }
.nav-drawer__link--sale { color: var(--color-sale) !important; }
.nav-drawer__expand { background: none; border: none; cursor: pointer; padding: 0; }
.nav-drawer__sub { overflow: hidden; max-height: 0; transition: max-height .3s ease; }
.nav-drawer__sub.open { max-height: 500px; }
.nav-drawer__sub a {
  display: block; padding: 10px 20px 10px 36px; font-size: 14px; font-weight: 500;
  color: var(--color-text-muted); text-decoration: none; border-bottom: 1px solid var(--color-divider);
  transition: color var(--t-fast);
}
.nav-drawer__sub a:hover { color: var(--color-deco); }
.nav-drawer__foot {
  padding: var(--sp-5) var(--sp-5); border-top: 1px solid var(--color-border);
  display: flex; flex-direction: column; gap: var(--sp-3);
}

/* ══ HERO ════════════════════════════════════════════ */
.hero-bombas {
  position: relative; overflow: hidden;
  min-height: clamp(480px, 65vh, 860px);
  display: flex; align-items: center;
}
.hero-bombas__img {
  position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
  transform-origin: center; will-change: transform;
  transition: transform 10s ease;
}
.hero-bombas__img--mobile { display: none; }
@media (max-width: 768px) {
  .hero-bombas__img--desktop { display: none; }
  .hero-bombas__img--mobile { display: block; }
}
.hero-bombas:hover .hero-bombas__img { transform: scale(1.04); }
.hero-bombas__overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(105deg, rgba(0,0,0,.52) 0%, rgba(0,0,0,.14) 100%);
}
.hero-bombas--light .hero-bombas__overlay {
  background: linear-gradient(105deg, rgba(255,255,255,.75) 0%, rgba(255,255,255,.08) 100%);
}
.hero-bombas__content {
  position: relative; z-index: 2; width: 100%;
  padding-block: clamp(var(--sp-16), 8vw, var(--sp-24));
}
.hero-bombas__inner { max-width: 680px; }
.hero-bombas h1 {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5.5vw, 5rem);
  font-weight: 900; line-height: 1.05; letter-spacing: -.04em;
  color: #fff; margin-bottom: var(--sp-4);
}
.hero-bombas--light .hero-bombas__inner h1 { color: var(--color-text); }
.hero-bombas__sub {
  font-size: clamp(1rem, 2vw, 1.2rem); font-weight: 400;
  color: rgba(255,255,255,.85); max-width: 500px;
  margin-bottom: var(--sp-8); line-height: 1.65;
}
.hero-bombas--light .hero-bombas__sub { color: var(--color-text-muted); }
.label-eyebrow {
  display: inline-block; font-size: 11px; font-weight: 800;
  letter-spacing: .14em; text-transform: uppercase; margin-bottom: var(--sp-4); opacity: .85;
}
.hero-bombas__ctas { display: flex; flex-wrap: wrap; gap: 10px; }

/* ══ REVEAL ANIMATIONS ════════════════════════════════ */
.reveal {
  opacity: 0; transform: translateY(24px);
  transition: opacity .65s var(--ease-out), transform .65s var(--ease-out);
}
.reveal.is-visible { opacity: 1; transform: translateY(0); }

/* ══ TRUST BAR / BADGES ══════════════════════════════ */
.trust-bar {
  display: flex; align-items: center; justify-content: center;
  flex-wrap: wrap; gap: clamp(var(--sp-4), 4vw, var(--sp-10));
  padding-block: var(--sp-5);
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.trust-item {
  display: flex; align-items: center; gap: var(--sp-3);
  font-size: 13px; font-weight: 600; color: var(--color-text);
}
.trust-item svg { color: var(--color-deco); flex-shrink: 0; }
.trust-item__label { font-size: 11px; color: var(--color-text-muted); display: block; font-weight: 400; }

/* ══ IMPACT / REVIEWS STRIP ══════════════════════════ */
.stat-band {
  display: flex; flex-wrap: wrap; gap: 0;
  background: var(--color-primary);
}
.stat-item {
  flex: 1; min-width: 160px;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  padding: clamp(var(--sp-6), 4vw, var(--sp-10)) var(--sp-6);
  text-align: center; border-right: 1px solid rgba(255,255,255,.12);
  color: #fff;
}
.stat-item:last-child { border-right: none; }
.stat-item__num { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; line-height: 1; }
.stat-item__label { font-size: 13px; opacity: .75; margin-top: 6px; font-weight: 500; }

/* ══ TAB PILLS ════════════════════════════════════════ */
.tab-pills { display: flex; gap: var(--sp-2); flex-wrap: wrap; }
.tab-pill {
  padding: 8px 20px; border-radius: var(--radius-full);
  font-size: 13px; font-weight: 700; letter-spacing: .02em;
  background: var(--color-surface-2); color: var(--color-text-muted);
  border: 1.5px solid transparent; cursor: pointer;
  transition: all var(--t-fast);
}
.tab-pill:hover { background: var(--color-surface-offset); color: var(--color-text); }
.tab-pill.active {
  background: var(--color-text); color: #fff; border-color: var(--color-text);
}
.tab-pane { display: none; }
.tab-pane.active { display: block; }

/* ══ PAYMENT ICONS ════════════════════════════════════ */
.payment-icons { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.payment-icon {
  height: 24px; border-radius: 4px;
  border: 1px solid var(--color-border);
  padding: 0 4px; background: #fff;
  display: flex; align-items: center; justify-content: center;
}
.payment-icon img, .payment-icon svg { height: 16px; width: auto; display: block; }

/* ══ FOOTER ═══════════════════════════════════════════ */
.site-footer { background: var(--color-footer-bg); color: var(--color-footer-text); }
.footer-main {
  display: grid;
  grid-template-columns: 1.8fr repeat(3, 1fr);
  gap: clamp(var(--sp-8), 4vw, var(--sp-16));
  padding-block: clamp(var(--sp-12), 5vw, var(--sp-20));
}
.footer-heading {
  font-size: 11px; font-weight: 800; letter-spacing: .12em; text-transform: uppercase;
  color: #fff; margin-bottom: var(--sp-5);
}
.footer-links { display: flex; flex-direction: column; gap: var(--sp-3); }
.footer-links a {
  font-size: 14px; color: var(--color-footer-text, #ccc);
  transition: color var(--t-fast); text-decoration: none;
}
.footer-links a:hover { color: #fff; }
.footer-about { font-size: 14px; line-height: 1.7; margin-bottom: var(--sp-5); max-width: 32ch; opacity: .75; }
.footer-social { display: flex; gap: var(--sp-3); margin-bottom: var(--sp-6); }
.footer-social a {
  width: 38px; height: 38px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,.15); display: flex; align-items: center; justify-content: center;
  color: var(--color-footer-text, #ccc); transition: all var(--t-fast);
}
.footer-social a:hover { background: rgba(255,255,255,.1); color: #fff; border-color: rgba(255,255,255,.35); }
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.1);
  padding-block: var(--sp-5);
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-4);
  font-size: 12px; color: rgba(255,255,255,.45);
}
.footer-bottom a { color: rgba(255,255,255,.45); transition: color var(--t-fast); text-decoration: none; }
.footer-bottom a:hover { color: rgba(255,255,255,.8); }
.footer-legal { display: flex; gap: var(--sp-4); flex-wrap: wrap; }

/* ══ COOKIE CONSENT ══════════════════════════════════ */
#cookieBanner {
  position: fixed; bottom: 16px; left: 50%; transform: translateX(-50%);
  z-index: 999; width: min(600px, calc(100vw - 32px));
  background: #fff; color: var(--color-text);
  border: 1px solid var(--color-border); border-radius: var(--radius-xl);
  box-shadow: var(--shadow-xl); padding: var(--sp-5) var(--sp-6);
  display: flex; align-items: center; gap: var(--sp-4); flex-wrap: wrap;
}
#cookieBanner p { font-size: 13px; color: var(--color-text-muted); flex: 1; min-width: 200px; line-height: 1.5; }
#cookieBanner p a { color: var(--color-deco); text-decoration: underline; }
.cookie-btns { display: flex; gap: var(--sp-2); flex-shrink: 0; }

/* ══ SEARCH MODAL ════════════════════════════════════ */
#searchModal {
  position: fixed; inset: 0; z-index: 600;
  background: rgba(0,0,0,.65); backdrop-filter: blur(8px);
  opacity: 0; visibility: hidden;
  display: flex; align-items: flex-start; justify-content: center;
  padding-top: 80px;
  transition: opacity .25s ease, visibility .25s ease;
}
#searchModal.is-open { opacity: 1; visibility: visible; }
.search-modal-box {
  width: min(640px, calc(100vw - 32px));
  background: var(--color-surface); border-radius: var(--radius-xl);
  padding: var(--sp-5); box-shadow: var(--shadow-xl);
  transform: translateY(-12px); transition: transform .25s var(--ease-out);
}
#searchModal.is-open .search-modal-box { transform: translateY(0); }
.search-form {
  display: flex; gap: var(--sp-2);
  border: 1.5px solid var(--color-border); border-radius: var(--radius-full);
  padding: 6px 6px 6px 20px; align-items: center;
  transition: border-color .2s;
}
.search-form:focus-within { border-color: var(--color-deco); }
.search-form input {
  flex: 1; border: none; background: transparent; outline: none;
  font-size: 16px; color: var(--color-text);
}
.search-form button {
  background: var(--color-deco); color: #fff;
  border: none; border-radius: var(--radius-full); padding: 10px 20px;
  font-size: 14px; font-weight: 700; cursor: pointer;
  white-space: nowrap;
}

/* ══ MAIN PRODUCT PAGE ════════════════════════════════ */
.product-layout {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: clamp(var(--sp-8), 5vw, var(--sp-16));
  padding-block: clamp(var(--sp-8), 4vw, var(--sp-16));
  align-items: start;
}
.product-gallery__main {
  width: 100%; aspect-ratio: 4/5; border-radius: var(--radius-xl); overflow: hidden;
  background: var(--color-surface-2);
}
.product-gallery__main img { width: 100%; height: 100%; object-fit: cover; }
.product-gallery__thumbs { display: flex; gap: var(--sp-2); margin-top: var(--sp-3); flex-wrap: wrap; }
.product-gallery__thumb {
  width: 72px; height: 90px; border-radius: var(--radius-md); overflow: hidden;
  border: 2px solid transparent; cursor: pointer;
  transition: border-color var(--t-fast); flex-shrink: 0;
}
.product-gallery__thumb.active, .product-gallery__thumb:hover { border-color: var(--color-deco); }
.product-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
.product-info { display: flex; flex-direction: column; gap: var(--sp-4); }
.product-title {
  font-family: var(--font-display); font-size: clamp(1.4rem, 3vw, 2.2rem);
  font-weight: 800; color: var(--color-text); line-height: 1.15;
}
.product-vendor { font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--color-text-muted); }
.product-price-row { display: flex; align-items: baseline; gap: var(--sp-3); flex-wrap: wrap; }
.product-price { font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: 900; color: var(--color-text); }
.product-price--sale { color: var(--color-sale); }
.product-price--compare { font-size: 14px; font-weight: 500; color: var(--color-text-muted); text-decoration: line-through; }
.product-save { font-size: 12px; font-weight: 900; color: var(--color-sale); background: var(--color-sale-bg); padding: 4px 10px; border-radius: 999px; }
.product-rating { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--color-text-muted); }
.product-desc { font-size: 15px; color: var(--color-text-muted); line-height: 1.7; max-width: 55ch; }
.variant-label { font-size: 13px; font-weight: 700; color: var(--color-text); margin-bottom: var(--sp-2); }
.variant-options { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
.variant-opt {
  padding: 7px 16px; border: 1.5px solid var(--color-border); border-radius: var(--radius-full);
  font-size: 13px; font-weight: 600; cursor: pointer; background: none;
  transition: all var(--t-fast);
}
.variant-opt:hover { border-color: var(--color-text-muted); }
.variant-opt.active { background: var(--color-text); color: #fff; border-color: var(--color-text); }
.variant-opt.unavail { opacity: .35; cursor: not-allowed; text-decoration: line-through; }
.qty-row { display: flex; align-items: center; gap: var(--sp-3); }
.qty-box {
  display: flex; align-items: center; gap: 0;
  border: 1.5px solid var(--color-border); border-radius: var(--radius-full);
  overflow: hidden;
}
.qty-box button {
  width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
  background: none; border: none; cursor: pointer; font-size: 18px; line-height: 1;
  color: var(--color-text); transition: background var(--t-fast);
}
.qty-box button:hover { background: var(--color-surface-2); }
.qty-box input {
  width: 44px; text-align: center; font-size: 15px; font-weight: 700;
  border: none; outline: none; background: transparent;
}
.product-atc-btn {
  flex: 1; padding: 16px 32px; background: var(--color-deco); color: #fff;
  border: none; border-radius: var(--radius-btn); font-size: 16px; font-weight: 800;
  cursor: pointer; min-height: 54px;
  transition: filter var(--t-fast), transform var(--t-fast);
}
.product-atc-btn:hover { filter: brightness(.9); transform: translateY(-1px); }
.product-atc-btn:disabled { opacity: .55; cursor: not-allowed; transform: none; }
.product-wishlist {
  width: 54px; height: 54px; border-radius: var(--radius-full);
  border: 1.5px solid var(--color-border); display: flex; align-items: center; justify-content: center;
  cursor: pointer; background: none; color: var(--color-text-muted);
  transition: all var(--t-fast); flex-shrink: 0;
}
.product-wishlist:hover { border-color: var(--color-sale); color: var(--color-sale); background: var(--color-sale-bg); }
.product-guarantee { font-size: 12px; color: var(--color-text-muted); text-align: center; }
.product-tabs { border-top: 1px solid var(--color-border); margin-top: var(--sp-4); }
.prod-tab-btn {
  padding: 12px 0; font-size: 14px; font-weight: 700;
  background: none; border: none; cursor: pointer; color: var(--color-text-muted);
  border-bottom: 2px solid transparent; transition: all var(--t-fast);
  margin-right: var(--sp-6);
}
.prod-tab-btn.active { color: var(--color-text); border-bottom-color: var(--color-deco); }
.prod-tab-panel { display: none; padding-top: var(--sp-4); }
.prod-tab-panel.active { display: block; }

/* ══ ACCORDION / FAQ ═════════════════════════════════ */
.accordion-item { border-bottom: 1px solid var(--color-border); }
.accordion-btn, .accordion-trigger {
  width: 100%; display: flex; justify-content: space-between; align-items: center;
  padding: var(--sp-5) 0; font-size: 15px; font-weight: 700;
  background: none; border: none; cursor: pointer; color: var(--color-text);
  text-align: left; gap: var(--sp-4);
  transition: color var(--t-fast);
}
.accordion-btn:hover, .accordion-trigger:hover { color: var(--color-deco); }
.accordion-chevron { flex-shrink: 0; transition: transform .3s ease; }
.accordion-btn[aria-expanded="true"] .accordion-chevron, .accordion-trigger[aria-expanded="true"] svg:last-child { transform: rotate(180deg); }
.accordion-body {
  max-height: 0; overflow: hidden;
  font-size: 14px; color: var(--color-text-muted); line-height: 1.7;
  transition: max-height .35s ease, padding .3s ease;
}
.accordion-body.is-open { padding-bottom: var(--sp-5); max-height: 500px; }

/* ══ COLLECTION PAGE ════════════════════════════════ */
.collection-hero { padding: clamp(var(--sp-8), 5vw, var(--sp-16)) 0; }
.collection-hero__title {
  font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 900; color: var(--color-text); letter-spacing: -.03em; margin-bottom: var(--sp-3);
}
.collection-filters {
  display: flex; align-items: center; gap: var(--sp-3);
  padding-block: var(--sp-4); border-bottom: 1px solid var(--color-border);
  flex-wrap: wrap;
}
.filter-sort {
  margin-left: auto; display: flex; align-items: center; gap: var(--sp-2);
  font-size: 13px; font-weight: 600;
}
.filter-sort select { padding: 8px 32px 8px 12px; border: 1.5px solid var(--color-border); border-radius: var(--radius-md); font-size: 13px; background: none; cursor: pointer; }

/* ══ CART PAGE ════════════════════════════════════════ */
.cart-layout {
  display: grid; grid-template-columns: 1fr 380px;
  gap: clamp(var(--sp-8), 4vw, var(--sp-12));
  padding-block: clamp(var(--sp-8), 4vw, var(--sp-12));
  align-items: start;
}
.cart-summary {
  position: sticky; top: 88px;
  background: var(--color-surface); border: 1px solid var(--color-border);
  border-radius: var(--radius-xl); padding: var(--sp-6);
}
.cart-summary__title { font-size: 16px; font-weight: 800; margin-bottom: var(--sp-5); }
.cart-summary__row { display: flex; justify-content: space-between; font-size: 14px; color: var(--color-text-muted); margin-bottom: var(--sp-3); }
.cart-summary__total { font-size: 18px; font-weight: 900; border-top: 1px solid var(--color-border); padding-top: var(--sp-4); margin-top: var(--sp-2); display: flex; justify-content: space-between; }
.cart-table { width: 100%; }
.cart-table__row {
  display: grid; grid-template-columns: 100px 1fr auto;
  gap: var(--sp-5); padding: var(--sp-5) 0; border-bottom: 1px solid var(--color-border); align-items: start;
}
.cart-table__img { width: 100px; height: 125px; object-fit: cover; border-radius: var(--radius-md); }

/* ══ PAGE TEMPLATES ════════════════════════════════════ */
.page-content { padding-block: clamp(var(--sp-12), 6vw, var(--sp-24)); }
.page-content h1 {
  font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900; margin-bottom: var(--sp-8);
}
.page-content h2 { font-size: clamp(1.2rem, 3vw, 1.8rem); font-weight: 800; margin: var(--sp-8) 0 var(--sp-4); color: var(--color-text); }
.page-content p { font-size: 15px; color: var(--color-text-muted); line-height: 1.8; margin-bottom: var(--sp-5); max-width: 70ch; }

/* ══ 404 PAGE ════════════════════════════════════════ */
.page-404 {
  min-height: 60vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center; text-align: center;
  padding: clamp(var(--sp-16), 10vw, var(--sp-24));
}
.page-404 h1 {
  font-family: var(--font-display); font-size: clamp(5rem, 20vw, 12rem);
  font-weight: 900; color: var(--color-surface-offset); line-height: 1; margin-bottom: var(--sp-4);
}
.page-404 p { font-size: 18px; color: var(--color-text-muted); margin-bottom: var(--sp-8); }

/* ══ MOBILE RESPONSIVE ════════════════════════════════ */
@media (max-width: 1023px) {
  .header-nav, .header-nav-center { display: none; }
  .hamburger, #mobileNavTrigger { display: flex; }
  .header-inner { grid-template-columns: auto 1fr auto; }
  .footer-main { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 767px) {
  .cart-layout { grid-template-columns: 1fr; }
  .product-layout { grid-template-columns: 1fr; }
  .footer-main { grid-template-columns: 1fr; gap: var(--sp-8); }
  .footer-bottom { flex-direction: column; text-align: center; }
}
@media (max-width: 639px) {
  .trust-bar { gap: var(--sp-4); padding: var(--sp-4) var(--sp-4); }
  .trust-item span:not(.trust-item__label) { font-size: 12px; }
  .stat-band { flex-direction: column; }
  .stat-item { border-right: none; border-bottom: 1px solid rgba(255,255,255,.12); }
  .cart-table__row { grid-template-columns: 80px 1fr; }
}

/* ─── Product Card Premium Improvements ───────────────────────────────────── */
.prod-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--color-surface);
  transition: box-shadow 250ms ease, transform 250ms ease;
  transform-style: preserve-3d;
  perspective: 800px;
  box-shadow: 0 1px 3px oklch(0.2 0.01 80 / 0.06);
}
.prod-card:hover {
  box-shadow: 0 8px 32px oklch(0.2 0.01 80 / 0.14), 0 1px 4px oklch(0.2 0.01 80 / 0.08);
  transform: translateY(-5px) rotateX(1.5deg);
}
.prod-card__media {
  position: relative; overflow: hidden;
  aspect-ratio: 3/4;
  background: var(--color-surface-offset);
}
.prod-card__img--primary,
.prod-card__img--hover {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  transition: opacity 0.4s ease, transform 0.6s ease;
}
.prod-card__img--hover { opacity: 0; }
.prod-card:hover .prod-card__img--primary { transform: scale(1.04); }
.prod-card:hover .prod-card__img--hover   { opacity: 1; }
.prod-card:hover .prod-card__img--primary:not(:has(~ .prod-card__img--hover)) { opacity: 1; }

.prod-card__badges {
  position: absolute; top: 10px; left: 10px;
  display: flex; flex-direction: column; gap: 4px; z-index: 2;
}
.badge {
  display: inline-flex; align-items: center;
  padding: 3px 8px; border-radius: 4px;
  font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; line-height: 1.4;
}
.badge--sale, .prod-card__badge--sale {
  background: var(--color-sale, #dc2626); color: #fff;
}
.badge--new, .prod-card__badge--new {
  background: var(--color-primary); color: #fff;
}
.badge--bestseller, .prod-card__badge--best, .prod-card__badge--bestseller {
  background: #d97706; color: #fff;
}
.prod-card__quick-add {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 10px 12px;
  background: linear-gradient(0deg, rgba(0,0,0,0.45) 0%, transparent 100%);
  transform: translateY(100%);
  transition: transform 0.28s ease;
  z-index: 3;
}
.prod-card:hover .prod-card__quick-add { transform: translateY(0); }

.prod-card__info {
  padding: 14px 16px 18px;
  display: flex; flex-direction: column; gap: 5px;
}
.prod-card__vendor {
  font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--color-text-muted);
}
.prod-card__title {
  font-family: var(--font-body); font-weight: 600;
  font-size: var(--text-sm); line-height: 1.35;
}
.prod-card__title a { color: var(--color-text); text-decoration: none; }
.prod-card__title a:hover { color: var(--color-primary); }
.prod-card__rating {
  display: flex; align-items: center; gap: 4px;
}
.prod-card__rating .stars {
  display: flex; gap: 1px;
}
.prod-card__price {
  display: flex; align-items: center; gap: 8px;
  margin-top: 4px;
}
.prod-card__price--current {
  font-weight: 700; font-size: var(--text-base); color: var(--color-text);
}
.prod-card__price--compare {
  font-size: var(--text-sm); color: var(--color-text-muted);
  text-decoration: line-through;
}
/* Product grid responsive */
.prod-grid {
  display: grid;
  gap: clamp(14px, 2vw, 24px);
}
.prod-grid--4 { grid-template-columns: repeat(4, 1fr); }
.prod-grid--3 { grid-template-columns: repeat(3, 1fr); }
.prod-grid--2 { grid-template-columns: repeat(2, 1fr); }
@media (max-width: 1023px) {
  .prod-grid--4,
  .prod-grid--3 { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .prod-grid--4,
  .prod-grid--3,
  .prod-grid--2 { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .prod-card__info { padding: 10px 10px 12px; }
}

/* Section layout helpers */
.section-gap { padding: clamp(40px, 6vw, 80px) 0; }
.section-hdr { margin-bottom: clamp(24px, 4vw, 48px); }
.section-eyebrow {
  font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--color-primary);
  margin-bottom: 8px;
}
.section-title {
  font-family: var(--font-display, serif);
  font-size: clamp(1.5rem, 3vw, 2.4rem);
  font-weight: 700; line-height: 1.15;
  color: var(--color-text);
}
.section-subtitle {
  font-size: var(--text-base); color: var(--color-text-muted);
  margin-top: 8px; max-width: 56ch; margin-inline: auto;
}
