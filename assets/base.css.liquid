
/*
  BodyLuxCare — base.css.liquid  v4.0
  Art direction: Premium Wellness × Luxury Living
  Palette: Warm ivory · Near-black · Emerald deco · Red-orange sale
  Shopify .css.liquid — Liquid settings injected as CSS custom properties
*/

/* ── Reset ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  scroll-behavior: smooth;
  scroll-padding-top: 80px;
}
body {
  min-height: 100dvh;
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 16px;
  line-height: 1.6;
  color: var(--color-text);
  background: var(--color-bg);
}
img, picture, video, canvas, svg { display: block; max-width: 100%; height: auto; }
input, button, textarea, select { font: inherit; color: inherit; }
ul[role="list"], ol[role="list"] { list-style: none; }
h1,h2,h3,h4,h5,h6 { text-wrap: balance; line-height: 1.15; }
p,li { text-wrap: pretty; }
button { cursor: pointer; background: none; border: none; }
a { text-decoration: none; }

/* ══════════════════════════════════════════════════════
   CSS CUSTOM PROPERTIES — injected from Shopify settings
   All {{ }} expressions are valid in .css.liquid files
══════════════════════════════════════════════════════ */
:root {
  /* Brand colours */
  --c-primary:        {{ settings.color_primary | default: '#1a1a1a' }};
  --c-secondary:      {{ settings.color_secondary | default: '#e85d26' }};

  /* Sale — vivid red-orange urgency */
  --c-sale:           {{ settings.color_sale | default: '#e8260d' }};
  --c-sale-bg:        {{ settings.color_sale_bg | default: '#fff4f3' }};

  /* Decoration green — emerald luxury */
  --c-deco:           {{ settings.color_deco | default: '#2d7a4f' }};
  --c-deco-light:     {{ settings.color_deco_light | default: '#e8f5ee' }};

  /* Page surfaces */
  --c-bg:             {{ settings.color_bg | default: '#faf9f7' }};
  --c-surface:        #ffffff;
  --c-surface-2:      #f5f3f0;
  --c-surface-offset: #edeae6;

  /* Text */
  --c-text:           {{ settings.color_text | default: '#1a1a1a' }};
  --c-text-muted:     {{ settings.color_text_muted | default: '#666666' }};
  --c-text-faint:     #aaaaaa;
  --c-text-inv:       #ffffff;

  /* Border */
  --c-border:         {{ settings.color_border | default: '#e4e2de' }};

  /* Buttons */
  --c-btn-bg:         {{ settings.color_btn_primary_bg | default: '#1a1a1a' }};
  --c-btn-text:       {{ settings.color_btn_primary_text | default: '#ffffff' }};
  --c-btn-r:          {{ settings.button_border_radius | default: '9999px' }};

  /* Header */
  --c-header-bg:      {{ settings.color_header_bg | default: '#ffffff' }};
  --c-header-text:    {{ settings.color_header_text | default: '#1a1a1a' }};
  --c-header-border:  {{ settings.color_header_border | default: '#e4e2de' }};

  /* Footer */
  --c-footer-bg:      {{ settings.color_footer_bg | default: '#111111' }};
  --c-footer-text:    {{ settings.color_footer_text | default: '#cccccc' }};

  /* Layout */
  --max-w:            {{ settings.container_max_width | default: 1280 }}px;
  --section-gap:      {{ settings.section_spacing | default: 64 }}px;
  --card-r:           {{ settings.card_border_radius | default: '12px' }};

  /* 3-D tilt */
  --tilt-perspective: 900px;
  --tilt-max:         14deg;

  /* Shadows */
  --shadow-sm:  0 1px 3px rgba(0,0,0,.07);
  --shadow-md:  0 4px 16px rgba(0,0,0,.09);
  --shadow-lg:  0 12px 36px rgba(0,0,0,.13);
  --shadow-xl:  0 24px 60px rgba(0,0,0,.16);

  /* Easing */
  --ease-out:   cubic-bezier(0.16,1,0.3,1);
  --t-fast:     160ms cubic-bezier(0.16,1,0.3,1);
  --t-med:      280ms cubic-bezier(0.16,1,0.3,1);
  --t-slow:     500ms cubic-bezier(0.16,1,0.3,1);
}

/* ── Accessibility ── */
.skip-link {
  position:absolute; left:-9999px; top:8px; padding:8px 16px;
  background:var(--color-primary); color:#ffffff; border-radius:4px;
  font-size:13px; font-weight:700; z-index:9999;
}
.skip-link:focus { left:8px; }
:focus-visible { outline:2px solid var(--color-deco); outline-offset:3px; border-radius:3px; }
.sr-only { position:absolute; width:1px; height:1px; padding:0; margin:-1px; overflow:hidden; clip:rect(0,0,0,0); white-space:nowrap; border-width:0; }

@media (prefers-reduced-motion:reduce) {
  *, *::before, *::after {
    animation-duration:.01ms !important;
    transition-duration:.01ms !important;
    animation-iteration-count:1 !important;
  }
}

/* ══════════════════════════════════════════════════════
   LAYOUT UTILITIES
══════════════════════════════════════════════════════ */
.page-w {
  max-width: var(--max-w);
  margin-inline: auto;
  padding-inline: clamp(16px, 4vw, 48px);
}
.page-w--narrow { max-width:760px; margin-inline:auto; padding-inline:20px; }

/* ══════════════════════════════════════════════════════
   ANNOUNCEMENT BAR
══════════════════════════════════════════════════════ */
.ann-bar { overflow:hidden; position:relative; }
.ann-track {
  display:flex; width:max-content;
  animation:ann-scroll 30s linear infinite;
}
.ann-track:hover { animation-play-state:paused; }
.ann-item {
  display:flex; align-items:center; gap:10px;
  padding:0 48px; height:40px;
  font-size:13px; font-weight:600; letter-spacing:.03em;
  white-space:nowrap;
}
.ann-dot { width:4px; height:4px; border-radius:50%; background:currentColor; opacity:.4; flex-shrink:0; }
.ann-link { font-weight:700; text-decoration:underline; text-underline-offset:2px; color:inherit; margin-left:4px; }
.ann-close {
  position:absolute; right:12px; top:50%; transform:translateY(-50%);
  background:none; border:none; cursor:pointer; opacity:.6; font-size:16px; line-height:1;
  color:inherit; padding:6px;
}
.ann-close:hover { opacity:1; }
@keyframes ann-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }
@media (prefers-reduced-motion:reduce) { .ann-track { animation:none; justify-content:center; } }

/* ══════════════════════════════════════════════════════
   HEADER
══════════════════════════════════════════════════════ */
.site-header {
  position:sticky; top:0; z-index:200;
  background:var(--color-header-bg);
  border-bottom:1px solid var(--color-border);
  transition:box-shadow var(--t-fast);
}
.site-header.scrolled { box-shadow:0 2px 20px rgba(0,0,0,.08); }

.header-inner {
  display:grid;
  grid-template-columns:1fr auto 1fr;
  align-items:center;
  height:{{ settings.header_height | default: 64 }}px;
  gap:8px;
  padding-inline:clamp(16px,3vw,40px);
}
.header-left { display:flex; align-items:center; gap:4px; }
.header-logo { display:flex; align-items:center; text-decoration:none; }
.header-logo img { max-height:{{ settings.logo_height | default: 40 }}px; width:auto; display:block; }
.header-logo-text {
  font-size:20px; font-weight:900; letter-spacing:-.05em;
  color:var(--color-text); text-decoration:none;
}
.header-logo-text .accent { color:var(--color-deco); }

.header-nav { display:flex; align-items:center; gap:2px; }
.header-nav > a, .nav-item > a {
  font-size:13px; font-weight:600; letter-spacing:.02em;
  color:var(--color-text); text-decoration:none;
  padding:8px 12px; border-radius:6px; display:block;
  transition:background var(--t-fast), color var(--t-fast);
  white-space:nowrap;
}
.header-nav > a:hover, .nav-item > a:hover { background:var(--color-surface); }
.header-nav > a.active, .nav-item > a.active { color:var(--color-deco); }

/* Mega-nav dropdown */
.nav-item { position:relative; }
.nav-dropdown {
  position:absolute; top:calc(100% + 4px); left:50%;
  transform:translateX(-50%) translateY(-6px);
  min-width:520px; background:#fff;
  border:1px solid var(--color-border); border-radius:14px;
  padding:24px; box-shadow:var(--shadow-3d);
  display:grid; grid-template-columns:repeat(4,1fr); gap:4px;
  opacity:0; visibility:hidden; pointer-events:none;
  transition:opacity var(--t-fast), transform var(--t-fast), visibility var(--t-fast);
  z-index:300;
}
.nav-item:hover .nav-dropdown,
.nav-item:focus-within .nav-dropdown {
  opacity:1; visibility:visible; transform:translateX(-50%) translateY(0); pointer-events:auto;
}
.nd-col { display:flex; flex-direction:column; gap:2px; }
.nd-head {
  font-size:10px; font-weight:800; letter-spacing:.1em;
  text-transform:uppercase; color:var(--color-text-muted);
  padding:4px 10px 8px; border-bottom:1px solid var(--color-border); margin-bottom:4px;
}
.nd-col a {
  font-size:13px; font-weight:500; color:var(--color-text);
  padding:7px 10px; border-radius:7px;
  transition:background var(--t-fast), color var(--t-fast); white-space:nowrap;
}
.nd-col a:hover { background:var(--color-deco-light); color:var(--color-deco); }

.header-actions { display:flex; align-items:center; justify-content:flex-end; gap:2px; }
.icon-btn {
  width:40px; height:40px; display:flex; align-items:center; justify-content:center;
  border-radius:8px; color:var(--color-text); background:none; border:none;
  cursor:pointer; text-decoration:none; position:relative;
  transition:background var(--t-fast);
}
.icon-btn:hover { background:var(--color-surface); }
.icon-btn svg {
  width:20px; height:20px; stroke:currentColor; fill:none;
  stroke-width:1.8; stroke-linecap:round; stroke-linejoin:round; display:block;
}
.cart-badge {
  position:absolute; top:5px; right:5px;
  background:var(--color-sale); color:#fff;
  font-size:9px; font-weight:900;
  min-width:16px; height:16px; border-radius:999px;
  display:flex; align-items:center; justify-content:center;
  padding:0 3px; line-height:1;
  border:1.5px solid var(--color-header-bg);
}
.hamburger {
  display:none; flex-direction:column; justify-content:center; align-items:center;
  gap:5px; width:40px; height:40px; border-radius:8px; background:none; border:none; cursor:pointer;
  transition:background var(--t-fast);
}
.hamburger:hover { background:var(--color-surface); }
.ham-line {
  display:block; width:20px; height:2px;
  background:var(--color-text); border-radius:2px;
  transition:transform .25s, opacity .25s;
}

/* Search bar */
.header-search-bar {
  max-height:0; overflow:hidden;
  transition:max-height .3s var(--ease-out), padding .3s var(--ease-out);
  background:var(--color-header-bg);
  border-top:0 solid var(--color-border);
}
.header-search-bar.open {
  max-height:80px;
  border-top-width:1px;
  padding:10px clamp(16px,3vw,40px);
}
.header-search-form { max-width:560px; margin:0 auto; display:flex; gap:8px; }
.header-search-form input {
  flex:1; padding:10px 16px;
  border:1.5px solid var(--color-border); border-radius:9999px;
  font-size:14px; outline:none;
  transition:border-color var(--t-fast);
}
.header-search-form input:focus { border-color:var(--color-deco); }
.header-search-form button {
  padding:10px 20px; background:var(--color-deco); color:#fff;
  border:none; border-radius:9999px; font-size:13px; font-weight:700;
  cursor:pointer; white-space:nowrap; transition:filter var(--t-fast);
}
.header-search-form button:hover { filter:brightness(.9); }

/* ══════════════════════════════════════════════════════
   BUTTONS
══════════════════════════════════════════════════════ */
.btn {
  display:inline-flex; align-items:center; justify-content:center; gap:8px;
  font-size:14px; font-weight:700; letter-spacing:.02em;
  padding:12px 24px; border-radius:var(--radius-btn);
  border:2px solid transparent; cursor:pointer;
  transition:background var(--t-fast), color var(--t-fast),
             border-color var(--t-fast), box-shadow var(--t-fast), transform var(--t-fast);
  text-decoration:none; white-space:nowrap; line-height:1;
}
.btn:hover { transform:translateY(-1px); }
.btn:active { transform:translateY(0); }

.btn-primary, .btn-black {
  background:var(--color-primary); color:#ffffff;
  border-color:var(--color-primary);
}
.btn-primary:hover, .btn-black:hover { filter:brightness(.88); }

.btn-outline {
  background:transparent; color:var(--color-primary);
  border-color:var(--color-primary);
}
.btn-outline:hover { background:var(--color-primary); color:#ffffff; }

.btn-white { background:#fff; color:#1a1a1a; border-color:#fff; }
.btn-white:hover { background:rgba(255,255,255,.88); }

.btn-outline-white { background:transparent; color:#fff; border-color:rgba(255,255,255,.7); }
.btn-outline-white:hover { background:rgba(255,255,255,.15); border-color:#fff; }

.btn-sale {
  background:var(--color-sale); color:#fff; border-color:var(--color-sale);
  box-shadow:0 4px 20px rgba(232,38,13,.30);
}
.btn-sale:hover { filter:brightness(.9); box-shadow:0 6px 28px rgba(232,38,13,.40); }

.btn-deco {
  background:var(--color-deco); color:#fff; border-color:var(--color-deco);
}
.btn-deco:hover { filter:brightness(.9); }

.btn-sm  { padding:8px 16px; font-size:13px; }
.btn-lg  { padding:15px 32px; font-size:15px; }
.btn-xl  { padding:18px 40px; font-size:16px; }
.btn-full { width:100%; }

/* ATC states */
.atc-btn.added { background:var(--color-deco); border-color:var(--color-deco); }
.atc-btn:disabled { opacity:.6; cursor:not-allowed; transform:none; }

/* ══════════════════════════════════════════════════════
   ★ PRODUCT CARD — 3-D tilt + sale urgency + deco green
══════════════════════════════════════════════════════ */
.prod-card-wrap { perspective:var(--tilt-perspective); border-radius:var(--radius-card); }
.prod-card {
  position:relative; background:var(--color-surface);
  border-radius:var(--radius-card); overflow:visible;
  display:flex; flex-direction:column;
  transform-style:preserve-3d; will-change:transform;
  box-shadow:var(--shadow-sm);
  transform:perspective(var(--tilt-perspective)) rotateX(0) rotateY(0) scale3d(1,1,1);
  transition:box-shadow var(--t-med), transform var(--t-med);
}
.prod-card:hover { box-shadow:var(--shadow-3d); }

.prod-card__img-wrap {
  position:relative; overflow:hidden;
  border-radius:calc(var(--radius-card) - 2px) calc(var(--radius-card) - 2px) 0 0;
  aspect-ratio:{{ settings.card_image_ratio | default: '0.8' }};
  background:var(--color-surface);
}
.prod-card__img-wrap img {
  width:100%; height:100%; object-fit:cover;
  transition:transform 600ms var(--ease-out);
}
.prod-card:hover .prod-card__img-wrap img { transform:scale(1.05); }

/* Shine — 3-D glass reflection */
.prod-card__shine {
  position:absolute; inset:0; pointer-events:none;
  background:linear-gradient(135deg,rgba(255,255,255,.2) 0%,transparent 60%);
  opacity:0; transition:opacity var(--t-med); border-radius:inherit; z-index:2;
}
.prod-card:hover .prod-card__shine { opacity:1; }

/* SALE badge — vivid red-orange with pulse glow */
.prod-card__badge-sale {
  position:absolute; top:12px; left:12px; z-index:3;
  background:var(--color-sale); color:#fff;
  font-size:11px; font-weight:900; letter-spacing:.04em;
  padding:4px 10px; border-radius:999px;
  box-shadow:0 0 0 0 rgba(232,38,13,.35);
  animation:sale-pulse 2s ease-in-out infinite;
}
@keyframes sale-pulse {
  0%,100% { box-shadow:0 0 0 0 rgba(232,38,13,.35); }
  50%      { box-shadow:0 0 0 8px rgba(232,38,13,0); }
}

/* Deco green badge */
.prod-card__badge-new {
  position:absolute; top:12px; right:12px; z-index:3;
  background:var(--color-deco); color:#fff;
  font-size:11px; font-weight:900; letter-spacing:.04em;
  padding:4px 10px; border-radius:999px;
}

/* Quick-add hover button */
.prod-card__quick {
  position:absolute; bottom:12px; left:12px; right:12px; z-index:4;
  opacity:0; transform:translateY(8px);
  transition:opacity var(--t-med), transform var(--t-med);
}
.prod-card:hover .prod-card__quick { opacity:1; transform:translateY(0); }

.prod-card__info { padding:14px 16px 16px; display:flex; flex-direction:column; gap:6px; }
.prod-card__title { font-size:14px; font-weight:700; color:var(--color-text); line-height:1.3; }
.prod-card__vendor { font-size:12px; color:var(--color-text-muted); text-transform:uppercase; letter-spacing:.06em; }
.prod-card__price-row { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }

/* ─────────────────────────────────────────────────────
   PROD-CARD — Missing subclass styles
   ───────────────────────────────────────────────────── */

/* Media wrapper */
.prod-card__media {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-card) var(--radius-card) 0 0;
  background: var(--color-surface);
  aspect-ratio: 4/5;
}
.prod-card__img,
.prod-card__img--primary {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.3s ease, transform 0.5s var(--ease-out);
}
.prod-card__img--hover {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 0.35s ease;
}
.prod-card:hover .prod-card__img--primary { opacity: 0; }
.prod-card:hover .prod-card__img--hover   { opacity: 1; }

/* Badges */
.prod-card__badges {
  position: absolute; top: var(--space-3); left: var(--space-3);
  display: flex; flex-direction: column; gap: var(--space-1);
  z-index: 2;
}
.prod-card__badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: var(--radius-full);
  font-size: 11px; font-weight: 800;
  letter-spacing: 0.04em; text-transform: uppercase;
  line-height: 1.6;
}

/* Quick-add button */
.prod-card__quick-add {
  position: absolute; bottom: var(--space-3); left: var(--space-3); right: var(--space-3);
  opacity: 0; transform: translateY(8px);
  transition: opacity 0.2s ease, transform 0.25s var(--ease-out);
  z-index: 3;
}
.prod-card:hover .prod-card__quick-add {
  opacity: 1; transform: translateY(0);
}

/* Info section */
.prod-card__meta {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: var(--space-1);
}
.prod-card__name {
  font-size: var(--text-sm);
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Rating stars */
.prod-card__rating {
  display: flex; align-items: center; gap: 4px;
  font-size: var(--text-xs); color: var(--color-text-muted);
  margin-bottom: var(--space-1);
}

/* Price */
.prod-card__price {
  display: flex; align-items: baseline; gap: var(--space-2); flex-wrap: wrap;
  margin-top: var(--space-1);
}
.prod-card__price--current {
  font-size: var(--text-sm);
  font-weight: 800;
  color: var(--color-text);
}
.prod-card__price--compare,
.prod-card__was {
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: line-through;
}
.prod-card__save {
  font-size: var(--text-xs);
  font-weight: 800;
  color: var(--color-sale);
  background: color-mix(in oklch, var(--color-sale) 12%, transparent);
  padding: 2px 8px;
  border-radius: var(--radius-full);
}

/* Swatches */
.prod-card__swatches {
  display: flex; gap: 6px; flex-wrap: wrap;
  margin-top: var(--space-2);
}
.prod-card__swatches .swatch {
  width: 20px; height: 20px;
  border-radius: 50%;
  border: 2px solid transparent;
  box-shadow: 0 0 0 1.5px var(--color-border);
  cursor: pointer; transition: box-shadow var(--trans-fast);
}
.prod-card__swatches .swatch:hover,
.prod-card__swatches .swatch.active {
  box-shadow: 0 0 0 2px var(--color-primary);
}

/* ─────────────────────────────────────────────────────
   CAT-TILE — Missing subclass styles
   ───────────────────────────────────────────────────── */

.cat-tile__body {
  position: absolute; inset: 0;
  display: flex; flex-direction: column;
  align-items: flex-start; justify-content: flex-end;
  padding: var(--space-6);
  background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 55%);
  border-radius: var(--radius-lg);
}
.cat-tile__name {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 800;
  color: #ffffff;
  line-height: 1.1;
  margin-bottom: var(--space-3);
  text-shadow: 0 1px 4px rgba(0,0,0,0.3);
}
.cat-tile__btn {
  display: inline-flex; align-items: center; gap: var(--space-2);
  padding: 10px 20px;
  background: #ffffff;
  color: var(--color-text);
  font-size: var(--text-sm);
  font-weight: 700;
  border-radius: var(--radius-full);
  transition: background var(--trans-fast), transform var(--trans-fast);
  white-space: nowrap;
}
.cat-tile:hover .cat-tile__btn {
  background: var(--color-primary);
  color: #ffffff;
  transform: translateY(-2px);
}


/* Price */
.price { font-size:15px; font-weight:800; color:var(--color-text); }
.price--sale { color:var(--color-sale); }
.price--compare { font-size:13px; font-weight:500; color:var(--color-text-muted); text-decoration:line-through; }
.price--save {
  font-size:11px; font-weight:800; color:var(--color-sale);
  background:#fff4f3; padding:2px 7px; border-radius:999px;
}

/* Grid */
.product-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(min(230px,100%),1fr));
  gap:clamp(12px,2vw,24px);
}

/* ══════════════════════════════════════════════════════
   HERO BANNER
══════════════════════════════════════════════════════ */
.hero-bombas {
  position:relative; overflow:hidden;
  min-height:clamp(480px,65vh,800px);
  display:flex; align-items:center;
}
.hero-bombas__img {
  position:absolute; inset:0;
  width:100%; height:100%; object-fit:cover;
  transform-origin:center; will-change:transform;
}
.hero-bombas__overlay {
  position:absolute; inset:0; z-index:1;
  background:linear-gradient(105deg,rgba(0,0,0,.52) 0%,rgba(0,0,0,.18) 100%);
}
.hero-bombas--light .hero-bombas__overlay {
  background:linear-gradient(105deg,rgba(255,255,255,.7) 0%,rgba(255,255,255,.1) 100%);
}
.hero-bombas__content {
  position:relative; z-index:2;
  padding-block:clamp(48px,8vw,120px);
}
.hero-bombas__inner { max-width:680px; }
.hero-bombas h1 {
  font-size:clamp(2.2rem,5.5vw,5rem);
  font-weight:900; line-height:1.05; letter-spacing:-.04em;
  color:#fff; margin-bottom:16px;
}
.hero-bombas--light .hero-bombas__inner h1 { color:var(--color-text); }
.hero-bombas__sub {
  font-size:clamp(1rem,2vw,1.2rem); font-weight:400; color:rgba(255,255,255,.85);
  max-width:500px; margin-bottom:32px; line-height:1.6;
}
.hero-bombas--light .hero-bombas__sub { color:var(--color-text-muted); }
.label-eyebrow {
  display:inline-block; font-size:12px; font-weight:800;
  letter-spacing:.12em; text-transform:uppercase;
  margin-bottom:16px; opacity:.8;
}
.hero-bombas__ctas { display:flex; flex-wrap:wrap; gap:12px; }

/* ══════════════════════════════════════════════════════
   SECTION HEADINGS
══════════════════════════════════════════════════════ */
.section-title {
  font-size:clamp(1.5rem,3vw,2.2rem);
  font-weight:900; letter-spacing:-.03em; color:var(--color-text);
}
.section-subtitle { font-size:15px; color:var(--color-text-muted); margin-top:8px; }
.section-head { margin-bottom:clamp(24px,4vw,48px); }
.section-head.center { text-align:center; }

/* ══════════════════════════════════════════════════════
   CART DRAWER
══════════════════════════════════════════════════════ */
.cart-drawer {
  position:fixed; inset:0; z-index:400;
  pointer-events:none; visibility:hidden;
}
.cart-drawer.open { pointer-events:auto; visibility:visible; }
.cart-drawer__overlay {
  position:absolute; inset:0;
  background:rgba(0,0,0,.45); backdrop-filter:blur(2px);
  opacity:0; transition:opacity .3s ease;
}
.cart-drawer.open .cart-drawer__overlay { opacity:1; }
.cart-drawer__panel {
  position:absolute; top:0; right:0; bottom:0;
  width:min(420px,100vw);
  background:var(--color-surface); display:flex; flex-direction:column;
  transform:translateX(100%);
  transition:transform .35s var(--ease-out);
  box-shadow:-8px 0 40px rgba(0,0,0,.15);
}
.cart-drawer.open .cart-drawer__panel { transform:translateX(0); }
.cart-drawer__head {
  display:flex; align-items:center; justify-content:space-between;
  padding:20px 24px; border-bottom:1px solid var(--color-border);
  flex-shrink:0;
}
.cart-drawer__title { font-size:16px; font-weight:800; color:var(--color-text); }
.cart-drawer__close {
  width:36px; height:36px; display:flex; align-items:center; justify-content:center;
  border-radius:50%; cursor:pointer; font-size:20px; line-height:1;
  transition:background var(--t-fast);
}
.cart-drawer__close:hover { background:var(--color-surface); }
.cart-drawer__body { flex:1; overflow-y:auto; padding:16px 24px; }
.cart-drawer__empty { text-align:center; padding:48px 16px; }
.cart-drawer__empty p { color:var(--color-text-muted); margin-bottom:20px; }
.cart-item {
  display:grid; grid-template-columns:70px 1fr auto;
  gap:12px; padding:12px 0; border-bottom:1px solid var(--color-border); align-items:start;
}
.cart-item__img { width:70px; height:88px; object-fit:cover; border-radius:8px; }
.cart-item__name { font-size:14px; font-weight:700; color:var(--color-text); }
.cart-item__variant { font-size:12px; color:var(--color-text-muted); margin-top:2px; }
.cart-item__price { font-size:14px; font-weight:800; color:var(--color-text); margin-top:4px; }
.cart-qty { display:flex; align-items:center; gap:8px; margin-top:8px; }
.qty-btn {
  width:28px; height:28px; border:1.5px solid var(--color-border); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:16px; line-height:1; cursor:pointer; background:none;
  transition:background var(--t-fast), border-color var(--t-fast);
}
.qty-btn:hover { background:var(--color-surface); border-color:var(--color-text-muted); }
.qty-val { font-size:14px; font-weight:700; min-width:20px; text-align:center; }
.cart-item__del {
  width:28px; height:28px; display:flex; align-items:center; justify-content:center;
  cursor:pointer; color:var(--color-text-muted); border-radius:50%; font-size:14px;
  transition:background var(--t-fast), color var(--t-fast);
}
.cart-item__del:hover { background:#fff4f3; color:var(--color-sale); }
.cart-drawer__foot { padding:16px 24px; border-top:1px solid var(--color-border); flex-shrink:0; }
.cart-subtotal-row {
  display:flex; justify-content:space-between; align-items:center;
  font-size:15px; font-weight:800; margin-bottom:8px;
}
.cart-tax-note { font-size:12px; color:var(--color-text-muted); margin-bottom:16px; }
.btn-checkout {
  display:block; width:100%; padding:16px; text-align:center;
  background:var(--color-primary); color:#ffffff;
  border-radius:var(--radius-btn); font-size:15px; font-weight:800;
  text-decoration:none; margin-bottom:10px;
  transition:filter var(--t-fast), transform var(--t-fast);
}
.btn-checkout:hover { filter:brightness(.88); transform:translateY(-1px); }
.btn-continue {
  display:block; width:100%; padding:12px; text-align:center;
  background:none; border:1.5px solid var(--color-border); border-radius:var(--radius-btn);
  font-size:13px; font-weight:600; color:var(--color-text-muted); cursor:pointer;
  transition:border-color var(--t-fast), color var(--t-fast);
}
.btn-continue:hover { border-color:var(--color-text); color:var(--color-text); }
.cart-trust {
  display:flex; justify-content:center; gap:16px; flex-wrap:wrap;
  margin-top:12px; padding-top:12px; border-top:1px solid var(--color-border);
  font-size:11px; font-weight:600; color:var(--color-text-muted);
}

/* ══════════════════════════════════════════════════════
   MOBILE NAV
══════════════════════════════════════════════════════ */
.mobile-nav {
  position:fixed; inset:0; z-index:500;
  pointer-events:none; visibility:hidden;
}
.mobile-nav.open { pointer-events:auto; visibility:visible; }
.mobile-nav__overlay {
  position:absolute; inset:0; background:rgba(0,0,0,.5);
  opacity:0; transition:opacity .3s ease;
}
.mobile-nav.open .mobile-nav__overlay { opacity:1; }
.mobile-nav__panel {
  position:absolute; top:0; left:0; bottom:0;
  width:min(320px,88vw); background:var(--color-surface);
  display:flex; flex-direction:column; overflow-y:auto;
  transform:translateX(-100%);
  transition:transform .35s var(--ease-out);
}
.mobile-nav.open .mobile-nav__panel { transform:translateX(0); }
.mobile-nav__head {
  display:flex; align-items:center; justify-content:space-between;
  padding:18px 20px; border-bottom:1px solid var(--color-border); flex-shrink:0;
}
.mobile-nav__close {
  width:36px; height:36px; display:flex; align-items:center; justify-content:center;
  font-size:20px; cursor:pointer; border-radius:50%;
  transition:background var(--t-fast);
}
.mobile-nav__close:hover { background:var(--color-surface); }
.mobile-nav__links { padding:12px 8px; flex:1; }
.mobile-nav__link {
  display:block; padding:14px 16px; font-size:15px; font-weight:700;
  color:var(--color-text); text-decoration:none; border-radius:8px;
  transition:background var(--t-fast), color var(--t-fast);
}
.mobile-nav__link:hover { background:var(--color-surface); color:var(--color-deco); }
.mobile-nav__section {
  font-size:10px; font-weight:800; letter-spacing:.12em; text-transform:uppercase;
  color:var(--color-text-muted); padding:12px 16px 4px;
}
.mobile-nav__foot { padding:16px 20px; border-top:1px solid var(--color-border); flex-shrink:0; display:flex; flex-direction:column; gap:8px; }

/* ══════════════════════════════════════════════════════
   TOASTS
══════════════════════════════════════════════════════ */
.toasts { position:fixed; bottom:24px; right:24px; z-index:9999; display:flex; flex-direction:column; gap:8px; pointer-events:none; }
.toast {
  background:#1a1a1a; color:#fff; padding:12px 20px; border-radius:10px;
  font-size:13px; font-weight:600; box-shadow:var(--shadow-lg);
  opacity:0; transform:translateY(8px);
  transition:opacity .25s ease, transform .25s ease;
  pointer-events:auto; max-width:300px;
}
.toast.show { opacity:1; transform:translateY(0); }
.toast.success { background:var(--color-deco); }
.toast.error   { background:var(--color-sale); }

/* ══════════════════════════════════════════════════════
   TRUST BAR
══════════════════════════════════════════════════════ */
.trust-bar {
  display:flex; align-items:center; justify-content:center;
  flex-wrap:wrap; gap:24px; padding:14px clamp(16px,3vw,40px);
  border-bottom:1px solid var(--color-border);
  font-size:13px; font-weight:600; color:var(--color-text-muted);
  background:var(--color-surface);
}
.trust-bar__item { display:flex; align-items:center; gap:7px; white-space:nowrap; }
.trust-bar__icon { font-size:16px; flex-shrink:0; }

/* ══════════════════════════════════════════════════════
   IMPACT / STATS BAND
══════════════════════════════════════════════════════ */
.impact-band {
  display:flex; flex-wrap:wrap; align-items:center; justify-content:center;
  gap:clamp(24px,4vw,60px); padding:clamp(32px,5vw,64px) clamp(16px,4vw,48px);
}
.impact-stat { text-align:center; }
.impact-stat__num {
  font-size:clamp(2rem,4vw,3.2rem); font-weight:900;
  letter-spacing:-.04em; color:var(--color-text); line-height:1;
}
.impact-stat__num .accent { color:var(--color-deco); }
.impact-stat__label { font-size:13px; color:var(--color-text-muted); margin-top:4px; font-weight:600; }

/* ══════════════════════════════════════════════════════
   CATEGORY STRIP
══════════════════════════════════════════════════════ */
.cat-strip { padding:clamp(32px,5vw,64px) 0; }
.cat-strip .page-w { display:flex; flex-direction:column; gap:clamp(24px,4vw,40px); }
.cat-strip__grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(min(180px,100%),1fr));
  gap:clamp(12px,2vw,20px);
}
.cat-tile {
  position:relative; overflow:hidden; border-radius:var(--radius-card);
  aspect-ratio:.9; cursor:pointer; display:block; text-decoration:none;
  background:var(--color-surface);
}
.cat-tile img {
  width:100%; height:100%; object-fit:cover;
  transition:transform 500ms var(--ease-out);
}
.cat-tile:hover img { transform:scale(1.07); }
.cat-tile__label {
  position:absolute; bottom:0; left:0; right:0;
  padding:20px 16px 14px;
  background:linear-gradient(to top,rgba(0,0,0,.65) 0%,transparent 100%);
  color:#fff; font-size:15px; font-weight:800; letter-spacing:-.01em;
}
.cat-tile__sub { font-size:12px; opacity:.75; font-weight:500; margin-top:2px; }

/* ══════════════════════════════════════════════════════
   NEW ARRIVALS / TABS
══════════════════════════════════════════════════════ */
.tab-nav {
  display:flex; gap:4px; flex-wrap:wrap;
  border-bottom:2px solid var(--color-border);
  margin-bottom:clamp(20px,3vw,36px);
}
.tab-btn {
  padding:10px 20px; font-size:14px; font-weight:700; letter-spacing:.02em;
  color:var(--color-text-muted); background:none; border:none; cursor:pointer;
  border-bottom:2px solid transparent; margin-bottom:-2px;
  transition:color var(--t-fast), border-color var(--t-fast);
}
.tab-btn:hover { color:var(--color-text); }
.tab-btn.active { color:var(--color-text); border-bottom-color:var(--color-text); }
.tab-panel { display:none; }
.tab-panel.active { display:block; }

/* ══════════════════════════════════════════════════════
   REVIEWS
══════════════════════════════════════════════════════ */
.reviews-strip { overflow:hidden; }
.reviews-track { display:flex; gap:16px; padding-bottom:4px; overflow-x:auto; scroll-snap-type:x mandatory; scrollbar-width:none; }
.reviews-track::-webkit-scrollbar { display:none; }
.review-card {
  flex:0 0 clamp(280px,30vw,340px); background:var(--color-surface);
  border:1px solid var(--color-border); border-radius:var(--radius-card);
  padding:24px; scroll-snap-align:start;
  box-shadow:var(--shadow-sm);
}
.review-stars { color:#f5a623; font-size:14px; margin-bottom:10px; letter-spacing:2px; }
.review-text { font-size:14px; color:var(--color-text-muted); line-height:1.6; margin-bottom:12px; }
.review-author { font-size:13px; font-weight:700; color:var(--color-text); }

/* ══════════════════════════════════════════════════════
   NEWSLETTER BAR
══════════════════════════════════════════════════════ */
.newsletter-bar {
  background:var(--color-text); color:#fff;
  padding:clamp(40px,6vw,80px) clamp(16px,4vw,48px);
  text-align:center;
}
.newsletter-bar h2 { font-size:clamp(1.4rem,3vw,2rem); font-weight:900; color:#fff; margin-bottom:8px; }
.newsletter-bar p  { font-size:15px; color:rgba(255,255,255,.7); margin-bottom:24px; }
.newsletter-form   { display:flex; max-width:480px; margin:0 auto; gap:8px; flex-wrap:wrap; }
.newsletter-form input {
  flex:1; min-width:200px; padding:14px 18px;
  border:none; border-radius:9999px; font-size:14px; outline:none;
  background:#fff; color:var(--color-text);
}
.newsletter-form button {
  padding:14px 28px; background:var(--color-deco); color:#fff;
  border:none; border-radius:9999px; font-size:14px; font-weight:700;
  cursor:pointer; transition:filter var(--t-fast);
}
.newsletter-form button:hover { filter:brightness(.9); }
.newsletter-note { font-size:11px; color:rgba(255,255,255,.4); margin-top:12px; }

/* ══════════════════════════════════════════════════════
   TRUST BADGES (product page + home)
══════════════════════════════════════════════════════ */
.trust-badges-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(140px,1fr));
  gap:12px;
}
.trust-badge {
  display:flex; flex-direction:column; align-items:center;
  gap:8px; padding:16px 12px; text-align:center;
  background:var(--color-surface); border-radius:var(--radius-card);
  border:1px solid var(--color-border);
  transition:box-shadow var(--t-fast), transform var(--t-fast);
}
.trust-badge:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
.trust-badge svg { width:28px; height:28px; flex-shrink:0; }
.trust-badge__label { font-size:12px; font-weight:800; color:var(--color-text); line-height:1.2; }
.trust-badge__sub   { font-size:11px; color:var(--color-text-muted); }

/* ══════════════════════════════════════════════════════
   PAYMENT ICONS
══════════════════════════════════════════════════════ */
.payment-icons { display:flex; flex-wrap:wrap; align-items:center; gap:8px; }
.payment-icons svg { height:24px; width:auto; display:block; }

/* ══════════════════════════════════════════════════════
   MISSION BANNER
══════════════════════════════════════════════════════ */
.mission-banner {
  position:relative; overflow:hidden;
  min-height:clamp(300px,45vw,560px);
  display:flex; align-items:center;
}
.mission-banner__img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; }
.mission-banner__overlay { position:absolute; inset:0; }
.mission-banner__content {
  position:relative; z-index:2;
  padding:clamp(40px,6vw,80px) clamp(16px,4vw,48px);
  max-width:600px;
}
.mission-banner h2 { font-size:clamp(1.5rem,3.5vw,2.8rem); font-weight:900; margin-bottom:16px; }
.mission-banner p  { font-size:15px; line-height:1.7; margin-bottom:28px; opacity:.85; }

/* ══════════════════════════════════════════════════════
   PRODUCT PAGE
══════════════════════════════════════════════════════ */
.product-layout {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:clamp(24px,4vw,64px);
  padding-block:clamp(24px,4vw,48px);
}
.product-gallery { position:sticky; top:80px; }
.product-gallery__main {
  aspect-ratio:1; border-radius:var(--radius-card);
  overflow:hidden; background:var(--color-surface); margin-bottom:12px;
}
.product-gallery__main img { width:100%; height:100%; object-fit:cover; }
.product-gallery__thumbs { display:flex; gap:8px; flex-wrap:wrap; }
.product-gallery__thumb {
  width:60px; height:60px; border-radius:8px; overflow:hidden;
  border:2px solid transparent; cursor:pointer;
  transition:border-color var(--t-fast);
}
.product-gallery__thumb.active, .product-gallery__thumb:hover { border-color:var(--color-text); }
.product-gallery__thumb img { width:100%; height:100%; object-fit:cover; }

.product-info__title { font-size:clamp(1.3rem,2.5vw,1.9rem); font-weight:900; margin-bottom:8px; }
.product-info__vendor { font-size:12px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--color-text-muted); margin-bottom:12px; }
.product-info__price-row { display:flex; align-items:center; gap:10px; margin-bottom:20px; flex-wrap:wrap; }
.product-info__price { font-size:1.5rem; font-weight:900; }
.product-info__price.sale { color:var(--color-sale); }
.product-info__compare { font-size:1.1rem; font-weight:500; color:var(--color-text-muted); text-decoration:line-through; }
.product-info__save {
  background:var(--color-sale); color:#fff;
  font-size:12px; font-weight:800; padding:3px 10px; border-radius:999px;
}

/* Option selectors */
.product-option { margin-bottom:18px; }
.product-option__label { font-size:13px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; margin-bottom:8px; }
.option-btns { display:flex; gap:8px; flex-wrap:wrap; }
.option-btn {
  padding:8px 16px; border:2px solid var(--color-border); border-radius:8px;
  font-size:13px; font-weight:600; cursor:pointer; background:var(--color-surface);
  transition:border-color var(--t-fast), background var(--t-fast), color var(--t-fast);
}
.option-btn:hover { border-color:var(--color-text); }
.option-btn.selected { border-color:var(--color-text); background:var(--color-text); color:#fff; }
.option-btn.unavailable { opacity:.35; cursor:not-allowed; text-decoration:line-through; }

/* ATC area */
.product-atc-row { display:flex; gap:12px; flex-wrap:wrap; margin-bottom:20px; }
.product-atc-row .atc-btn { flex:1; min-width:180px; font-size:15px; padding:16px 24px; }

/* Benefits */
.product-benefits { display:flex; flex-direction:column; gap:10px; margin-bottom:24px; }
.product-benefit { display:flex; align-items:flex-start; gap:10px; font-size:14px; color:var(--color-text-muted); }
.product-benefit strong { color:var(--color-text); }

/* Description accordion */
.product-accordion { border-top:1px solid var(--color-border); }
.accordion-item { border-bottom:1px solid var(--color-border); }
.accordion-trigger {
  width:100%; display:flex; align-items:center; justify-content:space-between;
  padding:16px 0; font-size:14px; font-weight:700; color:var(--color-text);
  background:none; border:none; cursor:pointer;
  transition:color var(--t-fast);
}
.accordion-trigger:hover { color:var(--color-deco); }
.accordion-trigger svg {
  width:16px; height:16px; stroke:currentColor; fill:none;
  stroke-width:2; transition:transform var(--t-med); flex-shrink:0;
}
.accordion-item.open .accordion-trigger svg { transform:rotate(180deg); }
.accordion-body {
  max-height:0; overflow:hidden;
  transition:max-height var(--t-med);
}
.accordion-body-inner {
  padding-bottom:16px; font-size:14px; color:var(--color-text-muted); line-height:1.7;
}

/* ══════════════════════════════════════════════════════
   COLLECTION PAGE
══════════════════════════════════════════════════════ */
.collection-layout { display:grid; grid-template-columns:220px 1fr; gap:40px; }
.collection-filters { position:sticky; top:80px; align-self:start; }
.filter-group { margin-bottom:24px; padding-bottom:24px; border-bottom:1px solid var(--color-border); }
.filter-group__title { font-size:13px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; margin-bottom:12px; }
.filter-option {
  display:flex; align-items:center; gap:8px; padding:4px 0;
  font-size:13px; color:var(--color-text-muted); cursor:pointer;
}
.filter-option:hover { color:var(--color-text); }
.collection-sort-bar {
  display:flex; align-items:center; justify-content:space-between;
  margin-bottom:24px; flex-wrap:wrap; gap:8px;
}
.collection-sort-bar select {
  padding:8px 14px; border:1.5px solid var(--color-border); border-radius:8px;
  font-size:13px; font-weight:600; background:var(--color-surface); cursor:pointer;
}
.collection-count { font-size:13px; color:var(--color-text-muted); }

/* ══════════════════════════════════════════════════════
   FOOTER
══════════════════════════════════════════════════════ */
.site-footer {
  background:var(--color-footer-bg); color:var(--color-footer-text);
  padding-top:clamp(48px,6vw,80px);
}
.footer-grid {
  display:grid;
  grid-template-columns:1.6fr repeat(auto-fill,minmax(160px,1fr));
  gap:clamp(24px,4vw,48px);
  padding-bottom:clamp(32px,4vw,56px);
}
.footer-brand p { font-size:13px; color:rgba(255,255,255,.5); margin-top:12px; max-width:260px; line-height:1.6; }
.footer-social { display:flex; gap:8px; margin-top:16px; }
.social-btn {
  width:36px; height:36px; border-radius:50%;
  border:1px solid rgba(255,255,255,.15);
  display:flex; align-items:center; justify-content:center;
  color:rgba(255,255,255,.6); text-decoration:none;
  transition:background var(--t-fast), color var(--t-fast), border-color var(--t-fast);
}
.social-btn:hover { background:rgba(255,255,255,.1); color:#fff; border-color:rgba(255,255,255,.4); }
.social-btn svg { width:15px; height:15px; }
.footer-col h4 {
  font-size:12px; font-weight:800; text-transform:uppercase;
  letter-spacing:.1em; color:rgba(255,255,255,.4); margin-bottom:14px;
}
.footer-col a {
  display:block; font-size:13px; color:rgba(255,255,255,.65);
  text-decoration:none; padding:4px 0;
  transition:color var(--t-fast);
}
.footer-col a:hover { color:#fff; }
.footer-bottom {
  border-top:1px solid rgba(255,255,255,.08);
  padding:20px clamp(16px,4vw,48px);
  display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:12px;
}
.footer-bottom p { font-size:12px; color:rgba(255,255,255,.35); }
.footer-payment { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
.footer-payment svg { height:22px; width:auto; }

/* ══════════════════════════════════════════════════════
   FORMS (login, register, contact)
══════════════════════════════════════════════════════ */
.form-page { max-width:480px; margin:clamp(48px,8vw,96px) auto; padding-inline:20px; }
.form-page h1 { font-size:clamp(1.5rem,3vw,2rem); font-weight:900; margin-bottom:8px; }
.form-page p  { font-size:14px; color:var(--color-text-muted); margin-bottom:28px; }
.form-field { margin-bottom:16px; }
.form-field label { display:block; font-size:13px; font-weight:700; margin-bottom:6px; color:var(--color-text); }
.form-field input, .form-field textarea, .form-field select {
  width:100%; padding:12px 16px; border:1.5px solid var(--color-border);
  border-radius:10px; font-size:14px; background:var(--color-surface); color:var(--color-text);
  transition:border-color var(--t-fast); outline:none;
}
.form-field input:focus, .form-field textarea:focus { border-color:var(--color-deco); box-shadow:0 0 0 3px var(--color-deco-light); }
.form-field textarea { resize:vertical; min-height:120px; }
.form-error { font-size:12px; color:var(--color-sale); margin-top:4px; }

/* ══════════════════════════════════════════════════════
   GENERAL / MISC
══════════════════════════════════════════════════════ */
.section-pad { padding-block:var(--section-gap); }
.section-pad-sm { padding-block:clamp(32px,4vw,56px); }
.text-center { text-align:center; }
.text-sale { color:var(--color-sale); }
.text-deco { color:var(--color-deco); }
.badge-sale { background:var(--color-sale); color:#fff; font-size:11px; font-weight:800; padding:3px 9px; border-radius:999px; }
.badge-new  { background:var(--color-deco); color:#fff; font-size:11px; font-weight:800; padding:3px 9px; border-radius:999px; }

/* Scroll reveal */
.reveal { opacity:0; transform:translateY(20px); transition:opacity .6s var(--ease-out), transform .6s var(--ease-out); }
.reveal.in-view { opacity:1; transform:translateY(0); }

/* ══════════════════════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════════════════════ */
@media (max-width:900px) {
  .header-nav, .header-actions .icon-btn:not(.cart-icon-btn):not(#searchToggle) { display:none; }
  .hamburger { display:flex; }
  .header-inner { grid-template-columns:44px 1fr 80px; }
  .product-layout { grid-template-columns:1fr; }
  .product-gallery { position:static; }
  .collection-layout { grid-template-columns:1fr; }
  .collection-filters { position:static; display:none; }
  .collection-filters.mobile-open { display:block; }
}
@media (max-width:600px) {
  .footer-grid { grid-template-columns:1fr 1fr; }
  .footer-brand { grid-column:1/-1; }
  .hero-bombas__ctas { flex-direction:column; align-items:flex-start; }
  .hero-bombas__ctas .btn { width:100%; max-width:300px; }
  .product-atc-row { flex-direction:column; }
  .tab-nav { overflow-x:auto; scrollbar-width:none; }
  .tab-nav::-webkit-scrollbar { display:none; }
}
