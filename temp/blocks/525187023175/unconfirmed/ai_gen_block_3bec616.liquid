{% doc %}
  @prompt
    single product selling -
    will be there hero section customization-
    single prouct with trust badges and payment badges with fast checkout -
    customzation and all as a single product website has -
    also give like first hero left side image and right side txt , next section right side image and left side text  then prodcut with its like description or more as single prduct highly conversion single one product website 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-single-product-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-sp-hero-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 80px 40px;
    align-items: center;
  }

  .ai-sp-hero-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-sp-hero-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-sp-hero-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-sp-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    width: fit-content;
  }

  .ai-sp-hero-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-sp-hero-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-sp-trust-badges-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 12px;
  }

  .ai-sp-trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: {{ block.settings.trust_color }};
  }

  .ai-sp-trust-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-sp-cta-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    padding: 18px 40px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
    width: fit-content;
  }

  .ai-sp-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-sp-section-alt-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 80px 40px;
    align-items: center;
    background-color: {{ block.settings.alt_section_bg }};
  }

  .ai-sp-section-alt-{{ ai_gen_id }}.reverse {
    direction: rtl;
  }

  .ai-sp-section-alt-{{ ai_gen_id }}.reverse > * {
    direction: ltr;
  }

  .ai-sp-feature-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-sp-feature-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-sp-feature-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-sp-feature-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_title_size }}px;
    font-weight: 700;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-sp-feature-text-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.7;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-sp-product-section-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 80px 40px;
  }

  .ai-sp-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: start;
  }

  .ai-sp-product-images-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-sp-main-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-sp-main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-sp-product-info-{{ ai_gen_id }} {
    position: sticky;
    top: 100px;
  }

  .ai-sp-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
  }

  .ai-sp-price-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin-bottom: 24px;
  }

  .ai-sp-product-description-{{ ai_gen_id }} {
    font-size: 16px;
    line-height: 1.7;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
    margin-bottom: 32px;
  }

  .ai-sp-payment-badges-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .ai-sp-payment-icon-{{ ai_gen_id }} {
    height: 32px;
    width: auto;
    opacity: 0.7;
  }

  .ai-sp-guarantee-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    background-color: {{ block.settings.guarantee_bg }};
    padding: 16px 20px;
    border-radius: 12px;
    margin-top: 24px;
  }

  .ai-sp-guarantee-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .ai-sp-guarantee-text-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.guarantee_text_color }};
  }

  .ai-sp-features-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 24px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-sp-feature-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-sp-checkmark-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: {{ block.settings.trust_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-sp-hero-{{ ai_gen_id }},
    .ai-sp-section-alt-{{ ai_gen_id }},
    .ai-sp-product-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 60px 24px;
    }

    .ai-sp-section-alt-{{ ai_gen_id }}.reverse {
      direction: ltr;
    }

    .ai-sp-hero-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-sp-feature-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.feature_title_size | times: 0.8 }}px;
    }

    .ai-sp-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.product_title_size | times: 0.75 }}px;
    }

    .ai-sp-product-info-{{ ai_gen_id }} {
      position: static;
    }
  }
{% endstyle %}

<single-product-{{ ai_gen_id }} class="ai-single-product-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sp-hero-{{ ai_gen_id }}">
    <div class="ai-sp-hero-image-{{ ai_gen_id }}">
      {% if block.settings.hero_image %}
        <img
          src="{{ block.settings.hero_image | image_url: width: 1200 }}"
          alt="{{ block.settings.hero_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.hero_image.width }}"
          height="{{ block.settings.hero_image.height }}"
        >
      {% else %}
        <div style="background: #f4f4f4; aspect-ratio: 1; display: flex; align-items: center; justify-content: center;">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-sp-hero-content-{{ ai_gen_id }}">
      {% if block.settings.badge_text != blank %}
        <span class="ai-sp-badge-{{ ai_gen_id }}">{{ block.settings.badge_text }}</span>
      {% endif %}

      {% if block.settings.hero_title != blank %}
        <h1 class="ai-sp-hero-title-{{ ai_gen_id }}">{{ block.settings.hero_title }}</h1>
      {% endif %}

      {% if block.settings.hero_description != blank %}
        <div class="ai-sp-hero-description-{{ ai_gen_id }}">{{ block.settings.hero_description }}</div>
      {% endif %}

      <div class="ai-sp-trust-badges-{{ ai_gen_id }}">
        {% if block.settings.show_shipping_badge %}
          <div class="ai-sp-trust-item-{{ ai_gen_id }}">
            <svg class="ai-sp-trust-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
            </svg>
            <span>{{ block.settings.shipping_text }}</span>
          </div>
        {% endif %}

        {% if block.settings.show_guarantee_badge %}
          <div class="ai-sp-trust-item-{{ ai_gen_id }}">
            <svg class="ai-sp-trust-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            <span>{{ block.settings.guarantee_text }}</span>
          </div>
        {% endif %}

        {% if block.settings.show_secure_badge %}
          <div class="ai-sp-trust-item-{{ ai_gen_id }}">
            <svg class="ai-sp-trust-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            <span>{{ block.settings.secure_text }}</span>
          </div>
        {% endif %}
      </div>

      <a href="#product" class="ai-sp-cta-{{ ai_gen_id }}">{{ block.settings.cta_text }}</a>
    </div>
  </div>

  {% if block.settings.show_feature_section_1 %}
    <div class="ai-sp-section-alt-{{ ai_gen_id }} reverse">
      <div class="ai-sp-feature-image-{{ ai_gen_id }}">
        {% if block.settings.feature_image_1 %}
          <img
            src="{{ block.settings.feature_image_1 | image_url: width: 1200 }}"
            alt="{{ block.settings.feature_image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.feature_image_1.width }}"
            height="{{ block.settings.feature_image_1.height }}"
          >
        {% else %}
          <div style="background: #f4f4f4; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center;">
            {{ 'product-2' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-sp-feature-content-{{ ai_gen_id }}">
        {% if block.settings.feature_title_1 != blank %}
          <h2 class="ai-sp-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title_1 }}</h2>
        {% endif %}
        {% if block.settings.feature_text_1 != blank %}
          <div class="ai-sp-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_text_1 }}</div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_feature_section_2 %}
    <div class="ai-sp-section-alt-{{ ai_gen_id }}">
      <div class="ai-sp-feature-image-{{ ai_gen_id }}">
        {% if block.settings.feature_image_2 %}
          <img
            src="{{ block.settings.feature_image_2 | image_url: width: 1200 }}"
            alt="{{ block.settings.feature_image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.feature_image_2.width }}"
            height="{{ block.settings.feature_image_2.height }}"
          >
        {% else %}
          <div style="background: #f4f4f4; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center;">
            {{ 'product-3' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-sp-feature-content-{{ ai_gen_id }}">
        {% if block.settings.feature_title_2 != blank %}
          <h2 class="ai-sp-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_title_2 }}</h2>
        {% endif %}
        {% if block.settings.feature_text_2 != blank %}
          <div class="ai-sp-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_text_2 }}</div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <div class="ai-sp-product-section-{{ ai_gen_id }}" id="product">
    <div class="ai-sp-product-grid-{{ ai_gen_id }}">
      <div class="ai-sp-product-images-{{ ai_gen_id }}">
        <div class="ai-sp-main-image-{{ ai_gen_id }}">
          {% if block.settings.product_image %}
            <img
              src="{{ block.settings.product_image | image_url: width: 1200 }}"
              alt="{{ block.settings.product_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.product_image.width }}"
              height="{{ block.settings.product_image.height }}"
            >
          {% else %}
            <div style="background: #f4f4f4; aspect-ratio: 1; display: flex; align-items: center; justify-content: center;">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-sp-product-info-{{ ai_gen_id }}">
        {% if block.settings.product_title != blank %}
          <h2 class="ai-sp-product-title-{{ ai_gen_id }}">{{ block.settings.product_title }}</h2>
        {% endif %}

        {% if block.settings.product_price != blank %}
          <div class="ai-sp-price-{{ ai_gen_id }}">{{ block.settings.product_price }}</div>
        {% endif %}

        {% if block.settings.product_description != blank %}
          <div class="ai-sp-product-description-{{ ai_gen_id }}">{{ block.settings.product_description }}</div>
        {% endif %}

        {% if block.settings.show_features_list %}
          <ul class="ai-sp-features-list-{{ ai_gen_id }}">
            {% if block.settings.feature_1 != blank %}
              <li class="ai-sp-feature-item-{{ ai_gen_id }}">
                <svg class="ai-sp-checkmark-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>{{ block.settings.feature_1 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_2 != blank %}
              <li class="ai-sp-feature-item-{{ ai_gen_id }}">
                <svg class="ai-sp-checkmark-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>{{ block.settings.feature_2 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_3 != blank %}
              <li class="ai-sp-feature-item-{{ ai_gen_id }}">
                <svg class="ai-sp-checkmark-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>{{ block.settings.feature_3 }}</span>
              </li>
            {% endif %}
            {% if block.settings.feature_4 != blank %}
              <li class="ai-sp-feature-item-{{ ai_gen_id }}">
                <svg class="ai-sp-checkmark-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                <span>{{ block.settings.feature_4 }}</span>
              </li>
            {% endif %}
          </ul>
        {% endif %}

        <a href="{{ block.settings.checkout_url }}" class="ai-sp-cta-{{ ai_gen_id }}">{{ block.settings.buy_button_text }}</a>

        {% if block.settings.show_guarantee_box %}
          <div class="ai-sp-guarantee-{{ ai_gen_id }}">
            <svg class="ai-sp-guarantee-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            <span class="ai-sp-guarantee-text-{{ ai_gen_id }}">{{ block.settings.guarantee_box_text }}</span>
          </div>
        {% endif %}

        {% if block.settings.show_payment_badges %}
          <div class="ai-sp-payment-badges-{{ ai_gen_id }}">
            <svg class="ai-sp-payment-icon-{{ ai_gen_id }}" viewBox="0 0 38 24" fill="none">
              <rect width="38" height="24" rx="3" fill="#1434CB"/>
              <path d="M14.5 12L11 8.5L12.5 7L14.5 9L18.5 5L20 6.5L14.5 12Z" fill="white"/>
              <path d="M22 8H30V10H22V8ZM22 11H28V13H22V11ZM22 14H30V16H22V14Z" fill="white"/>
            </svg>
            <svg class="ai-sp-payment-icon-{{ ai_gen_id }}" viewBox="0 0 38 24" fill="none">
              <rect width="38" height="24" rx="3" fill="#00457C"/>
              <circle cx="14" cy="12" r="6" fill="#EB001B"/>
              <circle cx="24" cy="12" r="6" fill="#F79E1B"/>
              <path d="M19 7.5C20.5 8.8 21.5 10.3 21.5 12C21.5 13.7 20.5 15.2 19 16.5C17.5 15.2 16.5 13.7 16.5 12C16.5 10.3 17.5 8.8 19 7.5Z" fill="#FF5F00"/>
            </svg>
            <svg class="ai-sp-payment-icon-{{ ai_gen_id }}" viewBox="0 0 38 24" fill="none">
              <rect width="38" height="24" rx="3" fill="#0079C1"/>
              <path d="M12 8L16 16H14L13 14H11L10 16H8L12 8ZM12 10.5L11.2 12.5H12.8L12 10.5Z" fill="white"/>
              <path d="M18 8H24L26 10V14L24 16H18V8ZM20 10V14H23L24 13V11L23 10H20Z" fill="white"/>
            </svg>
            <svg class="ai-sp-payment-icon-{{ ai_gen_id }}" viewBox="0 0 38 24" fill="none">
              <rect width="38" height="24" rx="3" fill="#F7F7F7"/>
              <path d="M10 10H14V14H10V10Z" fill="#635BFF"/>
              <path d="M16 10H20V14H16V10Z" fill="#00D924"/>
              <path d="M22 10H26V14H22V10Z" fill="#FFC043"/>
              <path d="M28 10H32V14H28V10Z" fill="#87BBFD"/>
            </svg>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</single-product-{{ ai_gen_id }}>

<script>
  (function() {
    class SingleProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const ctaButtons = this.querySelectorAll('.ai-sp-cta-{{ ai_gen_id }}');
        ctaButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            if (button.getAttribute('href') === '#product') {
              e.preventDefault();
              const productSection = this.querySelector('#product');
              if (productSection) {
                productSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            }
          });
        });
      }
    }

    customElements.define('single-product-{{ ai_gen_id }}', SingleProduct{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Single product landing",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "alt_section_bg",
      "label": "Alternate section background",
      "default": "#f9f9f9"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Hero section"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "New Arrival"
    },
    {
      "type": "color",
