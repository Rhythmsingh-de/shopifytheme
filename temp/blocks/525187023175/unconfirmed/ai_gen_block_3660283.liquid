                  <div class="ai-pp-spec-item-{{ ai_gen_id }}">
                    <span class="ai-pp-spec-label-{{ ai_gen_id }}">{{ block.settings.spec_6_label }}</span>
                    <span class="ai-pp-spec-value-{{ ai_gen_id }}">{{ block.settings.spec_6_value }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}

          {% if block.settings.description_footer != blank %}
            <div class="ai-pp-description-{{ ai_gen_id }}" style="margin-top: 20px;">{{ block.settings.description_footer }}</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</product-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initCountdown();
      }

      initCountdown() {
        const countdownElement = this.querySelector('[data-countdown-target]');
        if (!countdownElement) return;

        const targetHours = parseInt(countdownElement.getAttribute('data-countdown-target'));
        if (isNaN(targetHours)) return;

        const updateCountdown = () => {
          const now = new Date();
          const endOfDay = new Date();
          endOfDay.setHours(23, 59, 59, 999);
          
          const diff = endOfDay - now;
          const hoursLeft = Math.floor(diff / (1000 * 60 * 60));
          const minutesLeft = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          
          if (hoursLeft <= targetHours) {
            countdownElement.textContent = hoursLeft + 'h ' + minutesLeft + 'm';
          }
        };

        updateCountdown();
        setInterval(updateCountdown, 60000);
      }
    }

    customElements.define('product-page-{{ ai_gen_id }}', ProductPage{{ ai_gen_id }});
  })();
</script>

