<script>
  (function() {
    class SingleProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const ctaButtons = this.querySelectorAll('.ai-sp-cta-{{ ai_gen_id }}');
        ctaButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            if (button.getAttribute('href') === '#product') {
              e.preventDefault();
              const productSection = this.querySelector('#product');
              if (productSection) {
                productSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            }
          });
        });
      }
    }

    customElements.define('single-product-{{ ai_gen_id }}', SingleProduct{{ ai_gen_id }});
  })();
</script>

