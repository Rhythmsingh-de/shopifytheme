{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}
{% assign featured_product = settings.primary_product %}

{% if featured_product == blank %}
  {% assign featured_product = all_products.first %}
{% endif %}

{% style %}
  .ai-hero-landing-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: {{ block.settings.bg_color }};
  }

  .ai-hero-landing__bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-hero-landing__bg-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position }};
  }

  .ai-hero-landing__bg-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f5f3f0 0%, #dddbd7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-landing__bg-placeholder-{{ ai_gen_id }} svg {
    width: 200px;
    height: 200px;
    opacity: 0.3;
  }

  .ai-hero-landing__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      {{ block.settings.overlay_direction }},
      rgba(0, 0, 0, {{ block.settings.overlay_opacity }}) 0%,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity | times: 0.5 }}) 100%
    );
    z-index: 2;
  }

  .ai-hero-landing__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
    text-align: {{ block.settings.text_align }};
    color: {{ block.settings.text_color }};
  }

  .ai-hero-landing__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 8px 20px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 20px;
    margin-bottom: 20px;
  }

  .ai-hero-landing__headline-{{ ai_gen_id }} {
    font-family: {{ settings.font_display.family }}, {{ settings.font_display.fallback_families }};
    font-weight: {{ settings.font_display.weight }};
    font-size: {{ block.settings.headline_size_mobile }}px;
    line-height: 1.1;
    margin: 0 0 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-landing__subheadline-{{ ai_gen_id }} {
    font-family: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
    font-weight: 300;
    font-size: {{ block.settings.subheadline_size_mobile }}px;
    line-height: 1.5;
    margin: 0 0 30px;
    color: {{ block.settings.text_color }};
    opacity: 0.9;
  }

  .ai-hero-landing__cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 15px;
    justify-content: {{ block.settings.text_align }};
    flex-wrap: wrap;
    margin-bottom: 30px;
  }

  .ai-hero-landing__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 40px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ settings.button_border_radius }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 200px;
  }

  .ai-hero-landing__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .ai-hero-landing__cta--secondary-{{ ai_gen_id }} {
    background-color: transparent;
    color: {{ block.settings.text_color }};
    border: 2px solid {{ block.settings.text_color }};
  }

  .ai-hero-landing__cta--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.text_color }};
    color: {{ block.settings.bg_color }};
  }

  .ai-hero-landing__countdown-{{ ai_gen_id }} {
    display: inline-flex;
    gap: 20px;
    padding: 20px 30px;
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ai-hero-landing__countdown-unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 60px;
  }

  .ai-hero-landing__countdown-value-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 5px;
  }

  .ai-hero-landing__countdown-label-{{ ai_gen_id }} {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.8;
  }

  .ai-hero-landing__trust-row-{{ ai_gen_id }} {
    display: flex;
    gap: 30px;
    justify-content: {{ block.settings.text_align }};
    flex-wrap: wrap;
    margin-top: 40px;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ai-hero-landing__trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    opacity: 0.9;
  }

  .ai-hero-landing__trust-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-hero-landing__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
    }

    .ai-hero-landing__subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size_desktop }}px;
    }

    .ai-hero-landing__content-{{ ai_gen_id }} {
      padding: 60px 40px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-hero-landing-{{ ai_gen_id }} {
      min-height: 80vh;
    }

    .ai-hero-landing__cta-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
    }

    .ai-hero-landing__cta-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-hero-landing__countdown-{{ ai_gen_id }} {
      gap: 15px;
      padding: 15px 20px;
    }

    .ai-hero-landing__countdown-value-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-hero-landing__trust-row-{{ ai_gen_id }} {
      justify-content: center;
      gap: 20px;
    }
  }
{% endstyle %}

<landing-hero-{{ ai_gen_id }}
  class="ai-hero-landing-{{ ai_gen_id }}"
  data-product-id="{{ featured_product.id }}"
  data-variant-id="{{ featured_product.selected_or_first_available_variant.id }}"
  data-product-price="{{ featured_product.price | money_without_currency }}"
  data-product-currency="{{ cart.currency.iso_code }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hero-landing__bg-{{ ai_gen_id }}">
    {% if block.settings.hero_image %}
      <img
        src="{{ block.settings.hero_image | image_url: width: 2000 }}"
        srcset="
          {{ block.settings.hero_image | image_url: width: 750 }} 750w,
          {{ block.settings.hero_image | image_url: width: 1500 }} 1500w,
          {{ block.settings.hero_image | image_url: width: 2000 }} 2000w
        "
        sizes="100vw"
        alt="{{ block.settings.hero_image.alt | escape }}"
        loading="eager"
        width="{{ block.settings.hero_image.width }}"
        height="{{ block.settings.hero_image.height }}"
      >
    {% else %}
      <div class="ai-hero-landing__bg-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.show_overlay %}
    <div class="ai-hero-landing__overlay-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-hero-landing__content-{{ ai_gen_id }}">
    {% if block.settings.show_badge and block.settings.badge_text != blank %}
      <div class="ai-hero-landing__badge-{{ ai_gen_id }}">
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-landing__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h1>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <p class="ai-hero-landing__subheadline-{{ ai_gen_id }}">
        {{ block.settings.subheadline }}
      </p>
    {% endif %}

    <div class="ai-hero-landing__cta-wrapper-{{ ai_gen_id }}">
      {% if block.settings.show_primary_cta %}
        <button
          type="button"
          class="ai-hero-landing__cta-{{ ai_gen_id }} ai-hero-landing__cta--primary-{{ ai_gen_id }}"
          data-action="add-to-cart"
        >
          {{ block.settings.cta_text }}
        </button>
      {% endif %}

      {% if block.settings.show_secondary_cta and block.settings.secondary_cta_text != blank %}
        <a
          href="{{ block.settings.secondary_cta_link }}"
          class="ai-hero-landing__cta-{{ ai_gen_id }} ai-hero-landing__cta--secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.secondary_cta_text }}
        </a>
      {% endif %}
    </div>

    {% if block.settings.show_countdown %}
      <div class="ai-hero-landing__countdown-{{ ai_gen_id }}" data-countdown-end="{{ block.settings.countdown_end_date }}">
        <div class="ai-hero-landing__countdown-unit-{{ ai_gen_id }}">
          <div class="ai-hero-landing__countdown-value-{{ ai_gen_id }}" data-unit="days">00</div>
          <div class="ai-hero-landing__countdown-label-{{ ai_gen_id }}">Days</div>
        </div>
        <div class="ai-hero-landing__countdown-unit-{{ ai_gen_id }}">
          <div class="ai-hero-landing__countdown-value-{{ ai_gen_id }}" data-unit="hours">00</div>
          <div class="ai-hero-landing__countdown-label-{{ ai_gen_id }}">Hours</div>
        </div>
        <div class="ai-hero-landing__countdown-unit-{{ ai_gen_id }}">
          <div class="ai-hero-landing__countdown-value-{{ ai_gen_id }}" data-unit="minutes">00</div>
          <div class="ai-hero-landing__countdown-label-{{ ai_gen_id }}">Min</div>
        </div>
        <div class="ai-hero-landing__countdown-unit-{{ ai_gen_id }}">
          <div class="ai-hero-landing__countdown-value-{{ ai_gen_id }}" data-unit="seconds">00</div>
          <div class="ai-hero-landing__countdown-label-{{ ai_gen_id }}">Sec</div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_trust_badges %}
      <div class="ai-hero-landing__trust-row-{{ ai_gen_id }}">
        <div class="ai-hero-landing__trust-item-{{ ai_gen_id }}">
          <svg class="ai-hero-landing__trust-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
          <span>{{ settings.trust_shipping_title }}</span>
        </div>
        <div class="ai-hero-landing__trust-item-{{ ai_gen_id }}">
          <svg class="ai-hero-landing__trust-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>{{ settings.trust_returns_title }}</span>
        </div>
        <div class="ai-hero-landing__trust-item-{{ ai_gen_id }}">
          <svg class="ai-hero-landing__trust-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <span>{{ settings.trust_secure_title }}</span>
        </div>
      </div>
    {% endif %}
  </div>
</landing-hero-{{ ai_gen_id }}>

<script>
(function() {
  class LandingHero{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.countdownInterval = null;
      this.trackingFired = {
        viewContent: false
      };
    }

    connectedCallback() {
      this.setupCountdown();
      this.setupAddToCart();
      this.setupTracking();
      this.fireViewContentTracking();
    }

    disconnectedCallback() {
      if (this.countdownInterval) {
        clearInterval(this.countdownInterval);
      }
    }

    setupCountdown() {
      const countdownEl = this.querySelector('.ai-hero-landing__countdown-{{ ai_gen_id }}');
      if (!countdownEl) return;

      const endDate = countdownEl.dataset.countdownEnd;
      if (!endDate) return;

      const updateCountdown = () => {
        const now = new Date().getTime();
        const end = new Date(endDate).getTime();
        const distance = end - now;

        if (distance < 0) {
          clearInterval(this.countdownInterval);
          countdownEl.innerHTML = '<div style="text-align: center; width: 100%;">{{ block.settings.countdown_expired_text }}</div>';
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        const daysEl = countdownEl.querySelector('[data-unit="days"]');
        const hoursEl = countdownEl.querySelector('[data-unit="hours"]');
        const minutesEl = countdownEl.querySelector('[data-unit="minutes"]');
        const secondsEl = countdownEl.querySelector('[data-unit="seconds"]');

        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      };

      updateCountdown();
      this.countdownInterval = setInterval(updateCountdown, 1000);
    }

    setupAddToCart() {
      const ctaButton = this.querySelector('[data-action="add-to-cart"]');
      if (!ctaButton) return;

      ctaButton.addEventListener('click', async () => {
        const variantId = this.dataset.variantId;
        if (!variantId) return;

        ctaButton.disabled = true;
        ctaButton.textContent = 'Adding...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              id: variantId,
              quantity: 1
            })
          });

          if (response.ok) {
            this.fireAddToCartTracking();
            
            document.dispatchEvent(new CustomEvent('cart:updated'));
            
            ctaButton.textContent = 'Added!';
            setTimeout(() => {
              ctaButton.textContent = '{{ block.settings.cta_text }}';
              ctaButton.disabled = false;
            }, 2000);

            const cartDrawer = document.querySelector('cart-drawer');
            if (cartDrawer && typeof cartDrawer.open === 'function') {
              cartDrawer.open();
            } else {
              window.location.href = '/cart';
            }
          } else {
            throw new Error('Failed to add to cart');
          }
        } catch (error) {
          console.error('Add to cart error:', error);
          ctaButton.textContent = 'Error - Try again';
          ctaButton.disabled = false;
        }
      });
    }

    setupTracking() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting && !this.trackingFired.viewContent) {
            this.fireViewContentTracking();
          }
        });
      }, { threshold: 0.5 });

      observer.observe(this);
    }

    fireViewContentTracking() {
      if (this.trackingFired.viewContent) return;
      this.trackingFired.viewContent = true;

      const productId = this.dataset.productId;
      const variantId = this.dataset.variantId;
      const price = this.dataset.productPrice;
      const currency = this.dataset.productCurrency;

      if (typeof fbq !== 'undefined') {
        fbq('track', 'ViewContent', {
          content_ids: [variantId],
          content_type: 'product',
          value: price,
          currency: currency
        });
      }

      if (typeof ttq !== 'undefined') {
        ttq.track('ViewContent', {
          content_id: variantId,
          content_type: 'product',
          value: price,
          currency: currency
        });
      }

      if (typeof gtag !== 'undefined') {
        gtag('event', 'view_item', {
          currency: currency,
          value: price,
          items: [{
            item_id: variantId,
            item_name: document.title,
            price: price
          }]
        });
      }

      if (window.dataLayer) {
        window.dataLayer.push({
          event: 'view_item',
          ecommerce: {
            currency: currency,
            value: price,
            items: [{
              item_id: variantId,
              item_name: document.title,
              price: price
            }]
          }
        });
      }
    }

    fireAddToCartTracking() {
      const productId = this.dataset.productId;
      const variantId = this.dataset.variantId;
      const price = this.dataset.productPrice;
      const currency = this.dataset.productCurrency;

      if (typeof fbq !== 'undefined') {
        fbq('track', 'AddToCart', {
          content_ids: [variantId],
          content_type: 'product',
          value: price,
          currency: currency
        });
      }

      if (typeof ttq !== 'undefined') {
        ttq.track('AddToCart', {
          content_id: variantId,
          content_type: 'product',
          value: price,
          currency: currency,
          quantity: 1
        });
      }

      if (typeof gtag !== 'undefined') {
        gtag('event', 'add_to_cart', {
          currency: currency,
          value: price,
          items: [{
            item_id: variantId,
            item_name: document.title,
            price: price,
            quantity: 1
          }]
        });
      }

      if (window.dataLayer) {
        window.dataLayer.push({
          event: 'add_to_cart',
          ecommerce: {
            currency: currency,
            value: price,
            items: [{
              item_id: variantId,
              item_name: document.title,
              price: price,
              quantity: 1
            }]
          }
        });
      }
    }
  }

  customElements.define('landing-hero-{{ ai_gen_id }}', LandingHero{{ ai_gen_id }});
})();
</script>

