{% doc %}
  @prompt
    Create a single-product store layout that transforms the homepage into a high-converting product landing page. It should include: a full-width hero section with the product image, a compelling headline and subheadline, key product benefits/features in a grid, a prominent Add to Cart button, a trust badges section (free shipping, secure checkout, money-back guarantee), and a customer reviews/testimonials section. The design should feel premium and luxury, with a clean minimal aesthetic suitable for a shapewear or body care brand.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-landing-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-product-landing__hero-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.hero_height_desktop }}vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: {{ block.settings.hero_bg_color }};
  }

  .ai-product-landing__hero-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-landing__hero-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #f5f3f0 0%, #faf9f7 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-landing__hero-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 600px;
    max-height: 600px;
    opacity: 0.3;
  }

  .ai-product-landing__hero-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, {{ block.settings.overlay_opacity_top }}),
      rgba(0, 0, 0, {{ block.settings.overlay_opacity_bottom }})
    );
  }

  .ai-product-landing__hero-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding: 40px 20px;
    color: {{ block.settings.hero_text_color }};
  }

  .ai-product-landing__hero-headline-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-size: {{ block.settings.headline_size_desktop }}px;
    line-height: 1.1;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
  }

  .ai-product-landing__hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size_desktop }}px;
    line-height: 1.5;
    margin: 0 0 40px;
    opacity: 0.95;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-product-landing__hero-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 48px;
    background-color: {{ block.settings.cta_bg_color }};
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    letter-spacing: 0.02em;
  }

  .ai-product-landing__hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_bg_color }};
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-product-landing__benefits-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_desktop }}px 20px;
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-product-landing__benefits-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.benefits_columns_desktop }}, 1fr);
    gap: {{ block.settings.benefits_gap }}px;
  }

  .ai-product-landing__benefit-{{ ai_gen_id }} {
    text-align: center;
    padding: {{ block.settings.benefit_card_padding }}px;
    background-color: {{ block.settings.benefit_card_bg }};
    border-radius: {{ block.settings.benefit_card_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-product-landing__benefit-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-product-landing__benefit-icon-{{ ai_gen_id }} {
    width: {{ block.settings.benefit_icon_size }}px;
    height: {{ block.settings.benefit_icon_size }}px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.benefit_icon_color }};
  }

  .ai-product-landing__benefit-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-product-landing__benefit-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_title_size }}px;
    font-weight: 600;
    margin: 0 0 12px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-landing__benefit-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_muted_color }};
    margin: 0;
  }

  .ai-product-landing__trust-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_desktop }}px 20px;
    background-color: {{ block.settings.trust_bg_color }};
  }

  .ai-product-landing__trust-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-product-landing__trust-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.trust_columns_desktop }}, 1fr);
    gap: {{ block.settings.trust_gap }}px;
  }

  .ai-product-landing__trust-badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.trust_badge_padding }}px;
  }

  .ai-product-landing__trust-icon-{{ ai_gen_id }} {
    width: {{ block.settings.trust_icon_size }}px;
    height: {{ block.settings.trust_icon_size }}px;
    margin-bottom: 16px;
    color: {{ block.settings.trust_icon_color }};
  }

  .ai-product-landing__trust-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-product-landing__trust-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-landing__trust-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.trust_subtitle_size }}px;
    color: {{ block.settings.text_muted_color }};
    margin: 0;
  }

  .ai-product-landing__reviews-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_desktop }}px 20px;
    background-color: {{ block.settings.reviews_bg_color }};
  }

  .ai-product-landing__reviews-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-product-landing__reviews-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-product-landing__reviews-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    font-weight: {{ block.settings.headline_font.weight }};
    font-size: {{ block.settings.reviews_title_size }}px;
    margin: 0 0 16px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-landing__reviews-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.reviews_subtitle_size }}px;
    color: {{ block.settings.text_muted_color }};
    margin: 0;
  }

  .ai-product-landing__reviews-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.reviews_columns_desktop }}, 1fr);
    gap: {{ block.settings.reviews_gap }}px;
  }

  .ai-product-landing__review-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.review_card_bg }};
    padding: {{ block.settings.review_card_padding }}px;
    border-radius: {{ block.settings.review_card_radius }}px;
    border: 1px solid {{ block.settings.review_card_border }};
  }

  .ai-product-landing__review-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    color: {{ block.settings.star_color }};
  }

  .ai-product-landing__review-stars-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-product-landing__review-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.review_text_size }}px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
  }

  .ai-product-landing__review-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-product-landing__review-avatar-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, {{ block.settings.benefit_icon_color }} 0%, {{ block.settings.trust_icon_color }} 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 18px;
  }

  .ai-product-landing__review-author-info-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-product-landing__review-author-name-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 4px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-landing__review-verified-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.trust_icon_color }};
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .ai-product-landing__review-verified-{{ ai_gen_id }} svg {
    width: 16px;
    height: 16px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-landing__hero-{{ ai_gen_id }} {
      min-height: {{ block.settings.hero_height_mobile }}vh;
    }

    .ai-product-landing__hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-product-landing__hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size_mobile }}px;
    }

    .ai-product-landing__benefits-{{ ai_gen_id }},
    .ai-product-landing__trust-{{ ai_gen_id }},
    .ai-product-landing__reviews-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 20px;
    }

    .ai-product-landing__benefits-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.benefits_columns_mobile }}, 1fr);
    }

    .ai-product-landing__trust-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.trust_columns_mobile }}, 1fr);
    }

    .ai-product-landing__reviews-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }
  }
{% endstyle %}

<product-landing-{{ ai_gen_id }} class="ai-product-landing-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-landing__hero-{{ ai_gen_id }}">
    {% if block.settings.hero_image %}
      <img
        src="{{ block.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ block.settings.hero_image.alt | escape }}"
        class="ai-product-landing__hero-image-{{ ai_gen_id }}"
        loading="eager"
        width="{{ block.settings.hero_image.width }}"
        height="{{ block.settings.hero_image.height }}"
      >
    {% else %}
      <div class="ai-product-landing__hero-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-product-landing__hero-overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-product-landing__hero-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h1 class="ai-product-landing__hero-headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h1>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <p class="ai-product-landing__hero-subheadline-{{ ai_gen_id }}">
          {{ block.settings.subheadline }}
        </p>
      {% endif %}

      {% if block.settings.show_hero_cta %}
        <a
          href="{{ block.settings.cta_link }}"
          class="ai-product-landing__hero-cta-{{ ai_gen_id }}"
        >
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>
  </div>

  {% if block.settings.show_benefits %}
    <div class="ai-product-landing__benefits-{{ ai_gen_id }}">
      <div class="ai-product-landing__benefits-grid-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% liquid
            assign title_key = 'benefit_' | append: i | append: '_title'
            assign text_key = 'benefit_' | append: i | append: '_text'
            assign icon_key = 'benefit_' | append: i | append: '_icon'

            assign title = block.settings[title_key]
            assign text = block.settings[text_key]
            assign icon = block.settings[icon_key]
          %}

          {% if title != blank %}
            <div class="ai-product-landing__benefit-{{ ai_gen_id }}">
              <div class="ai-product-landing__benefit-icon-{{ ai_gen_id }}">
                {% if icon == 'star' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% elsif icon == 'shield' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                {% elsif icon == 'truck' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {% elsif icon == 'heart' %}
                  <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                {% endif %}
              </div>
              <h3 class="ai-product-landing__benefit-title-{{ ai_gen_id }}">{{ title }}</h3>
              {% if text != blank %}
                <p class="ai-product-landing__benefit-text-{{ ai_gen_id }}">{{ text }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_trust %}
    <div class="ai-product-landing__trust-{{ ai_gen_id }}">
      <div class="ai-product-landing__trust-container-{{ ai_gen_id }}">
        <div class="ai-product-landing__trust-grid-{{ ai_gen_id }}">
          {% if block.settings.trust_1_title != blank %}
            <div class="ai-product-landing__trust-badge-{{ ai_gen_id }}">
              <div class="ai-product-landing__trust-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              </div>
              <div class="ai-product-landing__trust-title-{{ ai_gen_id }}">{{ block.settings.trust_1_title }}</div>
              {% if block.settings.trust_1_subtitle != blank %}
                <div class="ai-product-landing__trust-subtitle-{{ ai_gen_id }}">{{ block.settings.trust_1_subtitle }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.trust_2_title != blank %}
            <div class="ai-product-landing__trust-badge-{{ ai_gen_id }}">
              <div class="ai-product-landing__trust-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <div class="ai-product-landing__trust-title-{{ ai_gen_id }}">{{ block.settings.trust_2_title }}</div>
              {% if block.settings.trust_2_subtitle != blank %}
                <div class="ai-product-landing__trust-subtitle-{{ ai_gen_id }}">{{ block.settings.trust_2_subtitle }}</div>
              {% endif %}
            </div>
          {% endif %}

          {% if block.settings.trust_3_title != blank %}
            <div class="ai-product-landing__trust-badge-{{ ai_gen_id }}">
              <div class="ai-product-landing__trust-icon-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              </div>
              <div class="ai-product-landing__trust-title-{{ ai_gen_id }}">{{ block.settings.trust_3_title }}</div>
              {% if block.settings.trust_3_subtitle != blank %}
                <div class="ai-product-landing__trust-subtitle-{{ ai_gen_id }}">{{ block.settings.trust_3_subtitle }}</div>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}

  {% if block.settings.show_reviews %}
    <div class="ai-product-landing__reviews-{{ ai_gen_id }}">
      <div class="ai-product-landing__reviews-container-{{ ai_gen_id }}">
        <div class="ai-product-landing__reviews-header-{{ ai_gen_id }}">
          {% if block.settings.reviews_title != blank %}
            <h2 class="ai-product-landing__reviews-title-{{ ai_gen_id }}">{{ block.settings.reviews_title }}</h2>
          {% endif %}
          {% if block.settings.reviews_subtitle != blank %}
            <p class="ai-product-landing__reviews-subtitle-{{ ai_gen_id }}">{{ block.settings.reviews_subtitle }}</p>
          {% endif %}
        </div>

        <div class="ai-product-landing__reviews-grid-{{ ai_gen_id }}">
          {% for i in (1..3) %}
            {% liquid
              assign author_key = 'review_' | append: i | append: '_author'
              assign text_key = 'review_' | append: i | append: '_text'

              assign author = block.settings[author_key]
              assign text = block.settings[text_key]
            %}

            {% if author != blank and text != blank %}
              <div class="ai-product-landing__review-card-{{ ai_gen_id }}">
                <div class="ai-product-landing__review-stars-{{ ai_gen_id }}">
                  {% for star in (1..5) %}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  {% endfor %}
                </div>
                <p class="ai-product-landing__review-text-{{ ai_gen_id }}">{{ text }}</p>
                <div class="ai-product-landing__review-author-{{ ai_gen_id }}">
                  <div class="ai-product-landing__review-avatar-{{ ai_gen_id }}">
                    {{ author | slice: 0 | upcase }}
                  </div>
                  <div class="ai-product-landing__review-author-info-{{ ai_gen_id }}">
                    <div class="ai-product-landing__review-author-name-{{ ai_gen_id }}">{{ author }}</div>
                    <div class="ai-product-landing__review-verified-{{ ai_gen_id }}">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                      Verified Purchase
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</product-landing-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductLanding{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initScrollAnimations();
      }

      initScrollAnimations() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }
            });
          },
          { threshold: 0.1 }
        );

        const animatedElements = this.querySelectorAll(
          '.ai-product-landing__benefit-{{ ai_gen_id }}, .ai-product-landing__trust-badge-{{ ai_gen_id }}, .ai-product-landing__review-card-{{ ai_gen_id }}'
        );

        animatedElements.forEach((el, index) => {
          el.style.opacity = '0';
          el.style.transform = 'translateY(30px)';
          el.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
          observer.observe(el);
        });
      }
    }

    customElements.define('product-landing-{{ ai_gen_id }}', ProductLanding{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product landing page",
  "settings": [
    {
      "type": "header",
      "content": "Hero section"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Desktop height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Mobile height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 70
    },
    {
      "type": "color",
      "id": "hero_bg_color",
      "label": "Background color",
      "default": "#faf9f7"
