    },
    {
      "type": "header",
      "content": "Question 5"
    },
    {
      "type": "text",
      "id": "question_5",
      "label": "Question",
      "default": "Is my payment information secure?"
    },
    {
      "type": "textarea",
      "id": "answer_5",
      "label": "Answer",
      "default": "Yes, we use SSL encryption to protect your payment information. All transactions are processed securely through trusted payment gateways."
