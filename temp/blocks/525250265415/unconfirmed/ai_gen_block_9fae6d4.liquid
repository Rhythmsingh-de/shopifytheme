{% doc %}
  @prompt
    Hero — headline, product image, price, CTA button
    
    Trust badges — shipping, guarantee, security
    
    Benefits — 3-column icon grid
    
    Social proof — star ratings + review cards
    
    FAQ — accordion layout
    
    Urgency CTA — countdown timer banner
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-benefits-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-benefits-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .ai-benefits-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0;
  }

  .ai-benefits-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .ai-benefit-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
    padding: 32px 24px;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-benefit-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-benefit-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_bg_color }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
  }

  .ai-benefit-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-benefit-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-benefit-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_description_size }}px;
    color: {{ block.settings.subheading_color }};
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-benefits-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .ai-benefits-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.75);
    }
  }
{% endstyle %}

<div class="ai-benefits-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-benefits-header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-benefits-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-benefits-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-benefits-grid-{{ ai_gen_id }}">
    <div class="ai-benefit-card-{{ ai_gen_id }}">
      <div class="ai-benefit-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>
      <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_1_title }}</h3>
      <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_1_description }}</p>
    </div>

    <div class="ai-benefit-card-{{ ai_gen_id }}">
      <div class="ai-benefit-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      </div>
      <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_2_title }}</h3>
      <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_2_description }}</p>
    </div>

    <div class="ai-benefit-card-{{ ai_gen_id }}">
      <div class="ai-benefit-icon-{{ ai_gen_id }}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
      </div>
      <h3 class="ai-benefit-title-{{ ai_gen_id }}">{{ block.settings.benefit_3_title }}</h3>
      <p class="ai-benefit-description-{{ ai_gen_id }}">{{ block.settings.benefit_3_description }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Benefits grid",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium quality meets exceptional care"
    },
    {
      "type": "header",
      "content": "Benefit 1"
    },
    {
      "type": "text",
      "id": "benefit_1_title",
      "label": "Title",
      "default": "Premium Quality"
    },
    {
      "type": "textarea",
      "id": "benefit_1_description",
      "label": "Description",
      "default": "Crafted with the finest materials for lasting comfort and durability."
    },
    {
      "type": "header",
      "content": "Benefit 2"
    },
    {
      "type": "text",
      "id": "benefit_2_title",
      "label": "Title",
      "default": "Body Confidence"
    },
    {
      "type": "textarea",
      "id": "benefit_2_description",
      "label": "Description",
      "default": "Designed to enhance your natural shape and boost your confidence."
    },
    {
      "type": "header",
      "content": "Benefit 3"
    },
    {
      "type": "text",
      "id": "benefit_3_title",
      "label": "Title",
      "default": "Trusted by Thousands"
    },
    {
      "type": "textarea",
      "id": "benefit_3_description",
      "label": "Description",
      "default": "Join thousands of satisfied customers who love our products."
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#faf9f7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background",
      "default": "#e6f4ed"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#1d6b44"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 14,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "benefit_title_size",
      "label": "Benefit title size",
      "min": 16,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "benefit_description_size",
      "label": "Benefit description size",
      "min": 14,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 48,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Container border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Heading font",
      "default": "playfair_display_n4"
    }
  ],
  "presets": [
    {
      "name": "Benefits grid"
    }
  ]
}
{% endschema %}
