      "id": "item_hover_bg_color",
      "label": "Item hover background",
      "default": "#f5f3f0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "answer_color",
      "label": "Answer text",
      "default": "#6b7280"
