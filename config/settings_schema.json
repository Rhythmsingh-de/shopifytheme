      {"type": "color", "id": "text_muted", "label": "Muted text", "default": "#666666"},
      {"type": "color", "id": "accent_color", "label": "Accent (CTA buttons)", "default": "#ff3c00"},
      {"type": "color", "id": "accent_hover", "label": "Accent hover", "default": "#e03500"},
      {"type": "color", "id": "surface_color", "label": "Surface / card background", "default": "#f7f7f7"}
