[
  {
    "name": "theme_info",
    "theme_name": "BodyLuxCare",
    "theme_version": "2.0.0",
    "theme_author": "BodyLuxCare",
    "theme_documentation_url": "https://github.com/Rhythmsingh-de/shopifytheme",
    "theme_support_url": "https://github.com/Rhythmsingh-de/shopifytheme/issues"
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "header", "content": "Display Font (headings)" },
      { "type": "font_picker", "id": "font_display", "label": "Display font", "default": "playfair_display_n4" },
      { "type": "header", "content": "Body Font" },
      { "type": "font_picker", "id": "font_body", "label": "Body font", "default": "work_sans_n4" },
      { "type": "range", "id": "body_font_size", "label": "Base font size (px)", "min": 14, "max": 20, "step": 1, "default": 16 }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "header", "content": "Surfaces" },
      { "type": "color", "id": "color_bg", "label": "Page background", "default": "#ffffff" },
      { "type": "color", "id": "color_surface", "label": "Card surface", "default": "#f9f9f9" },
      { "type": "color", "id": "color_surface_2", "label": "Elevated surface", "default": "#f3f3f3" },
      { "type": "color", "id": "color_border", "label": "Border color", "default": "#e5e5e5" },
      { "type": "header", "content": "Text" },
      { "type": "color", "id": "color_text", "label": "Primary text", "default": "#111111" },
      { "type": "color", "id": "color_text_muted", "label": "Muted text", "default": "#666666" },
      { "type": "header", "content": "Buttons & Accents" },
      { "type": "color", "id": "color_btn_primary_bg", "label": "Primary button background", "default": "#111111" },
      { "type": "color", "id": "color_btn_primary_text", "label": "Primary button text", "default": "#ffffff" },
      { "type": "color", "id": "color_secondary", "label": "Secondary accent", "default": "#e8260d" },
      { "type": "color", "id": "color_sale", "label": "Sale badge color", "default": "#e8260d" },
      { "type": "color", "id": "color_sale_bg", "label": "Sale badge background", "default": "#ffeeed" },
      { "type": "header", "content": "Highlight / Deco (progress bars, urgency)" },
      { "type": "color", "id": "color_deco", "label": "Deco color (progress, urgency)", "default": "#1d6b44" },
      { "type": "color", "id": "color_deco_light", "label": "Deco light (background tint)", "default": "#e6f4ed" },
      { "type": "header", "content": "Header" },
      { "type": "color", "id": "color_header_bg", "label": "Header background", "default": "#ffffff" },
      { "type": "color", "id": "color_header_text", "label": "Header text & icons", "default": "#111111" },
      { "type": "header", "content": "Footer" },
      { "type": "color", "id": "color_footer_bg", "label": "Footer background", "default": "#111111" },
      { "type": "color", "id": "color_footer_text", "label": "Footer text", "default": "#ffffff" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      { "type": "range", "id": "container_max_width", "label": "Max container width (px)", "min": 960, "max": 1600, "step": 40, "default": 1200 },
      { "type": "range", "id": "card_border_radius", "label": "Card border radius (px)", "min": 0, "max": 24, "step": 2, "default": 8 },
      { "type": "select", "id": "button_border_radius", "label": "Button style", "options": [
        { "value": "9999px", "label": "Pill" },
        { "value": "8px", "label": "Rounded" },
        { "value": "4px", "label": "Square" }
      ], "default": "9999px" },
      { "type": "select", "id": "product_grid_columns", "label": "Product grid columns (desktop)", "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ], "default": "4" }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      { "type": "checkbox", "id": "card_quick_add", "label": "Show Quick Add button", "default": true },
      { "type": "checkbox", "id": "card_show_rating", "label": "Show star rating (requires reviews app)", "default": false },
      { "type": "checkbox", "id": "card_show_vendor", "label": "Show vendor name", "default": false },
      { "type": "checkbox", "id": "card_show_sale_badge", "label": "Show sale % badge", "default": true },
      { "type": "checkbox", "id": "card_show_new_badge", "label": "Show new/bestseller badge (tag-based)", "default": true },
      { "type": "checkbox", "id": "card_hover_second_image", "label": "Show second image on hover", "default": true }
    ]
  },
  {
    "name": "Cart & Checkout",
    "settings": [
      { "type": "number", "id": "free_shipping_threshold", "label": "Free shipping threshold ($)", "default": 75 },
      { "type": "checkbox", "id": "cart_show_upsell", "label": "Show upsell in cart drawer", "default": true },
      { "type": "text", "id": "cart_upsell_title", "label": "Cart upsell title", "default": "You might also like" }
    ]
  },
  {
    "name": "Trust & Badges",
    "settings": [
      { "type": "text", "id": "trust_returns_title", "label": "Returns badge title", "default": "30-Day Money Back" },
      { "type": "text", "id": "trust_returns_sub", "label": "Returns badge subtitle", "default": "No questions asked" },
      { "type": "text", "id": "trust_shipping_title", "label": "Shipping badge title", "default": "International Shipping" },
      { "type": "text", "id": "trust_shipping_sub", "label": "Shipping badge subtitle", "default": "5–10 business days" },
      { "type": "text", "id": "trust_secure_title", "label": "Secure checkout title", "default": "Secure Checkout" },
      { "type": "text", "id": "trust_secure_sub", "label": "Secure checkout subtitle", "default": "SSL encrypted" },
      { "type": "text", "id": "trust_support_title", "label": "Support badge title", "default": "24/7 Support" },
      { "type": "text", "id": "trust_support_sub", "label": "Support badge subtitle", "default": "We reply within hours" }
    ]
  },
  {
    "name": "Custom CSS",
    "settings": [
      { "type": "textarea", "id": "custom_css", "label": "Custom CSS", "default": "" }
    ]
  }
]
