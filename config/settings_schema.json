[
  {
    "name": "theme_info",
    "theme_name": "BodyLuxCare",
    "theme_version": "3.3.0",
    "theme_author": "Rhythmsingh",
    "theme_documentation_url": "https://github.com/Rhythmsingh-de/shopifytheme",
    "theme_support_url": "https://github.com/Rhythmsingh-de/shopifytheme"
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "header", "content": "Page Surfaces" },
      { "type": "color", "id": "color_bg",        "label": "Page background",       "default": "#faf9f7" },
      { "type": "color", "id": "color_surface",    "label": "Card / surface background", "default": "#ffffff" },
      { "type": "color", "id": "color_surface_2",  "label": "Offset surface",         "default": "#f5f3f0" },
      { "type": "color", "id": "color_border",     "label": "Border / divider",       "default": "#dddbd7" },
      { "type": "header", "content": "Text" },
      { "type": "color", "id": "color_text",       "label": "Body text",              "default": "#1a1a1a" },
      { "type": "color", "id": "color_text_muted", "label": "Muted text",             "default": "#6b7280" },
      { "type": "header", "content": "Buttons" },
      { "type": "color", "id": "color_btn_primary_bg",   "label": "Primary button background", "default": "#1a1a1a" },
      { "type": "color", "id": "color_btn_primary_text", "label": "Primary button text",       "default": "#ffffff" },
      { "type": "color", "id": "color_secondary",        "label": "CTA accent (sale/urgency)", "default": "#e8260d" },
      { "type": "header", "content": "Sale & Badges" },
      { "type": "color", "id": "color_sale",      "label": "Sale badge color",              "default": "#e8260d" },
      { "type": "color", "id": "color_sale_bg",   "label": "Sale badge background",         "default": "#fff1f0" },
      { "type": "color", "id": "color_deco",      "label": "Trust/guarantee accent (emerald)", "default": "#1d6b44" },
      { "type": "color", "id": "color_deco_light","label": "Trust accent light background", "default": "#e6f4ed" },
      { "type": "header", "content": "Header & Footer" },
      { "type": "color", "id": "color_header_bg",   "label": "Header background", "default": "#ffffff" },
      { "type": "color", "id": "color_header_text", "label": "Header text",       "default": "#1a1a1a" },
      { "type": "color", "id": "color_footer_bg",   "label": "Footer background", "default": "#111111" },
      { "type": "color", "id": "color_footer_text", "label": "Footer text",       "default": "#cccccc" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "font_picker", "id": "font_display", "label": "Display / heading font", "default": "playfair_display_n4" },
      { "type": "font_picker", "id": "font_body",    "label": "Body font",              "default": "work_sans_n4" },
      { "type": "range", "id": "body_font_size", "label": "Base font size", "min": 14, "max": 18, "step": 1, "default": 16, "unit": "px" }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      { "type": "select", "id": "theme_mode", "label": "Theme mode",
        "options": [
          { "value": "system", "label": "Follow system" },
          { "value": "light", "label": "Light" },
          { "value": "dark", "label": "Dark" }
        ],
        "default": "light" },
      { "type": "range",  "id": "container_max_width",  "label": "Max page width",    "min": 960, "max": 1440, "step": 40, "default": 1280, "unit": "px" },
      { "type": "select", "id": "button_border_radius", "label": "Button shape",
        "options": [
          { "value": "0px",    "label": "Square" },
          { "value": "6px",    "label": "Slightly rounded" },
          { "value": "12px",   "label": "Rounded" },
          { "value": "9999px", "label": "Pill" }
        ], "default": "9999px" },
      { "type": "range", "id": "card_border_radius", "label": "Card corner radius", "min": 0, "max": 24, "step": 2, "default": 12, "unit": "px" }
    ]
  },
  {
    "name": "Storefront Mode",
    "settings": [
      { "type": "header", "content": "Selling Mode" },
      { "type": "select", "id": "storefront_mode", "label": "Default selling mode",
        "info": "Controls global product and collection fallbacks used by hero, header, urgency, and featured product sections.",
        "options": [
          { "value": "single_product", "label": "Single product focused" },
          { "value": "multi_product", "label": "Multiple products / collection focused" }
        ],
        "default": "single_product" },
      { "type": "product", "id": "primary_product", "label": "Primary product" },
      { "type": "collection", "id": "primary_collection", "label": "Primary collection" },
      { "type": "checkbox", "id": "single_product_sections_follow_mode", "label": "Hide single-product sections when multiple-products mode is active", "default": false }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      { "type": "checkbox", "id": "card_hover_second_image", "label": "Show alternate image on hover", "default": true },
      { "type": "checkbox", "id": "card_quick_add",          "label": "Show Quick Add button",         "default": true },
      { "type": "checkbox", "id": "card_show_vendor",        "label": "Show vendor name",              "default": false },
      { "type": "checkbox", "id": "card_show_rating",        "label": "Show star rating",              "default": true },
      { "type": "checkbox", "id": "card_show_sale_badge",    "label": "Show sale % badge",             "default": true },
      { "type": "checkbox", "id": "card_show_new_badge",     "label": "Show 'New' badge",              "default": true }
    ]
  },
  {
    "name": "Collection Pages",
    "settings": [
      { "type": "header", "content": "Collection Layout Defaults" },
      { "type": "range", "id": "collection_products_per_page", "label": "Products per page", "min": 8, "max": 48, "step": 4, "default": 24 },
      { "type": "range", "id": "collection_columns_desktop", "label": "Desktop columns", "min": 2, "max": 5, "step": 1, "default": 4 },
      { "type": "select", "id": "collection_columns_mobile", "label": "Mobile columns",
        "options": [
          { "value": "1", "label": "1 column" },
          { "value": "2", "label": "2 columns" }
        ],
        "default": "2" },
      { "type": "checkbox", "id": "collection_show_sort", "label": "Show sort selector", "default": true },
      { "type": "checkbox", "id": "collection_show_filters", "label": "Show filters", "default": true },
      { "type": "checkbox", "id": "collection_show_empty_state_cta", "label": "Show empty-state CTA", "default": true },
      { "type": "header", "content": "Collection Trust Row" },
      { "type": "checkbox", "id": "collection_show_trust_bar", "label": "Show trust row on collection pages", "default": true },
      { "type": "text", "id": "collection_trust_text", "label": "Collection trust text", "default": "Free shipping on all orders - 14-day guarantee - Secure checkout" }
    ]
  },
  {
    "name": "Reviews & Social Proof",
    "settings": [
      { "type": "header", "content": "Review Display Defaults" },
      { "type": "text", "id": "reviews_summary_text", "label": "Review summary text", "default": "Excellent 4.8/5 from verified customers" },
      { "type": "range", "id": "reviews_visible_count", "label": "Visible review cards", "min": 1, "max": 3, "step": 1, "default": 3 },
      { "type": "checkbox", "id": "reviews_autoplay", "label": "Auto-rotate extra reviews", "default": true },
      { "type": "range", "id": "reviews_autoplay_interval", "label": "Rotation interval", "min": 2, "max": 10, "step": 1, "default": 4, "unit": "s" },
      { "type": "checkbox", "id": "reviews_show_verified_badge", "label": "Show verified badges", "default": true }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      { "type": "header", "content": "Free Shipping Progress Bar" },
      { "type": "checkbox", "id": "show_free_shipping_bar",
        "label": "Show free shipping progress bar in cart",
        "default": true },
      { "type": "number", "id": "free_shipping_threshold",
        "label": "Free shipping threshold (in your store currency)",
        "default": 0,
        "info": "Customers see a progress bar until their cart reaches this value. Set to 0 to disable." },
      { "type": "header", "content": "Cart Upsell" },
      { "type": "checkbox", "id": "cart_show_upsell",
        "label": "Show upsell product in cart summary",
        "default": true,
        "info": "Set the upsell product per-page in the cart section settings." },
      { "type": "text", "id": "cart_upsell_title",
        "label": "Upsell section heading",
        "default": "You might also like" },
      { "type": "product", "id": "cart_drawer_upsell_product",
        "label": "Cart drawer upsell product",
        "info": "Optional. Cart page upsell still uses the cart section setting." },
      { "type": "header", "content": "Cart Note" },
      { "type": "checkbox", "id": "cart_show_note",
        "label": "Allow customers to add a note to their order",
        "default": false },
      { "type": "header", "content": "Cart Trust" },
      { "type": "checkbox", "id": "trust_show_payment_icons",
        "label": "Show payment icons in cart drawer",
        "default": true }
    ]
  },
  {
    "name": "Trust & Conversion",
    "settings": [
      { "type": "header", "content": "Shipping & Returns" },
      { "type": "text", "id": "trust_shipping_title", "label": "Shipping badge title",         "default": "Free Shipping" },
      { "type": "text", "id": "trust_shipping_sub",   "label": "Shipping badge subtitle",      "default": "On all orders" },
      { "type": "text", "id": "trust_returns_title",  "label": "Returns badge title",          "default": "14-Day Guarantee" },
      { "type": "text", "id": "trust_returns_sub",    "label": "Returns badge subtitle",       "default": "No questions asked" },
      { "type": "text", "id": "trust_secure_title",   "label": "Secure payment badge title",   "default": "Secure Checkout" },
      { "type": "text", "id": "trust_secure_sub",     "label": "Secure payment badge subtitle", "default": "SSL encrypted" },
      { "type": "text", "id": "trust_support_title",  "label": "Support badge title",          "default": "24/7 Support" },
      { "type": "text", "id": "trust_support_sub",    "label": "Support badge subtitle",       "default": "We reply within hours" },
      { "type": "header", "content": "Urgency / Scarcity" },
      { "type": "checkbox", "id": "show_urgency_banner", "label": "Show announcement urgency banner",       "default": true },
      { "type": "checkbox", "id": "show_scarcity_bar",   "label": "Show stock scarcity bar on product",    "default": true },
      { "type": "header", "content": "Global CTA Defaults" },
      { "type": "text", "id": "conversion_primary_cta_label", "label": "Primary add-to-cart label", "default": "Add to Cart" },
      { "type": "text", "id": "conversion_buy_now_label", "label": "Buy now label", "default": "Buy Now" },
      { "type": "text", "id": "conversion_fast_checkout_label", "label": "Fast checkout label", "default": "Fast Checkout" },
      { "type": "checkbox", "id": "conversion_show_fast_checkout", "label": "Show fast checkout buttons", "default": true },
      { "type": "select", "id": "conversion_checkout_button_mode", "label": "Product CTA button layout",
        "options": [
          { "value": "both", "label": "Add to cart and fast checkout" },
          { "value": "cart_only", "label": "Add to cart only" },
          { "value": "checkout_only", "label": "Fast checkout only" }
        ],
        "default": "both" },
      { "type": "select", "id": "fast_checkout_destination", "label": "Fast checkout destination",
        "options": [
          { "value": "checkout", "label": "Checkout permalink" },
          { "value": "cart", "label": "Cart permalink" }
        ],
        "default": "checkout" },
      { "type": "text", "id": "conversion_microcopy", "label": "Checkout trust microcopy", "default": "Secure checkout - free shipping on all orders - 14-day guarantee" },
      { "type": "checkbox", "id": "product_sticky_atc_enabled", "label": "Show sticky add-to-cart on product pages", "default": true },
      { "type": "header", "content": "Product Page Benefit Defaults" },
      { "type": "text", "id": "product_benefit_1", "label": "Product benefit 1", "default": "Premium quality, built to last" },
      { "type": "text", "id": "product_benefit_2", "label": "Product benefit 2", "default": "Free shipping on all orders" },
      { "type": "text", "id": "product_benefit_3", "label": "Product benefit 3", "default": "14-day money-back guarantee" },
      { "type": "text", "id": "product_benefit_4", "label": "Product benefit 4", "default": "Secure checkout guaranteed" }
    ]
  },
  {
    "name": "Compliance & Tracking",
    "settings": [
      { "type": "header", "content": "Cookie Consent Banner" },
      { "type": "checkbox", "id": "gdpr_cookie_banner", "label": "Show cookie consent banner", "default": true },
      { "type": "textarea", "id": "cookie_text",
        "label": "Cookie banner body text",
        "default": "We use cookies to enhance your browsing experience, serve personalised content and analyse traffic. By clicking Accept you consent to our use of cookies." },
      { "type": "url", "id": "privacy_policy_url", "label": "Privacy policy page URL" },
      { "type": "header", "content": "Tracking Override" },
      { "type": "select", "id": "tracking_mode",
        "label": "Tracking mode",
        "info": "Controls whether analytics/pixels fire regardless of cookie consent. 'Respect user choice' is GDPR-safe default.",
        "options": [
          { "value": "consent", "label": "Respect user choice (GDPR safe - recommended)" },
          { "value": "always_on", "label": "Always ON - fire tracking regardless of consent" },
          { "value": "always_off", "label": "Always OFF - block all tracking (development/testing)" }
        ],
        "default": "consent" },
      { "type": "paragraph", "content": "'Always ON' may violate GDPR/CCPA if no explicit consent is collected. Only use if you have a separate consent solution or operate outside these jurisdictions." },
      { "type": "header", "content": "Analytics & Pixels" },
      { "type": "text", "id": "facebook_pixel_id", "label": "Meta / Facebook Pixel ID",
        "info": "Paste your Pixel ID. The theme writes it to dataLayer; activate via GTM." },
      { "type": "text", "id": "tiktok_pixel_id", "label": "TikTok Pixel ID" },
      { "type": "checkbox", "id": "meta_data_layer_enabled", "label": "Send Meta-ready dataLayer payloads", "default": true,
        "info": "Adds Meta standard event names and custom_data fields to theme dataLayer events for GTM." },
      { "type": "checkbox", "id": "tiktok_data_layer_enabled", "label": "Send TikTok-ready dataLayer payloads", "default": true,
        "info": "Adds TikTok standard event names and properties to theme dataLayer events for GTM." },
      { "type": "text", "id": "klaviyo_company_id", "label": "Klaviyo Company ID",
        "info": "Used for back-in-stock subscriptions." },
      { "type": "text", "id": "gtm_container_id", "label": "Google Tag Manager container ID",
        "info": "Example: GTM-XXXXXXX" },
      { "type": "text", "id": "google_site_verification", "label": "Google Search Console verification code" },
      { "type": "header", "content": "DataLayer Event Controls" },
      { "type": "checkbox", "id": "data_layer_enabled", "label": "Enable theme dataLayer events", "default": true },
      { "type": "checkbox", "id": "gtm_noscript_enabled", "label": "Render GTM noscript iframe", "default": true },
      { "type": "checkbox", "id": "track_page_views", "label": "Track page views", "default": true },
      { "type": "checkbox", "id": "track_ecommerce_events", "label": "Track ecommerce events", "default": true },
      { "type": "checkbox", "id": "track_lead_events", "label": "Track email/contact leads", "default": true },
      { "type": "checkbox", "id": "track_engagement_events", "label": "Track engagement events", "default": true },
      { "type": "select", "id": "tracking_blocked_event_mode", "label": "When consent is declined",
        "options": [
          { "value": "status_only", "label": "Record blocked-event status only" },
          { "value": "none", "label": "Record nothing after decline" }
        ],
        "default": "status_only" }
    ]
  },
  {
    "name": "Weekly Offer",
    "settings": [
      { "type": "header", "content": "Weekly Drop Offer" },
      { "type": "checkbox", "id": "weekly_offer_enabled", "label": "Enable weekly offer mode", "default": true,
        "info": "Shows 'This Week's Drop' badge on hero and product section." },
      { "type": "text", "id": "weekly_offer_label", "label": "Offer badge label", "default": "This Week's Drop" },
      { "type": "text", "id": "weekly_offer_headline", "label": "Offer headline (hero overlay)", "default": "Limited Weekly Drop" },
      { "type": "text", "id": "weekly_offer_end_datetime", "label": "Offer end date/time (ISO 8601)",
        "default": "2026-12-31T23:59:59",
        "info": "Example: 2026-12-31T23:59:59. Used for countdown timers." },
      { "type": "text", "id": "weekly_scarcity_text", "label": "Scarcity text (near ATC button)",
        "default": "Only 14 left in stock - order soon",
        "info": "Leave blank to hide. Example: 'Only 12 left in stock!'" },
      { "type": "select", "id": "offer_countdown_mode", "label": "Default countdown source",
        "options": [
          { "value": "weekly_offer", "label": "Weekly offer ends" },
          { "value": "upcoming_sale", "label": "Upcoming sale starts" }
        ],
        "default": "weekly_offer" },
      { "type": "text", "id": "weekly_countdown_label", "label": "Weekly countdown label", "default": "Ends in" },
      { "type": "text", "id": "offer_countdown_expired_text", "label": "Expired countdown text", "default": "Offer ended" },
      { "type": "header", "content": "Weekly Offer Targeting" },
      { "type": "select", "id": "weekly_offer_scope", "label": "Where weekly offer applies",
        "options": [
          { "value": "all", "label": "All pages" },
          { "value": "homepage_only", "label": "Homepage only" },
          { "value": "all_products", "label": "All products" },
          { "value": "all_collections", "label": "All collections" },
          { "value": "selected_products", "label": "Selected products" },
          { "value": "selected_collection", "label": "Selected collection" }
        ],
        "default": "all" },
      { "type": "product", "id": "weekly_offer_product", "label": "Featured weekly offer product" },
      { "type": "product_list", "id": "weekly_offer_products", "label": "Selected weekly offer products", "limit": 12 },
      { "type": "collection", "id": "weekly_offer_collection", "label": "Weekly offer collection" },
      { "type": "text", "id": "weekly_offer_cta_label", "label": "Weekly offer CTA label", "default": "Shop the offer" },
      { "type": "header", "content": "Upcoming Sale" },
      { "type": "checkbox", "id": "upcoming_sale_enabled", "label": "Enable upcoming sale countdown", "default": false },
      { "type": "text", "id": "upcoming_sale_label", "label": "Upcoming sale badge label", "default": "Next Sale Coming" },
      { "type": "text", "id": "upcoming_sale_countdown_label", "label": "Upcoming countdown label", "default": "Starts in" },
      { "type": "text", "id": "upcoming_sale_start_datetime", "label": "Sale start date/time (ISO 8601)", "default": "2026-12-31T09:00:00" },
      { "type": "select", "id": "upcoming_sale_scope", "label": "Where upcoming sale applies",
        "options": [
          { "value": "all", "label": "All pages" },
          { "value": "homepage_only", "label": "Homepage only" },
          { "value": "all_products", "label": "All products" },
          { "value": "all_collections", "label": "All collections" },
          { "value": "selected_products", "label": "Selected products" },
          { "value": "selected_collection", "label": "Selected collection" }
        ],
        "default": "all" },
      { "type": "product", "id": "upcoming_sale_product", "label": "Featured upcoming sale product" },
      { "type": "product_list", "id": "upcoming_sale_products", "label": "Selected upcoming sale products", "limit": 12 },
      { "type": "collection", "id": "upcoming_sale_collection", "label": "Upcoming sale collection" },
      { "type": "text", "id": "upcoming_sale_cta_label", "label": "Upcoming sale CTA label", "default": "Preview the sale" },
      { "type": "header", "content": "Sale Stripe" },
      { "type": "checkbox", "id": "sale_stripe_enabled", "label": "Show sale stripe", "default": true },
      { "type": "text", "id": "sale_stripe_text", "label": "Sale stripe text", "default": "SALE" },
      { "type": "select", "id": "sale_stripe_style", "label": "Sale stripe style",
        "options": [
          { "value": "rolling_strip", "label": "Rolling sale strip" },
          { "value": "classic_ribbon", "label": "Classic angled ribbon" }
        ],
        "default": "rolling_strip" },
      { "type": "select", "id": "sale_stripe_position", "label": "Sale stripe position",
        "options": [
          { "value": "left", "label": "Left vertical" },
          { "value": "right", "label": "Right vertical" },
          { "value": "top", "label": "Top horizontal" },
          { "value": "bottom", "label": "Bottom horizontal" }
        ],
        "default": "left" },
      { "type": "range", "id": "sale_stripe_speed", "label": "Sale stripe animation speed", "min": 6, "max": 24, "step": 2, "default": 12, "unit": "s" },
      { "type": "checkbox", "id": "sale_stripe_always_show", "label": "Show stripe even when product is not discounted", "default": true },
      { "type": "checkbox", "id": "sale_stripe_show_savings", "label": "Append savings percentage", "default": false },
      { "type": "checkbox", "id": "sale_stripe_animate", "label": "Animate sale stripe", "default": true }
    ]
  },
  {
    "name": "Cursor & Effects",
    "settings": [
      { "type": "header", "content": "Custom Cursor (Desktop only)" },
      { "type": "checkbox", "id": "cursor_enabled", "label": "Enable custom cursor", "default": true,
        "info": "Replaces default cursor with a magnetic dot + trailing ring on desktop. Auto-disabled on touch devices." },
      { "type": "select", "id": "cursor_style", "label": "Cursor style",
        "options": [
          { "value": "dot-ring", "label": "Magnetic dot + trailing ring" },
          { "value": "spotlight", "label": "Spotlight glow" },
          { "value": "simple", "label": "Simple custom dot" }
        ],
        "default": "dot-ring" },
      { "type": "color", "id": "cursor_color", "label": "Cursor accent color", "default": "#1a1a1a" },
      { "type": "header", "content": "Scroll & Reveal Animations" },
      { "type": "checkbox", "id": "reveal_animations", "label": "Enable scroll-reveal animations", "default": true },
      { "type": "header", "content": "Header" },
      { "type": "checkbox", "id": "header_transparent_hero", "label": "Transparent header over hero", "default": false,
        "info": "Header starts transparent when a hero section is first on page, becomes solid on scroll." }
    ]
  },
  {
    "name": "Footer & SEO",
    "settings": [
      { "type": "header", "content": "Footer Utility Links" },
      { "type": "checkbox", "id": "show_order_tracking_link", "label": "Show order tracking link in footer", "default": false },
      { "type": "text", "id": "order_tracking_label", "label": "Order tracking link label", "default": "Track Order" },
      { "type": "url", "id": "order_tracking_url", "label": "Order tracking URL" },
      { "type": "header", "content": "Social Sharing" },
      { "type": "image_picker", "id": "og_default_image", "label": "Default social sharing image" }
    ]
  },
  {
    "name": "Advanced",
    "settings": [
      { "type": "textarea", "id": "custom_css",
        "label": "Custom CSS",
        "info": "Injected inside a <style> tag in <head>. Use sparingly \u2014 prefer section/snippet styles instead." }
    ]
  }
]
