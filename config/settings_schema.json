  },
  {
    "name": "Layout",
    "settings": [
      {"type": "range", "id": "max_width", "label": "Max page width", "min": 960, "max": 1440, "step": 40, "default": 1200, "unit": "px"},
      {"type": "range", "id": "border_radius", "label": "Button / card radius", "min": 0, "max": 16, "step": 2, "default": 4, "unit": "px"}
    ]
  },
  {
    "name": "Compliance & Tracking",
    "settings": [
