      {"type": "text", "id": "tiktok_pixel_id", "label": "TikTok Pixel ID", "info": "Optional. Used by your marketing stack or GTM; theme does not inject ttq() by itself."},
      {"type": "text", "id": "gtm_container_id", "label": "Google Tag Manager container ID", "info": "Optional. Example: GTM-XXXXXXX."}
    ]
