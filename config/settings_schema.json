[
  {
    "name": "theme_info",
    "theme_name": "BodyLuxCare",
    "theme_version": "2.0.0",
    "theme_author": "BodyLuxCare",
    "theme_documentation_url": "https://bodyluxcare.com",
    "theme_support_url": "https://bodyluxcare.com/pages/contact"
  },
  {
    "name": "Brand & Logo",
    "settings": [
      { "type": "image_picker", "id": "logo", "label": "Logo image" },
      { "type": "range", "id": "logo_width", "label": "Logo width (px)", "min": 60, "max": 300, "step": 10, "default": 140 },
      { "type": "text", "id": "brand_name", "label": "Brand name (fallback if no logo)", "default": "BodyLuxCare" },
      { "type": "image_picker", "id": "favicon", "label": "Favicon" }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      { "type": "color", "id": "color_bg", "label": "Page background", "default": "#ffffff" },
      { "type": "color", "id": "color_surface", "label": "Surface / card background", "default": "#f9f8f5" },
      { "type": "color", "id": "color_text", "label": "Body text", "default": "#1a1a1a" },
      { "type": "color", "id": "color_text_muted", "label": "Muted text", "default": "#6b7280" },
      { "type": "color", "id": "color_primary", "label": "Primary accent (buttons, links)", "default": "#1d5c3a" },
      { "type": "color", "id": "color_primary_hover", "label": "Primary hover", "default": "#164530" },
      { "type": "color", "id": "color_sale", "label": "Sale / badge color", "default": "#dc2626" },
      { "type": "color", "id": "color_border", "label": "Border color", "default": "#e5e7eb" },
      { "type": "color", "id": "color_announcement_bg", "label": "Announcement bar background", "default": "#1d5c3a" },
      { "type": "color", "id": "color_announcement_text", "label": "Announcement bar text", "default": "#ffffff" },
      { "type": "color", "id": "color_header_bg", "label": "Header background", "default": "#ffffff" },
      { "type": "color", "id": "color_footer_bg", "label": "Footer background", "default": "#111827" },
      { "type": "color", "id": "color_footer_text", "label": "Footer text", "default": "#f9fafb" }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      { "type": "font_picker", "id": "font_display", "label": "Display / heading font", "default": "playfair_display_n4" },
      { "type": "font_picker", "id": "font_body", "label": "Body font", "default": "work_sans_n4" },
      { "type": "select", "id": "type_base_size", "label": "Base font size", "options": [
        { "value": "14px", "label": "Small (14px)" },
        { "value": "16px", "label": "Medium (16px)" },
        { "value": "18px", "label": "Large (18px)" }
      ], "default": "16px" }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      { "type": "select", "id": "btn_radius", "label": "Button shape", "options": [
        { "value": "0px", "label": "Square" },
        { "value": "6px", "label": "Rounded (default)" },
        { "value": "9999px", "label": "Pill" }
      ], "default": "6px" },
      { "type": "select", "id": "btn_size", "label": "Button size", "options": [
        { "value": "sm", "label": "Small" },
        { "value": "md", "label": "Medium" },
        { "value": "lg", "label": "Large" }
      ], "default": "md" }
    ]
  },
  {
    "name": "Announcement Bar",
    "settings": [
      { "type": "checkbox", "id": "announcement_enabled", "label": "Show announcement bar", "default": true },
      { "type": "text", "id": "announcement_text_1", "label": "Message 1", "default": "🚚 Free U.S. shipping on orders $75+ · 30-day easy returns" },
      { "type": "text", "id": "announcement_text_2", "label": "Message 2 (optional)", "default": "Use code WELCOME10 for 10% off your first order" },
      { "type": "text", "id": "announcement_text_3", "label": "Message 3 (optional)", "default": "" },
      { "type": "url", "id": "announcement_link", "label": "Link (optional)" },
      { "type": "checkbox", "id": "announcement_auto_rotate", "label": "Auto-rotate messages", "default": true },
      { "type": "range", "id": "announcement_speed", "label": "Rotation speed (seconds)", "min": 2, "max": 10, "step": 1, "default": 4 }
    ]
  },
  {
    "name": "Header",
    "settings": [
      { "type": "checkbox", "id": "header_sticky", "label": "Sticky header", "default": true },
      { "type": "checkbox", "id": "header_show_search", "label": "Show search icon", "default": true },
      { "type": "checkbox", "id": "header_show_account", "label": "Show account icon", "default": true },
      { "type": "checkbox", "id": "header_transparent", "label": "Transparent header on homepage hero", "default": true },
      { "type": "link_list", "id": "main_menu", "label": "Main navigation menu", "default": "main-menu" }
    ]
  },
  {
    "name": "Product Cards",
    "settings": [
      { "type": "select", "id": "card_radius", "label": "Card corner radius", "options": [
        { "value": "0px", "label": "None" },
        { "value": "8px", "label": "Soft (8px)" },
        { "value": "16px", "label": "Rounded (16px)" }
      ], "default": "8px" },
      { "type": "checkbox", "id": "card_show_vendor", "label": "Show vendor name", "default": false },
      { "type": "checkbox", "id": "card_show_rating", "label": "Show star rating", "default": true },
      { "type": "checkbox", "id": "card_hover_second_image", "label": "Show second image on hover", "default": true },
      { "type": "checkbox", "id": "card_quick_add", "label": "Show quick add button", "default": true }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      { "type": "select", "id": "cart_type", "label": "Cart type", "options": [
        { "value": "drawer", "label": "Slide-out drawer" },
        { "value": "page", "label": "Cart page" }
      ], "default": "drawer" },
      { "type": "checkbox", "id": "cart_show_order_note", "label": "Show order note field", "default": true },
      { "type": "text", "id": "cart_upsell_text", "label": "Free shipping threshold message", "default": "You're {{ amount }} away from FREE shipping! 🚚" },
      { "type": "range", "id": "cart_free_shipping_threshold", "label": "Free shipping threshold ($)", "min": 0, "max": 200, "step": 5, "default": 75 }
    ]
  },
  {
    "name": "Trust & Social Proof",
    "settings": [
      { "type": "checkbox", "id": "trust_show_payment_icons", "label": "Show payment icons", "default": true },
      { "type": "text", "id": "trust_badge_1", "label": "Trust badge 1 label", "default": "14-Day Returns" },
      { "type": "text", "id": "trust_badge_2", "label": "Trust badge 2 label", "default": "7–10 Day Shipping" },
      { "type": "text", "id": "trust_badge_3", "label": "Trust badge 3 label", "default": "Secure Payments" },
      { "type": "text", "id": "trust_badge_4", "label": "Trust badge 4 label", "default": "Satisfaction Guarantee" }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      { "type": "image_picker", "id": "footer_logo", "label": "Footer logo (optional)" },
      { "type": "richtext", "id": "footer_about_text", "label": "About / brand description", "default": "<p>Premium wellness and lifestyle products for you, your home, and your pets.</p>" },
      { "type": "text", "id": "footer_email", "label": "Contact email", "default": "info@bodyluxcare.com" },
      { "type": "text", "id": "footer_phone", "label": "Phone number (optional)", "default": "" },
      { "type": "text", "id": "footer_instagram", "label": "Instagram URL", "default": "" },
      { "type": "text", "id": "footer_facebook", "label": "Facebook URL", "default": "" },
      { "type": "text", "id": "footer_tiktok", "label": "TikTok URL", "default": "" },
      { "type": "text", "id": "footer_pinterest", "label": "Pinterest URL", "default": "" },
      { "type": "checkbox", "id": "footer_show_payment_icons", "label": "Show payment icons in footer", "default": true },
      { "type": "text", "id": "footer_copyright", "label": "Copyright text", "default": "© 2026 BodyLuxCare. All rights reserved." }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram handle", "default": "@bodyluxcare" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL", "default": "" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL", "default": "" }
    ]
  },
  {
    "name": "SEO & Analytics",
    "settings": [
      { "type": "text", "id": "seo_title_suffix", "label": "Page title suffix", "default": "| BodyLuxCare" },
      { "type": "textarea", "id": "seo_meta_description", "label": "Default meta description", "default": "Premium wellness and lifestyle products for women, men, pets, and home." },
      { "type": "text", "id": "gtm_id", "label": "Google Tag Manager ID (GTM-XXXXXX)", "default": "" },
      { "type": "text", "id": "ga4_id", "label": "GA4 Measurement ID (G-XXXXXXXX)", "default": "" },
      { "type": "text", "id": "pixel_id", "label": "Meta Pixel ID", "default": "" },
      { "type": "text", "id": "tiktok_pixel_id", "label": "TikTok Pixel ID", "default": "" }
    ]
  },
  {
    "name": "Cookie Consent (GDPR)",
    "settings": [
      { "type": "checkbox", "id": "cookie_consent_enabled", "label": "Show cookie consent banner", "default": true },
      { "type": "textarea", "id": "cookie_consent_text", "label": "Cookie banner message", "default": "We use cookies to improve your experience and for marketing. By continuing, you accept our Privacy Policy." },
      { "type": "text", "id": "cookie_accept_text", "label": "Accept button text", "default": "Accept All" },
      { "type": "text", "id": "cookie_decline_text", "label": "Decline button text", "default": "Essential Only" },
      { "type": "url", "id": "cookie_policy_url", "label": "Privacy policy URL", "default": "/policies/privacy-policy" }
    ]
  }
]
