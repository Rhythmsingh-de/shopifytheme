{% doc %}
  @prompt
    sample products
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sample-products-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-sample-products__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 32px;
  }

  .ai-sample-products__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 12px;
    font-weight: 700;
  }

  .ai-sample-products__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
  }

  .ai-sample-products__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: 32px;
  }

  .ai-sample-products__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-sample-products__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-sample-products__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-sample-products__image-wrapper-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-sample-products__image-wrapper-{{ ai_gen_id }} svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-sample-products__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .ai-sample-products__content-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-sample-products__product-title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .ai-sample-products__product-title-{{ ai_gen_id }} a {
    color: inherit;
    text-decoration: none;
  }

  .ai-sample-products__product-title-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  .ai-sample-products__price-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 700;
    color: {{ block.settings.price_color }};
    margin-bottom: 12px;
  }

  .ai-sample-products__price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    color: {{ block.settings.compare_price_color }};
    font-size: 14px;
    margin-left: 8px;
    font-weight: 400;
  }

  .ai-sample-products__button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 12px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    transition: background-color 0.3s ease;
  }

  .ai-sample-products__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-sample-products__view-all-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-sample-products__view-all-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.view_all_background }};
    color: {{ block.settings.view_all_text_color }};
    border: 2px solid {{ block.settings.view_all_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ai-sample-products__view-all-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_background }};
    color: {{ block.settings.view_all_hover_text_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-sample-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-sample-products__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-sample-products__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<sample-products-{{ ai_gen_id }}
  class="ai-sample-products-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank or block.settings.description != blank %}
    <div class="ai-sample-products__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-sample-products__title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.description != blank %}
        <div class="ai-sample-products__description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-sample-products__grid-{{ ai_gen_id }}">
    {% if block.settings.product_list != blank %}
      {% for product in block.settings.product_list limit: block.settings.products_to_show %}
        <div class="ai-sample-products__card-{{ ai_gen_id }}">
          <div class="ai-sample-products__image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
                width="600"
                height="600"
              >
            {% else %}
              {{ 'product-1' | placeholder_svg_tag }}
            {% endif %}

            {% if block.settings.show_badge and product.compare_at_price > product.price %}
              <span class="ai-sample-products__badge-{{ ai_gen_id }}">
                {{ block.settings.badge_text }}
              </span>
            {% endif %}
          </div>

          <div class="ai-sample-products__content-{{ ai_gen_id }}">
            <h3 class="ai-sample-products__product-title-{{ ai_gen_id }}">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>

            <div class="ai-sample-products__price-{{ ai_gen_id }}">
              {{ product.price | money }}
              {% if product.compare_at_price > product.price %}
                <span class="ai-sample-products__price-compare-{{ ai_gen_id }}">
                  {{ product.compare_at_price | money }}
                </span>
              {% endif %}
            </div>

            {% if block.settings.show_add_to_cart %}
              <a
                href="{{ product.url }}"
                class="ai-sample-products__button-{{ ai_gen_id }}"
              >
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% else %}
      {% for i in (1..block.settings.products_to_show) %}
        <div class="ai-sample-products__card-{{ ai_gen_id }}">
          <div class="ai-sample-products__image-wrapper-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
          <div class="ai-sample-products__content-{{ ai_gen_id }}">
            <h3 class="ai-sample-products__product-title-{{ ai_gen_id }}">
              Sample Product {{ i }}
            </h3>
            <div class="ai-sample-products__price-{{ ai_gen_id }}">$29.99</div>
            {% if block.settings.show_add_to_cart %}
              <a href="#" class="ai-sample-products__button-{{ ai_gen_id }}">
                {{ block.settings.button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>

  {% if block.settings.show_view_all and block.settings.view_all_link != blank %}
    <div class="ai-sample-products__view-all-{{ ai_gen_id }}">
      <a
        href="{{ block.settings.view_all_link }}"
        class="ai-sample-products__view-all-link-{{ ai_gen_id }}"
      >
        {{ block.settings.view_all_text }}
      </a>
    </div>
  {% endif %}
</sample-products-{{ ai_gen_id }}>

<script>
  (function() {
    class SampleProducts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('sample-products-{{ ai_gen_id }}', SampleProducts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Sample products",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Discover our best-selling products</p>"
    },
    {
      "type": "product_list",
      "id": "product_list",
      "label": "Products",
      "limit": 12
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns on tablet",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Product card"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Sale"
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "View Product"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 6
    },
    {
      "type": "header",
      "content": "View all button"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "Button text",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#1d5c3a"
    },
    {
      "type": "color",
      "id": "compare_price_color",
      "label": "Compare price",
      "default": "#9ca3af"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Badge background",
      "default": "#dc2626"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#1d5c3a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#164530"
    },
    {
      "type": "color",
      "id": "view_all_background",
      "label": "View all background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "view_all_text_color",
      "label": "View all text",
      "default": "#1d5c3a"
    },
    {
      "type": "color",
      "id": "view_all_border_color",
      "label": "View all border",
      "default": "#1d5c3a"
    },
    {
      "type": "color",
      "id": "view_all_hover_background",
      "label": "View all hover background",
      "default": "#1d5c3a"
    },
    {
      "type": "color",
      "id": "view_all_hover_text_color",
      "label": "View all hover text",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Sample products"
    }
  ]
}
{% endschema %}
