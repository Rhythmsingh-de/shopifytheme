<script>
  (function() {
    class ProductPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initCountdown();
        this.initDeliveryDate();
      }

      initCountdown() {
        const countdownElement = this.querySelector('[data-countdown-hours]');
        if (!countdownElement) return;

        const targetHours = parseInt(countdownElement.getAttribute('data-countdown-hours'));
        if (isNaN(targetHours)) return;

        const updateCountdown = () => {
          const now = new Date();
          const endOfDay = new Date();
          endOfDay.setHours(23, 59, 59, 999);
          
          const diff = endOfDay - now;
          const hoursLeft = Math.floor(diff / (1000 * 60 * 60));
          const minutesLeft = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          
          if (hoursLeft <= targetHours) {
            countdownElement.textContent = hoursLeft + 'h ' + minutesLeft + 'm';
          } else {
            countdownElement.textContent = targetHours + 'h';
          }
        };

        updateCountdown();
        setInterval(updateCountdown, 60000);
      }

      initDeliveryDate() {
        const dateElement = this.querySelector('[data-delivery-days]');
        if (!dateElement) return;

        const deliveryDays = parseInt(dateElement.getAttribute('data-delivery-days'));
        if (isNaN(deliveryDays)) return;

        const today = new Date();
        const deliveryDate = new Date(today);
        deliveryDate.setDate(today.getDate() + deliveryDays);

        const options = { weekday: 'long', year: 'numeric', month: 'numeric', day: 'numeric' };
        const formattedDate = deliveryDate.toLocaleDateString('en-US', options);
        
        dateElement.textContent = formattedDate;
      }
    }

    customElements.define('product-page-{{ ai_gen_id }}', ProductPage{{ ai_gen_id }});
  })();
</script>

