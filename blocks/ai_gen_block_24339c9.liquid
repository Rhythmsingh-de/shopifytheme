{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-page-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
  }

  .ai-pp-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 60px 40px;
  }

  .ai-pp-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .ai-pp-images-{{ ai_gen_id }} {
    position: sticky;
    top: 100px;
  }

  .ai-pp-main-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .ai-pp-main-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-pp-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-pp-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-pp-price-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
  }

  .ai-pp-price-compare-{{ ai_gen_id }} {
    font-size: 24px;
    color: {{ block.settings.text_color }};
    opacity: 0.5;
    text-decoration: line-through;
    margin-left: 12px;
  }

  .ai-pp-delivery-box-{{ ai_gen_id }} {
    background-color: {{ block.settings.delivery_bg }};
    border: 2px solid {{ block.settings.delivery_border }};
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-pp-delivery-countdown-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    color: {{ block.settings.text_color }};
  }

  .ai-pp-delivery-time-{{ ai_gen_id }} {
    font-weight: 700;
    color: {{ block.settings.delivery_accent }};
  }

  .ai-pp-delivery-date-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: {{ block.settings.text_color }};
  }

  .ai-pp-delivery-date-value-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 16px;
    color: {{ block.settings.delivery_accent }};
  }

  .ai-pp-trust-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    padding: 24px;
    background-color: {{ block.settings.trust_bg }};
    border-radius: 12px;
    border: 1px solid {{ block.settings.trust_border }};
  }

  .ai-pp-trust-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: center;
    align-items: center;
  }

  .ai-pp-trust-icon-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    color: {{ block.settings.trust_icon_color }};
    margin-bottom: 4px;
  }

  .ai-pp-trust-title-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-pp-trust-subtitle-{{ ai_gen_id }} {
    font-size: 11px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
    line-height: 1.3;
  }

  .ai-pp-cta-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text }};
    padding: 18px 40px;
    border-radius: {{ block.settings.button_radius }}px;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    text-align: center;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
    width: 100%;
  }

  .ai-pp-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
  }

  .ai-pp-ask-question-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 12px;
    background-color: transparent;
    border: 2px solid {{ block.settings.text_color }};
    border-radius: {{ block.settings.button_radius }}px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-pp-ask-question-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
  }

  .ai-pp-ask-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
  }

  .ai-pp-details-section-{{ ai_gen_id }} {
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid {{ block.settings.trust_border }};
  }

  .ai-pp-details-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
  }

  .ai-pp-details-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-pp-detail-item-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 12px;
    font-size: 14px;
    padding: 8px 0;
    border-bottom: 1px solid {{ block.settings.trust_border }};
  }

  .ai-pp-detail-label-{{ ai_gen_id }} {
    font-weight: 600;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-pp-detail-value-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  .ai-pp-description-section-{{ ai_gen_id }} {
    margin-top: 40px;
  }

  .ai-pp-description-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
  }

  .ai-pp-description-{{ ai_gen_id }} {
    font-size: 15px;
    line-height: 1.7;
    color: {{ block.settings.text_color }};
    opacity: 0.85;
  }

  .ai-pp-features-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 20px 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-pp-feature-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
  }

  .ai-pp-feature-check-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    color: {{ block.settings.trust_icon_color }};
    flex-shrink: 0;
    margin-top: 2px;
  }

  @media screen and (max-width: 989px) {
    .ai-pp-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-pp-images-{{ ai_gen_id }} {
      position: static;
    }

    .ai-pp-container-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-pp-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.75 }}px;
    }

    .ai-pp-trust-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .ai-pp-detail-item-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 4px;
    }
  }
{% endstyle %}

